---
export interface Props {
  slot?: string;
}
const { slot = 'default' } = Astro.props;
---

<ins class="adsbygoogle"
     style="display:block"
     data-ad-client="ca-pub-7942711962511546"
     data-ad-slot={slot}
     data-ad-format="auto"
     data-full-width-responsive="true"></ins>
<script is:inline>
  (adsbygoogle = window.adsbygoogle || []).push({});
</script>
