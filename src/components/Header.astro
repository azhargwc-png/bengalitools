---
// Header with navigation and language toggle
---

<header class="bg-teal-700 text-white shadow-md sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Top bar -->
    <div class="flex items-center justify-between py-3">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-white no-underline">
        <span class="text-2xl font-bold tracking-tight">
          <span class="text-yellow-200">বাংলা</span>Tools
        </span>
      </a>

      <!-- Right side: search + lang toggle -->
      <div class="flex items-center gap-3">
        <!-- Search (desktop) -->
        <div class="hidden md:block relative">
          <input
            type="text"
            id="header-search"
            placeholder="টুল খুঁজুন..."
            class="w-48 lg:w-64 px-3 py-2 rounded-lg text-gray-900 text-base bg-white border-0 focus:outline-none focus:ring-2 focus:ring-saffron-400"
            autocomplete="off"
          />
          <div id="search-results" class="hidden absolute top-full left-0 w-full bg-white rounded-lg shadow-xl mt-1 max-h-72 overflow-y-auto z-50 text-gray-900"></div>
        </div>

        <!-- Language Toggle -->
        <button
          id="lang-toggle"
          onclick="toggleLang()"
          class="px-3 py-2 bg-saffron-500 hover:bg-saffron-600 text-gray-900 rounded-lg text-base font-medium transition-colors min-h-[44px]"
          aria-label="Switch language"
        >
          English
        </button>

        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="md:hidden p-2 rounded-lg hover:bg-teal-600 transition-colors"
          aria-label="Menu"
          onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-1 pb-2 text-base overflow-x-auto">
      <a href="/converters/kg-to-lbs/" class="nav-link whitespace-nowrap px-3 py-1.5 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="কনভার্টার" data-en="Converters">কনভার্টার</span>
      </a>
      <a href="/currency/usd-to-inr/" class="nav-link whitespace-nowrap px-3 py-1.5 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="মুদ্রা" data-en="Currency">মুদ্রা</span>
      </a>
      <a href="/health/bmi-calculator/" class="nav-link whitespace-nowrap px-3 py-1.5 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="স্বাস্থ্য" data-en="Health">স্বাস্থ্য</span>
      </a>
      <a href="/calculators/percentage/" class="nav-link whitespace-nowrap px-3 py-1.5 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="ক্যালকুলেটর" data-en="Calculators">ক্যালকুলেটর</span>
      </a>
      <a href="/food/calorie-lookup/" class="nav-link whitespace-nowrap px-3 py-1.5 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="খাবার ও ক্যালরি" data-en="Food & Calories">খাবার ও ক্যালরি</span>
      </a>
      <a href="/india/gst-calculator/" class="nav-link whitespace-nowrap px-3 py-1.5 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="ভারত টুলস" data-en="India Tools">ভারত টুলস</span>
      </a>
      <a href="/blog/" class="nav-link whitespace-nowrap px-3 py-1.5 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="ব্লগ" data-en="Blog">ব্লগ</span>
      </a>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-teal-800 px-4 pb-4">
    <!-- Mobile search -->
    <div class="relative mb-3 pt-3">
      <input
        type="text"
        id="mobile-search"
        placeholder="টুল খুঁজুন..."
        class="w-full px-3 py-2 rounded-lg text-gray-900 text-base bg-white border-0 focus:outline-none"
        autocomplete="off"
      />
    </div>
    <nav class="grid grid-cols-2 gap-2 text-base">
      <a href="/converters/kg-to-lbs/" class="px-3 py-2 bg-teal-700 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="ইউনিট কনভার্টার" data-en="Unit Converters">ইউনিট কনভার্টার</span>
      </a>
      <a href="/currency/usd-to-inr/" class="px-3 py-2 bg-teal-700 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="মুদ্রা বিনিময়" data-en="Currency">মুদ্রা বিনিময়</span>
      </a>
      <a href="/health/bmi-calculator/" class="px-3 py-2 bg-teal-700 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="স্বাস্থ্য সরঞ্জাম" data-en="Health Tools">স্বাস্থ্য সরঞ্জাম</span>
      </a>
      <a href="/calculators/percentage/" class="px-3 py-2 bg-teal-700 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="ক্যালকুলেটর" data-en="Calculators">ক্যালকুলেটর</span>
      </a>
      <a href="/food/calorie-lookup/" class="px-3 py-2 bg-teal-700 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="খাবার ও ক্যালরি" data-en="Food & Calories">খাবার ও ক্যালরি</span>
      </a>
      <a href="/india/gst-calculator/" class="px-3 py-2 bg-teal-700 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="ভারত টুলস" data-en="India Tools">ভারত টুলস</span>
      </a>
      <a href="/blog/" class="px-3 py-2 bg-teal-700 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="ব্লগ" data-en="Blog">ব্লগ</span>
      </a>
      <a href="/about/" class="px-3 py-2 bg-teal-700 rounded hover:bg-teal-600 transition-colors">
        <span data-bn="আমাদের সম্পর্কে" data-en="About">আমাদের সম্পর্কে</span>
      </a>
    </nav>
  </div>
</header>

<script is:inline>
// Search data
var allTools = [
  { name: 'কেজি থেকে পাউন্ড', en: 'kg to lbs', url: '/converters/kg-to-lbs/' },
  { name: 'সেন্টিমিটার থেকে ইঞ্চি', en: 'cm to inches', url: '/converters/cm-to-inches/' },
  { name: 'সেলসিয়াস থেকে ফারেনহাইট', en: 'celsius fahrenheit temperature', url: '/converters/celsius-to-fahrenheit/' },
  { name: 'কিলোমিটার থেকে মাইল', en: 'km to miles', url: '/converters/km-to-miles/' },
  { name: 'ফুট থেকে মিটার', en: 'feet to meters', url: '/converters/feet-to-meters/' },
  { name: 'লিটার থেকে গ্যালন', en: 'litre to gallon', url: '/converters/litre-to-gallon/' },
  { name: 'ডলার থেকে রুপি', en: 'USD to INR dollar', url: '/currency/usd-to-inr/' },
  { name: 'দিরহাম থেকে রুপি', en: 'AED to INR dirham dubai', url: '/currency/aed-to-inr/' },
  { name: 'ইউরো থেকে রুপি', en: 'EUR to INR euro', url: '/currency/eur-to-inr/' },
  { name: 'পাউন্ড থেকে রুপি', en: 'GBP to INR pound', url: '/currency/gbp-to-inr/' },
  { name: 'বাংলাদেশি টাকা থেকে রুপি', en: 'BDT to INR taka', url: '/currency/bdt-to-inr/' },
  { name: 'বিএমআই ক্যালকুলেটর', en: 'BMI calculator', url: '/health/bmi-calculator/' },
  { name: 'বয়স ক্যালকুলেটর', en: 'age calculator', url: '/health/age-calculator/' },
  { name: 'ক্যালরি ক্যালকুলেটর', en: 'calorie calculator', url: '/health/calorie-calculator/' },
  { name: 'আদর্শ ওজন', en: 'ideal weight calculator', url: '/health/ideal-weight/' },
  { name: 'জল পান ক্যালকুলেটর', en: 'water intake calculator', url: '/health/water-intake/' },
  { name: 'শতাংশ ক্যালকুলেটর', en: 'percentage calculator', url: '/calculators/percentage/' },
  { name: 'ছাড় ক্যালকুলেটর', en: 'discount calculator', url: '/calculators/discount/' },
  { name: 'টিপ ক্যালকুলেটর', en: 'tip calculator', url: '/calculators/tip/' },
  { name: 'তারিখের ব্যবধান', en: 'date difference calculator', url: '/calculators/date-difference/' },
  { name: 'গতি ক্যালকুলেটর', en: 'speed distance time', url: '/calculators/speed/' },
  { name: 'জ্বালানি খরচ', en: 'fuel cost petrol calculator', url: '/calculators/fuel-cost/' },
  { name: 'খাবারের ক্যালরি', en: 'food calorie lookup', url: '/food/calorie-lookup/' },
  { name: 'রেসিপি ক্যালরি', en: 'recipe calorie calculator', url: '/food/recipe-calculator/' },
  { name: 'বাংলা খাবার চার্ট', en: 'Bengali food calorie chart', url: '/food/bengali-food-chart/' },
  { name: 'জিএসটি ক্যালকুলেটর', en: 'GST calculator India', url: '/india/gst-calculator/' },
  { name: 'বাংলা তারিখ কনভার্টার', en: 'Bengali calendar date converter', url: '/india/bengali-calendar/' },
  { name: 'সংখ্যা বাংলায়', en: 'number to Bengali words', url: '/india/number-to-bengali/' },
  { name: 'বেতন ক্যালকুলেটর', en: 'salary hourly calculator', url: '/india/salary-to-hourly/' },
  { name: 'ফর্মের ছবি রিসাইজার', en: 'govt form photo resizer SSC PSC Railway image resize KB pixels', url: '/india/image-resizer/' },
  { name: 'জমির পরিমাণ কনভার্টার', en: 'land area converter bigha katha decimal acre sqft', url: '/converters/land-area/' },
  { name: 'কাট-অফ মার্কস ক্যালকুলেটর', en: 'cutoff marks calculator percentage madhyamik HS SSC PSC', url: '/calculators/cutoff-marks/' },
  { name: 'নম্বর থেকে গ্রেড', en: 'marks to grade converter WB board CBSE CGPA madhyamik', url: '/calculators/marks-grade/' },
];

function doSearch(q, resultsEl) {
  if (!q || q.trim().length < 1) { resultsEl.classList.add('hidden'); return; }
  var r = allTools.filter(function(t) {
    return t.name.includes(q) || t.en.toLowerCase().includes(q.toLowerCase());
  }).slice(0, 8);
  if (r.length === 0) { resultsEl.classList.add('hidden'); return; }
  resultsEl.innerHTML = r.map(function(t) {
    return '<a href="' + t.url + '" class="flex items-center px-4 py-3 hover:bg-gray-100 border-b border-gray-100 last:border-0">' +
      '<span class="font-medium text-gray-900 text-base">' + t.name + '</span>' +
      '<span class="ml-2 text-gray-500 text-sm">' + t.en + '</span></a>';
  }).join('');
  resultsEl.classList.remove('hidden');
}

document.addEventListener('DOMContentLoaded', function() {
  var hsearch = document.getElementById('header-search');
  var hresults = document.getElementById('search-results');
  if (hsearch && hresults) {
    hsearch.addEventListener('input', function() { doSearch(this.value, hresults); });
    document.addEventListener('click', function(e) {
      if (!hsearch.contains(e.target) && !hresults.contains(e.target)) hresults.classList.add('hidden');
    });
  }
});
</script>
