  </section>

  <div class="mt-8 text-center">
    <a href="/health/water-intake/" class="bg-teal-700 hover:bg-teal-800 text-white font-semibold py-3 px-6 rounded-xl transition-colors inline-block">
      <span data-bn="আমার দৈনিক পানির পরিমাণ হিসাব করুন →" data-en="Calculate My Daily Water Intake →">আমার দৈনিক পানির পরিমাণ হিসাব করুন →</span>
    </a>
  </div>

  <AdSlot slot="blog-bottom" />
</BlogLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function () {
  var wEl = document.getElementById('wp-weight');
  var aEl = document.getElementById('wp-activity');
  var resEl = document.getElementById('wp-result');
  var litresEl = document.getElementById('wp-litres');
  var glassesEl = document.getElementById('wp-glasses');

  function calc() {
    var w = parseFloat(wEl.value);
    if (isNaN(w) || w <= 0) { resEl.classList.add('hidden'); return; }
    var ml = w * 35;
    var act = aEl.value;
    if (act === 'active') ml += 500;
    if (act === 'very_active') ml += 1000;
    var litres = (ml / 1000).toFixed(1);
    var glasses = Math.ceil(ml / 250);
    var lang = localStorage.getItem('bt-lang') || 'bn';
    litresEl.textContent = litres + ' ' + (lang === 'bn' ? 'লিটার' : 'litres');
    glassesEl.textContent = glasses + ' ' + (lang === 'bn' ? 'গ্লাস প্রতিদিন (২৫০ মিলি করে)' : 'glasses per day (250 ml each)');
    resEl.classList.remove('hidden');
  }

  wEl.addEventListener('input', calc);
  aEl.addEventListener('change', calc);
});
</script>
