---
import BlogLayout from '../../layouts/BlogLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<BlogLayout
  title="প্রতিদিন কত পানি পান করা উচিত — সম্পূর্ণ গাইড | BanglaTools"
  description="প্রতিদিন কতটুকু পানি পান করা উচিত? ওজন অনুযায়ী সঠিক পরিমাণ জানুন। ৮ গ্লাসের মিথ, পানিশূন্যতার লক্ষণ ও পানি পানের সঠিক সময় — বাংলায় সম্পূর্ণ গাইড।"
  datePublished="2026-04-16"
>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog/" class="hover:text-teal-700">ব্লগ</a> → প্রতিদিন কত পানি পান করা উচিত
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    <span data-bn="প্রতিদিন কত পানি পান করা উচিত — সম্পূর্ণ গাইড" data-en="How Much Water Should You Drink Per Day — Complete Guide">প্রতিদিন কত পানি পান করা উচিত — সম্পূর্ণ গাইড</span>
  </h1>

  <AdSlot slot="blog-top" />

  <!-- Key fact box -->
  <div class="bg-blue-50 rounded-2xl p-5 border border-blue-200 mb-8">
    <div class="text-center">
      <div class="text-5xl mb-3">💧</div>
      <p class="text-2xl font-bold text-blue-800" data-bn="৬০ কেজি → প্রতিদিন ২.১ লিটার (৮ গ্লাস)" data-en="60 kg → 2.1 litres (8 glasses) per day">৬০ কেজি → প্রতিদিন ২.১ লিটার (৮ গ্লাস)</p>
      <p class="text-blue-700 mt-1 text-sm" data-bn="(সূত্র: ওজন × ৩৫ মিলি — WHO নির্দেশিকা অনুসরণ করে)" data-en="(Formula: weight × 35 ml — based on WHO guidance)">(সূত্র: ওজন × ৩৫ মিলি — WHO নির্দেশিকা অনুসরণ করে)</p>
    </div>
  </div>

  <!-- Inline mini calculator -->
  <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200 mb-8">
    <h2 class="font-bold text-teal-800 mb-4 text-lg">
      <span data-bn="আপনার দৈনিক পানির চাহিদা বের করুন" data-en="Calculate Your Daily Water Needs">আপনার দৈনিক পানির চাহিদা বের করুন</span>
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          <span data-bn="ওজন (কেজি)" data-en="Weight (kg)">ওজন (কেজি)</span>
        </label>
        <input type="number" id="wp-weight" placeholder="60" min="10" max="200"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          <span data-bn="কার্যকলাপের মাত্রা" data-en="Activity Level">কার্যকলাপের মাত্রা</span>
        </label>
        <select id="wp-activity"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px] bg-white">
          <option value="normal" data-bn="স্বাভাবিক (অফিস, হাঁটা)" data-en="Normal (office, walking)">স্বাভাবিক (অফিস, হাঁটা)</option>
          <option value="active" data-bn="সক্রিয় (ব্যায়াম, শারীরিক কাজ)" data-en="Active (exercise, physical work)">সক্রিয় (ব্যায়াম, শারীরিক কাজ)</option>
          <option value="very_active" data-bn="অত্যন্ত সক্রিয় (খেলাধুলা, কঠিন পরিশ্রম)" data-en="Very active (sports, heavy labour)">অত্যন্ত সক্রিয় (খেলাধুলা, কঠিন পরিশ্রম)</option>
        </select>
      </div>
    </div>
    <div id="wp-result" class="hidden rounded-xl p-5 border-2 border-blue-300 bg-blue-50 text-center">
      <p class="text-3xl font-bold text-blue-700" id="wp-litres"></p>
      <p class="text-blue-600 mt-1 text-sm" id="wp-glasses"></p>
    </div>
    <p class="text-center mt-3">
      <a href="/health/water-intake/" class="text-sm text-teal-700 hover:underline">→ <span data-bn="সম্পূর্ণ ক্যালকুলেটর (গরমের বিকল্পসহ)" data-en="Full calculator (with hot weather option)">সম্পূর্ণ ক্যালকুলেটর (গরমের বিকল্পসহ)</span></a>
    </p>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">
    <div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">৮ গ্লাসের নিয়ম কোথা থেকে এলো?</h2>
      <p>"প্রতিদিন ৮ গ্লাস পানি পান করুন" — এই পরামর্শটি আমরা সবাই ছোটবেলা থেকে শুনে আসছি। কিন্তু এই সংখ্যাটি কোথা থেকে এলো? ১৯৪৫ সালে আমেরিকার National Research Council একটি নির্দেশিকা প্রকাশ করেছিল যাতে বলা হয়েছিল প্রতি ক্যালরি খাবারের জন্য ১ মিলিলিটার পানি প্রয়োজন। গড়ে ২০০০ ক্যালরির ডায়েটে তা হয় ২ লিটার, যা প্রায় ৮ গ্লাসের সমান। কিন্তু ওই নির্দেশিকাতেই বলা ছিল খাবার থেকেও অনেকটা পানি আসে — যে অংশটি পরে প্রায়ই বাদ দেওয়া হয়েছে।</p>
      <p class="mt-3">বাস্তবতা হলো, প্রতিটি মানুষের পানির চাহিদা আলাদা। এটি নির্ভর করে ওজন, উচ্চতা, বয়স, লিঙ্গ, আবহাওয়া এবং শারীরিক কার্যকলাপের উপর। তাই "৮ গ্লাস" একটি মোটামুটি নির্দেশিকা, সবার জন্য সঠিক নিয়ম নয়।</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">পানি পানের সঠিক সূত্র</h2>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200 text-center">
        <p class="text-xl font-bold text-teal-800">দৈনিক পানির চাহিদা = ওজন (কেজি) × ৩৫ মিলিলিটার</p>
        <p class="text-sm text-teal-600 mt-2">উদাহরণ: ৭০ কেজি → ৭০ × ৩৫ = ২৪৫০ মিলি = ২.৪৫ লিটার = প্রায় ১০ গ্লাস</p>
      </div>
      <p class="mt-3">এই সূত্রটি প্রাপ্তবয়স্কদের জন্য একটি ভালো বেসলাইন। এরপর শারীরিক পরিশ্রম ও আবহাওয়া অনুযায়ী আরও যোগ করতে হয়।</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">ওজন অনুযায়ী দৈনিক পানির চাহিদা</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-teal-700 text-white">
              <th class="p-3 text-left">ওজন</th>
              <th class="p-3 text-center">মিলিলিটার</th>
              <th class="p-3 text-center">লিটার</th>
              <th class="p-3 text-center">গ্লাস (২৫০ মিলি)</th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3">৪০ কেজি</td><td class="p-3 text-center">১৪০০ মিলি</td><td class="p-3 text-center">১.৪ লি</td><td class="p-3 text-center font-bold">৬ গ্লাস</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3">৫০ কেজি</td><td class="p-3 text-center">১৭৫০ মিলি</td><td class="p-3 text-center">১.৮ লি</td><td class="p-3 text-center font-bold">৭ গ্লাস</td></tr>
            <tr class="bg-white border-b"><td class="p-3">৬০ কেজি</td><td class="p-3 text-center">২১০০ মিলি</td><td class="p-3 text-center">২.১ লি</td><td class="p-3 text-center font-bold">৮–৯ গ্লাস</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3">৭০ কেজি</td><td class="p-3 text-center">২৪৫০ মিলি</td><td class="p-3 text-center">২.৫ লি</td><td class="p-3 text-center font-bold">১০ গ্লাস</td></tr>
            <tr class="bg-white border-b"><td class="p-3">৮০ কেজি</td><td class="p-3 text-center">২৮০০ মিলি</td><td class="p-3 text-center">২.৮ লি</td><td class="p-3 text-center font-bold">১১ গ্লাস</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3">৯০ কেজি</td><td class="p-3 text-center">৩১৫০ মিলি</td><td class="p-3 text-center">৩.২ লি</td><td class="p-3 text-center font-bold">১৩ গ্লাস</td></tr>
            <tr class="bg-white border-b"><td class="p-3">১০০ কেজি</td><td class="p-3 text-center">৩৫০০ মিলি</td><td class="p-3 text-center">৩.৫ লি</td><td class="p-3 text-center font-bold">১৪ গ্লাস</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-500 mt-2">* স্বাভাবিক কার্যকলাপের জন্য। ব্যায়াম ও গরমে আরও ৫০০–১০০০ মিলি যোগ করুন।</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">শারীরিক পরিশ্রম ও আবহাওয়া অনুযায়ী অতিরিক্ত পানি</h2>
      <div class="space-y-3">
        <div class="bg-orange-50 rounded-xl p-4 border border-orange-200">
          <p class="font-semibold text-orange-800">🏃 সক্রিয় ব্যক্তি (দৈনিক ব্যায়াম বা শারীরিক কাজ)</p>
          <p class="text-gray-700 mt-1 text-sm">বেস পরিমাণের সাথে অতিরিক্ত <strong>৫০০ মিলি</strong> (২ গ্লাস) যোগ করুন।</p>
        </div>
        <div class="bg-red-50 rounded-xl p-4 border border-red-200">
          <p class="font-semibold text-red-800">🏋️ অত্যন্ত সক্রিয় (খেলাধুলা, কঠিন শ্রম)</p>
          <p class="text-gray-700 mt-1 text-sm">বেস পরিমাণের সাথে অতিরিক্ত <strong>১০০০ মিলি</strong> (৪ গ্লাস) যোগ করুন।</p>
        </div>
        <div class="bg-yellow-50 rounded-xl p-4 border border-yellow-200">
          <p class="font-semibold text-yellow-800">☀️ গরম মৌসুম বা উষ্ণ আবহাওয়া</p>
          <p class="text-gray-700 mt-1 text-sm">ঘামের ক্ষতি পূরণে অতিরিক্ত <strong>৫০০ মিলি</strong> যোগ করুন।</p>
        </div>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">পানিশূন্যতার লক্ষণ — কীভাবে বুঝবেন?</h2>
      <p>প্রস্রাবের রঙ পানিশূন্যতার সবচেয়ে সহজ সূচক। হালকা হলুদ বা প্রায় রঙহীন প্রস্রাব মানে হাইড্রেশন ভালো। গাঢ় হলুদ বা কমলা রঙের প্রস্রাব মানে আরও পানি দরকার।</p>
      <div class="space-y-2 mt-3">
        <div class="flex items-start gap-3 bg-gray-50 rounded-xl p-3 border border-gray-200">
          <span class="text-xl">🟡</span>
          <div>
            <p class="font-semibold text-gray-900">হালকা পানিশূন্যতা (১–২% ঘাটতি)</p>
            <p class="text-sm text-gray-600">মাথাব্যথা, মনোযোগ কমে যাওয়া, মুখ সামান্য শুষ্ক অনুভব করা, প্রস্রাব গাঢ় হলুদ।</p>
          </div>
        </div>
        <div class="flex items-start gap-3 bg-orange-50 rounded-xl p-3 border border-orange-200">
          <span class="text-xl">🟠</span>
          <div>
            <p class="font-semibold text-gray-900">মাঝারি পানিশূন্যতা (৩–৪% ঘাটতি)</p>
            <p class="text-sm text-gray-600">তীব্র তৃষ্ণা, ক্লান্তি, কর্মক্ষমতা উল্লেখযোগ্যভাবে কমে যাওয়া, মাথা ঘোরা।</p>
          </div>
        </div>
        <div class="flex items-start gap-3 bg-red-50 rounded-xl p-3 border border-red-200">
          <span class="text-xl">🔴</span>
          <div>
            <p class="font-semibold text-gray-900">তীব্র পানিশূন্যতা (৫%+ ঘাটতি)</p>
            <p class="text-sm text-gray-600">দ্রুত হৃদস্পন্দন, শ্বাস নিতে কষ্ট, অজ্ঞান হওয়ার সম্ভাবনা — তাৎক্ষণিক চিকিৎসা নেওয়া উচিত।</p>
          </div>
        </div>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">সঠিক সময়ে পানি পান — দিনের রুটিন</h2>
      <div class="space-y-2">
        <div class="bg-blue-50 rounded-xl p-3 border border-blue-200 flex gap-3 items-start">
          <span class="text-lg font-bold text-blue-700 min-w-[60px]">সকাল</span>
          <p class="text-sm text-gray-700">ঘুম থেকে ওঠার পর ১–২ গ্লাস পানি পান করুন। ঘুমের সময় শরীর থেকে পানি বের হয়ে যায়, তাই সকালে পানি পান বিপাকক্রিয়া শুরু করতে সাহায্য করে।</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-3 border border-blue-200 flex gap-3 items-start">
          <span class="text-lg font-bold text-blue-700 min-w-[60px]">খাবারের আগে</span>
          <p class="text-sm text-gray-700">প্রতি বেলা খাওয়ার ৩০ মিনিট আগে ১ গ্লাস পানি পান করলে হজম ভালো হয় এবং অতিরিক্ত খাওয়া কমে।</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-3 border border-blue-200 flex gap-3 items-start">
          <span class="text-lg font-bold text-blue-700 min-w-[60px]">ব্যায়ামের সময়</span>
          <p class="text-sm text-gray-700">ব্যায়ামের আগে ২৫০–৫০০ মিলি, মাঝে প্রতি ১৫–২০ মিনিটে ১৫০–২৫০ মিলি, এবং ব্যায়ামের পরে ৫০০ মিলি পানি পান করুন।</p>
        </div>
        <div class="bg-blue-50 rounded-xl p-3 border border-blue-200 flex gap-3 items-start">
          <span class="text-lg font-bold text-blue-700 min-w-[60px]">রাতে</span>
          <p class="text-sm text-gray-700">ঘুমানোর ১–২ ঘণ্টা আগে বেশি পানি পান এড়িয়ে চলুন — ঘুম ভেঙে বারবার শৌচাগারে যেতে হবে।</p>
        </div>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">পানি পানের উপকারিতা — বৈজ্ঞানিক তথ্য</h2>
      <ul class="space-y-2 text-sm">
        <li class="flex gap-2 items-start"><span class="text-teal-600 font-bold">🧠</span> <span><strong>মস্তিষ্কের কার্যক্ষমতা:</strong> মাত্র ১–২% পানিশূন্যতা মনোযোগ ও স্মৃতিশক্তি উল্লেখযোগ্যভাবে কমিয়ে দেয় (Journal of Nutrition, 2012)।</span></li>
        <li class="flex gap-2 items-start"><span class="text-teal-600 font-bold">⚡</span> <span><strong>শক্তি ও ক্লান্তি:</strong> পর্যাপ্ত পানি পান শক্তির মাত্রা বজায় রাখে। পানিশূন্যতা শরীরের শক্তি উৎপাদন প্রক্রিয়া ধীর করে দেয়।</span></li>
        <li class="flex gap-2 items-start"><span class="text-teal-600 font-bold">🫘</span> <span><strong>কিডনির স্বাস্থ্য:</strong> পর্যাপ্ত পানি পান কিডনির পাথর হওয়ার সম্ভাবনা কমায়। প্রস্রাবের সাথে খনিজ ও বর্জ্য পদার্থ বেরিয়ে যায়।</span></li>
        <li class="flex gap-2 items-start"><span class="text-teal-600 font-bold">🫀</span> <span><strong>হজম ও কোষ্ঠকাঠিন্য:</strong> পানি হজমে সাহায্য করে এবং কোষ্ঠকাঠিন্য প্রতিরোধ করে। অন্ত্র সঠিকভাবে কাজ করতে পানির প্রয়োজন।</span></li>
        <li class="flex gap-2 items-start"><span class="text-teal-600 font-bold">✨</span> <span><strong>ত্বকের যত্ন:</strong> পর্যাপ্ত হাইড্রেশন ত্বক উজ্জ্বল ও আর্দ্র রাখে। পানিশূন্যতায় ত্বক শুষ্ক ও নিস্তেজ দেখায়।</span></li>
        <li class="flex gap-2 items-start"><span class="text-teal-600 font-bold">⚖️</span> <span><strong>ওজন নিয়ন্ত্রণ:</strong> খাওয়ার আগে পানি পান করলে ক্ষুধা কিছুটা কমে এবং অতিরিক্ত খাওয়া এড়ানো যায়।</span></li>
      </ul>

