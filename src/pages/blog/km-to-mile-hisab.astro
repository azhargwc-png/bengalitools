---
import BlogLayout from '../../layouts/BlogLayout.astro';
import AdSlot from '../../components/AdSlot.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "১ কিলোমিটার সমান কত মাইল?",
      "acceptedAnswer": { "@type": "Answer", "text": "১ কিলোমিটার সমান ০.৬২১৩৭১ মাইল। সহজে মনে রাখতে পারেন: ১ কিলোমিটার ≈ ০.৬২ মাইল।" }
    },
    {
      "@type": "Question",
      "name": "১ মাইল সমান কত কিলোমিটার?",
      "acceptedAnswer": { "@type": "Answer", "text": "১ মাইল সমান ১.৬০৯৩৪ কিলোমিটার। অর্থাৎ ১ মাইল প্রায় দেড় কিলোমিটারের একটু বেশি।" }
    },
    {
      "@type": "Question",
      "name": "কিলোমিটার থেকে মাইল বের করার সূত্র কী?",
      "acceptedAnswer": { "@type": "Answer", "text": "সূত্র: মাইল = কিলোমিটার × ০.৬২১৩৭১। উদাহরণ: ১০ কিলোমিটার = ১০ × ০.৬২১৩৭১ = ৬.২১ মাইল।" }
    },
    {
      "@type": "Question",
      "name": "ভারতে কিলোমিটার না মাইল ব্যবহার হয়?",
      "acceptedAnswer": { "@type": "Answer", "text": "ভারত ও বাংলাদেশে কিলোমিটার ব্যবহার হয়। মাইল মূলত যুক্তরাষ্ট্র, যুক্তরাজ্য ও মিয়ানমারে ব্যবহার হয়।" }
    },
    {
      "@type": "Question",
      "name": "১০০ কিলোমিটার মানে কত মাইল?",
      "acceptedAnswer": { "@type": "Answer", "text": "১০০ কিলোমিটার = ৬২.১৩ মাইল। সহজে মনে রাখুন: ১০০ কিলোমিটার ≈ ৬২ মাইল।" }
    }
  ]
};
---

<BlogLayout
  title="কিলোমিটার থেকে মাইল রূপান্তর — সম্পূর্ণ গাইড | BanglaTools"
  description="কিলোমিটার থেকে মাইল রূপান্তরের সহজ সূত্র ও টেবিল। ১ কিলোমিটার = কত মাইল? বাংলায় বিস্তারিত গাইড ও বিনামূল্যে কনভার্টার।"
  datePublished="2026-04-28"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)}></script>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog/" class="hover:text-teal-700">ব্লগ</a> → কিলোমিটার থেকে মাইল
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    কিলোমিটার থেকে মাইল রূপান্তর — সম্পূর্ণ গাইড
  </h1>

  <AdSlot slot="blog-top" />

  <div class="bg-teal-50 rounded-2xl p-5 border border-teal-200 mb-8">
    <h2 class="font-bold text-teal-800 mb-3">তাৎক্ষণিক km ↔ miles রূপান্তর</h2>
    <p class="text-gray-700 mb-3">যেকোনো দূরত্ব কিলোমিটার থেকে মাইলে বা মাইল থেকে কিলোমিটারে রূপান্তর করুন:</p>
    <p class="text-center">
      <a href="/converters/km-to-miles/" class="inline-block bg-teal-700 text-white px-6 py-3 rounded-xl font-semibold hover:bg-teal-800 transition-colors">
        → km ↔ miles কনভার্টার ব্যবহার করুন
      </a>
    </p>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">কিলোমিটার ও মাইল — কোনটি কোথায় ব্যবহার হয়?</h2>
      <p>বিশ্বের বেশিরভাগ দেশে দূরত্ব কিলোমিটারে পরিমাপ করা হয়। ভারত, বাংলাদেশ, চীন, ইউরোপ — সব জায়গায় কিলোমিটার প্রচলিত। তবে যুক্তরাষ্ট্র এখনো মাইল ব্যবহার করে। যুক্তরাজ্যে রাস্তার দূরত্বে মাইল এবং বৈজ্ঞানিক কাজে কিলোমিটার ব্যবহার হয়।</p>
      <p>বিদেশি মানচিত্র, গাড়ি চালানোর অ্যাপ বা ফিটনেস ট্র্যাকার ব্যবহার করার সময় কিলোমিটার ও মাইলের মধ্যে রূপান্তর জানা দরকার।</p>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">কিলোমিটার থেকে মাইল রূপান্তরের সূত্র</h2>
      <div class="bg-teal-50 border border-teal-200 rounded-xl p-4 my-4">
        <p class="font-bold text-teal-900 text-lg">মাইল = কিলোমিটার × ০.৬২১৩৭১</p>
      </div>
      <p><strong>উদাহরণ:</strong></p>
      <ul class="list-disc pl-5 space-y-1 mt-2">
        <li>৫ km = ৫ × ০.৬২১৩৭১ = <strong>৩.১১ miles</strong></li>
        <li>১০ km = ১০ × ০.৬২১৩৭১ = <strong>৬.২১ miles</strong></li>
        <li>৪২.১৯৫ km (ম্যারাথন) = <strong>২৬.২২ miles</strong></li>
      </ul>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">মাইল থেকে কিলোমিটার রূপান্তরের সূত্র</h2>
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 my-4">
        <p class="font-bold text-blue-900 text-lg">কিলোমিটার = মাইল × ১.৬০৯৩৪</p>
      </div>
      <p><strong>উদাহরণ:</strong></p>
      <ul class="list-disc pl-5 space-y-1 mt-2">
        <li>১ mile = ১ × ১.৬০৯৩৪ = <strong>১.৬১ km</strong></li>
        <li>৫ miles = ৫ × ১.৬০৯৩৪ = <strong>৮.০৫ km</strong></li>
        <li>২৬.২ miles (ম্যারাথন) = <strong>৪২.১৬ km</strong></li>
      </ul>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">কিলোমিটার থেকে মাইল রূপান্তর টেবিল</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3">কিলোমিটার (km)</th><th class="p-3">মাইল (miles)</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 text-center">১ km</td><td class="p-3 text-center font-bold">০.৬২ miles</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">৫ km</td><td class="p-3 text-center font-bold">৩.১১ miles</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">১০ km</td><td class="p-3 text-center font-bold">৬.২১ miles</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">২১.১ km (হাফ ম্যারাথন)</td><td class="p-3 text-center font-bold">১৩.১১ miles</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">৪২.২ km (ম্যারাথন)</td><td class="p-3 text-center font-bold">২৬.২২ miles</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">৫০ km</td><td class="p-3 text-center font-bold">৩১.০৭ miles</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">১০০ km</td><td class="p-3 text-center font-bold">৬২.১৪ miles</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">৫০০ km</td><td class="p-3 text-center font-bold">৩১০.৬৯ miles</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">পরিচিত দূরত্ব তুলনা</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><strong>ঢাকা থেকে চট্টগ্রাম:</strong> প্রায় ২৬৪ km = ১৬৪ miles</li>
        <li><strong>কলকাতা থেকে দিল্লি:</strong> প্রায় ১,৪৭৩ km = ৯১৫ miles</li>
        <li><strong>কলকাতা থেকে ঢাকা:</strong> প্রায় ৩০৭ km = ১৯১ miles</li>
        <li><strong>স্থানীয় দৌড় (৫ km রান):</strong> ৫ km = ৩.১১ miles</li>
      </ul>
    </div>

  </div>

  <section class="mb-8 mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">সাধারণ প্রশ্নোত্তর</h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">১ কিলোমিটার সমান কত মাইল?</summary>
        <p class="mt-3 text-gray-700">১ কিলোমিটার সমান ০.৬২১৩৭১ মাইল। সহজে মনে রাখুন: ১ km ≈ ০.৬২ miles।</p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">১ মাইল সমান কত কিলোমিটার?</summary>
        <p class="mt-3 text-gray-700">১ মাইল সমান ১.৬০৯৩৪ কিলোমিটার। অর্থাৎ ১ মাইল প্রায় দেড় কিলোমিটারের একটু বেশি।</p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">কিলোমিটার থেকে মাইল বের করার সূত্র কী?</summary>
        <p class="mt-3 text-gray-700">সূত্র: মাইল = কিলোমিটার × ০.৬২১৩৭১। উদাহরণ: ১০ km = ৬.২১ miles।</p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">ভারতে কিলোমিটার না মাইল ব্যবহার হয়?</summary>
        <p class="mt-3 text-gray-700">ভারত ও বাংলাদেশে কিলোমিটার ব্যবহার হয়। মাইল মূলত যুক্তরাষ্ট্র ও যুক্তরাজ্যে ব্যবহার হয়।</p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">১০০ কিলোমিটার মানে কত মাইল?</summary>
        <p class="mt-3 text-gray-700">১০০ কিলোমিটার = ৬২.১৩ মাইল।</p>
      </details>
    </div>
  </section>

  <AdSlot slot="blog-bottom" />

  <div class="mt-8 p-5 bg-teal-50 rounded-2xl border border-teal-200">
    <h3 class="font-bold text-teal-800 mb-3">সম্পর্কিত টুলস</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a href="/converters/km-to-miles/" class="block bg-white border border-teal-200 rounded-xl p-3 hover:border-teal-400 transition-colors">
        <div class="font-semibold text-gray-900">🛣️ km ↔ miles কনভার্টার</div>
        <div class="text-sm text-gray-500 mt-1">তাৎক্ষণিক দূরত্ব রূপান্তর</div>
      </a>
      <a href="/converters/feet-to-meters/" class="block bg-white border border-teal-200 rounded-xl p-3 hover:border-teal-400 transition-colors">
        <div class="font-semibold text-gray-900">📏 ফুট থেকে মিটার কনভার্টার</div>
        <div class="text-sm text-gray-500 mt-1">দৈর্ঘ্য রূপান্তর করুন</div>
      </a>
    </div>
  </div>
</BlogLayout>
