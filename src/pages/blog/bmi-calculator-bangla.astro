---
import BlogLayout from '../../layouts/BlogLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<BlogLayout
  title="বিএমআই ক্যালকুলেটর বাংলা | BanglaTools"
  description="বিনামূল্যে বাংলা BMI ক্যালকুলেটর — উচ্চতা ও ওজন দিয়ে তাৎক্ষণিক ফলাফল পান। WHO গাইডলাইন, BMI চার্ট ও স্বাস্থ্য পরামর্শ সহ সম্পূর্ণ গাইড।"
  datePublished="2026-03-25"
>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog/" class="hover:text-teal-700">ব্লগ</a> → বিএমআই ক্যালকুলেটর বাংলা
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    <span data-bn="বিএমআই ক্যালকুলেটর বাংলা — অনলাইনে বিনামূল্যে" data-en="BMI Calculator in Bengali — Free Online">বিএমআই ক্যালকুলেটর বাংলা — অনলাইনে বিনামূল্যে</span>
  </h1>

  <AdSlot slot="blog-top" />

  <!-- Full BMI calculator embed -->
  <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200 mb-8">
    <h2 class="font-bold text-teal-800 mb-4"><span data-bn="আপনার BMI বের করুন" data-en="Calculate Your BMI">আপনার BMI বের করুন</span></h2>
    <div class="space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><span data-bn="উচ্চতা (সেমি)" data-en="Height (cm)">উচ্চতা (সেমি)</span></label>
          <input type="number" id="b2-height" placeholder="170" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><span data-bn="ওজন (কেজি)" data-en="Weight (kg)">ওজন (কেজি)</span></label>
          <input type="number" id="b2-weight" placeholder="70" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
      </div>
      <div id="b2-result" class="hidden rounded-xl p-5 border-2 text-center">
        <div id="b2-score" class="text-4xl font-bold mb-2"></div>
        <div id="b2-category" class="text-lg font-semibold"></div>
        <div id="b2-advice" class="text-sm text-gray-600 mt-2"></div>
      </div>
    </div>
    <p class="text-center mt-3">
      <a href="/health/bmi-calculator/" class="text-sm text-teal-700 hover:underline">→ <span data-bn="সম্পূর্ণ BMI ক্যালকুলেটর (imperial সহ)" data-en="Full BMI calculator (including imperial)">সম্পূর্ণ BMI ক্যালকুলেটর (imperial সহ)</span></a>
    </p>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">
    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">BMI কী এবং কেন দরকার?</h2>
      <p>BMI (Body Mass Index) হলো শরীরের ওজন ও উচ্চতার অনুপাত থেকে হিসাব করা একটি সংখ্যা। এটি বলে দেয় আপনার ওজন স্বাস্থ্যকর কিনা। BMI পরীক্ষা করার জন্য ডাক্তারের কাছে যাওয়ার দরকার নেই — এই বিনামূল্যে অনলাইন ক্যালকুলেটর ব্যবহার করুন।</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">BMI বের করার সূত্র</h2>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200 text-center">
        <p class="text-xl font-bold text-teal-800">BMI = ওজন (কেজি) ÷ উচ্চতা (মিটার)²</p>
        <p class="text-sm text-teal-600 mt-2">উদাহরণ: ১৭০ সেমি, ৭০ কেজি → BMI = ৭০ ÷ (১.৭)² = ৭০ ÷ ২.৮৯ = ২৪.২</p>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">ঘরে বসে BMI কীভাবে মাপবেন?</h2>
      <ol class="space-y-2">
        <li>১. একটি মাপার ফিতা দিয়ে আপনার উচ্চতা সেন্টিমিটারে মাপুন।</li>
        <li>২. একটি ওজন মাপার যন্ত্রে আপনার ওজন কেজিতে মাপুন।</li>
        <li>৩. উপরের ক্যালকুলেটরে উচ্চতা ও ওজন লিখুন।</li>
        <li>৪. আপনার BMI ও স্বাস্থ্যের অবস্থা জানুন।</li>
      </ol>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">BMI সম্পর্কে সাধারণ ভুল ধারণা</h2>
      <p><strong>ভুল ধারণা:</strong> BMI বেশি মানেই অসুস্থ।</p>
      <p class="mt-1"><strong>সঠিক তথ্য:</strong> অ্যাথলেট বা মাংসপেশি বেশি এমন মানুষের BMI বেশি হতে পারে কিন্তু তারা সুস্থ। BMI একটি সাধারণ পরিমাপ — সম্পূর্ণ স্বাস্থ্য পরিমাপের জন্য ডাক্তারের পরামর্শ নিন।</p>
    </div>

  </div>

  <!-- FAQ -->
  <section class="mb-8 mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-3">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="বিএমআই কত হলে স্বাস্থ্যকর?" data-en="What BMI is considered healthy?">বিএমআই কত হলে স্বাস্থ্যকর?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="WHO অনুযায়ী ১৮.৫ থেকে ২৪.৯ এর মধ্যে BMI স্বাস্থ্যকর। ১৮.৫-এর কম মানে কম ওজন, ২৫-২৯.৯ মানে অতিরিক্ত ওজন এবং ৩০ বা তার বেশি মানে স্থূলতা।" data-en="According to WHO, a BMI between 18.5 and 24.9 is healthy. Below 18.5 is underweight, 25-29.9 is overweight and 30 or above is obese.">WHO অনুযায়ী ১৮.৫ থেকে ২৪.৯ এর মধ্যে BMI স্বাস্থ্যকর। ১৮.৫-এর কম মানে কম ওজন, ২৫-২৯.৯ মানে অতিরিক্ত ওজন এবং ৩০ বা তার বেশি মানে স্থূলতা।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="BMI বের করার সূত্র কী?" data-en="What is the BMI formula?">BMI বের করার সূত্র কী?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="BMI = ওজন (কেজি) ÷ উচ্চতা (মিটার)²। যেমন, ৭০ কেজি ওজন ও ১.৭০ মিটার উচ্চতায় BMI = ৭০ ÷ (১.৭০)² = ২৪.২। এই ক্যালকুলেটর স্বয়ংক্রিয়ভাবে হিসাব করে দেয়।" data-en="BMI = weight (kg) ÷ height (m)². Example: 70 kg and 1.70 m height → BMI = 70 ÷ (1.70)² = 24.2. This calculator computes it automatically.">BMI = ওজন (কেজি) ÷ উচ্চতা (মিটার)²। যেমন, ৭০ কেজি ওজন ও ১.৭০ মিটার উচ্চতায় BMI = ৭০ ÷ (১.৭০)² = ২৪.২। এই ক্যালকুলেটর স্বয়ংক্রিয়ভাবে হিসাব করে দেয়।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="মহিলা ও পুরুষের BMI কি আলাদা?" data-en="Is BMI different for men and women?">মহিলা ও পুরুষের BMI কি আলাদা?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="BMI সূত্র ও স্বাস্থ্যকর পরিসর নারী-পুরুষের জন্য একই। তবে একই BMI-তে নারীর শরীরে চর্বির পরিমাণ সাধারণত পুরুষের চেয়ে বেশি থাকে, যা স্বাভাবিক।" data-en="The BMI formula and healthy range are the same for men and women. However, women typically have more body fat at the same BMI compared to men, which is normal.">BMI সূত্র ও স্বাস্থ্যকর পরিসর নারী-পুরুষের জন্য একই। তবে একই BMI-তে নারীর শরীরে চর্বির পরিমাণ সাধারণত পুরুষের চেয়ে বেশি থাকে, যা স্বাভাবিক।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="শিশুদের BMI কীভাবে মাপা হয়?" data-en="How is BMI measured for children?">শিশুদের BMI কীভাবে মাপা হয়?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="শিশুদের BMI একই সূত্রে হিসাব করা হয় কিন্তু বয়স ও লিঙ্গ অনুযায়ী আলাদা চার্টে মূল্যায়ন করা হয়। প্রাপ্তবয়স্কদের ১৮.৫-২৪.৯ সীমা শিশুদের ক্ষেত্রে প্রযোজ্য নয়।" data-en="Children's BMI uses the same formula but is assessed on age and gender-specific charts. The adult threshold of 18.5-24.9 does not apply to children.">শিশুদের BMI একই সূত্রে হিসাব করা হয় কিন্তু বয়স ও লিঙ্গ অনুযায়ী আলাদা চার্টে মূল্যায়ন করা হয়। প্রাপ্তবয়স্কদের ১৮.৫-২৪.৯ সীমা শিশুদের ক্ষেত্রে প্রযোজ্য নয়।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="BMI কি সবসময় সঠিক?" data-en="Is BMI always accurate?">BMI কি সবসময় সঠিক?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="BMI একটি সাধারণ পরিমাপ, সবসময় নির্ভুল নয়। অ্যাথলেট বা মাংসপেশি বেশি এমন মানুষের BMI বেশি হতে পারে তবুও তারা সুস্থ। সম্পূর্ণ স্বাস্থ্য মূল্যায়নের জন্য ডাক্তারের পরামর্শ নিন।" data-en="BMI is a general measure and not always accurate. Athletes or muscular people may have a high BMI yet still be healthy. For a complete health assessment, consult a doctor.">BMI একটি সাধারণ পরিমাপ, সবসময় নির্ভুল নয়। অ্যাথলেট বা মাংসপেশি বেশি এমন মানুষের BMI বেশি হতে পারে তবুও তারা সুস্থ। সম্পূর্ণ স্বাস্থ্য মূল্যায়নের জন্য ডাক্তারের পরামর্শ নিন।</span></p>
      </details>
    </div>
  </section>

  <div class="mt-8 text-center">
    <a href="/health/bmi-calculator/" class="bg-teal-700 hover:bg-teal-800 text-white font-semibold py-3 px-6 rounded-xl transition-colors inline-block">
      <span data-bn="সম্পূর্ণ BMI ক্যালকুলেটর খুলুন →" data-en="Open Full BMI Calculator →">সম্পূর্ণ BMI ক্যালকুলেটর খুলুন →</span>
    </a>
  </div>

  <AdSlot slot="blog-bottom" />
</BlogLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var hEl = document.getElementById('b2-height');
  var wEl = document.getElementById('b2-weight');
  var resultEl = document.getElementById('b2-result');
  var scoreEl = document.getElementById('b2-score');
  var catEl = document.getElementById('b2-category');
  var advEl = document.getElementById('b2-advice');

  function calc() {
    var h = parseFloat(hEl.value) / 100;
    var w = parseFloat(wEl.value);
    if (isNaN(h) || isNaN(w) || h <= 0 || w <= 0) { resultEl.classList.add('hidden'); return; }
    var bmi = w / (h * h);
    var cat, color, advice;

    if (bmi < 18.5) {
      cat = 'কম ওজন / Underweight'; color = 'border-blue-300 bg-blue-50 text-blue-800';
      advice = 'পুষ্টিকর খাবার বাড়ান / Increase nutritious food intake';
    } else if (bmi < 25) {
      cat = 'স্বাস্থ্যকর / Healthy ✓'; color = 'border-green-300 bg-green-50 text-green-800';
      advice = 'চমৎকার! এই ওজন বজায় রাখুন / Excellent! Maintain this weight';
    } else if (bmi < 30) {
      cat = 'অতিরিক্ত ওজন / Overweight'; color = 'border-orange-300 bg-orange-50 text-orange-800';
      advice = 'খাবারে নজর দিন ও ব্যায়াম করুন / Watch diet and exercise more';
    } else {
      cat = 'স্থূলতা / Obese'; color = 'border-red-300 bg-red-50 text-red-800';
      advice = 'ডাক্তারের পরামর্শ নিন / Please consult a doctor';
    }

    resultEl.className = 'rounded-xl p-5 border-2 text-center ' + color;
    scoreEl.textContent = 'BMI: ' + bmi.toFixed(1);
    catEl.textContent = cat;
    advEl.textContent = advice;
    resultEl.classList.remove('hidden');
  }

  hEl.addEventListener('input', calc);
  wEl.addEventListener('input', calc);
});
</script>
