---
import ToolLayout from '../../layouts/ToolLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="বাংলা মিষ্টির ক্যালরি তালিকা — রসগোল্লা, সন্দেশ, মিষ্টি দই ও আরও | BanglaTools"
  description="রসগোল্লা, সন্দেশ, মিষ্টি দই, চমচম, জিলাপি সহ ১৫+ বাংলা মিষ্টির সম্পূর্ণ ক্যালরি তালিকা। কোন মিষ্টিতে কত ক্যালরি — পুষ্টি তথ্য ও ডায়েট পরামর্শ সহ।"
>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog" class="hover:text-teal-700">ব্লগ</a> → বাংলা মিষ্টির ক্যালরি তালিকা
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    <span data-bn="বাংলা মিষ্টির ক্যালরি তালিকা — ১৫+ মিষ্টির সম্পূর্ণ গাইড" data-en="Bengali Sweets Calorie List — Complete Guide to 15+ Sweets">বাংলা মিষ্টির ক্যালরি তালিকা — ১৫+ মিষ্টির সম্পূর্ণ গাইড</span>
  </h1>

  <AdSlot slot="blog-top" />

  <!-- Key fact box -->
  <div class="bg-orange-50 rounded-2xl p-5 border border-orange-200 mb-8">
    <div class="text-center">
      <div class="text-5xl mb-3">🍮</div>
      <p class="text-xl font-bold text-orange-800 mb-3" data-bn="সংক্ষিপ্ত ক্যালরি তুলনা" data-en="Quick calorie comparison">সংক্ষিপ্ত ক্যালরি তুলনা</p>
      <div class="grid grid-cols-3 gap-3 text-sm">
        <div class="bg-green-100 rounded-xl p-3">
          <p class="font-bold text-green-700" data-bn="সবচেয়ে কম" data-en="Lowest">সবচেয়ে কম</p>
          <p class="text-green-800 font-semibold" data-bn="মিষ্টি দই" data-en="Mishti Doi">মিষ্টি দই</p>
          <p class="text-green-600 text-xs" data-bn="~১০০ ক্যালরি/১০০গ্রাম" data-en="~100 cal/100g">~১০০ ক্যালরি/১০০গ্রাম</p>
        </div>
        <div class="bg-orange-100 rounded-xl p-3">
          <p class="font-bold text-orange-700" data-bn="মাঝারি" data-en="Moderate">মাঝারি</p>
          <p class="text-orange-800 font-semibold" data-bn="রসগোল্লা" data-en="Rasgolla">রসগোল্লা</p>
          <p class="text-orange-600 text-xs" data-bn="~১১২ ক্যালরি/পিস" data-en="~112 cal/piece">~১১২ ক্যালরি/পিস</p>
        </div>
        <div class="bg-red-100 rounded-xl p-3">
          <p class="font-bold text-red-700" data-bn="সবচেয়ে বেশি" data-en="Highest">সবচেয়ে বেশি</p>
          <p class="text-red-800 font-semibold" data-bn="কালাকান্দ" data-en="Kalakand">কালাকান্দ</p>
          <p class="text-red-600 text-xs" data-bn="~৩৮০ ক্যালরি/১০০গ্রাম" data-en="~380 cal/100g">~৩৮০ ক্যালরি/১০০গ্রাম</p>
        </div>
      </div>
    </div>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">
    <div data-lang-bn>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">১৫+ বাংলা মিষ্টির ক্যালরি তালিকা</h2>
      <p class="text-sm text-gray-500 mb-3">নোট: ক্যালরির পরিমাণ রেসিপি ও প্রস্তুতকারীর উপর কিছুটা ভিন্ন হতে পারে। এখানে গড় মান দেওয়া হয়েছে।</p>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-teal-700 text-white">
              <th class="p-3 text-left">মিষ্টির নাম</th>
              <th class="p-3 text-center">পরিবেশনের আকার</th>
              <th class="p-3 text-center">ক্যালরি</th>
              <th class="p-3 text-center">প্রতি ১০০গ্রামে</th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">রসগোল্লা</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৫০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১০০–১২৫</td>
              <td class="p-3 text-center text-gray-600">২০০–২৫০</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">সন্দেশ</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৩০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১২০–১৫০</td>
              <td class="p-3 text-center text-gray-600">৪০০–৫০০</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">মিষ্টি দই</td>
              <td class="p-3 text-center text-gray-500">১ ভাঁড় (~১০০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-green-600">৯০–১১০</td>
              <td class="p-3 text-center text-gray-600">৯০–১১০</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">রসমালাই</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৫০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১৩০–১৫০</td>
              <td class="p-3 text-center text-gray-600">২৬০–৩০০</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">গুলাব জামুন</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৪০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-red-600">১৫০–১৮০</td>
              <td class="p-3 text-center text-gray-600">৩৭৫–৪৫০</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">চমচম</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৫০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১৩০–১৬০</td>
              <td class="p-3 text-center text-gray-600">২৬০–৩২০</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">পান্তুয়া</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৫০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১৪০–১৭০</td>
              <td class="p-3 text-center text-gray-600">২৮০–৩৪০</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">পায়েস / ক্ষীর</td>
              <td class="p-3 text-center text-gray-500">১ বাটি (~১০০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১৫০–১৮০</td>
              <td class="p-3 text-center text-gray-600">১৫০–১৮০</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">জিলাপি</td>
              <td class="p-3 text-center text-gray-500">৩–৪ পিস (~৫০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১৫০–১৭৫</td>
              <td class="p-3 text-center text-gray-600">৩০০–৩৫০</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">লাড্ডু (বেসনের)</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৪০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-red-600">১৫০–২০০</td>
              <td class="p-3 text-center text-gray-600">৩৭৫–৫০০</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">কালাকান্দ</td>
              <td class="p-3 text-center text-gray-500">১ টুকরো (~৫০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-red-600">১৭০–২০০</td>
              <td class="p-3 text-center text-gray-600">৩৪০–৩৮০</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">মালপোয়া</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৬০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-red-600">১৮০–২২০</td>
              <td class="p-3 text-center text-gray-600">৩০০–৩৬৫</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">পাটিসাপটা</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৬০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১২০–১৫০</td>
              <td class="p-3 text-center text-gray-600">২০০–২৫০</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">নারকেল নাড়ু</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৩০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১২০–১৪০</td>
              <td class="p-3 text-center text-gray-600">৪০০–৪৭০</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">তিলের নাড়ু</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৩০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১৩৫–১৬৫</td>
              <td class="p-3 text-center text-gray-600">৪৫০–৫৫০</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">পিঠা (ভাপা)</td>
              <td class="p-3 text-center text-gray-500">১ পিস (~৬০গ্রাম)</td>
              <td class="p-3 text-center font-bold text-orange-600">১৩০–১৬০</td>
              <td class="p-3 text-center text-gray-600">২১৫–২৬৫</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-8 mb-3">শীর্ষ ৫ মিষ্টির বিস্তারিত পুষ্টি উপাদান</h2>
      <p class="text-sm text-gray-500 mb-3">প্রতি ১০০ গ্রামে পুষ্টি উপাদানের পরিমাণ:</p>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-teal-700 text-white">
              <th class="p-3 text-left">মিষ্টি</th>
              <th class="p-3 text-center">ক্যালরি</th>
              <th class="p-3 text-center">কার্বোহাইড্রেট</th>
              <th class="p-3 text-center">প্রোটিন</th>
              <th class="p-3 text-center">ফ্যাট</th>
              <th class="p-3 text-center">চিনি</th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">রসগোল্লা</td>
              <td class="p-3 text-center font-bold">২০০–২৫০</td>
              <td class="p-3 text-center">৩৬–৪৪গ্রাম</td>
              <td class="p-3 text-center">৬–১০গ্রাম</td>
              <td class="p-3 text-center">৪–৮গ্রাম</td>
              <td class="p-3 text-center">৩০–৪০গ্রাম</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">সন্দেশ</td>
              <td class="p-3 text-center font-bold">৪০০–৫০০</td>
              <td class="p-3 text-center">৪৫–৬০গ্রাম</td>
              <td class="p-3 text-center">১০–১৫গ্রাম</td>
              <td class="p-3 text-center">১২–১৮গ্রাম</td>
              <td class="p-3 text-center">৪০–৫৫গ্রাম</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">মিষ্টি দই</td>
              <td class="p-3 text-center font-bold">৯০–১১০</td>
              <td class="p-3 text-center">১৪–১৮গ্রাম</td>
              <td class="p-3 text-center">৩–৫গ্রাম</td>
              <td class="p-3 text-center">২–৪গ্রাম</td>
              <td class="p-3 text-center">১৩–১৬গ্রাম</td>
            </tr>
            <tr class="bg-gray-50 border-b">
              <td class="p-3 font-medium">গুলাব জামুন</td>
              <td class="p-3 text-center font-bold">৩৭৫–৪৫০</td>
              <td class="p-3 text-center">৫০–৬৫গ্রাম</td>
              <td class="p-3 text-center">৫–৮গ্রাম</td>
              <td class="p-3 text-center">১৪–১৮গ্রাম</td>
              <td class="p-3 text-center">৪৫–৫৫গ্রাম</td>
            </tr>
            <tr class="bg-white border-b">
              <td class="p-3 font-medium">পায়েস</td>
              <td class="p-3 text-center font-bold">১৫০–১৮০</td>
              <td class="p-3 text-center">২৫–৩৫গ্রাম</td>
              <td class="p-3 text-center">৩–৫গ্রাম</td>
              <td class="p-3 text-center">৩–৭গ্রাম</td>
              <td class="p-3 text-center">১৮–২৮গ্রাম</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-8 mb-3">মিষ্টি খেলে কতটুকু ব্যায়াম দরকার?</h2>
      <p>একটি মিষ্টি খেলে সেই ক্যালরি পোড়াতে কতটুকু ব্যায়াম করতে হয় — জেনে রাখলে পরিমিত খাওয়া সহজ হয়।</p>
      <div class="overflow-x-auto mt-3">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-teal-700 text-white">
              <th class="p-3 text-left">মিষ্টি (১ পিস)</th>
              <th class="p-3 text-center">ক্যালরি</th>
              <th class="p-3 text-center">🚶 হাঁটা (৫ কিমি/ঘণ্টা)</th>
              <th class="p-3 text-center">🏃 দৌড়ানো (৮ কিমি/ঘণ্টা)</th>
              <th class="p-3 text-center">🚴 সাইকেল</th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3">মিষ্টি দই (১০০গ্রাম)</td><td class="p-3 text-center">১০০</td><td class="p-3 text-center">২৫ মিনিট</td><td class="p-3 text-center">১২ মিনিট</td><td class="p-3 text-center">১৭ মিনিট</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3">রসগোল্লা (১ পিস)</td><td class="p-3 text-center">১১২</td><td class="p-3 text-center">২৮ মিনিট</td><td class="p-3 text-center">১৩ মিনিট</td><td class="p-3 text-center">২০ মিনিট</td></tr>
            <tr class="bg-white border-b"><td class="p-3">পাটিসাপটা (১ পিস)</td><td class="p-3 text-center">১৩৫</td><td class="p-3 text-center">৩৪ মিনিট</td><td class="p-3 text-center">১৬ মিনিট</td><td class="p-3 text-center">২৩ মিনিট</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3">রসমালাই (১ পিস)</td><td class="p-3 text-center">১৪০</td><td class="p-3 text-center">৩৫ মিনিট</td><td class="p-3 text-center">১৭ মিনিট</td><td class="p-3 text-center">২৪ মিনিট</td></tr>
            <tr class="bg-white border-b"><td class="p-3">গুলাব জামুন (১ পিস)</td><td class="p-3 text-center">১৬৫</td><td class="p-3 text-center">৪১ মিনিট</td><td class="p-3 text-center">২০ মিনিট</td><td class="p-3 text-center">২৮ মিনিট</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3">মালপোয়া (১ পিস)</td><td class="p-3 text-center">২০০</td><td class="p-3 text-center">৫০ মিনিট</td><td class="p-3 text-center">২৪ মিনিট</td><td class="p-3 text-center">৩৪ মিনিট</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-500 mt-2">* ৬৫ কেজি ওজনের একজন প্রাপ্তবয়স্কের জন্য আনুমানিক হিসাব।</p>

      <h2 class="text-xl font-bold text-gray-900 mt-8 mb-3">ডায়াবেটিস রোগীদের জন্য কোন মিষ্টি তুলনামূলক ভালো?</h2>
      <p>ডায়াবেটিস রোগীদের জন্য মিষ্টি খাওয়া সীমিত রাখাই সবচেয়ে ভালো। তবে মাঝেমাঝে খেতে হলে কোনগুলো তুলনামূলক কম ঝুঁকির?</p>
      <div class="space-y-3 mt-3">
        <div class="bg-green-50 rounded-xl p-4 border border-green-200">
          <p class="font-semibold text-green-800">✅ তুলনামূলক ভালো বিকল্প (সীমিত পরিমাণে)</p>
          <ul class="mt-2 text-sm text-gray-700 space-y-1">
            <li>🟢 <strong>মিষ্টি দই:</strong> কম ক্যালরি, প্রোটিন আছে। গ্লাইসেমিক ইনডেক্স মাঝারি।</li>
            <li>🟢 <strong>রসগোল্লা:</strong> চিনির সিরাপ কম খেলে গ্লাইসেমিক প্রভাব কমে। ছানা থেকে প্রোটিনও আসে।</li>
            <li>🟢 <strong>সুগার-ফ্রি সন্দেশ:</strong> অনেক মিষ্টির দোকান এখন কৃত্রিম মিষ্টি দিয়ে তৈরি করে।</li>
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-4 border border-red-200">
          <p class="font-semibold text-red-800">❌ এড়িয়ে চলুন</p>
          <ul class="mt-2 text-sm text-gray-700 space-y-1">
            <li>🔴 <strong>জিলাপি:</strong> ময়দা ও চিনির সংমিশ্রণ — গ্লাইসেমিক ইনডেক্স অত্যন্ত বেশি।</li>
            <li>🔴 <strong>গুলাব জামুন ও মালপোয়া:</strong> চিনির সিরাপে ডুবানো, ক্যালরি ও চিনি দুটোই বেশি।</li>
            <li>🔴 <strong>লাড্ডু:</strong> তেল ও চিনি বেশি, নিয়ন্ত্রণ কঠিন।</li>
          </ul>
        </div>
