---
import ToolLayout from '../../layouts/ToolLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="১ কেজি সমান কত পাউন্ড — সম্পূর্ণ গাইড | BanglaTools"
  description="১ কেজি সমান ২.২০৪৬২ পাউন্ড। কেজি থেকে পাউন্ড রূপান্তরের সম্পূর্ণ গাইড, সূত্র ও উদাহরণ সহ।"
>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog" class="hover:text-teal-700">ব্লগ</a> → ১ কেজি সমান কত পাউন্ড
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    <span data-bn="১ কেজি সমান কত পাউন্ড — সম্পূর্ণ গাইড" data-en="1 kg equals how many pounds — Complete Guide">১ কেজি সমান কত পাউন্ড — সম্পূর্ণ গাইড</span>
  </h1>

  <AdSlot slot="blog-top" />

  <!-- Embed converter -->
  <div class="bg-teal-50 rounded-2xl p-5 border border-teal-200 mb-8">
    <h2 class="font-bold text-teal-800 mb-3">
      <span data-bn="কেজি থেকে পাউন্ড কনভার্টার" data-en="kg to lbs Converter">কেজি থেকে পাউন্ড কনভার্টার</span>
    </h2>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="text-sm text-gray-600" for="blog-kg"><span data-bn="কেজি" data-en="kg">কেজি</span></label>
        <input type="number" id="blog-kg" placeholder="70" class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg text-lg focus:border-teal-500 focus:outline-none mt-1 min-h-[44px]" />
      </div>
      <div>
        <label class="text-sm text-gray-600" for="blog-lbs"><span data-bn="পাউন্ড" data-en="lbs">পাউন্ড</span></label>
        <input type="number" id="blog-lbs" placeholder="154.32" class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg text-lg focus:border-teal-500 focus:outline-none mt-1 min-h-[44px]" />
      </div>
    </div>
    <p class="text-center mt-2">
      <a href="/converters/kg-to-lbs" class="text-sm text-teal-700 hover:underline">
        <span data-bn="→ সম্পূর্ণ কনভার্টার দেখুন" data-en="→ See full converter">→ সম্পূর্ণ কনভার্টার দেখুন</span>
      </a>
    </p>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">
    <div data-lang-bn>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">১ কেজি সমান কত পাউন্ড?</h2>
      <p>
        সহজ উত্তর: <strong>১ কেজি = ২.২০৪৬২ পাউন্ড</strong>। অর্থাৎ প্রতি কেজিতে প্রায় ২.২ পাউন্ড। মনে রাখার সহজ উপায়: কেজির সংখ্যাকে ২.২ দিয়ে গুণ করুন।
      </p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">কেজি থেকে পাউন্ড বের করার সূত্র</h2>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200 text-center">
        <p class="text-xl font-bold text-teal-800">পাউন্ড = কেজি × ২.২০৪৬২</p>
        <p class="text-sm text-teal-600 mt-1">লিটার = পাউন্ড ÷ ২.২০৪৬২</p>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">কেজি থেকে পাউন্ড রূপান্তরের সহজ টেবিল</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3">কেজি</th><th class="p-3">পাউন্ড</th><th class="p-3">ব্যবহার</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 text-center">১</td><td class="p-3 text-center font-bold">২.২০</td><td class="p-3">মানদণ্ড</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">৩.৫</td><td class="p-3 text-center font-bold">৭.৭২</td><td class="p-3">নবজাতক শিশুর ওজন</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">২৩</td><td class="p-3 text-center font-bold">৫০.৭১</td><td class="p-3">বিমানের লাগেজ</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">৫০</td><td class="p-3 text-center font-bold">১১০.২৩</td><td class="p-3">মানুষের ওজন</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">৭০</td><td class="p-3 text-center font-bold">১৫৪.৩২</td><td class="p-3">মানুষের ওজন</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">১০০</td><td class="p-3 text-center font-bold">২২০.৪৬</td><td class="p-3">মানদণ্ড</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">কখন কেজি থেকে পাউন্ড রূপান্তর দরকার হয়?</h2>
      <ul class="space-y-2">
        <li>✈️ <strong>বিমান ভ্রমণ:</strong> অনেক আন্তর্জাতিক বিমানবন্দরে লাগেজের ওজন পাউন্ডে বলা হয়। ২৩ কেজি = ৫০.৭১ পাউন্ড।</li>
        <li>🏥 <strong>বিদেশি চিকিৎসা:</strong> আমেরিকান ডাক্তারের প্রেসক্রিপশনে ওজন পাউন্ডে থাকতে পারে।</li>
        <li>👶 <strong>শিশুর ওজন:</strong> বিদেশে জন্মানো শিশুর ওজন পাউন্ডে বলা হয়।</li>
        <li>🛒 <strong>আন্তর্জাতিক শপিং:</strong> বিদেশি ওয়েবসাইটে পণ্যের ওজন পাউন্ডে থাকে।</li>
        <li>💪 <strong>ফিটনেস:</strong> আন্তর্জাতিক ফিটনেস অ্যাপে ওজন পাউন্ডে দেখানো হয়।</li>
      </ul>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">প্রায়ই জিজ্ঞাসিত প্রশ্ন</h2>
      <p><strong>১ পাউন্ড সমান কত কেজি?</strong> ১ পাউন্ড = ০.৪৫৩৫৯ কেজি। প্রায় আধা কেজি।</p>
      <p class="mt-2"><strong>১০ কেজি সমান কত পাউন্ড?</strong> ১০ × ২.২০৪৬২ = ২২.০৪৬২ পাউন্ড।</p>
      <p class="mt-2"><strong>৬০ কেজি সমান কত পাউন্ড?</strong> ৬০ × ২.২০৪৬২ = ১৩২.২৭ পাউন্ড।</p>
    </div>

    <div data-lang-en style="display:none">
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">1 kg equals how many pounds?</h2>
      <p>
        Simple answer: <strong>1 kg = 2.20462 pounds</strong>. That means every kilogram is approximately 2.2 pounds. The easy way to remember: multiply kilograms by 2.2.
      </p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">Formula for converting kg to lbs</h2>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200 text-center">
        <p class="text-xl font-bold text-teal-800">pounds = kg × 2.20462</p>
        <p class="text-sm text-teal-600 mt-1">kg = pounds ÷ 2.20462</p>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">Quick kg to lbs conversion table</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3">kg</th><th class="p-3">lbs</th><th class="p-3">Common use</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 text-center">1</td><td class="p-3 text-center font-bold">2.20</td><td class="p-3">Reference</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">3.5</td><td class="p-3 text-center font-bold">7.72</td><td class="p-3">Newborn weight</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">23</td><td class="p-3 text-center font-bold">50.71</td><td class="p-3">Airline luggage</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">50</td><td class="p-3 text-center font-bold">110.23</td><td class="p-3">Human weight</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">70</td><td class="p-3 text-center font-bold">154.32</td><td class="p-3">Human weight</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">100</td><td class="p-3 text-center font-bold">220.46</td><td class="p-3">Reference</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">When do you need to convert kg to lbs?</h2>
      <ul class="space-y-2">
        <li>✈️ <strong>Air travel:</strong> Many international airports display luggage limits in pounds. 23 kg = 50.71 lbs.</li>
        <li>🏥 <strong>Medical records:</strong> American doctors often record weight in pounds.</li>
        <li>👶 <strong>Baby weight:</strong> Babies born abroad are often weighed in pounds.</li>
        <li>🛒 <strong>International shopping:</strong> Foreign websites display product weight in pounds.</li>
        <li>💪 <strong>Fitness apps:</strong> Many international fitness apps use pounds.</li>
      </ul>
    </div>
  </div>

  <div class="mt-8 p-4 bg-gray-50 rounded-xl border border-gray-200 text-center">
    <a href="/converters/kg-to-lbs" class="bg-teal-700 hover:bg-teal-800 text-white font-semibold py-3 px-6 rounded-xl transition-colors inline-block">
      <span data-bn="কেজি থেকে পাউন্ড কনভার্টার খুলুন →" data-en="Open kg to lbs Converter →">কেজি থেকে পাউন্ড কনভার্টার খুলুন →</span>
    </a>
  </div>

  <AdSlot slot="blog-bottom" />
</ToolLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var kgEl = document.getElementById('blog-kg');
  var lbsEl = document.getElementById('blog-lbs');
  kgEl.addEventListener('input', function() {
    var v = parseFloat(kgEl.value);
    lbsEl.value = isNaN(v) ? '' : (v * 2.20462).toFixed(4);
  });
  lbsEl.addEventListener('input', function() {
    var v = parseFloat(lbsEl.value);
    kgEl.value = isNaN(v) ? '' : (v / 2.20462).toFixed(4);
  });
});
</script>
