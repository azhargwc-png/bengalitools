---
import ToolLayout from '../../layouts/ToolLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="১ ফুট সমান কত সেন্টিমিটার — ফুট থেকে সেমি গাইড | BanglaTools"
  description="১ ফুট সমান ৩০.৪৮ সেন্টিমিটার। ফুট থেকে সেমি রূপান্তরের সম্পূর্ণ গাইড, সূত্র ও উদাহরণ।"
>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog" class="hover:text-teal-700">ব্লগ</a> → ১ ফুট সমান কত সেন্টিমিটার
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    <span data-bn="১ ফুট সমান কত সেন্টিমিটার — ফুট থেকে সেমি গাইড" data-en="1 foot equals how many cm — feet to cm guide">১ ফুট সমান কত সেন্টিমিটার — ফুট থেকে সেমি গাইড</span>
  </h1>

  <AdSlot slot="blog-top" />

  <!-- Key fact + converter -->
  <div class="bg-teal-50 rounded-2xl p-5 border border-teal-200 mb-8">
    <p class="text-2xl font-bold text-teal-800 text-center mb-4" data-bn="১ ফুট = ৩০.৪৮ সেন্টিমিটার" data-en="1 foot = 30.48 centimetres">১ ফুট = ৩০.৪৮ সেন্টিমিটার</p>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="text-sm text-gray-600"><span data-bn="ফুট" data-en="feet">ফুট</span></label>
        <input type="number" id="ft-in" placeholder="5" class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg text-lg focus:border-teal-500 focus:outline-none mt-1 min-h-[44px]" />
      </div>
      <div>
        <label class="text-sm text-gray-600"><span data-bn="সেন্টিমিটার" data-en="cm">সেন্টিমিটার</span></label>
        <input type="number" id="cm-out" placeholder="152.4" class="w-full px-3 py-2 border-2 border-teal-300 bg-teal-50 rounded-lg text-lg mt-1 min-h-[44px]" readonly />
      </div>
    </div>
    <p class="text-center mt-2">
      <a href="/converters/feet-to-meters" class="text-sm text-teal-700 hover:underline">→ <span data-bn="সম্পূর্ণ কনভার্টার" data-en="Full Converter">সম্পূর্ণ কনভার্টার</span></a>
    </p>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">
    <div data-lang-bn>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">ফুট থেকে সেন্টিমিটার রূপান্তরের সূত্র</h2>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200 text-center">
        <p class="text-xl font-bold text-teal-800">সেন্টিমিটার = ফুট × ৩০.৪৮</p>
        <p class="text-sm text-teal-600 mt-1">ফুট = সেন্টিমিটার ÷ ৩০.৪৮</p>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">দ্রুত রূপান্তর টেবিল</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3">ফুট</th><th class="p-3">সেন্টিমিটার</th><th class="p-3">উদাহরণ</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 text-center">১</td><td class="p-3 text-center font-bold">৩০.৪৮</td><td class="p-3">শাসক</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">৪</td><td class="p-3 text-center font-bold">১২১.৯২</td><td class="p-3">ছোট শিশু</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">৫</td><td class="p-3 text-center font-bold">১৫২.৪০</td><td class="p-3">সাধারণ উচ্চতা</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">৫.৫</td><td class="p-3 text-center font-bold">১৬৭.৬৪</td><td class="p-3">গড় উচ্চতা</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">৬</td><td class="p-3 text-center font-bold">১৮২.৮৮</td><td class="p-3">লম্বা পুরুষ</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">১০</td><td class="p-3 text-center font-bold">৩০৪.৮০</td><td class="p-3">ঘরের ছাদ</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">উচ্চতা রূপান্তর — ফুট থেকে সেমি</h2>
      <p>বাংলাদেশ ও ভারতে সাধারণত উচ্চতা ফুট ও ইঞ্চিতে বলা হয়। কিন্তু ডাক্তারি রেকর্ড, পাসপোর্ট বা আন্তর্জাতিক ফর্মে সেন্টিমিটারে লিখতে হয়।</p>
      <p class="mt-2">যেমন: ৫ ফুট ৬ ইঞ্চি = (৫ × ৩০.৪৮) + (৬ × ২.৫৪) = ১৫২.৪ + ১৫.২৪ = <strong>১৬৭.৬৪ সেমি</strong></p>
    </div>

    <div data-lang-en style="display:none">
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">Formula for feet to cm conversion</h2>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200 text-center">
        <p class="text-xl font-bold text-teal-800">cm = feet × 30.48</p>
        <p class="text-sm text-teal-600 mt-1">feet = cm ÷ 30.48</p>
      </div>
      <p class="mt-4">Example: 5 feet 6 inches = (5 × 30.48) + (6 × 2.54) = 152.4 + 15.24 = <strong>167.64 cm</strong></p>
    </div>
  </div>

  <div class="mt-8 text-center">
    <a href="/converters/feet-to-meters" class="bg-teal-700 hover:bg-teal-800 text-white font-semibold py-3 px-6 rounded-xl transition-colors inline-block">
      <span data-bn="ফুট থেকে মিটার কনভার্টার →" data-en="Feet to Meters Converter →">ফুট থেকে মিটার কনভার্টার →</span>
    </a>
  </div>

  <AdSlot slot="blog-bottom" />
</ToolLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var ftEl = document.getElementById('ft-in');
  var cmEl = document.getElementById('cm-out');
  ftEl.addEventListener('input', function() {
    var v = parseFloat(ftEl.value);
    cmEl.value = isNaN(v) ? '' : (v * 30.48).toFixed(2);
  });
});
</script>
