---
import ToolLayout from '../../layouts/ToolLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="দুবাই দিরহাম আজকের রেট — AED to INR | BanglaTools"
  description="আজকের দুবাই দিরহাম রেট লাইভ দেখুন। AED থেকে INR বিনিময় হার, প্রবাসী বাঙালিদের জন্য সেরা রেটে টাকা পাঠানোর গাইড ও কনভার্টার।"
>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog" class="hover:text-teal-700">ব্লগ</a> → দুবাই দিরহাম আজকের রেট
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    <span data-bn="দুবাই দিরহাম আজকের রেট — AED থেকে INR লাইভ রেট" data-en="Dubai Dirham Today's Rate — AED to INR Live">দুবাই দিরহাম আজকের রেট — AED থেকে INR লাইভ রেট</span>
  </h1>

  <AdSlot slot="blog-top" />

  <!-- Live rate -->
  <div class="bg-teal-50 rounded-2xl p-5 border border-teal-200 mb-8">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold text-teal-800"><span data-bn="আজকের লাইভ দিরহাম রেট" data-en="Today's Live Dirham Rate">আজকের লাইভ দিরহাম রেট</span></h2>
      <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full">Live</span>
    </div>
    <div id="aed-rate-display" class="text-3xl font-bold text-teal-900 mb-1">লোড হচ্ছে...</div>
    <div id="aed-updated" class="text-xs text-gray-500 mb-4"></div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="text-sm text-gray-600"><span data-bn="দিরহাম (AED)" data-en="AED">দিরহাম (AED)</span></label>
        <input type="number" id="aed-in" placeholder="1000" class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg text-lg focus:border-teal-500 focus:outline-none mt-1 min-h-[44px]" />
      </div>
      <div>
        <label class="text-sm text-gray-600"><span data-bn="রুপি (INR)" data-en="INR">রুপি (INR)</span></label>
        <input type="number" id="inr-aed-out" placeholder="..." class="w-full px-3 py-2 border-2 border-teal-300 bg-teal-50 rounded-lg text-lg mt-1 min-h-[44px]" readonly />
      </div>
    </div>
    <p class="text-center mt-2">
      <a href="/currency/aed-to-inr" class="text-sm text-teal-700 hover:underline">→ <span data-bn="সম্পূর্ণ কনভার্টার" data-en="Full Converter">সম্পূর্ণ কনভার্টার</span></a>
    </p>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">
    <div data-lang-bn>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">দুবাইয়ে বাঙালি প্রবাসীরা</h2>
      <p>সংযুক্ত আরব আমিরাত (UAE), বিশেষত দুবাই ও আবুধাবিতে প্রচুর ভারতীয় এবং বাংলাদেশী বাঙালি কাজ করেন। তারা নিয়মিত দিরহামকে ভারতীয় রুপি বা বাংলাদেশী টাকায় রূপান্তর করে পরিবারকে পাঠান।</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">দিরহাম রূপান্তর উদাহরণ</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3">AED</th><th class="p-3">আনুমানিক INR (₹২২/AED হলে)</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 text-center">৫০০ AED</td><td class="p-3 text-center font-bold">₹১১,০০০</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">১,০০০ AED</td><td class="p-3 text-center font-bold">₹২২,০০০</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">৫,০০০ AED</td><td class="p-3 text-center font-bold">₹১,১০,০০০</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-500 mt-1">* আনুমানিক মান। সঠিক রেটের জন্য উপরের লাইভ কনভার্টার ব্যবহার করুন।</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">সেরা রেটে টাকা পাঠাতে</h2>
      <ul class="space-y-2">
        <li>• <strong>Wise (TransferWise):</strong> সাধারণত সেরা এক্সচেঞ্জ রেট দেয়।</li>
        <li>• <strong>Al Ansari Exchange:</strong> দুবাইয়ে জনপ্রিয়।</li>
        <li>• <strong>Western Union / MoneyGram:</strong> ব্যাপকভাবে পাওয়া যায়।</li>
        <li>• সবসময় ফি সহ মোট খরচ তুলনা করুন।</li>
      </ul>
    </div>

    <div data-lang-en style="display:none">
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">Bengali workers in Dubai</h2>
      <p>A large number of Indian and Bangladeshi Bengalis work in the UAE, particularly in Dubai and Abu Dhabi. They regularly convert dirhams to Indian rupees or Bangladeshi taka to send money home to their families.</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">Dirham conversion examples</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3">AED</th><th class="p-3">Approx. INR (at ₹22/AED)</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 text-center">500 AED</td><td class="p-3 text-center font-bold">₹11,000</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">1,000 AED</td><td class="p-3 text-center font-bold">₹22,000</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">5,000 AED</td><td class="p-3 text-center font-bold">₹1,10,000</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <section class="mb-8 mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-3">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="আজকে ১ দিরহাম কত ভারতীয় রুপি?" data-en="How many Indian rupees is 1 dirham today?">আজকে ১ দিরহাম কত ভারতীয় রুপি?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="বর্তমানে ১ AED প্রায় ₹২২–২৩ INR। সঠিক রেটের জন্য উপরের লাইভ কনভার্টার ব্যবহার করুন।" data-en="Currently 1 AED is approximately ₹22–23 INR. Use the live converter above for the exact rate.">বর্তমানে ১ AED প্রায় ₹২২–২৩ INR। সঠিক রেটের জন্য উপরের লাইভ কনভার্টার ব্যবহার করুন।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="দুবাই থেকে ভারতে টাকা পাঠানোর সেরা উপায় কী?" data-en="What is the best way to send money from Dubai to India?">দুবাই থেকে ভারতে টাকা পাঠানোর সেরা উপায় কী?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="Wise (TransferWise) ও Al Ansari Exchange সাধারণত সেরা রেট দেয়। Western Union ও MoneyGram ব্যাপকভাবে পাওয়া যায়। সবসময় ফি সহ মোট খরচ তুলনা করুন।" data-en="Wise (TransferWise) and Al Ansari Exchange generally offer the best rates. Western Union and MoneyGram are widely available. Always compare total cost including fees.">Wise (TransferWise) ও Al Ansari Exchange সাধারণত সেরা রেট দেয়। Western Union ও MoneyGram ব্যাপকভাবে পাওয়া যায়। সবসময় ফি সহ মোট খরচ তুলনা করুন।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="দিরহাম রেট কি স্থিতিশীল?" data-en="Is the dirham rate stable?">দিরহাম রেট কি স্থিতিশীল?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="AED মার্কিন ডলারের সাথে পেগড (১ USD = ৩.৬৭ AED), তাই USD/INR রেটের সাথে সাথে AED/INR রেটও পরিবর্তন হয়।" data-en="AED is pegged to the US dollar (1 USD = 3.67 AED), so as the USD/INR rate changes, the AED/INR rate also changes accordingly.">AED মার্কিন ডলারের সাথে পেগড (১ USD = ৩.৬৭ AED), তাই USD/INR রেটের সাথে সাথে AED/INR রেটও পরিবর্তন হয়।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="২০০০ দিরহাম কত রুপি?" data-en="How many rupees is 2000 dirhams?">২০০০ দিরহাম কত রুপি?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="২০০০ AED × ₹২২ = ₹৪৪,০০০ (আনুমানিক)। সঠিক হিসাবের জন্য উপরের লাইভ রেট দিয়ে গণনা করুন।" data-en="2000 AED × ₹22 = ₹44,000 (approx). Use the live rate above for exact calculation.">২০০০ AED × ₹২২ = ₹৪৪,০০০ (আনুমানিক)। সঠিক হিসাবের জন্য উপরের লাইভ রেট দিয়ে গণনা করুন।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="দুবাইতে কোন মানি এক্সচেঞ্জ সেরা?" data-en="Which money exchange is best in Dubai?">দুবাইতে কোন মানি এক্সচেঞ্জ সেরা?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="Al Ansari Exchange, Al Fardan Exchange ও UAE Exchange দুবাইয়ে জনপ্রিয়। ডিজিটাল ট্রান্সফারের জন্য Wise অ্যাপও উপকারী।" data-en="Al Ansari Exchange, Al Fardan Exchange and UAE Exchange are popular in Dubai. For digital transfers, the Wise app is also useful.">Al Ansari Exchange, Al Fardan Exchange ও UAE Exchange দুবাইয়ে জনপ্রিয়। ডিজিটাল ট্রান্সফারের জন্য Wise অ্যাপও উপকারী।</span></p>
      </details>
    </div>
  </section>

  <div class="mt-8 text-center">
    <a href="/currency/aed-to-inr" class="bg-teal-700 hover:bg-teal-800 text-white font-semibold py-3 px-6 rounded-xl transition-colors inline-block">
      <span data-bn="লাইভ AED to INR কনভার্টার →" data-en="Live AED to INR Converter →">লাইভ AED to INR কনভার্টার →</span>
    </a>
  </div>

  <AdSlot slot="blog-bottom" />
</ToolLayout>

<script is:inline>
var aedRate = null;
document.addEventListener('DOMContentLoaded', function() {
  var aedEl = document.getElementById('aed-in');
  var inrEl = document.getElementById('inr-aed-out');

  fetch('https://api.frankfurter.app/latest?from=AED&to=INR')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      aedRate = data.rates.INR;
      document.getElementById('aed-rate-display').textContent = '1 AED = ₹' + aedRate.toFixed(4);
      document.getElementById('aed-updated').textContent = 'আপডেট: ' + data.date;
    })
    .catch(function() {
      document.getElementById('aed-rate-display').textContent = 'রেট লোড করা যায়নি';
    });

  aedEl.addEventListener('input', function() {
    if (!aedRate) return;
    var v = parseFloat(aedEl.value);
    inrEl.value = isNaN(v) ? '' : (v * aedRate).toFixed(2);
  });
});
</script>
