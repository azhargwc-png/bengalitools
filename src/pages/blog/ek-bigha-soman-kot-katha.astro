---
import ToolLayout from '../../layouts/ToolLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="এক বিঘা সমান কত কাঠা — জমির মাপের সম্পূর্ণ গাইড | BanglaTools"
  description="১ বিঘা = ২০ কাঠা = ১৪,৪০০ বর্গফুট। বিঘা, কাঠা, ডেসিমেল, একর ও বর্গফুটের সম্পূর্ণ রূপান্তর টেবিল এবং জমি কেনার আগে জানার দরকারি তথ্য।"
>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog/" class="hover:text-teal-700">ব্লগ</a> → এক বিঘা সমান কত কাঠা
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    <span data-bn="এক বিঘা সমান কত কাঠা — জমির মাপের সম্পূর্ণ গাইড" data-en="1 Bigha equals how many Katha — Complete land measurement guide">এক বিঘা সমান কত কাঠা — জমির মাপের সম্পূর্ণ গাইড</span>
  </h1>

  <AdSlot slot="blog-top" />

  <!-- Key fact box -->
  <div class="bg-teal-50 rounded-2xl p-5 border border-teal-200 mb-8">
    <div class="text-center">
      <div class="text-5xl mb-3">🏡</div>
      <p class="text-2xl font-bold text-teal-800" data-bn="১ বিঘা = ২০ কাঠা = ১৪,৪০০ বর্গফুট" data-en="1 Bigha = 20 Katha = 14,400 sqft">১ বিঘা = ২০ কাঠা = ১৪,৪০০ বর্গফুট</p>
      <p class="text-teal-700 mt-1 text-sm" data-bn="(পশ্চিমবঙ্গ ও বাংলাদেশের মানদণ্ড অনুযায়ী)" data-en="(West Bengal and Bangladesh standard)">(পশ্চিমবঙ্গ ও বাংলাদেশের মানদণ্ড অনুযায়ী)</p>
    </div>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">
    <div data-lang-bn>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">বিঘা থেকে কাঠা রূপান্তরের সূত্র</h2>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200 text-center space-y-2">
        <p class="text-xl font-bold text-teal-800">কাঠা = বিঘা × ২০</p>
        <p class="text-sm text-teal-600">বিঘা = কাঠা ÷ ২০</p>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">জমির মাপের সম্পূর্ণ রূপান্তর টেবিল</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3 text-left">একক</th><th class="p-3">বিঘা</th><th class="p-3">কাঠা</th><th class="p-3">ডেসিমেল</th><th class="p-3">বর্গফুট</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 font-medium">১ বিঘা</td><td class="p-3 text-center font-bold text-teal-700">১</td><td class="p-3 text-center font-bold">২০</td><td class="p-3 text-center">৩৩.০৬</td><td class="p-3 text-center">১৪,৪০০</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-medium">১ কাঠা</td><td class="p-3 text-center">০.০৫</td><td class="p-3 text-center font-bold text-teal-700">১</td><td class="p-3 text-center">১.৬৫</td><td class="p-3 text-center font-bold">৭২০</td></tr>
            <tr class="bg-white border-b"><td class="p-3 font-medium">১ ছটাক</td><td class="p-3 text-center">০.০০৩১</td><td class="p-3 text-center">০.০৬২৫</td><td class="p-3 text-center">০.১০৩</td><td class="p-3 text-center">৪৫</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-medium">১ ডেসিমেল</td><td class="p-3 text-center">০.০৩০২</td><td class="p-3 text-center">০.৬০৫</td><td class="p-3 text-center font-bold text-teal-700">১</td><td class="p-3 text-center">৪৩৫.৬</td></tr>
            <tr class="bg-white border-b"><td class="p-3 font-medium">১ একর</td><td class="p-3 text-center">৩.০২৫</td><td class="p-3 text-center">৬০.৫</td><td class="p-3 text-center">১০০</td><td class="p-3 text-center">৪৩,৫৬০</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-medium">১ হেক্টর</td><td class="p-3 text-center">৭.৪৭৮</td><td class="p-3 text-center">১৪৯.৫</td><td class="p-3 text-center">২৪৭.১</td><td class="p-3 text-center">১,০৭,৬৩৯</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">বিঘা থেকে কাঠার দ্রুত রূপান্তর</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3">বিঘা</th><th class="p-3">কাঠা</th><th class="p-3">বর্গফুট</th><th class="p-3">ডেসিমেল</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 text-center">০.৫</td><td class="p-3 text-center font-bold">১০</td><td class="p-3 text-center">৭,২০০</td><td class="p-3 text-center">১৬.৫৩</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">১</td><td class="p-3 text-center font-bold">২০</td><td class="p-3 text-center">১৪,৪০০</td><td class="p-3 text-center">৩৩.০৬</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">১.৫</td><td class="p-3 text-center font-bold">৩০</td><td class="p-3 text-center">২১,৬০০</td><td class="p-3 text-center">৪৯.৫৯</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">২</td><td class="p-3 text-center font-bold">৪০</td><td class="p-3 text-center">২৮,৮০০</td><td class="p-3 text-center">৬৬.১২</td></tr>
            <tr class="bg-white border-b"><td class="p-3 text-center">৩</td><td class="p-3 text-center font-bold">৬০</td><td class="p-3 text-center">৪৩,২০০</td><td class="p-3 text-center">৯৯.১৭</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 text-center">৫</td><td class="p-3 text-center font-bold">১০০</td><td class="p-3 text-center">৭২,০০০</td><td class="p-3 text-center">১৬৫.২৯</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">বিভিন্ন রাজ্যে বিঘার মাপ আলাদা কেন?</h2>
      <p>বিঘা একটি ঐতিহ্যবাহী মাপ যার কোনো আন্তর্জাতিক মানদণ্ড নেই। পশ্চিমবঙ্গ ও বাংলাদেশে ১ বিঘা = ১৪,৪০০ বর্গফুট, কিন্তু ভারতের অন্যান্য রাজ্যে এটি ভিন্ন:</p>
      <div class="overflow-x-auto mt-3">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-gray-700 text-white"><th class="p-3 text-left">অঞ্চল</th><th class="p-3">১ বিঘা = কত বর্গফুট</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3">পশ্চিমবঙ্গ / বাংলাদেশ</td><td class="p-3 text-center font-bold text-teal-700">১৪,৪০০ বর্গফুট</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3">উত্তরপ্রদেশ / মধ্যপ্রদেশ</td><td class="p-3 text-center">২৭,২২৫ বর্গফুট</td></tr>
            <tr class="bg-white border-b"><td class="p-3">রাজস্থান / গুজরাট</td><td class="p-3 text-center">১৭,৪২৭ বর্গফুট</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3">হিমাচল প্রদেশ</td><td class="p-3 text-center">৮,৭১২ বর্গফুট</td></tr>
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-sm text-gray-500">তাই অন্য রাজ্যের জমির দলিল বা বিজ্ঞাপনে বিঘার উল্লেখ থাকলে সেই রাজ্যের স্থানীয় মান নিশ্চিত করুন।</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">জমি কেনার আগে যে মাপগুলো জানা দরকার</h2>
      <ul class="space-y-2">
        <li>📄 <strong>ডেসিমেল / শতাংশ:</strong> সরকারি দলিলে সাধারণত ডেসিমেলে মাপ লেখা থাকে। ১০ ডেসিমেল = ৬.০৫ কাঠা।</li>
        <li>🏗️ <strong>বর্গফুট:</strong> ফ্ল্যাট বা বাড়ির প্লট সাধারণত বর্গফুটে মাপা হয়। ১ কাঠা = ৭২০ বর্গফুট।</li>
        <li>🌾 <strong>একর:</strong> কৃষি জমি প্রায়ই একরে মাপা হয়। ১ একর = ৩.০২৫ বিঘা।</li>
        <li>🔍 <strong>ছটাক:</strong> ছোট জমির টুকরো বা ঘরের পরিমাপে ব্যবহৃত হয়। ১ কাঠা = ১৬ ছটাক।</li>
      </ul>
    </div>

    <div data-lang-en style="display:none">
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">How many Katha in 1 Bigha?</h2>
      <p>By the West Bengal and Bangladesh standard: <strong>1 Bigha = 20 Katha = 14,400 sqft</strong>. To convert bigha to katha, multiply by 20. To convert katha to bigha, divide by 20.</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">Why does Bigha vary by state?</h2>
      <p>Bigha is a traditional unit with no single national standard. West Bengal and Bangladesh use 14,400 sqft, while Uttar Pradesh uses 27,225 sqft and Rajasthan uses 17,427 sqft per bigha. Always confirm the local standard when reading land documents from other states.</p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">Key units to know before buying land</h2>
      <ul class="space-y-2">
        <li>📄 <strong>Decimal/Shotangso:</strong> Used in official government documents. 10 Decimal = 6.05 Katha.</li>
        <li>🏗️ <strong>Sqft:</strong> Flats and plots are usually measured in sqft. 1 Katha = 720 sqft.</li>
        <li>🌾 <strong>Acre:</strong> Agricultural land is often in acres. 1 Acre = 3.025 Bigha.</li>
        <li>🔍 <strong>Chhatak:</strong> Used for small land pieces. 1 Katha = 16 Chhatak.</li>
      </ul>
    </div>
  </div>

  <!-- FAQ -->
  <section class="mb-8 mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-3">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="১ কাঠা সমান কত বর্গফুট?" data-en="How many sqft is 1 Katha?">১ কাঠা সমান কত বর্গফুট?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="১ কাঠা = ৭২০ বর্গফুট = ১৬ ছটাক। পশ্চিমবঙ্গ ও বাংলাদেশ উভয় জায়গায় এই মান প্রচলিত।" data-en="1 Katha = 720 sqft = 16 Chhatak. This standard is used in both West Bengal and Bangladesh.">১ কাঠা = ৭২০ বর্গফুট = ১৬ ছটাক। পশ্চিমবঙ্গ ও বাংলাদেশ উভয় জায়গায় এই মান প্রচলিত।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="ডেসিমেল ও শতাংশ কি একই?" data-en="Are Decimal and Shotangso the same?">ডেসিমেল ও শতাংশ কি একই?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="হ্যাঁ, ডেসিমেল, শতাংশ ও ডিসমিল একই একক। ১ ডেসিমেল = ৪৩৫.৬ বর্গফুট = ১/১০০ একর। সরকারি দলিলে সাধারণত শতাংশ বা ডিসমিল লেখা হয়।" data-en="Yes, Decimal, Shotangso, and Dismil are the same unit. 1 Decimal = 435.6 sqft = 1/100 Acre. Government documents usually write Shotangso or Dismil.">হ্যাঁ, ডেসিমেল, শতাংশ ও ডিসমিল একই একক। ১ ডেসিমেল = ৪৩৫.৬ বর্গফুট = ১/১০০ একর। সরকারি দলিলে সাধারণত শতাংশ বা ডিসমিল লেখা হয়।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="১ একর সমান কত বিঘা?" data-en="How many Bigha is 1 Acre?">১ একর সমান কত বিঘা?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="১ একর = ৩.০২৫ বিঘা = ৬০.৫ কাঠা = ১০০ ডেসিমেল = ৪৩,৫৬০ বর্গফুট।" data-en="1 Acre = 3.025 Bigha = 60.5 Katha = 100 Decimal = 43,560 sqft.">১ একর = ৩.০২৫ বিঘা = ৬০.৫ কাঠা = ১০০ ডেসিমেল = ৪৩,৫৬০ বর্গফুট।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="৫ কাঠা জমি কত বর্গফুট?" data-en="How many sqft is 5 Katha of land?">৫ কাঠা জমি কত বর্গফুট?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="৫ কাঠা = ৫ × ৭২০ = ৩,৬০০ বর্গফুট = ০.২৫ বিঘা। এটি একটি সাধারণ আবাসিক প্লটের আকার।" data-en="5 Katha = 5 × 720 = 3,600 sqft = 0.25 Bigha. This is a common size for a residential plot.">৫ কাঠা = ৫ × ৭২০ = ৩,৬০০ বর্গফুট = ০.২৫ বিঘা। এটি একটি সাধারণ আবাসিক প্লটের আকার।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="১ বিঘা জমির দাম কত হতে পারে?" data-en="What could be the price of 1 Bigha of land?">১ বিঘা জমির দাম কত হতে পারে?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="জমির দাম এলাকাভেদে ব্যাপকভাবে পরিবর্তিত হয়। শহরতলিতে প্রতি কাঠার দাম থেকে মোট বিঘার দাম হিসাব করা হয়। আমাদের জমির মাপ কনভার্টার ব্যবহার করে মাপ রূপান্তর করুন, তারপর স্থানীয় বাজারদর দিয়ে গুণ করুন।" data-en="Land price varies widely by location. Calculate by multiplying the local per-katha or per-sqft rate by the area. Use our land area converter to get the exact measurement, then multiply by the local market rate.">জমির দাম এলাকাভেদে ব্যাপকভাবে পরিবর্তিত হয়। শহরতলিতে প্রতি কাঠার দাম থেকে মোট বিঘার দাম হিসাব করা হয়। আমাদের জমির মাপ কনভার্টার ব্যবহার করে মাপ রূপান্তর করুন, তারপর স্থানীয় বাজারদর দিয়ে গুণ করুন।</span></p>
      </details>
    </div>
  </section>

  <div class="mt-8 text-center">
    <a href="/converters/land-area/" class="bg-teal-700 hover:bg-teal-800 text-white font-semibold py-3 px-6 rounded-xl transition-colors inline-block">
      <span data-bn="জমির পরিমাণ কনভার্টার খুলুন →" data-en="Open Land Area Converter →">জমির পরিমাণ কনভার্টার খুলুন →</span>
    </a>
  </div>

  <AdSlot slot="blog-bottom" />
</ToolLayout>
