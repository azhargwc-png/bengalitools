---
import BlogLayout from '../../layouts/BlogLayout.astro';
import AdSlot from '../../components/AdSlot.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "বাংলা সন ২০২৬ সালে কত?",
      "acceptedAnswer": { "@type": "Answer", "text": "২০২৬ ইংরেজি বছরে বাংলা সন ১৪৩২-১৪৩৩। বৈশাখ মাস (এপ্রিল) থেকে নতুন বাংলা বছর শুরু হয়।" }
    },
    {
      "@type": "Question",
      "name": "পহেলা বৈশাখ ২০২৬ কত তারিখে?",
      "acceptedAnswer": { "@type": "Answer", "text": "২০২৬ সালে পহেলা বৈশাখ পশ্চিমবঙ্গে ১৫ এপ্রিল এবং বাংলাদেশে ১৪ এপ্রিল পালিত হবে।" }
    },
    {
      "@type": "Question",
      "name": "বাংলা মাসের নাম কী কী?",
      "acceptedAnswer": { "@type": "Answer", "text": "বাংলা বছরের ১২টি মাস হলো: বৈশাখ, জ্যৈষ্ঠ, আষাঢ়, শ্রাবণ, ভাদ্র, আশ্বিন, কার্তিক, অগ্রহায়ণ, পৌষ, মাঘ, ফাল্গুন, চৈত্র।" }
    },
    {
      "@type": "Question",
      "name": "ইংরেজি তারিখ থেকে বাংলা তারিখ কীভাবে বের করব?",
      "acceptedAnswer": { "@type": "Answer", "text": "আমাদের বাংলা ক্যালেন্ডার টুল ব্যবহার করুন। যেকোনো ইংরেজি তারিখ দিলে সঙ্গে সঙ্গে বাংলা তারিখ দেখাবে।" }
    },
    {
      "@type": "Question",
      "name": "বাংলা নববর্ষ মানে কী?",
      "acceptedAnswer": { "@type": "Answer", "text": "বাংলা নববর্ষ বা পহেলা বৈশাখ হলো বাংলা সনের প্রথম দিন। এটি বাংলা সংস্কৃতির সবচেয়ে বড় অনুষ্ঠান। পশ্চিমবঙ্গ ও বাংলাদেশ উভয় জায়গায় এটি উদযাপিত হয়।" }
    }
  ]
};
---

<BlogLayout
  title="বাংলা ক্যালেন্ডার ২০২৬ — বাংলা তারিখ ও ইংরেজি তারিখ গাইড | BanglaTools"
  description="বাংলা ক্যালেন্ডার ২০২৬ — বাংলা সন ১৪৩২-১৪৩৩। পহেলা বৈশাখ, বাংলা মাসের নাম ও ইংরেজি তারিখ রূপান্তর। বিনামূল্যে বাংলা ক্যালেন্ডার।"
  datePublished="2026-04-28"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)}></script>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog/" class="hover:text-teal-700">ব্লগ</a> → বাংলা ক্যালেন্ডার ২০২৬
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    বাংলা ক্যালেন্ডার ২০২৬ — বাংলা তারিখ ও ইংরেজি তারিখ গাইড
  </h1>

  <AdSlot slot="blog-top" />

  <div class="bg-teal-50 rounded-2xl p-5 border border-teal-200 mb-8">
    <h2 class="font-bold text-teal-800 mb-3">আজকের বাংলা তারিখ জানুন</h2>
    <p class="text-gray-700 mb-3">যেকোনো ইংরেজি তারিখ দিন — সঙ্গে সঙ্গে বাংলা তারিখ পাবেন:</p>
    <p class="text-center">
      <a href="/india/bengali-calendar/" class="inline-block bg-teal-700 text-white px-6 py-3 rounded-xl font-semibold hover:bg-teal-800 transition-colors">
        → বাংলা ক্যালেন্ডার টুল ব্যবহার করুন
      </a>
    </p>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">বাংলা সন কী?</h2>
      <p>বাংলা সন বা বঙ্গাব্দ হলো বাংলা ভাষাভাষী মানুষের নিজস্ব পঞ্জিকা। সম্রাট আকবরের সময় এটি প্রচলিত হয়েছিল বলে মনে করা হয়। বাংলা সন ইংরেজি সনের চেয়ে প্রায় ৫৯৩-৫৯৪ বছর কম।</p>
      <p>২০২৬ ইংরেজি সনে বাংলা সন ১৪৩২-১৪৩৩। বৈশাখ মাস থেকে নতুন বছর শুরু হয়, যা সাধারণত এপ্রিল মাসে পড়ে।</p>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">বাংলা মাসের নাম ও ইংরেজি মাসের সাথে মিল</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead><tr class="bg-teal-700 text-white"><th class="p-3">বাংলা মাস</th><th class="p-3">সময়কাল</th><th class="p-3">ইংরেজি মাস</th></tr></thead>
          <tbody>
            <tr class="bg-white border-b"><td class="p-3 font-bold">বৈশাখ</td><td class="p-3 text-center">১৪-১৫ এপ্রিল থেকে</td><td class="p-3">এপ্রিল-মে</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-bold">জ্যৈষ্ঠ</td><td class="p-3 text-center">১৫-১৬ মে থেকে</td><td class="p-3">মে-জুন</td></tr>
            <tr class="bg-white border-b"><td class="p-3 font-bold">আষাঢ়</td><td class="p-3 text-center">১৫-১৬ জুন থেকে</td><td class="p-3">জুন-জুলাই</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-bold">শ্রাবণ</td><td class="p-3 text-center">১৬-১৭ জুলাই থেকে</td><td class="p-3">জুলাই-আগস্ট</td></tr>
            <tr class="bg-white border-b"><td class="p-3 font-bold">ভাদ্র</td><td class="p-3 text-center">১৬-১৭ আগস্ট থেকে</td><td class="p-3">আগস্ট-সেপ্টেম্বর</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-bold">আশ্বিন</td><td class="p-3 text-center">১৬-১৭ সেপ্টেম্বর থেকে</td><td class="p-3">সেপ্টেম্বর-অক্টোবর</td></tr>
            <tr class="bg-white border-b"><td class="p-3 font-bold">কার্তিক</td><td class="p-3 text-center">১৬-১৭ অক্টোবর থেকে</td><td class="p-3">অক্টোবর-নভেম্বর</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-bold">অগ্রহায়ণ</td><td class="p-3 text-center">১৫-১৬ নভেম্বর থেকে</td><td class="p-3">নভেম্বর-ডিসেম্বর</td></tr>
            <tr class="bg-white border-b"><td class="p-3 font-bold">পৌষ</td><td class="p-3 text-center">১৫-১৬ ডিসেম্বর থেকে</td><td class="p-3">ডিসেম্বর-জানুয়ারি</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-bold">মাঘ</td><td class="p-3 text-center">১৩-১৪ জানুয়ারি থেকে</td><td class="p-3">জানুয়ারি-ফেব্রুয়ারি</td></tr>
            <tr class="bg-white border-b"><td class="p-3 font-bold">ফাল্গুন</td><td class="p-3 text-center">১৩-১৪ ফেব্রুয়ারি থেকে</td><td class="p-3">ফেব্রুয়ারি-মার্চ</td></tr>
            <tr class="bg-gray-50 border-b"><td class="p-3 font-bold">চৈত্র</td><td class="p-3 text-center">১৪-১৫ মার্চ থেকে</td><td class="p-3">মার্চ-এপ্রিল</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">২০২৬ সালের গুরুত্বপূর্ণ বাংলা দিন</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><strong>পহেলা বৈশাখ ১৪৩৩:</strong> ১৫ এপ্রিল ২০২৬ (পশ্চিমবঙ্গ) / ১৪ এপ্রিল ২০২৬ (বাংলাদেশ)</li>
        <li><strong>পহেলা ফাল্গুন (বসন্ত উৎসব):</strong> ১৩ ফেব্রুয়ারি ২০২৬</li>
        <li><strong>নবান্ন উৎসব:</strong> অগ্রহায়ণ মাসের প্রথম দিক (নভেম্বর)</li>
        <li><strong>পৌষ সংক্রান্তি:</strong> ১৫ জানুয়ারি ২০২৬</li>
      </ul>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">ইংরেজি থেকে বাংলা তারিখ কীভাবে হিসাব করবেন?</h2>
      <p>সহজ নিয়ম: ইংরেজি তারিখ থেকে ৫৯৩ বা ৫৯৪ বিয়োগ করলে বাংলা সন পাওয়া যায়।</p>
      <p class="mt-2"><strong>উদাহরণ:</strong> ২০২৬ - ৫৯৩ = ১৪৩৩ (যদি বৈশাখ মাস পেরিয়ে গেলে)</p>
      <p class="mt-2">তবে সঠিক বাংলা তারিখ জানতে আমাদের <a href="/india/bengali-calendar/" class="text-teal-700 underline">বাংলা ক্যালেন্ডার টুল</a> ব্যবহার করুন।</p>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">বাংলা মাসের নাম মনে রাখার সহজ উপায়</h2>
      <div class="bg-teal-50 border border-teal-200 rounded-xl p-4">
        <p class="font-bold text-teal-800">ছড়া দিয়ে মনে রাখুন:</p>
        <p class="text-teal-700 mt-2 text-lg leading-relaxed">"বৈশাখ জ্যৈষ্ঠ আষাঢ় শ্রাবণ, ভাদ্র আশ্বিন করে গান,<br/>কার্তিক অগ্রহায়ণ পৌষ মাঘ, ফাল্গুন চৈত্র সারাবছর আছে।"</p>
      </div>
    </div>

  </div>

  <section class="mb-8 mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">সাধারণ প্রশ্নোত্তর</h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">বাংলা সন ২০২৬ সালে কত?</summary>
        <p class="mt-3 text-gray-700">২০২৬ ইংরেজি বছরে বাংলা সন ১৪৩২-১৪৩৩।</p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">পহেলা বৈশাখ ২০২৬ কত তারিখে?</summary>
        <p class="mt-3 text-gray-700">২০২৬ সালে পহেলা বৈশাখ পশ্চিমবঙ্গে ১৫ এপ্রিল এবং বাংলাদেশে ১৪ এপ্রিল।</p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">বাংলা মাসের নাম কী কী?</summary>
        <p class="mt-3 text-gray-700">বৈশাখ, জ্যৈষ্ঠ, আষাঢ়, শ্রাবণ, ভাদ্র, আশ্বিন, কার্তিক, অগ্রহায়ণ, পৌষ, মাঘ, ফাল্গুন, চৈত্র।</p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">ইংরেজি তারিখ থেকে বাংলা তারিখ কীভাবে বের করব?</summary>
        <p class="mt-3 text-gray-700">আমাদের বাংলা ক্যালেন্ডার টুল ব্যবহার করুন। যেকোনো ইংরেজি তারিখ দিলে সঙ্গে সঙ্গে বাংলা তারিখ দেখাবে।</p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">বাংলা নববর্ষ মানে কী?</summary>
        <p class="mt-3 text-gray-700">বাংলা নববর্ষ বা পহেলা বৈশাখ হলো বাংলা সনের প্রথম দিন। এটি বাংলা সংস্কৃতির অন্যতম প্রধান উৎসব।</p>
      </details>
    </div>
  </section>

  <AdSlot slot="blog-bottom" />

  <div class="mt-8 p-5 bg-teal-50 rounded-2xl border border-teal-200">
    <h3 class="font-bold text-teal-800 mb-3">সম্পর্কিত টুলস</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a href="/india/bengali-calendar/" class="block bg-white border border-teal-200 rounded-xl p-3 hover:border-teal-400 transition-colors">
        <div class="font-semibold text-gray-900">📅 বাংলা ক্যালেন্ডার</div>
        <div class="text-sm text-gray-500 mt-1">ইংরেজি ↔ বাংলা তারিখ রূপান্তর</div>
      </a>
      <a href="/calculators/date-difference/" class="block bg-white border border-teal-200 rounded-xl p-3 hover:border-teal-400 transition-colors">
        <div class="font-semibold text-gray-900">🗓️ তারিখের পার্থক্য ক্যালকুলেটর</div>
        <div class="text-sm text-gray-500 mt-1">দুটি তারিখের মধ্যে দিন গণনা</div>
      </a>
    </div>
  </div>
</BlogLayout>
