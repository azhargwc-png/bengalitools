<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var hEl = document.getElementById('bmi-h');
  var wEl = document.getElementById('bmi-w');
  var resultEl = document.getElementById('bmi-result');

  function calc() {
    var h = parseFloat(hEl.value) / 100;
    var w = parseFloat(wEl.value);
    if (isNaN(h) || isNaN(w) || h <= 0 || w <= 0) { resultEl.classList.add('hidden'); return; }
    var bmi = w / (h * h);
    var cat, color;
    if (bmi < 18.5) { cat = 'কম ওজন / Underweight'; color = 'bg-blue-100 text-blue-800'; }
    else if (bmi < 25) { cat = 'স্বাস্থ্যকর / Healthy ✓'; color = 'bg-green-100 text-green-800'; }
    else if (bmi < 30) { cat = 'অতিরিক্ত ওজন / Overweight'; color = 'bg-orange-100 text-orange-800'; }
    else { cat = 'স্থূলতা / Obese'; color = 'bg-red-100 text-red-800'; }
    resultEl.className = 'text-center py-3 rounded-xl font-bold text-xl ' + color;
    resultEl.textContent = 'BMI: ' + bmi.toFixed(1) + ' — ' + cat;
    resultEl.classList.remove('hidden');
  }

  hEl.addEventListener('input', calc);
  wEl.addEventListener('input', calc);
});
</script>
