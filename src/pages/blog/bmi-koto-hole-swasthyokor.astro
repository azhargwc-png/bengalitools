---
import BlogLayout from '../../layouts/BlogLayout.astro';
import AdSlot from '../../components/AdSlot.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "বিএমআই ১৮.৫-এর কম হলে কী করব?",
      "acceptedAnswer": { "@type": "Answer", "text": "BMI ১৮.৫-এর কম মানে কম ওজন। পুষ্টিকর খাবার বাড়ান — ভাত, ডাল, মাছ, ডিম, দুধ। প্রয়োজনে পুষ্টিবিদের পরামর্শ নিন। দ্রুত ওজন বাড়ানোর চেষ্টা না করে ধীরে সুষম খাবার খান।" }
    },
    {
      "@type": "Question",
      "name": "BMI ২৫-এর বেশি হলে কী করব?",
      "acceptedAnswer": { "@type": "Answer", "text": "BMI ২৫-২৯.৯ মানে অতিরিক্ত ওজন। খাবারে চিনি ও ভাজাপোড়া কমান, প্রতিদিন ৩০ মিনিট হাঁটুন এবং পর্যাপ্ত জল পান করুন। ডায়েট ক্র্যাশ না করে ধীরে ধীরে জীবনযাত্রা পরিবর্তন করুন।" }
    },
    {
      "@type": "Question",
      "name": "BMI ৩০ বা তার বেশি হলে কী হয়?",
      "acceptedAnswer": { "@type": "Answer", "text": "BMI ৩০-এর বেশি মানে স্থূলতা, যা ডায়াবেটিস, হৃদরোগ, উচ্চ রক্তচাপ ও হাঁটুর সমস্যার ঝুঁকি বাড়ায়। ডাক্তারের সাথে পরামর্শ করুন। চিকিৎসার পাশাপাশি খাদ্যাভ্যাস ও ব্যায়ামে পরিবর্তন আনুন।" }
    },
    {
      "@type": "Question",
      "name": "এশীয়দের জন্য BMI সীমা কি আলাদা?",
      "acceptedAnswer": { "@type": "Answer", "text": "হ্যাঁ। অনেক গবেষণা দেখায় যে এশীয়দের জন্য ২৩-এর বেশি BMI অতিরিক্ত ওজন ও ২৭.৫-এর বেশি স্থূলতা হিসাবে বিবেচনা করা উচিত। বাঙালিদের জন্য WHO-র সাধারণ সীমার চেয়ে কম সীমা আরও উপযুক্ত।" }
    },
    {
      "@type": "Question",
      "name": "BMI কমানোর সবচেয়ে কার্যকর উপায় কী?",
      "acceptedAnswer": { "@type": "Answer", "text": "খাবারে ক্যালরি সামান্য কমান এবং নিয়মিত ব্যায়াম করুন। প্রতিদিন ৩০ মিনিট হাঁটা, চিনিযুক্ত পানীয় বাদ দেওয়া এবং রাতে কম খাওয়া — এই তিনটি পরিবর্তন সবচেয়ে বেশি কাজ করে।" }
    }
  ]
};
---

<BlogLayout
  title="বিএমআই কত হলে স্বাস্থ্যকর | BanglaTools"
  description="WHO অনুযায়ী ১৮.৫ থেকে ২৪.৯ BMI স্বাস্থ্যকর। সম্পূর্ণ BMI চার্ট, চারটি ক্যাটাগরির বিস্তারিত ব্যাখ্যা, বাস্তব উদাহরণ ও বিনামূল্যে BMI ক্যালকুলেটর।"
  datePublished="2026-03-25"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)}></script>
  <div class="text-sm text-gray-500 mb-4">
    <a href="/blog/" class="hover:text-teal-700">ব্লগ</a> → বিএমআই কত হলে স্বাস্থ্যকর
  </div>

  <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">
    <span data-bn="বিএমআই কত হলে স্বাস্থ্যকর — WHO এর গাইডলাইন" data-en="What BMI is Healthy — WHO Guidelines">বিএমআই কত হলে স্বাস্থ্যকর — WHO এর গাইডলাইন</span>
  </h1>

  <AdSlot slot="blog-top" />

  <!-- Embed BMI calculator -->
  <div class="bg-teal-50 rounded-2xl p-5 border border-teal-200 mb-8">
    <h2 class="font-bold text-teal-800 mb-3">
      <span data-bn="আপনার BMI পরীক্ষা করুন" data-en="Check Your BMI">আপনার BMI পরীক্ষা করুন</span>
    </h2>
    <div class="grid grid-cols-2 gap-3 mb-3">
      <div>
        <label class="text-sm text-gray-600"><span data-bn="উচ্চতা (সেমি)" data-en="Height (cm)">উচ্চতা (সেমি)</span></label>
        <input type="number" id="bmi-h" placeholder="170" class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg text-lg focus:border-teal-500 focus:outline-none mt-1 min-h-[44px]" />
      </div>
      <div>
        <label class="text-sm text-gray-600"><span data-bn="ওজন (কেজি)" data-en="Weight (kg)">ওজন (কেজি)</span></label>
        <input type="number" id="bmi-w" placeholder="70" class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg text-lg focus:border-teal-500 focus:outline-none mt-1 min-h-[44px]" />
      </div>
    </div>
    <div id="bmi-result" class="hidden text-center py-3 rounded-xl font-bold text-xl"></div>
    <p class="text-center mt-2">
      <a href="/health/bmi-calculator/" class="text-sm text-teal-700 hover:underline">
        <span data-bn="→ সম্পূর্ণ BMI ক্যালকুলেটর দেখুন" data-en="→ See full BMI calculator">→ সম্পূর্ণ BMI ক্যালকুলেটর দেখুন</span>
      </a>
    </p>
  </div>

  <div class="prose max-w-none text-gray-700 leading-relaxed space-y-6">
    <div>
      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">BMI কী?</h2>
      <p>BMI (Body Mass Index) হলো শরীরের ওজন ও উচ্চতার অনুপাতের একটি পরিমাপ। WHO (বিশ্ব স্বাস্থ্য সংস্থা) BMI ব্যবহার করে মানুষের শরীরের ওজন স্বাস্থ্যকর কিনা তা নির্ধারণ করে।</p>
      <p>সূত্র: <strong>BMI = ওজন (কেজি) ÷ উচ্চতা (মিটার)²</strong></p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">WHO অনুযায়ী BMI চার্ট</h2>
      <div class="space-y-3">
        <div class="flex items-center gap-3 bg-blue-50 p-4 rounded-xl border border-blue-200">
          <div class="w-4 h-4 bg-blue-500 rounded-full flex-shrink-0"></div>
          <div><p class="font-bold">BMI ১৮.৫-এর কম — কম ওজন (Underweight)</p><p class="text-sm text-gray-600 mt-1">ওজন বাড়ানোর প্রয়োজন। পুষ্টিবিদের পরামর্শ নিন।</p></div>
        </div>
        <div class="flex items-center gap-3 bg-green-50 p-4 rounded-xl border border-green-200">
          <div class="w-4 h-4 bg-green-500 rounded-full flex-shrink-0"></div>
          <div><p class="font-bold">BMI ১৮.৫–২৪.৯ — স্বাস্থ্যকর (Healthy) ✓</p><p class="text-sm text-gray-600 mt-1">এটি আদর্শ পরিসর। এই BMI বজায় রাখুন।</p></div>
        </div>
        <div class="flex items-center gap-3 bg-orange-50 p-4 rounded-xl border border-orange-200">
          <div class="w-4 h-4 bg-orange-500 rounded-full flex-shrink-0"></div>
          <div><p class="font-bold">BMI ২৫–২৯.৯ — অতিরিক্ত ওজন (Overweight)</p><p class="text-sm text-gray-600 mt-1">ডায়াবেটিস ও হৃদরোগের ঝুঁকি বাড়ে। জীবনযাত্রা পরিবর্তন করুন।</p></div>
        </div>
        <div class="flex items-center gap-3 bg-red-50 p-4 rounded-xl border border-red-200">
          <div class="w-4 h-4 bg-red-500 rounded-full flex-shrink-0"></div>
          <div><p class="font-bold">BMI ৩০ বা তার বেশি — স্থূলতা (Obese)</p><p class="text-sm text-gray-600 mt-1">ডাক্তারের সাথে পরামর্শ করুন। চিকিৎসা প্রয়োজন হতে পারে।</p></div>
        </div>
      </div>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">বাস্তব উদাহরণ</h2>
      <p><strong>উদাহরণ ১:</strong> নারী, উচ্চতা ১৫৮ সেমি, ওজন ৫৫ কেজি → BMI = ৫৫ ÷ (১.৫৮)² = ২২.০ → <span class="text-green-700 font-bold">স্বাস্থ্যকর</span></p>
      <p class="mt-2"><strong>উদাহরণ ২:</strong> পুরুষ, উচ্চতা ১৭০ সেমি, ওজন ৮০ কেজি → BMI = ৮০ ÷ (১.৭০)² = ২৭.৭ → <span class="text-orange-700 font-bold">অতিরিক্ত ওজন</span></p>
      <p class="mt-2"><strong>উদাহরণ ৩:</strong> কিশোর, উচ্চতা ১৬৫ সেমি, ওজন ৪৫ কেজি → BMI = ৪৫ ÷ (১.৬৫)² = ১৬.৫ → <span class="text-blue-700 font-bold">কম ওজন</span></p>

      <h2 class="text-xl font-bold text-gray-900 mt-6 mb-3">BMI-এর সীমাবদ্ধতা</h2>
      <p>BMI সবার জন্য নিখুঁত নয়। অ্যাথলেট বা মাংসপেশি বেশি এমন মানুষের BMI বেশি হতে পারে তবুও তারা স্বাস্থ্যকর। বয়স্ক মানুষের ক্ষেত্রে BMI ভিন্নভাবে ব্যাখ্যা করতে হয়।</p>
    </div>

  </div>

  <!-- FAQ -->
  <section class="mb-8 mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-3">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="বিএমআই ১৮.৫-এর কম হলে কী করব?" data-en="What should I do if BMI is below 18.5?">বিএমআই ১৮.৫-এর কম হলে কী করব?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="BMI ১৮.৫-এর কম মানে কম ওজন। পুষ্টিকর খাবার বাড়ান — ভাত, ডাল, মাছ, ডিম, দুধ। প্রয়োজনে পুষ্টিবিদের পরামর্শ নিন। দ্রুত ওজন বাড়ানোর চেষ্টা না করে ধীরে সুষম খাবার খান।" data-en="A BMI below 18.5 means underweight. Increase nutritious food — rice, lentils, fish, eggs, milk. Consult a nutritionist if needed. Gradually eat balanced meals rather than trying to gain weight quickly.">BMI ১৮.৫-এর কম মানে কম ওজন। পুষ্টিকর খাবার বাড়ান — ভাত, ডাল, মাছ, ডিম, দুধ। প্রয়োজনে পুষ্টিবিদের পরামর্শ নিন। দ্রুত ওজন বাড়ানোর চেষ্টা না করে ধীরে সুষম খাবার খান।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="BMI ২৫-এর বেশি হলে কী করব?" data-en="What should I do if BMI is above 25?">BMI ২৫-এর বেশি হলে কী করব?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="BMI ২৫-২৯.৯ মানে অতিরিক্ত ওজন। খাবারে চিনি ও ভাজাপোড়া কমান, প্রতিদিন ৩০ মিনিট হাঁটুন এবং পর্যাপ্ত জল পান করুন। ডায়েট ক্র্যাশ না করে ধীরে ধীরে জীবনযাত্রা পরিবর্তন করুন।" data-en="BMI 25-29.9 means overweight. Reduce sugar and fried foods, walk 30 minutes daily and drink enough water. Make gradual lifestyle changes rather than crash dieting.">BMI ২৫-২৯.৯ মানে অতিরিক্ত ওজন। খাবারে চিনি ও ভাজাপোড়া কমান, প্রতিদিন ৩০ মিনিট হাঁটুন এবং পর্যাপ্ত জল পান করুন। ডায়েট ক্র্যাশ না করে ধীরে ধীরে জীবনযাত্রা পরিবর্তন করুন।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="BMI ৩০ বা তার বেশি হলে কী হয়?" data-en="What happens with BMI of 30 or above?">BMI ৩০ বা তার বেশি হলে কী হয়?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="BMI ৩০-এর বেশি মানে স্থূলতা, যা ডায়াবেটিস, হৃদরোগ, উচ্চ রক্তচাপ ও হাঁটুর সমস্যার ঝুঁকি বাড়ায়। ডাক্তারের সাথে পরামর্শ করুন। চিকিৎসার পাশাপাশি খাদ্যাভ্যাস ও ব্যায়ামে পরিবর্তন আনুন।" data-en="BMI above 30 is obesity, which increases the risk of diabetes, heart disease, high blood pressure and knee problems. Consult a doctor. Make changes to diet and exercise alongside medical treatment.">BMI ৩০-এর বেশি মানে স্থূলতা, যা ডায়াবেটিস, হৃদরোগ, উচ্চ রক্তচাপ ও হাঁটুর সমস্যার ঝুঁকি বাড়ায়। ডাক্তারের সাথে পরামর্শ করুন। চিকিৎসার পাশাপাশি খাদ্যাভ্যাস ও ব্যায়ামে পরিবর্তন আনুন।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="এশীয়দের জন্য BMI সীমা কি আলাদা?" data-en="Is the BMI threshold different for Asians?">এশীয়দের জন্য BMI সীমা কি আলাদা?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="হ্যাঁ। অনেক গবেষণা দেখায় যে এশীয়দের জন্য ২৩-এর বেশি BMI অতিরিক্ত ওজন ও ২৭.৫-এর বেশি স্থূলতা হিসাবে বিবেচনা করা উচিত। বাঙালিদের জন্য WHO-র সাধারণ সীমার চেয়ে কম সীমা আরও উপযুক্ত।" data-en="Yes. Many studies show that for Asians, a BMI above 23 should be considered overweight and above 27.5 obese. Lower thresholds than WHO's general limits are more appropriate for Bengalis.">হ্যাঁ। অনেক গবেষণা দেখায় যে এশীয়দের জন্য ২৩-এর বেশি BMI অতিরিক্ত ওজন ও ২৭.৫-এর বেশি স্থূলতা হিসাবে বিবেচনা করা উচিত। বাঙালিদের জন্য WHO-র সাধারণ সীমার চেয়ে কম সীমা আরও উপযুক্ত।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="BMI কমানোর সবচেয়ে কার্যকর উপায় কী?" data-en="What is the most effective way to lower BMI?">BMI কমানোর সবচেয়ে কার্যকর উপায় কী?</span></summary>
