---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="মাসিক বেতন থেকে ঘণ্টায় বেতন ক্যালকুলেটর | BanglaTools"
  description="মাসিক বেতন থেকে ঘণ্টায়, দৈনিক, সাপ্তাহিক ও বার্ষিক বেতন বের করুন। বিনামূল্যে বেতন ক্যালকুলেটর।"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="মাসিক বেতন থেকে ঘণ্টায় বেতন ক্যালকুলেটর" data-en="Salary to Hourly Calculator">মাসিক বেতন থেকে ঘণ্টায় বেতন ক্যালকুলেটর</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="মাসিক বেতন থেকে ঘণ্টায়, দৈনিক ও বার্ষিক বেতন বের করুন" data-en="Convert monthly salary to hourly, daily, weekly and annual rates">মাসিক বেতন থেকে ঘণ্টায়, দৈনিক ও বার্ষিক বেতন বের করুন</span>
  </p>

  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <!-- Mode Toggle -->
    <div class="flex gap-2 mb-5">
      <button id="btn-monthly" onclick="setMode('monthly')" class="flex-1 py-2 px-4 rounded-lg font-medium bg-teal-700 text-white transition-colors">
        <span data-bn="মাসিক → ঘণ্টায়" data-en="Monthly → Hourly">মাসিক → ঘণ্টায়</span>
      </button>
      <button id="btn-hourly" onclick="setMode('hourly')" class="flex-1 py-2 px-4 rounded-lg font-medium bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors">
        <span data-bn="ঘণ্টায় → মাসিক" data-en="Hourly → Monthly">ঘণ্টায় → মাসিক</span>
      </button>
    </div>

    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="salary-input">
          <span id="salary-label" data-bn="মাসিক বেতন (₹)" data-en="Monthly Salary (₹)">মাসিক বেতন (₹)</span>
        </label>
        <input
          type="number"
          id="salary-input"
          placeholder="যেমন: 30000"
          min="0"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            <span data-bn="কাজের দিন/মাস" data-en="Working Days/Month">কাজের দিন/মাস</span>
          </label>
          <select id="work-days" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-base focus:border-teal-500 focus:outline-none bg-white min-h-[44px]">
            <option value="22">২২ দিন (standard)</option>
            <option value="25">২৫ দিন</option>
            <option value="26">২৬ দিন</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            <span data-bn="কাজের ঘণ্টা/দিন" data-en="Working Hours/Day">কাজের ঘণ্টা/দিন</span>
          </label>
          <select id="work-hours" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-base focus:border-teal-500 focus:outline-none bg-white min-h-[44px]">
            <option value="8">৮ ঘণ্টা (standard)</option>
            <option value="9">৯ ঘণ্টা</option>
            <option value="10">১০ ঘণ্টা</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="salary-results" class="mt-6 hidden grid grid-cols-2 gap-3">
      <div class="bg-white rounded-xl p-4 border border-gray-200 text-center">
        <div class="text-sm text-gray-500 mb-1" data-bn="ঘণ্টায়" data-en="Per Hour">ঘণ্টায়</div>
        <div id="result-hourly" class="text-2xl font-bold text-teal-700"></div>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-200 text-center">
        <div class="text-sm text-gray-500 mb-1" data-bn="দৈনিক" data-en="Per Day">দৈনিক</div>
        <div id="result-daily" class="text-2xl font-bold text-teal-700"></div>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-200 text-center">
        <div class="text-sm text-gray-500 mb-1" data-bn="সাপ্তাহিক" data-en="Per Week">সাপ্তাহিক</div>
        <div id="result-weekly" class="text-2xl font-bold text-teal-700"></div>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200 text-center">
        <div class="text-sm text-gray-500 mb-1" data-bn="বার্ষিক" data-en="Annual">বার্ষিক</div>
        <div id="result-annual" class="text-2xl font-bold text-teal-700"></div>
      </div>
    </div>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span></h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">১.</span><span data-bn="মোড নির্বাচন করুন — মাসিক থেকে ঘণ্টায় বা বিপরীত" data-en="Select mode — monthly to hourly or reverse">মোড নির্বাচন করুন — মাসিক থেকে ঘণ্টায় বা বিপরীত</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">২.</span><span data-bn="বেতনের পরিমাণ লিখুন" data-en="Enter the salary amount">বেতনের পরিমাণ লিখুন</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">৩.</span><span data-bn="কাজের দিন ও ঘণ্টা নির্বাচন করুন" data-en="Select working days and hours">কাজের দিন ও ঘণ্টা নির্বাচন করুন</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">৪.</span><span data-bn="ঘণ্টায়, দৈনিক, সাপ্তাহিক ও বার্ষিক হার দেখুন" data-en="See hourly, daily, weekly and annual rates">ঘণ্টায়, দৈনিক, সাপ্তাহিক ও বার্ষিক হার দেখুন</span></li>
    </ol>
  </section>

  <!-- Description -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span></h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        মাসিক বেতন থেকে ঘণ্টায় বেতন বের করার সময় অনেকেই ভুল করেন। এই ক্যালকুলেটর ব্যবহার করে আপনি সহজেই জানতে পারবেন আপনার প্রতি ঘণ্টায় কত টাকা আয় হচ্ছে। ভারতে সাধারণত মাসে ২২টি কাজের দিন এবং প্রতিদিন ৮ ঘণ্টা কাজ ধরে হিসাব করা হয়। চাকরির অফারে বেতন তুলনা করতে, ফ্রিল্যান্স রেট নির্ধারণ করতে বা অতিরিক্ত কাজের ভাতা হিসাব করতে এই টুলটি কাজে আসবে।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span></h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ১: মাসিক বেতন ₹৩০,০০০" data-en="Example 1: Monthly salary ₹30,000">উদাহরণ ১: মাসিক বেতন ₹৩০,০০০</span></p>
        <p class="text-gray-700 mt-1"><span data-bn="ঘণ্টায়: ₹১৭০.৪৫ | দৈনিক: ₹১,৩৬৪ | বার্ষিক: ₹৩,৬০,০০০" data-en="Hourly: ₹170.45 | Daily: ₹1,364 | Annual: ₹3,60,000">ঘণ্টায়: ₹১৭০.৪৫ | দৈনিক: ₹১,৩৬৪ | বার্ষিক: ₹৩,৬০,০০০</span></p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ২: মাসিক বেতন ₹৫০,০০০" data-en="Example 2: Monthly salary ₹50,000">উদাহরণ ২: মাসিক বেতন ₹৫০,০০০</span></p>
        <p class="text-gray-700 mt-1"><span data-bn="ঘণ্টায়: ₹২৮৪.০৯ | দৈনিক: ₹২,২৭৩ | বার্ষিক: ₹৬,০০,০০০" data-en="Hourly: ₹284.09 | Daily: ₹2,273 | Annual: ₹6,00,000">ঘণ্টায়: ₹২৮৪.০৯ | দৈনিক: ₹২,২৭৩ | বার্ষিক: ₹৬,০০,০০০</span></p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ৩: মাসিক বেতন ₹১,০০,০০০" data-en="Example 3: Monthly salary ₹1,00,000">উদাহরণ ৩: মাসিক বেতন ₹১,০০,০০০</span></p>
        <p class="text-gray-700 mt-1"><span data-bn="ঘণ্টায়: ₹৫৬৮.১৮ | দৈনিক: ₹৪,৫৪৫ | বার্ষিক: ₹১২,০০,০০০" data-en="Hourly: ₹568.18 | Daily: ₹4,545 | Annual: ₹12,00,000">ঘণ্টায়: ₹৫৬৮.১৮ | দৈনিক: ₹৪,৫৪৫ | বার্ষিক: ₹১২,০০,০০০</span></p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span></h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="মাসিক বেতন থেকে ঘণ্টায় বেতন কীভাবে বের করব?" data-en="How to calculate hourly rate from monthly salary?">মাসিক বেতন থেকে ঘণ্টায় বেতন কীভাবে বের করব?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="সূত্র: ঘণ্টায় বেতন = মাসিক বেতন ÷ (কাজের দিন × ঘণ্টা)। যেমন: ₹৩০,০০০ ÷ (২২ × ৮) = ₹৩০,০০০ ÷ ১৭৬ = ₹১৭০.৪৫।" data-en="Formula: Hourly rate = Monthly salary ÷ (working days × hours per day). E.g.: ₹30,000 ÷ (22 × 8) = ₹30,000 ÷ 176 = ₹170.45.">সূত্র: ঘণ্টায় বেতন = মাসিক বেতন ÷ (কাজের দিন × ঘণ্টা)। যেমন: ₹৩০,০০০ ÷ (২২ × ৮) = ₹৩০,০০০ ÷ ১৭৬ = ₹১৭০.৪৫।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="ভারতে মাসে কতদিন কাজ ধরা হয়?" data-en="How many working days per month in India?">ভারতে মাসে কতদিন কাজ ধরা হয়?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="ভারতে সাধারণত মাসে ২২টি কাজের দিন ধরা হয় (সপ্তাহে ৫ দিন, রবিবার ও শনিবার বাদ)। কিছু কোম্পানিতে শনিবারও কাজ হয়, তাহলে ২৬ দিন ধরা হয়।" data-en="India generally uses 22 working days per month (5 days a week). Some companies work on Saturdays, making it 26 days.">ভারতে সাধারণত মাসে ২২টি কাজের দিন ধরা হয় (সপ্তাহে ৫ দিন, রবিবার ও শনিবার বাদ)। কিছু কোম্পানিতে শনিবারও কাজ হয়, তাহলে ২৬ দিন ধরা হয়।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="CTC ও নেট বেতন কি এক?" data-en="Is CTC the same as net salary?">CTC ও নেট বেতন কি এক?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="না। CTC (Cost to Company) হলো কোম্পানির মোট খরচ। নেট বেতন হলো PF, TDS ইত্যাদি কাটার পরে হাতে আসা টাকা। সাধারণত নেট বেতন CTC-এর ৭০-৮০%।" data-en="No. CTC (Cost to Company) is the total cost to the employer. Net salary is what you receive after deductions like PF and TDS. Net salary is typically 70-80% of CTC.">না। CTC (Cost to Company) হলো কোম্পানির মোট খরচ। নেট বেতন হলো PF, TDS ইত্যাদি কাটার পরে হাতে আসা টাকা। সাধারণত নেট বেতন CTC-এর ৭০-৮০%।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="ফ্রিল্যান্সারদের জন্য ঘণ্টায় রেট কত হওয়া উচিত?" data-en="What hourly rate should freelancers charge?">ফ্রিল্যান্সারদের জন্য ঘণ্টায় রেট কত হওয়া উচিত?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="ফ্রিল্যান্সারদের সমতুল্য চাকরির মাসিক বেতনের ঘণ্টা হারের ১.৫ থেকে ২ গুণ চার্জ করা উচিত কারণ ছুটির দিন, পেনশন ও স্বাস্থ্য বীমা নিজেকে বহন করতে হয়।" data-en="Freelancers should charge 1.5 to 2 times the equivalent hourly rate from a salaried job, because they bear the cost of holidays, pension and health insurance themselves.">ফ্রিল্যান্সারদের সমতুল্য চাকরির মাসিক বেতনের ঘণ্টা হারের ১.৫ থেকে ২ গুণ চার্জ করা উচিত কারণ ছুটির দিন, পেনশন ও স্বাস্থ্য বীমা নিজেকে বহন করতে হয়।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="বার্ষিক বেতন কীভাবে হিসাব হয়?" data-en="How is annual salary calculated?">বার্ষিক বেতন কীভাবে হিসাব হয়?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="বার্ষিক বেতন = মাসিক বেতন × ১২। যেমন মাসিক বেতন ₹৫০,০০০ হলে বার্ষিক বেতন ₹৬,০০,০০০।" data-en="Annual salary = Monthly salary × 12. For example, a monthly salary of ₹50,000 equals an annual salary of ₹6,00,000.">বার্ষিক বেতন = মাসিক বেতন × ১২। যেমন মাসিক বেতন ₹৫০,০০০ হলে বার্ষিক বেতন ₹৬,০০,০০০।</span></p>
      </details>
    </div>
  </section>

  <AdSlot slot="below-faq" />

  <RelatedTools tools={[
    { url: "/india/gst-calculator", nameBn: "জিএসটি ক্যালকুলেটর", nameEn: "GST Calculator", descBn: "জিএসটি হিসাব করুন", descEn: "Calculate GST", icon: "🧾" },
    { url: "/calculators/percentage", nameBn: "শতাংশ ক্যালকুলেটর", nameEn: "Percentage Calculator", descBn: "শতাংশ বের করুন", descEn: "Calculate percentages", icon: "%" },
    { url: "/calculators/fuel-cost", nameBn: "জ্বালানি খরচ", nameEn: "Fuel Cost", descBn: "পেট্রোল খরচ হিসাব", descEn: "Fuel cost calculator", icon: "⛽" }
  ]} />
</ToolLayout>

<script is:inline>
var salaryMode = 'monthly';

function setMode(mode) {
  salaryMode = mode;
  var mBtn = document.getElementById('btn-monthly');
  var hBtn = document.getElementById('btn-hourly');
  var label = document.getElementById('salary-label');
  if (mode === 'monthly') {
    mBtn.className = 'flex-1 py-2 px-4 rounded-lg font-medium bg-teal-700 text-white transition-colors';
    hBtn.className = 'flex-1 py-2 px-4 rounded-lg font-medium bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors';
    label.setAttribute('data-bn', 'মাসিক বেতন (₹)');
    label.setAttribute('data-en', 'Monthly Salary (₹)');
  } else {
    hBtn.className = 'flex-1 py-2 px-4 rounded-lg font-medium bg-teal-700 text-white transition-colors';
    mBtn.className = 'flex-1 py-2 px-4 rounded-lg font-medium bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors';
    label.setAttribute('data-bn', 'ঘণ্টায় বেতন (₹)');
    label.setAttribute('data-en', 'Hourly Rate (₹)');
  }
  if (typeof applyLang === 'function') applyLang(typeof getLang === 'function' ? getLang() : 'bn');
  calculate();
}

function calculate() {
  var val = parseFloat(document.getElementById('salary-input').value);
  var days = parseFloat(document.getElementById('work-days').value);
  var hours = parseFloat(document.getElementById('work-hours').value);
  var resultsEl = document.getElementById('salary-results');

  if (isNaN(val) || val <= 0) { resultsEl.classList.add('hidden'); return; }

  var monthly, hourly, daily, weekly, annual;
  var fmt = function(n) { return '₹' + Math.round(n).toLocaleString('en-IN'); };

  if (salaryMode === 'monthly') {
    monthly = val;
    daily = monthly / days;
    hourly = daily / hours;
    weekly = daily * 5;
    annual = monthly * 12;
  } else {
    hourly = val;
    daily = hourly * hours;
    weekly = daily * 5;
    monthly = daily * days;
    annual = monthly * 12;
  }

  document.getElementById('result-hourly').textContent = '₹' + hourly.toFixed(2);
  document.getElementById('result-daily').textContent = fmt(daily);
  document.getElementById('result-weekly').textContent = fmt(weekly);
  document.getElementById('result-annual').textContent = fmt(annual);
  resultsEl.classList.remove('hidden');
}

document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('salary-input').addEventListener('input', calculate);
  document.getElementById('work-days').addEventListener('change', calculate);
  document.getElementById('work-hours').addEventListener('change', calculate);
});
</script>
