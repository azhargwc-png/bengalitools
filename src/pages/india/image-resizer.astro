<script>
  const uploadArea = document.getElementById('upload-area')!;
  const imgInput = document.getElementById('img-input') as HTMLInputElement;
  const processBtn = document.getElementById('process-btn') as HTMLButtonElement;
  const resultArea = document.getElementById('result-area')!;
  const previewBefore = document.getElementById('preview-before') as HTMLImageElement;
  const previewAfter = document.getElementById('preview-after') as HTMLImageElement;
  const infoBefore = document.getElementById('info-before')!;
  const infoAfter = document.getElementById('info-after')!;
  const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
  const warningMsg = document.getElementById('warning-msg')!;
  const widthInput = document.getElementById('img-width') as HTMLInputElement;
  const heightInput = document.getElementById('img-height') as HTMLInputElement;
  const kbInput = document.getElementById('img-kb') as HTMLInputElement;
  const presetBtns = document.querySelectorAll('.preset-btn') as NodeListOf<HTMLButtonElement>;

  let uploadedFile: File | null = null;
  let originalDataUrl: string = '';

  // Preset selection
  presetBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      presetBtns.forEach(b => {
        b.className = b.className.replace('border-teal-500 bg-teal-50 text-teal-700', 'border-gray-300 bg-white text-gray-700');
      });
      btn.className = btn.className.replace('border-gray-300 bg-white text-gray-700', 'border-teal-500 bg-teal-50 text-teal-700');

      const w = btn.dataset.w;
      const h = btn.dataset.h;
      const kb = btn.dataset.kb;
      if (w) widthInput.value = w;
      if (h) heightInput.value = h;
      if (kb) kbInput.value = kb;
    });
  });

  // Select PSC by default
  (presetBtns[0] as HTMLButtonElement).click();

  // Upload handlers
  uploadArea.addEventListener('click', () => imgInput.click());

  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('border-teal-500', 'bg-teal-50');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('border-teal-500', 'bg-teal-50');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('border-teal-500', 'bg-teal-50');
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith('image/')) handleFile(file);
  });

  imgInput.addEventListener('change', () => {
    if (imgInput.files?.[0]) handleFile(imgInput.files[0]);
  });

  function handleFile(file: File) {
    uploadedFile = file;
    const reader = new FileReader();
    reader.onload = (e) => {
      originalDataUrl = e.target?.result as string;
      previewBefore.src = originalDataUrl;
      const sizeKB = (file.size / 1024).toFixed(1);
      const lang = (window as any).getLang?.() || 'bn';
      infoBefore.textContent = lang === 'bn'
        ? `${sizeKB} KB — মূল ছবি`
        : `${sizeKB} KB — Original`;

      // Enable button
      processBtn.disabled = false;
      processBtn.className = 'w-full py-4 rounded-xl font-bold text-lg bg-teal-600 hover:bg-teal-700 text-white cursor-pointer transition-all min-h-[52px]';

      resultArea.classList.add('hidden');
    };
    reader.readAsDataURL(file);

    // Update upload area label
    uploadArea.querySelector('p.font-semibold span')!.textContent = file.name;
  }

  processBtn.addEventListener('click', async () => {
    if (!uploadedFile || !originalDataUrl) return;

    const targetW = parseInt(widthInput.value) || 200;
    const targetH = parseInt(heightInput.value) || 230;
    const targetKB = parseInt(kbInput.value) || 50;
    const targetBytes = targetKB * 1024;

    processBtn.textContent = '...';
    processBtn.disabled = true;

    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = targetW;
      canvas.height = targetH;
      const ctx = canvas.getContext('2d')!;
      ctx.drawImage(img, 0, 0, targetW, targetH);

      // Binary search for quality to hit target KB
      compressToTarget(canvas, targetBytes).then(({ blob, quality, hitTarget }) => {
        const url = URL.createObjectURL(blob);
        previewAfter.src = url;
        downloadBtn.href = url;
        downloadBtn.download = 'resized-photo.jpg';

        const actualKB = (blob.size / 1024).toFixed(1);
        const lang = (window as any).getLang?.() || 'bn';
        infoAfter.textContent = lang === 'bn'
          ? `${actualKB} KB — ${targetW}×${targetH}px`
          : `${actualKB} KB — ${targetW}×${targetH}px`;

        if (!hitTarget) {
          warningMsg.classList.remove('hidden');
          warningMsg.textContent = lang === 'bn'
            ? `⚠️ ${targetKB}KB-এর মধ্যে আনা সম্ভব হয়নি। ফলাফল ${actualKB}KB। KB লিমিট বাড়িয়ে আবার চেষ্টা করুন।`
            : `⚠️ Could not compress to ${targetKB}KB. Result is ${actualKB}KB. Try increasing the KB limit.`;
        } else {
          warningMsg.classList.add('hidden');
        }

        resultArea.classList.remove('hidden');

        processBtn.disabled = false;
        const lang2 = (window as any).getLang?.() || 'bn';
        processBtn.textContent = lang2 === 'bn' ? 'ছবি তৈরি করুন' : 'Resize Photo';
        processBtn.className = 'w-full py-4 rounded-xl font-bold text-lg bg-teal-600 hover:bg-teal-700 text-white cursor-pointer transition-all min-h-[52px]';
      });
    };
    img.src = originalDataUrl;
  });

  async function compressToTarget(
    canvas: HTMLCanvasElement,
    targetBytes: number
  ): Promise<{ blob: Blob; quality: number; hitTarget: boolean }> {
    let lo = 0.01;
    let hi = 0.99;
    let bestBlob: Blob | null = null;
    let hitTarget = false;

    // First check if full quality is already under target
    const fullBlob = await canvasToBlob(canvas, 0.99);
    if (fullBlob.size <= targetBytes) {
      return { blob: fullBlob, quality: 0.99, hitTarget: true };
    }

    // Binary search
    for (let i = 0; i < 16; i++) {
      const mid = (lo + hi) / 2;
      const blob = await canvasToBlob(canvas, mid);
      if (blob.size <= targetBytes) {
        bestBlob = blob;
        hitTarget = true;
        lo = mid;
      } else {
        hi = mid;
      }
      if (hi - lo < 0.005) break;
    }

    if (!bestBlob) {
      // Can't fit — return lowest quality we have
      bestBlob = await canvasToBlob(canvas, 0.01);
    }

    return { blob: bestBlob, quality: lo, hitTarget };
  }

  function canvasToBlob(canvas: HTMLCanvasElement, quality: number): Promise<Blob> {
    return new Promise((resolve) => {
      canvas.toBlob((blob) => resolve(blob!), 'image/jpeg', quality);
    });
  }
</script>
