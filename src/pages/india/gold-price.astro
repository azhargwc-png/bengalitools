---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="আজকের সোনার দাম — Gold Price Today India | BanglaTools"
  description="আজকের ভারতে সোনার দাম। ২৪ ক্যারেট, ২২ ক্যারেট, ১৮ ক্যারেট প্রতি গ্রাম ও তোলায় লাইভ রেট।"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="আজকের সোনার দাম — ভারত" data-en="Gold Price Today India">আজকের সোনার দাম — ভারত</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="আন্তর্জাতিক বাজার অনুযায়ী আজকের সোনার দাম — প্রতি গ্রাম ও তোলায়" data-en="Today's gold price based on international market — per gram and per tola">আন্তর্জাতিক বাজার অনুযায়ী আজকের সোনার দাম — প্রতি গ্রাম ও তোলায়</span>
  </p>

  <AdSlot slot="above-tool" />

  <!-- Live Price Display -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <!-- Status bar -->
    <div class="flex items-center justify-between mb-5 flex-wrap gap-2">
      <div class="flex items-center gap-2">
        <span id="price-change-badge" class="px-3 py-1 rounded-full text-sm font-semibold hidden"></span>
        <span id="load-status" class="text-gray-500 text-sm">
          <span data-bn="লোড হচ্ছে..." data-en="Loading...">লোড হচ্ছে...</span>
        </span>
      </div>
      <p class="text-xs text-gray-500">
        <span data-bn="সর্বশেষ আপডেট:" data-en="Last updated:">সর্বশেষ আপডেট:</span>
        <span id="last-updated">—</span>
      </p>
    </div>

    <!-- Price Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
      <!-- 24K per gram -->
      <div class="bg-yellow-50 rounded-xl p-4 border border-yellow-200">
        <p class="text-sm font-medium text-yellow-800 mb-1">
          <span data-bn="২৪ ক্যারেট (প্রতি গ্রাম)" data-en="24K Gold (per gram)">২৪ ক্যারেট (প্রতি গ্রাম)</span>
        </p>
        <p id="price-24k-gram" class="text-2xl font-bold text-yellow-700">—</p>
      </div>
      <!-- 22K per gram -->
      <div class="bg-yellow-50 rounded-xl p-4 border border-yellow-200">
        <p class="text-sm font-medium text-yellow-800 mb-1">
          <span data-bn="২২ ক্যারেট (প্রতি গ্রাম)" data-en="22K Gold (per gram)">২২ ক্যারেট (প্রতি গ্রাম)</span>
        </p>
        <p id="price-22k-gram" class="text-2xl font-bold text-yellow-700">—</p>
      </div>
      <!-- 18K per gram -->
      <div class="bg-yellow-50 rounded-xl p-4 border border-yellow-200">
        <p class="text-sm font-medium text-yellow-800 mb-1">
          <span data-bn="১৮ ক্যারেট (প্রতি গ্রাম)" data-en="18K Gold (per gram)">১৮ ক্যারেট (প্রতি গ্রাম)</span>
        </p>
        <p id="price-18k-gram" class="text-2xl font-bold text-yellow-700">—</p>
      </div>
      <!-- 24K per 10g -->
      <div class="bg-yellow-50 rounded-xl p-4 border border-yellow-200">
        <p class="text-sm font-medium text-yellow-800 mb-1">
          <span data-bn="২৪ ক্যারেট (প্রতি ১০ গ্রাম)" data-en="24K Gold (per 10 grams)">২৪ ক্যারেট (প্রতি ১০ গ্রাম)</span>
        </p>
        <p id="price-24k-10g" class="text-2xl font-bold text-yellow-700">—</p>
      </div>
    </div>

    <!-- Tola highlight -->
    <div class="bg-teal-50 rounded-xl p-4 border border-teal-300">
      <div class="flex justify-between items-center">
        <div>
          <p class="font-bold text-teal-800">
            <span data-bn="২৪ ক্যারেট প্রতি তোলা (১১.৬৬ গ্রাম)" data-en="24K Gold per Tola (11.66g)">২৪ ক্যারেট প্রতি তোলা (১১.৬৬ গ্রাম)</span>
          </p>
          <p class="text-sm text-teal-600 mt-0.5">
            <span data-bn="ভারতে গহনার সবচেয়ে প্রচলিত মাপ" data-en="Most common jewellery measurement in India">ভারতে গহনার সবচেয়ে প্রচলিত মাপ</span>
          </p>
        </div>
        <p id="price-24k-tola" class="text-2xl font-bold text-teal-700">—</p>
      </div>
    </div>

    <!-- Error message -->
    <div id="error-msg" class="hidden mt-4 bg-red-50 rounded-xl p-4 border border-red-200">
      <p class="text-red-700 text-sm">
        <span data-bn="দাম লোড করা যায়নি। পরে আবার চেষ্টা করুন।" data-en="Could not load prices. Please try again later.">দাম লোড করা যায়নি। পরে আবার চেষ্টা করুন।</span>
      </p>
    </div>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে পড়বেন" data-en="How to Read This">কীভাবে পড়বেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">১.</span><span data-bn="পেজ লোড হলেই আন্তর্জাতিক বাজার থেকে সোনার দাম আনা হয়" data-en="Gold prices are fetched from international markets when the page loads">পেজ লোড হলেই আন্তর্জাতিক বাজার থেকে সোনার দাম আনা হয়</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">২.</span><span data-bn="USD/INR বিনিময় হার দিয়ে রুপিতে রূপান্তর করা হয়" data-en="Prices are converted to INR using the live USD/INR exchange rate">USD/INR বিনিময় হার দিয়ে রুপিতে রূপান্তর করা হয়</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">৩.</span><span data-bn="২৪K, ২২K, ১৮K ও তোলায় আলাদাভাবে দাম দেখানো হয়" data-en="Prices shown separately for 24K, 22K, 18K and per tola">২৪K, ২২K, ১৮K ও তোলায় আলাদাভাবে দাম দেখানো হয়</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">৪.</span><span data-bn="সবুজ মানে দাম বেড়েছে, লাল মানে কমেছে" data-en="Green means price is up, red means price is down">সবুজ মানে দাম বেড়েছে, লাল মানে কমেছে</span></li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই পেজ সম্পর্কে" data-en="About This Page">এই পেজ সম্পর্কে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed space-y-3">
      <p data-lang-bn>
        আজকের সোনার দাম জানা ভারতের প্রতিটি পরিবারের জন্য জরুরি। বিয়ের গহনা কেনা থেকে শুরু করে বিনিয়োগের সিদ্ধান্ত পর্যন্ত সোনার দামের উপর অনেক কিছু নির্ভর করে। এই পেজে আন্তর্জাতিক বাজারের সাথে সামঞ্জস্য রেখে ভারতীয় রুপিতে সোনার দাম দেখানো হয়। ২৪ ক্যারেট সোনা সবচেয়ে বিশুদ্ধ — বিনিয়োগের জন্য এটি ব্যবহার হয়। ২২ ক্যারেট সোনা গহনা তৈরিতে বেশি প্রচলিত কারণ এটি বেশি শক্ত। ১৮ ক্যারেট হালকা গহনায় ব্যবহার হয়। তোলা হলো ভারতে গহনার ঐতিহ্যবাহী মাপ — ১ তোলা = ১১.৬৬ গ্রাম।
      </p>
      <p data-lang-en style="display:none">
        Knowing today's gold price is essential for every household in India. From buying jewellery for weddings to making investment decisions, many things depend on the gold rate. This page shows gold prices in Indian Rupees based on international market rates. 24K gold is the purest form, used mainly for investment. 22K gold is the most popular for jewellery as it is more durable. 18K gold is used for lightweight jewellery. Tola is the traditional jewellery measurement in India — 1 tola equals 11.66 grams. Prices here reflect the international spot price converted to INR and may vary slightly from local jeweller prices due to making charges and local taxes.
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ হিসাব" data-en="Worked Examples">উদাহরণ হিসাব</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ১: বিয়ের গহনা — ২২ ক্যারেট, ২০ গ্রাম" data-en="Example 1: Wedding jewellery — 22K, 20 grams">উদাহরণ ১: বিয়ের গহনা — ২২ ক্যারেট, ২০ গ্রাম</span></p>
        <p class="text-gray-700 mt-2 text-sm"><span data-bn="যদি আজকের ২২K দাম ৭,৫০০ টাকা/গ্রাম হয়, তাহলে ২০ গ্রামের দাম = ২০ × ৭,৫০০ = ₹১,৫০,০০০। এর উপর মেকিং চার্জ ও জিএসটি আলাদা যোগ হবে।" data-en="If today's 22K price is ₹7,500/gram, then 20 grams costs = 20 × ₹7,500 = ₹1,50,000. Making charges and GST are added separately by the jeweller.">যদি আজকের ২২K দাম ৭,৫০০ টাকা/গ্রাম হয়, তাহলে ২০ গ্রামের দাম = ২০ × ৭,৫০০ = ₹১,৫০,০০০। এর উপর মেকিং চার্জ ও জিএসটি আলাদা যোগ হবে।</span></p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ২: গোল্ড কয়েন বিনিয়োগ — ২৪ ক্যারেট, ৫ গ্রাম" data-en="Example 2: Gold coin investment — 24K, 5 grams">উদাহরণ ২: গোল্ড কয়েন বিনিয়োগ — ২৪ ক্যারেট, ৫ গ্রাম</span></p>
        <p class="text-gray-700 mt-2 text-sm"><span data-bn="যদি আজকের ২৪K দাম ৮,২০০ টাকা/গ্রাম হয়, তাহলে ৫ গ্রামের কয়েনের দাম = ৫ × ৮,২০০ = ₹৪১,০০০। বিনিয়োগে ২৪K সবচেয়ে ভালো কারণ বিশুদ্ধতা বেশি।" data-en="If today's 24K price is ₹8,200/gram, then a 5 gram coin costs = 5 × ₹8,200 = ₹41,000. 24K is best for investment because it has the highest purity.">যদি আজকের ২৪K দাম ৮,২০০ টাকা/গ্রাম হয়, তাহলে ৫ গ্রামের কয়েনের দাম = ৫ × ৮,২০০ = ₹৪১,০০০। বিনিয়োগে ২৪K সবচেয়ে ভালো কারণ বিশুদ্ধতা বেশি।</span></p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ৩: তোলায় হিসাব — ২ তোলা সোনার হার" data-en="Example 3: Tola calculation — price of 2 tolas of gold">উদাহরণ ৩: তোলায় হিসাব — ২ তোলা সোনার হার</span></p>
        <p class="text-gray-700 mt-2 text-sm"><span data-bn="১ তোলা = ১১.৬৬ গ্রাম। যদি ২৪K প্রতি তোলায় ₹৯৫,৬০০ হয়, তাহলে ২ তোলার দাম = ২ × ₹৯৫,৬০০ = ₹১,৯১,২০০।" data-en="1 tola = 11.66 grams. If 24K gold is ₹95,600 per tola, then 2 tolas cost = 2 × ₹95,600 = ₹1,91,200.">১ তোলা = ১১.৬৬ গ্রাম। যদি ২৪K প্রতি তোলায় ₹৯৫,৬০০ হয়, তাহলে ২ তোলার দাম = ২ × ₹৯৫,৬০০ = ₹১,৯১,২০০।</span></p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="২৪K ও ২২K সোনার মধ্যে পার্থক্য কী?" data-en="What is the difference between 24K and 22K gold?">২৪K ও ২২K সোনার মধ্যে পার্থক্য কী?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="২৪ ক্যারেট সোনা ৯৯.৯% বিশুদ্ধ এবং বিনিয়োগ বা কয়েনের জন্য ব্যবহার হয়। ২২ ক্যারেট সোনায় ৯১.৭% সোনা ও কিছু মিশ্র ধাতু থাকে, যা গহনাকে বেশি শক্ত ও দীর্ঘস্থায়ী করে। ভারতে বেশিরভাগ গহনা ২২K দিয়ে তৈরি।" data-en="24K gold is 99.9% pure and is used for investment or coins. 22K gold contains 91.7% gold mixed with other metals, making jewellery more durable. Most jewellery in India is made with 22K gold.">২৪ ক্যারেট সোনা ৯৯.৯% বিশুদ্ধ এবং বিনিয়োগ বা কয়েনের জন্য ব্যবহার হয়। ২২ ক্যারেট সোনায় ৯১.৭% সোনা ও কিছু মিশ্র ধাতু থাকে, যা গহনাকে বেশি শক্ত ও দীর্ঘস্থায়ী করে। ভারতে বেশিরভাগ গহনা ২২K দিয়ে তৈরি।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="এখানে দেখানো দাম কি দোকানের দামের সাথে মিলবে?" data-en="Will the price here match jeweller prices?">এখানে দেখানো দাম কি দোকানের দামের সাথে মিলবে?</span></summary>
        <p class="mt-3 text-gray-700 text-sm"><span data-bn="এখানে দেখানো দাম আন্তর্জাতিক বাজারের স্পট প্রাইস থেকে রূপান্তরিত। দোকানের দামে মেকিং চার্জ (৫-২০%), জিএসটি ৩%, এবং স্থানীয় ট্যাক্স যোগ হয়। তাই সোনার দোকানে দাম কিছুটা বেশি হবে।" data-en="The prices shown here are converted from international spot prices. Jeweller prices include making charges (5-20%), 3% GST, and local taxes. So the price at a jewellery shop will be somewhat higher.">এখানে দেখানো দাম আন্তর্জাতিক বাজারের স্পট প্রাইস থেকে রূপান্তরিত। দোকানের দামে মেকিং চার্জ (৫-২০%), জিএসটি ৩%, এবং স্থানীয় ট্যাক্স যোগ হয়। তাই সোনার দোকানে দাম কিছুটা বেশি হবে।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="১ তোলা মানে কত গ্রাম?" data-en="How many grams is 1 tola?">১ তোলা মানে কত গ্রাম?</span></summary>
