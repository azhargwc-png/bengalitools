<script is:inline>
var TROY_OZ_TO_GRAMS = 31.1035;
var TOLA_GRAMS = 11.66;

function fmtINR(n) {
  return '₹' + Math.round(n).toLocaleString('en-IN');
}

function setStatus(text, isError) {
  var el = document.getElementById('load-status');
  if (el) el.textContent = text;
  if (isError) {
    document.getElementById('error-msg').classList.remove('hidden');
  }
}

function showChange(ch, chp) {
  var badge = document.getElementById('price-change-badge');
  if (!badge) return;
  badge.classList.remove('hidden');
  if (ch >= 0) {
    badge.textContent = '▲ $' + ch.toFixed(2) + ' (' + chp.toFixed(2) + '%)';
    badge.className = 'px-3 py-1 rounded-full text-sm font-semibold bg-green-100 text-green-800';
  } else {
    badge.textContent = '▼ $' + Math.abs(ch).toFixed(2) + ' (' + Math.abs(chp).toFixed(2) + '%)';
    badge.className = 'px-3 py-1 rounded-full text-sm font-semibold bg-red-100 text-red-800';
  }
}

async function loadGoldPrice() {
  try {
    var goldRes = await fetch('https://api.gold-api.com/price/XAU');
    if (!goldRes.ok) throw new Error('gold api error');
    var goldData = await goldRes.json();

    var fxRes = await fetch('https://api.frankfurter.app/latest?from=USD&to=INR');
    if (!fxRes.ok) throw new Error('fx api error');
    var fxData = await fxRes.json();

    var usdInr = fxData.rates.INR;
    var pricePerOzUSD = goldData.price;
    var pricePerGramUSD = pricePerOzUSD / TROY_OZ_TO_GRAMS;

    var price24k = pricePerGramUSD * usdInr;
    var price22k = price24k * (22 / 24);
    var price18k = price24k * (18 / 24);

    document.getElementById('price-24k-gram').textContent = fmtINR(price24k);
    document.getElementById('price-22k-gram').textContent = fmtINR(price22k);
    document.getElementById('price-18k-gram').textContent = fmtINR(price18k);
    document.getElementById('price-24k-10g').textContent = fmtINR(price24k * 10);
    document.getElementById('price-24k-tola').textContent = fmtINR(price24k * TOLA_GRAMS);

    if (goldData.ch !== undefined && goldData.chp !== undefined) {
      showChange(goldData.ch, goldData.chp);
    }

    var now = new Date();
    document.getElementById('last-updated').textContent = now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });

    var lang = (typeof getLang === 'function') ? getLang() : 'bn';
    setStatus(lang === 'bn' ? 'লাইভ রেট — আন্তর্জাতিক বাজার' : 'Live rate — International market', false);

  } catch (e) {
    var lang = (typeof getLang === 'function') ? getLang() : 'bn';
    setStatus(lang === 'bn' ? 'লোড করা যায়নি' : 'Could not load', true);
  }
}

document.addEventListener('DOMContentLoaded', loadGoldPrice);
</script>
