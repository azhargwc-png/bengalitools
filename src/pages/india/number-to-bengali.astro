---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="সংখ্যা বাংলায় — ইংরেজি সংখ্যা বাংলা কথায় | BanglaTools"
  description="যেকোনো সংখ্যা বাংলা শব্দে লিখুন। চেক লেখা, আনুষ্ঠানিক কাগজপত্রের জন্য সংখ্যাকে বাংলায় রূপান্তর করুন।"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="সংখ্যা বাংলায় — ইংরেজি সংখ্যা বাংলা কথায়" data-en="Number to Bengali Words Converter">সংখ্যা বাংলায় — ইংরেজি সংখ্যা বাংলা কথায়</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="যেকোনো সংখ্যা বাংলা শব্দে রূপান্তর করুন — চেক, দলিল ও বিদ্যালয়ের কাজে" data-en="Convert any number into Bengali words — for cheques, documents and school work">যেকোনো সংখ্যা বাংলা শব্দে রূপান্তর করুন — চেক, দলিল ও বিদ্যালয়ের কাজে</span>
  </p>

  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="number-input">
          <span data-bn="সংখ্যা লিখুন (০ থেকে ৯৯,৯৯,৯৯,৯৯৯)" data-en="Enter number (0 to 99,99,99,999)">সংখ্যা লিখুন (০ থেকে ৯৯,৯৯,৯৯,৯৯৯)</span>
        </label>
        <input
          type="number"
          id="number-input"
          placeholder="যেমন: 1234"
          min="0"
          max="9999999999"
          step="1"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>

      <!-- Result -->
      <div id="number-result" class="hidden">
        <label class="block text-sm font-medium text-gray-700 mb-2">
          <span data-bn="বাংলায় শব্দে" data-en="In Bengali Words">বাংলায় শব্দে</span>
        </label>
        <div id="bn-words" class="w-full px-4 py-4 bg-teal-50 border-2 border-teal-300 rounded-xl text-xl font-bold text-teal-800 leading-relaxed"></div>
        <div class="mt-3">
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <span data-bn="ইংরেজিতে শব্দে" data-en="In English Words">ইংরেজিতে শব্দে</span>
          </label>
          <div id="en-words" class="w-full px-4 py-3 bg-gray-100 border border-gray-300 rounded-xl text-base text-gray-700"></div>
        </div>
        <button
          onclick="copyResult()"
          class="mt-3 px-4 py-2 bg-teal-700 hover:bg-teal-800 text-white rounded-lg text-sm font-medium transition-colors"
        >
          <span data-bn="কপি করুন" data-en="Copy">কপি করুন</span>
        </button>
      </div>
    </div>

    <!-- Quick examples -->
    <div class="mt-5 pt-4 border-t border-gray-200">
      <p class="text-sm text-gray-600 mb-2"><span data-bn="দ্রুত উদাহরণ:" data-en="Quick examples:">দ্রুত উদাহরণ:</span></p>
      <div class="flex flex-wrap gap-2">
        {[100, 1000, 5000, 50000, 100000, 500000, 1000000].map((n) => (
          <button
            onclick={`quickSet(${n})`}
            class="px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-sm hover:border-teal-500 hover:text-teal-700 transition-colors"
          >
            {n.toLocaleString('en-IN')}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span></h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">১.</span><span data-bn="সংখ্যা ঘরে যেকোনো সংখ্যা লিখুন" data-en="Type any number in the input box">সংখ্যা ঘরে যেকোনো সংখ্যা লিখুন</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">২.</span><span data-bn="বাংলা ও ইংরেজি শব্দ তাৎক্ষণিকভাবে দেখাবে" data-en="Bengali and English words appear instantly">বাংলা ও ইংরেজি শব্দ তাৎক্ষণিকভাবে দেখাবে</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">৩.</span><span data-bn="কপি বাটনে ক্লিক করে কপি করুন" data-en="Click the copy button to copy the text">কপি বাটনে ক্লিক করে কপি করুন</span></li>
    </ol>
  </section>

  <!-- Description -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span></h2>
    <div class="text-gray-700 leading-relaxed">
      <p data-lang-bn>
        বাংলায় সংখ্যা লেখার নিয়ম ইংরেজি থেকে আলাদা। বাংলায় হাজার, লক্ষ, কোটি ব্যবহার করা হয়। এই টুলটি যেকোনো সংখ্যাকে সঠিক বাংলা শব্দে রূপান্তর করে। চেক লেখার সময়, আনুষ্ঠানিক দলিলে, বিদ্যালয়ের অ্যাসাইনমেন্টে এবং ব্যবসায়িক কাজে এই টুলটি অত্যন্ত কাজে আসে। ৯৯ কোটি পর্যন্ত সংখ্যা সঠিকভাবে বাংলায় লেখা যাবে।
      </p>
      <p data-lang-en style="display:none">
        Bengali number words follow a different system from English. Bengali uses হাজার (thousand), লক্ষ (hundred thousand), and কোটি (ten million). This tool converts any number into correct Bengali words, making it useful for writing cheques, formal documents, school assignments, and business paperwork. Numbers up to 99 crore can be converted accurately.
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span></h2>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse">
        <thead>
          <tr class="bg-teal-700 text-white">
            <th class="p-3 text-left rounded-tl-lg"><span data-bn="সংখ্যা" data-en="Number">সংখ্যা</span></th>
            <th class="p-3 text-left rounded-tr-lg"><span data-bn="বাংলায়" data-en="In Bengali">বাংলায়</span></th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-gray-200">
            <td class="p-3 font-medium">১,২৩৪</td>
            <td class="p-3 text-teal-700 font-semibold">এক হাজার দুইশত চৌত্রিশ</td>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <td class="p-3 font-medium">৫০,০০০</td>
            <td class="p-3 text-teal-700 font-semibold">পঞ্চাশ হাজার</td>
          </tr>
          <tr class="border-b border-gray-200">
            <td class="p-3 font-medium">১,০০,০০০</td>
            <td class="p-3 text-teal-700 font-semibold">এক লক্ষ</td>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <td class="p-3 font-medium">১০,০০,০০০</td>
            <td class="p-3 text-teal-700 font-semibold">দশ লক্ষ</td>
          </tr>
          <tr class="border-b border-gray-200">
            <td class="p-3 font-medium">১,০০,০০,০০০</td>
            <td class="p-3 text-teal-700 font-semibold">এক কোটি</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span></h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="১ লক্ষ মানে কত?" data-en="What is 1 lakh in numbers?">১ লক্ষ মানে কত?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="১ লক্ষ = ১,০০,০০০ = এক লক্ষ। ইংরেজিতে one hundred thousand।" data-en="1 lakh = 1,00,000 = one hundred thousand in English.">১ লক্ষ = ১,০০,০০০ = এক লক্ষ। ইংরেজিতে one hundred thousand।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="১ কোটি মানে কত?" data-en="What is 1 crore in numbers?">১ কোটি মানে কত?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="১ কোটি = ১,০০,০০,০০০ = এক কোটি। ইংরেজিতে ten million।" data-en="1 crore = 1,00,00,000 = ten million in English.">১ কোটি = ১,০০,০০,০০০ = এক কোটি। ইংরেজিতে ten million।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="চেকে সংখ্যা বাংলায় লেখার নিয়ম কী?" data-en="How to write numbers in Bengali on a cheque?">চেকে সংখ্যা বাংলায় লেখার নিয়ম কী?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="চেকে সংখ্যা শব্দে লিখতে হয়। যেমন ₹৫০,০০০ হলে লিখবেন 'পঞ্চাশ হাজার টাকা মাত্র'। এই টুল দিয়ে সংখ্যাটি বাংলায় বের করুন।" data-en="Cheques require the amount in words. For example, ₹50,000 should be written as 'Fifty thousand rupees only'. Use this tool to get the Bengali words.">চেকে সংখ্যা শব্দে লিখতে হয়। যেমন ₹৫০,০০০ হলে লিখবেন 'পঞ্চাশ হাজার টাকা মাত্র'। এই টুল দিয়ে সংখ্যাটি বাংলায় বের করুন।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="বাংলায় শূন্য কীভাবে লেখে?" data-en="How is zero written in Bengali?">বাংলায় শূন্য কীভাবে লেখে?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="বাংলায় শূন্য লেখা হয় 'শূন্য'। বাংলা সংখ্যায় ০ = শূন্য।" data-en="Zero in Bengali is শূন্য. The Bengali digit for 0 is ০.">বাংলায় শূন্য লেখা হয় 'শূন্য'। বাংলা সংখ্যায় ০ = শূন্য।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="এই টুল কত বড় সংখ্যা সমর্থন করে?" data-en="What is the maximum number this tool supports?">এই টুল কত বড় সংখ্যা সমর্থন করে?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="এই টুল ৯৯ কোটি ৯৯ লক্ষ ৯৯ হাজার ৯৯৯ পর্যন্ত সংখ্যাকে বাংলায় রূপান্তর করতে পারে।" data-en="This tool can convert numbers up to 99,99,99,999 (ninety-nine crore ninety-nine lakh ninety-nine thousand nine hundred and ninety-nine) into Bengali words.">এই টুল ৯৯ কোটি ৯৯ লক্ষ ৯৯ হাজার ৯৯৯ পর্যন্ত সংখ্যাকে বাংলায় রূপান্তর করতে পারে।</span></p>
      </details>
    </div>
  </section>

  <AdSlot slot="below-faq" />

  <RelatedTools tools={[
    { url: "/india/bengali-calendar", nameBn: "বাংলা তারিখ কনভার্টার", nameEn: "Bengali Calendar", descBn: "ইংরেজি থেকে বাংলা তারিখ", descEn: "English to Bengali date", icon: "📆" },
    { url: "/calculators/percentage", nameBn: "শতাংশ ক্যালকুলেটর", nameEn: "Percentage Calculator", descBn: "শতাংশ বের করুন", descEn: "Calculate percentages", icon: "%" },
    { url: "/india/gst-calculator", nameBn: "জিএসটি ক্যালকুলেটর", nameEn: "GST Calculator", descBn: "জিএসটি হিসাব করুন", descEn: "Calculate GST", icon: "🧾" }
  ]} />
</ToolLayout>

<script is:inline>
var ones = ['', 'এক', 'দুই', 'তিন', 'চার', 'পাঁচ', 'ছয়', 'সাত', 'আট', 'নয়',
  'দশ', 'এগারো', 'বারো', 'তেরো', 'চৌদ্দ', 'পনেরো', 'ষোলো', 'সতেরো', 'আঠারো', 'উনিশ'];
var tens = ['', '', 'বিশ', 'ত্রিশ', 'চল্লিশ', 'পঞ্চাশ', 'ষাট', 'সত্তর', 'আশি', 'নব্বই'];
var onesEn = ['', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine',
  'ten', 'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen', 'seventeen', 'eighteen', 'nineteen'];
var tensEn = ['', '', 'twenty', 'thirty', 'forty', 'fifty', 'sixty', 'seventy', 'eighty', 'ninety'];

function twoDigitBn(n) {
  if (n === 0) return '';
  if (n < 20) return ones[n];
  return tens[Math.floor(n/10)] + (n % 10 ? ' ' + ones[n % 10] : '');
}
function twoDigitEn(n) {
  if (n === 0) return '';
  if (n < 20) return onesEn[n];
  return tensEn[Math.floor(n/10)] + (n % 10 ? '-' + onesEn[n % 10] : '');
}
function threeDigitBn(n) {
  if (n === 0) return '';
  var h = Math.floor(n / 100);
  var r = n % 100;
  var s = h ? (ones[h] + 'শত') : '';
  if (r) s += (s ? ' ' : '') + twoDigitBn(r);
  return s;
}
function threeDigitEn(n) {
  if (n === 0) return '';
  var h = Math.floor(n / 100);
  var r = n % 100;
  var s = h ? (onesEn[h] + ' hundred') : '';
  if (r) s += (s ? ' ' : '') + twoDigitEn(r);
  return s;
}

function numToBengali(n) {
  n = Math.floor(n);
  if (n === 0) return 'শূন্য';
  var parts = [];
  var partsEn = [];

  var crore = Math.floor(n / 10000000); n %= 10000000;
  var lakh = Math.floor(n / 100000); n %= 100000;
  var thousand = Math.floor(n / 1000); n %= 1000;
  var rest = n;

  if (crore) { parts.push(twoDigitBn(crore) + ' কোটি'); partsEn.push(twoDigitEn(crore) + ' crore'); }
  if (lakh) { parts.push(twoDigitBn(lakh) + ' লক্ষ'); partsEn.push(twoDigitEn(lakh) + ' lakh'); }
  if (thousand) { parts.push(twoDigitBn(thousand) + ' হাজার'); partsEn.push(twoDigitEn(thousand) + ' thousand'); }
  if (rest) { parts.push(threeDigitBn(rest)); partsEn.push(threeDigitEn(rest)); }

  return { bn: parts.join(' '), en: partsEn.join(' ') };
}

function convert() {
  var val = document.getElementById('number-input').value;
  var n = parseInt(val, 10);
  var resultEl = document.getElementById('number-result');
  if (isNaN(n) || val === '') { resultEl.classList.add('hidden'); return; }
  if (n < 0 || n > 9999999999) {
    document.getElementById('bn-words').textContent = 'সংখ্যাটি ০ থেকে ৯৯,৯৯,৯৯,৯৯৯-এর মধ্যে হতে হবে';
    document.getElementById('en-words').textContent = 'Number must be between 0 and 9,99,99,99,999';
    resultEl.classList.remove('hidden');
    return;
  }
  var result = numToBengali(n);
  document.getElementById('bn-words').textContent = result.bn;
  document.getElementById('en-words').textContent = result.en;
  resultEl.classList.remove('hidden');
}

function quickSet(n) {
  document.getElementById('number-input').value = n;
  convert();
}

function copyResult() {
  var text = document.getElementById('bn-words').textContent;
  navigator.clipboard.writeText(text).then(function() {
    var btn = event.target.closest('button');
    var orig = btn.querySelector('[data-bn]');
    if (orig) {
      orig.setAttribute('data-bn', 'কপি হয়েছে ✓');
      orig.setAttribute('data-en', 'Copied ✓');
      orig.textContent = 'কপি হয়েছে ✓';
      setTimeout(function() {
        orig.setAttribute('data-bn', 'কপি করুন');
        orig.setAttribute('data-en', 'Copy');
        if (typeof applyLang === 'function') applyLang(typeof getLang === 'function' ? getLang() : 'bn');
      }, 2000);
    }
  });
}

document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('number-input').addEventListener('input', convert);
});
</script>
