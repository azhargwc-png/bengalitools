---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "জিএসটি ক্যালকুলেটর",
      "url": "https://www.bengalitools.com/india/gst-calculator/",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "জিএসটি কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "জিএসটি (Goods and Services Tax) হলো ভারতের একটি পরোক্ষ কর যা পণ্য ও পরিষেবার উপর আরোপ করা হয়।"
          }
        },
        {
          "@type": "Question",
          "name": "ভারতে জিএসটি স্ল্যাব কতটি?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ভারতে মূলত চারটি জিএসটি স্ল্যাব রয়েছে: ৫%, ১২%, ১৮% এবং ২৮%।"
          }
        },
        {
          "@type": "Question",
          "name": "রেস্তোরাঁতে কত জিএসটি?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "সাধারণ রেস্তোরাঁতে ৫% জিএসটি প্রযোজ্য। এসি রেস্তোরাঁতে ১২% বা ১৮% হতে পারে।"
          }
        },
        {
          "@type": "Question",
          "name": "জিএসটি ছাড়া দাম কীভাবে বের করব?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "সূত্র: মূল দাম = মোট দাম ÷ (১ + জিএসটি হার/১০০)। যেমন ১১৮ টাকায় ১৮% জিএসটি থাকলে মূল দাম = ১০০ টাকা।"
          }
        },
        {
          "@type": "Question",
          "name": "CGST ও SGST কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CGST হলো কেন্দ্রীয় সরকারের অংশ এবং SGST হলো রাজ্য সরকারের অংশ।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="GST Calculator India — জিএসটি ক্যালকুলেটর | BanglaTools"
  description="Add or remove GST at 5%, 12%, 18%, 28% rates. Free GST calculator for India. জিএসটি যোগ বা বাদ দিন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="জিএসটি ক্যালকুলেটর" data-en="GST Calculator India">জিএসটি ক্যালকুলেটর</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="জিএসটি যোগ করুন বা বাদ দিন — ভারতের সব জিএসটি স্ল্যাব সহ" data-en="Add or remove GST — with all Indian GST slabs">জিএসটি যোগ করুন বা বাদ দিন — ভারতের সব জিএসটি স্ল্যাব সহ</span>
  </p>

  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <!-- Mode Toggle -->
    <div class="flex gap-2 mb-6">
      <button
        id="btn-add"
        onclick="setMode('add')"
        class="flex-1 py-2 px-4 rounded-lg font-medium transition-colors bg-teal-700 text-white"
      >
        <span data-bn="জিএসটি যোগ করুন" data-en="Add GST">জিএসটি যোগ করুন</span>
      </button>
      <button
        id="btn-remove"
        onclick="setMode('remove')"
        class="flex-1 py-2 px-4 rounded-lg font-medium transition-colors bg-gray-200 text-gray-700 hover:bg-gray-300"
      >
        <span data-bn="জিএসটি বাদ দিন" data-en="Remove GST">জিএসটি বাদ দিন</span>
      </button>
    </div>

    <div class="space-y-4">
      <!-- Price Input -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="price-input">
          <span id="price-label" data-bn="জিএসটির আগের দাম (₹)" data-en="Price before GST (₹)">জিএসটির আগের দাম (₹)</span>
        </label>
        <input
          type="number"
          id="price-input"
          placeholder="যেমন: 1000"
          min="0"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>

      <!-- GST Rate -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          <span data-bn="জিএসটি হার নির্বাচন করুন" data-en="Select GST Rate">জিএসটি হার নির্বাচন করুন</span>
        </label>
        <div class="grid grid-cols-4 gap-2">
          {['5', '12', '18', '28'].map((rate) => (
            <button
              class="gst-rate-btn py-3 rounded-xl font-bold text-lg border-2 border-gray-300 bg-white hover:border-teal-500 transition-colors"
              data-rate={rate}
              onclick={`selectRate(${rate})`}
            >
              {rate}%
            </button>
          ))}
        </div>
        <div class="mt-2 flex items-center gap-2">
          <span class="text-sm text-gray-600" data-bn="অথবা লিখুন:" data-en="Or enter:">অথবা লিখুন:</span>
          <input
            type="number"
            id="custom-rate"
            placeholder="যেমন: 3"
            min="0"
            max="100"
            step="any"
            oninput="selectCustomRate()"
            class="w-28 px-3 py-2 border-2 border-gray-300 rounded-lg text-sm focus:border-teal-500 focus:outline-none"
          />
          <span class="text-sm text-gray-600">%</span>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="gst-results" class="mt-6 hidden space-y-3">
      <div class="bg-white rounded-xl p-4 border border-gray-200 flex justify-between items-center">
        <span class="text-gray-700" data-bn="মূল দাম" data-en="Original Price">মূল দাম</span>
        <span id="result-original" class="text-xl font-bold text-gray-900"></span>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-200 flex justify-between items-center">
        <span class="text-gray-700" data-bn="জিএসটি পরিমাণ" data-en="GST Amount">জিএসটি পরিমাণ</span>
        <span id="result-gst" class="text-xl font-bold text-teal-700"></span>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-200 flex justify-between items-center">
        <span id="cgst-label" class="text-gray-700" data-bn="সিজিএসটি" data-en="CGST">সিজিএসটি</span>
        <span id="result-cgst" class="text-xl font-bold text-teal-600"></span>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-200 flex justify-between items-center">
        <span id="sgst-label" class="text-gray-700" data-bn="এসজিএসটি" data-en="SGST">এসজিএসটি</span>
        <span id="result-sgst" class="text-xl font-bold text-teal-600"></span>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-300 flex justify-between items-center">
        <span class="font-bold text-teal-800" id="total-label" data-bn="জিএসটি সহ মোট দাম" data-en="Total Price with GST">জিএসটি সহ মোট দাম</span>
        <span id="result-total" class="text-2xl font-bold text-teal-700"></span>
      </div>
      <button
        onclick="resetCalculator()"
        class="w-full py-2.5 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl font-medium transition-colors"
      >
        <span data-bn="রিসেট করুন" data-en="Reset">রিসেট করুন</span>
      </button>
    </div>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">১.</span><span data-bn="মোড নির্বাচন করুন — জিএসটি যোগ বা বাদ" data-en="Select mode — add or remove GST">মোড নির্বাচন করুন — জিএসটি যোগ বা বাদ</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">২.</span><span data-bn="পণ্যের দাম লিখুন" data-en="Enter the product price">পণ্যের দাম লিখুন</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">৩.</span><span data-bn="জিএসটি হার নির্বাচন করুন (৫%, ১২%, ১৮%, ২৮%)" data-en="Select GST rate (5%, 12%, 18%, 28%)">জিএসটি হার নির্বাচন করুন (৫%, ১২%, ১৮%, ২৮%)</span></li>
      <li class="flex gap-3"><span class="font-bold text-teal-700 min-w-[24px]">৪.</span><span data-bn="ফলাফল তাৎক্ষণিকভাবে দেখুন" data-en="See the result instantly">ফলাফল তাৎক্ষণিকভাবে দেখুন</span></li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        জিএসটি ক্যালকুলেটর ব্যবহার করে আপনি দুইভাবে হিসাব করতে পারবেন। প্রথমত, কোনো পণ্যের দামে জিএসটি যোগ করে মোট দাম বের করতে পারবেন। দ্বিতীয়ত, যদি ইতোমধ্যে জিএসটি সহ দাম জানা থাকে, তাহলে মূল দাম এবং জিএসটির পরিমাণ আলাদাভাবে বের করতে পারবেন। ভারতে চারটি প্রধান জিএসটি স্ল্যাব রয়েছে: ৫%, ১২%, ১৮% এবং ২৮%। খাদ্যপণ্যে সাধারণত ৫% বা শূন্য, ইলেকট্রনিক্সে ১৮%, এবং বিলাসবহুল পণ্যে ২৮% জিএসটি প্রযোজ্য।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ১: মোবাইল ফোন (১৮% জিএসটি)" data-en="Example 1: Mobile phone (18% GST)">উদাহরণ ১: মোবাইল ফোন (১৮% জিএসটি)</span></p>
        <p class="text-gray-700 mt-1"><span data-bn="মূল দাম: ₹১০,০০০ | জিএসটি (১৮%): ₹১,৮০০ | মোট: ₹১১,৮০০" data-en="Base price: ₹10,000 | GST (18%): ₹1,800 | Total: ₹11,800">মূল দাম: ₹১০,০০০ | জিএসটি (১৮%): ₹১,৮০০ | মোট: ₹১১,৮০০</span></p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ২: রেস্তোরাঁ খাবার (৫% জিএসটি)" data-en="Example 2: Restaurant food (5% GST)">উদাহরণ ২: রেস্তোরাঁ খাবার (৫% জিএসটি)</span></p>
        <p class="text-gray-700 mt-1"><span data-bn="মূল দাম: ₹৫০০ | জিএসটি (৫%): ₹২৫ | মোট: ₹৫২৫" data-en="Base price: ₹500 | GST (5%): ₹25 | Total: ₹525">মূল দাম: ₹৫০০ | জিএসটি (৫%): ₹২৫ | মোট: ₹৫২৫</span></p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800"><span data-bn="উদাহরণ ৩: বিলাসবহুল পণ্য (২৮% জিএসটি)" data-en="Example 3: Luxury item (28% GST)">উদাহরণ ৩: বিলাসবহুল পণ্য (২৮% জিএসটি)</span></p>
        <p class="text-gray-700 mt-1"><span data-bn="মূল দাম: ₹২০,০০০ | জিএসটি (২৮%): ₹৫,৬০০ | মোট: ₹২৫,৬০০" data-en="Base price: ₹20,000 | GST (28%): ₹5,600 | Total: ₹25,600">মূল দাম: ₹২০,০০০ | জিএসটি (২৮%): ₹৫,৬০০ | মোট: ₹২৫,৬০০</span></p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="জিএসটি কী?" data-en="What is GST?">জিএসটি কী?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="জিএসটি (Goods and Services Tax) হলো ভারতের একটি পরোক্ষ কর যা পণ্য ও পরিষেবার উপর আরোপ করা হয়। ২০১৭ সালে এটি চালু হয় এবং আগের অনেক করকে প্রতিস্থাপন করে।" data-en="GST (Goods and Services Tax) is India's indirect tax on goods and services, introduced in 2017, replacing many previous taxes.">জিএসটি (Goods and Services Tax) হলো ভারতের একটি পরোক্ষ কর যা পণ্য ও পরিষেবার উপর আরোপ করা হয়। ২০১৭ সালে এটি চালু হয় এবং আগের অনেক করকে প্রতিস্থাপন করে।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="ভারতে জিএসটি স্ল্যাব কতটি?" data-en="How many GST slabs are there in India?">ভারতে জিএসটি স্ল্যাব কতটি?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="ভারতে মূলত চারটি জিএসটি স্ল্যাব রয়েছে: ৫%, ১২%, ১৮% এবং ২৮%। এছাড়া কিছু প্রয়োজনীয় পণ্যে ০% জিএসটি প্রযোজ্য।" data-en="India has four main GST slabs: 5%, 12%, 18%, and 28%. Some essential items attract 0% GST.">ভারতে মূলত চারটি জিএসটি স্ল্যাব রয়েছে: ৫%, ১২%, ১৮% এবং ২৮%। এছাড়া কিছু প্রয়োজনীয় পণ্যে ০% জিএসটি প্রযোজ্য।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="রেস্তোরাঁতে কত জিএসটি?" data-en="What GST applies at restaurants?">রেস্তোরাঁতে কত জিএসটি?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="সাধারণ রেস্তোরাঁতে ৫% জিএসটি প্রযোজ্য। এসি রেস্তোরাঁ বা হোটেলের রেস্তোরাঁতে ১২% বা ১৮% হতে পারে।" data-en="Regular restaurants attract 5% GST. Air-conditioned restaurants or hotel restaurants may attract 12% or 18%.">সাধারণ রেস্তোরাঁতে ৫% জিএসটি প্রযোজ্য। এসি রেস্তোরাঁ বা হোটেলের রেস্তোরাঁতে ১২% বা ১৮% হতে পারে।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="জিএসটি ছাড়া দাম কীভাবে বের করব?" data-en="How to find the price before GST?">জিএসটি ছাড়া দাম কীভাবে বের করব?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="সূত্র: মূল দাম = মোট দাম ÷ (১ + জিএসটি হার/১০০)। যেমন, ১১৮ টাকায় ১৮% জিএসটি থাকলে মূল দাম = ১১৮ ÷ ১.১৮ = ১০০ টাকা।" data-en="Formula: Original price = Total price ÷ (1 + GST rate/100). E.g., ₹118 with 18% GST: ₹118 ÷ 1.18 = ₹100.">সূত্র: মূল দাম = মোট দাম ÷ (১ + জিএসটি হার/১০০)। যেমন, ১১৮ টাকায় ১৮% জিএসটি থাকলে মূল দাম = ১১৮ ÷ ১.১৮ = ১০০ টাকা।</span></p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer"><span data-bn="CGST ও SGST কী?" data-en="What are CGST and SGST?">CGST ও SGST কী?</span></summary>
        <p class="mt-3 text-gray-700"><span data-bn="CGST হলো কেন্দ্রীয় সরকারের অংশ এবং SGST হলো রাজ্য সরকারের অংশ। উভয়ই মিলিয়ে মোট জিএসটি হয়। যেমন ১৮% জিএসটিতে ৯% CGST এবং ৯% SGST।" data-en="CGST goes to the central government and SGST to the state government. Together they make the total GST. For example, 18% GST = 9% CGST + 9% SGST.">CGST হলো কেন্দ্রীয় সরকারের অংশ এবং SGST হলো রাজ্য সরকারের অংশ। উভয়ই মিলিয়ে মোট জিএসটি হয়। যেমন ১৮% জিএসটিতে ৯% CGST এবং ৯% SGST।</span></p>
      </details>
