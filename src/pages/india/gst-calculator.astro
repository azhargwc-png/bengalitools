<script is:inline>
var currentMode = 'add';
var currentRate = 18;

function setMode(mode) {
  currentMode = mode;
  var addBtn = document.getElementById('btn-add');
  var removeBtn = document.getElementById('btn-remove');
  var priceLabel = document.getElementById('price-label');
  var totalLabel = document.getElementById('total-label');
  var lang = typeof getLang === 'function' ? getLang() : 'bn';

  if (mode === 'add') {
    addBtn.className = 'flex-1 py-2 px-4 rounded-lg font-medium transition-colors bg-teal-700 text-white';
    removeBtn.className = 'flex-1 py-2 px-4 rounded-lg font-medium transition-colors bg-gray-200 text-gray-700 hover:bg-gray-300';
    priceLabel.setAttribute('data-bn', 'জিএসটির আগের দাম (₹)');
    priceLabel.setAttribute('data-en', 'Price before GST (₹)');
    totalLabel.setAttribute('data-bn', 'জিএসটি সহ মোট দাম');
    totalLabel.setAttribute('data-en', 'Total Price with GST');
  } else {
    removeBtn.className = 'flex-1 py-2 px-4 rounded-lg font-medium transition-colors bg-teal-700 text-white';
    addBtn.className = 'flex-1 py-2 px-4 rounded-lg font-medium transition-colors bg-gray-200 text-gray-700 hover:bg-gray-300';
    priceLabel.setAttribute('data-bn', 'জিএসটি সহ মোট দাম (₹)');
    priceLabel.setAttribute('data-en', 'Price including GST (₹)');
    totalLabel.setAttribute('data-bn', 'জিএসটি ছাড়া মূল দাম');
    totalLabel.setAttribute('data-en', 'Original Price without GST');
  }
  if (typeof applyLang === 'function') applyLang(lang);
  calculate();
}

function selectRate(rate) {
  currentRate = rate;
  document.querySelectorAll('.gst-rate-btn').forEach(function(btn) {
    if (parseFloat(btn.getAttribute('data-rate')) === rate) {
      btn.className = 'gst-rate-btn py-3 rounded-xl font-bold text-lg border-2 border-teal-600 bg-teal-50 text-teal-700 transition-colors';
    } else {
      btn.className = 'gst-rate-btn py-3 rounded-xl font-bold text-lg border-2 border-gray-300 bg-white hover:border-teal-500 transition-colors';
    }
  });
  document.getElementById('custom-rate').value = '';
  calculate();
}

function selectCustomRate() {
  var val = parseFloat(document.getElementById('custom-rate').value);
  if (!isNaN(val) && val >= 0) {
    currentRate = val;
    document.querySelectorAll('.gst-rate-btn').forEach(function(btn) {
      btn.className = 'gst-rate-btn py-3 rounded-xl font-bold text-lg border-2 border-gray-300 bg-white hover:border-teal-500 transition-colors';
    });
    calculate();
  }
}

function calculate() {
  var price = parseFloat(document.getElementById('price-input').value);
  var resultsEl = document.getElementById('gst-results');

  if (isNaN(price) || price < 0) {
    resultsEl.classList.add('hidden');
    return;
  }

  var original, gstAmt, total;

  if (currentMode === 'add') {
    original = price;
    gstAmt = price * (currentRate / 100);
    total = price + gstAmt;
  } else {
    total = price;
    original = price / (1 + currentRate / 100);
    gstAmt = price - original;
  }

  var fmt = function(n) { return '₹' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ','); };
  var halfRate = currentRate / 2;
  var cgstAmt = gstAmt / 2;
  var sgstAmt = gstAmt / 2;

  var lang = typeof getLang === 'function' ? getLang() : 'bn';
  var cgstLabelEl = document.getElementById('cgst-label');
  var sgstLabelEl = document.getElementById('sgst-label');
  cgstLabelEl.setAttribute('data-bn', 'সিজিএসটি (' + halfRate + '%)');
  cgstLabelEl.setAttribute('data-en', 'CGST (' + halfRate + '%)');
  sgstLabelEl.setAttribute('data-bn', 'এসজিএসটি (' + halfRate + '%)');
  sgstLabelEl.setAttribute('data-en', 'SGST (' + halfRate + '%)');
  if (typeof applyLang === 'function') applyLang(lang);

  if (currentMode === 'add') {
    document.getElementById('result-original').textContent = fmt(original);
    document.getElementById('result-gst').textContent = fmt(gstAmt) + ' (' + currentRate + '%)';
    document.getElementById('result-cgst').textContent = fmt(cgstAmt);
    document.getElementById('result-sgst').textContent = fmt(sgstAmt);
    document.getElementById('result-total').textContent = fmt(total);
  } else {
    document.getElementById('result-original').textContent = fmt(total);
    document.getElementById('result-gst').textContent = fmt(gstAmt) + ' (' + currentRate + '%)';
    document.getElementById('result-cgst').textContent = fmt(cgstAmt);
    document.getElementById('result-sgst').textContent = fmt(sgstAmt);
    document.getElementById('result-total').textContent = fmt(original);
  }

  resultsEl.classList.remove('hidden');
}

function resetCalculator() {
  document.getElementById('price-input').value = '';
  document.getElementById('custom-rate').value = '';
  document.getElementById('gst-results').classList.add('hidden');
  selectRate(18);
  setMode('add');
}

document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('price-input').addEventListener('input', calculate);
  selectRate(18);
});
</script>
