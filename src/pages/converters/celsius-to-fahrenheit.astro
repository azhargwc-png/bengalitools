<script>
  const celsiusInput = document.getElementById('celsius-input') as HTMLInputElement;
  const fahrenheitInput = document.getElementById('fahrenheit-input') as HTMLInputElement;
  const resultDisplay = document.getElementById('result-display') as HTMLElement;
  const resultMain = document.getElementById('result-main') as HTMLElement;
  const formulaDisplay = document.getElementById('formula-display') as HTMLElement;
  const tempContextDisplay = document.getElementById('temp-context-display') as HTMLElement;

  function getTempContext(celsius: number): string {
    if (celsius < 0) return '❄️ Freezing / বরফ জমার নিচে';
    if (celsius < 10) return '🥶 Very cold / অত্যন্ত ঠান্ডা';
    if (celsius < 20) return '🌤️ Cool / ঠান্ডা';
    if (celsius < 30) return '🌡️ Comfortable / আরামদায়ক';
    if (celsius < 37) return '☀️ Warm / গরম';
    if (celsius === 37) return '✅ Normal body temp / শরীরের স্বাভাবিক তাপমাত্রা';
    if (celsius < 38) return '🌡️ Slightly elevated / সামান্য বেশি';
    if (celsius < 40) return '🤒 Fever / জ্বর';
    if (celsius === 100) return '♨️ Water boiling point / পানির ফুটার তাপমাত্রা';
    if (celsius >= 40) return '🔥 High fever / উচ্চ জ্বর';
    return '';
  }

  celsiusInput?.addEventListener('input', () => {
    const celsius = parseFloat(celsiusInput.value);
    if (!isNaN(celsius)) {
      const fahrenheit = (celsius * 9 / 5) + 32;
      fahrenheitInput.value = fahrenheit.toFixed(2);
      resultMain.textContent = `${fahrenheit.toFixed(2)}°F`;
      formulaDisplay.textContent = `(${celsius} × 9/5) + 32 = ${fahrenheit.toFixed(2)}°F`;
      resultDisplay.classList.remove('hidden');
      const ctx = getTempContext(celsius);
      if (ctx) {
        tempContextDisplay.textContent = ctx;
        tempContextDisplay.classList.remove('hidden');
      } else {
        tempContextDisplay.classList.add('hidden');
      }
    } else {
      fahrenheitInput.value = '';
      resultDisplay.classList.add('hidden');
      tempContextDisplay.classList.add('hidden');
    }
  });

  fahrenheitInput?.addEventListener('input', () => {
    const fahrenheit = parseFloat(fahrenheitInput.value);
    if (!isNaN(fahrenheit)) {
      const celsius = (fahrenheit - 32) * 5 / 9;
      celsiusInput.value = celsius.toFixed(2);
      resultMain.textContent = `${celsius.toFixed(2)}°C`;
      formulaDisplay.textContent = `(${fahrenheit} − 32) × 5/9 = ${celsius.toFixed(2)}°C`;
      resultDisplay.classList.remove('hidden');
      const ctx = getTempContext(celsius);
      if (ctx) {
        tempContextDisplay.textContent = ctx;
        tempContextDisplay.classList.remove('hidden');
      } else {
        tempContextDisplay.classList.add('hidden');
      }
    } else {
      celsiusInput.value = '';
      resultDisplay.classList.add('hidden');
      tempContextDisplay.classList.add('hidden');
    }
  });

  (window as any).resetTool = function() {
    celsiusInput.value = '';
    fahrenheitInput.value = '';
    resultDisplay.classList.add('hidden');
    tempContextDisplay.classList.add('hidden');
  };
</script>
