---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "সেলসিয়াস থেকে ফারেনহাইট কনভার্টার",
      "url": "https://www.bengalitools.com/converters/celsius-to-fahrenheit/",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "শরীরের স্বাভাবিক তাপমাত্রা ফারেনহাইটে কত?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "শরীরের স্বাভাবিক তাপমাত্রা ৯৮.৬°F বা ৩৭°C। ৩৮°C (১০০.৪°F) বা তার বেশি হলে জ্বর বলে গণ্য করা হয়।"
          }
        },
        {
          "@type": "Question",
          "name": "৩৭ ডিগ্রি সেলসিয়াস ফারেনহাইটে কত?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "৩৭ ডিগ্রি সেলসিয়াস = ৯৮.৬ ডিগ্রি ফারেনহাইট। হিসাব: (৩৭ × ৯/৫) + ৩২ = ৯৮.৬°F।"
          }
        },
        {
          "@type": "Question",
          "name": "৯৮.৬°F সেলসিয়াসে কত?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "৯৮.৬°F সমান ৩৭°C। হিসাব: (৯৮.৬ - ৩২) × ৫/৯ = ৩৭°C। এটি শরীরের স্বাভাবিক তাপমাত্রা।"
          }
        },
        {
          "@type": "Question",
          "name": "সেলসিয়াস থেকে ফারেনহাইট রূপান্তরের সূত্র কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "সূত্র: °F = (°C × ৯/৫) + ৩২। বিপরীতে: °C = (°F - ৩২) × ৫/৯।"
          }
        },
        {
          "@type": "Question",
          "name": "সেলসিয়াস ও ফারেনহাইটের মধ্যে পার্থক্য কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "সেলসিয়াস স্কেলে পানির জমার বিন্দু ০° এবং ফুটার বিন্দু ১০০°। ফারেনহাইট স্কেলে এগুলো যথাক্রমে ৩২° এবং ২১২°।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="সেলসিয়াস থেকে ফারেনহাইট কনভার্টার | BanglaTools"
  description="সেলসিয়াস থেকে ফারেনহাইট বা ফারেনহাইট থেকে সেলসিয়াস রূপান্তর করুন। শরীরের তাপমাত্রা পরীক্ষা করুন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <!-- H1 -->
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="সেলসিয়াস থেকে ফারেনহাইট কনভার্টার" data-en="Celsius to Fahrenheit Converter">সেলসিয়াস থেকে ফারেনহাইট কনভার্টার</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="তাৎক্ষণিকভাবে সেলসিয়াস ও ফারেনহাইটের মধ্যে তাপমাত্রা রূপান্তর করুন" data-en="Instantly convert between Celsius and Fahrenheit temperatures">তাৎক্ষণিকভাবে সেলসিয়াস ও ফারেনহাইটের মধ্যে তাপমাত্রা রূপান্তর করুন</span>
  </p>

  <!-- AdSense Slot 1 -->
  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="celsius-input">
          <span data-bn="সেলসিয়াস (°C)" data-en="Celsius (°C)">সেলসিয়াস (°C)</span>
        </label>
        <input
          type="number"
          id="celsius-input"
          placeholder="যেমন: 37"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-xl focus:border-teal-500 focus:outline-none"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="fahrenheit-input">
          <span data-bn="ফারেনহাইট (°F)" data-en="Fahrenheit (°F)">ফারেনহাইট (°F)</span>
        </label>
        <input
          type="number"
          id="fahrenheit-input"
          placeholder="যেমন: 98.6"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-xl focus:border-teal-500 focus:outline-none"
        />
      </div>
    </div>
    <div id="result-display" class="mt-4 text-center hidden">
      <p class="text-4xl font-bold text-teal-700" id="result-main"></p>
      <p class="text-sm text-gray-500 mt-1" id="formula-display"></p>
    </div>
    <div id="temp-context-display" class="mt-2 text-sm text-amber-700 font-medium text-center bg-amber-50 rounded-lg py-2 px-4 hidden"></div>
    <button id="reset-btn" onclick="resetTool()" class="mt-3 w-full py-2 px-4 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-sm font-medium transition-colors"><span data-bn="পরিষ্কার করুন ✕" data-en="Clear ✕">পরিষ্কার করুন ✕</span></button>
  </div>

  <!-- Reference temperatures -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="গুরুত্বপূর্ণ তাপমাত্রা রেফারেন্স" data-en="Important Temperature References">গুরুত্বপূর্ণ তাপমাত্রা রেফারেন্স</span>
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <button
        onclick="document.getElementById('celsius-input').value='0'; document.getElementById('celsius-input').dispatchEvent(new Event('input'))"
        class="bg-blue-50 border border-blue-200 rounded-xl p-3 text-center hover:bg-blue-100 transition-colors cursor-pointer"
      >
        <p class="font-bold text-blue-800 text-lg">0°C</p>
        <p class="text-xs text-blue-600 mt-1"><span data-bn="পানি জমার বিন্দু" data-en="Freezing point">পানি জমার বিন্দু</span></p>
      </button>
      <button
        onclick="document.getElementById('celsius-input').value='37'; document.getElementById('celsius-input').dispatchEvent(new Event('input'))"
        class="bg-green-50 border border-green-200 rounded-xl p-3 text-center hover:bg-green-100 transition-colors cursor-pointer"
      >
        <p class="font-bold text-green-800 text-lg">37°C</p>
        <p class="text-xs text-green-600 mt-1"><span data-bn="শরীরের স্বাভাবিক তাপমাত্রা" data-en="Normal body temp">শরীরের স্বাভাবিক তাপমাত্রা</span></p>
      </button>
      <button
        onclick="document.getElementById('celsius-input').value='100'; document.getElementById('celsius-input').dispatchEvent(new Event('input'))"
        class="bg-red-50 border border-red-200 rounded-xl p-3 text-center hover:bg-red-100 transition-colors cursor-pointer"
      >
        <p class="font-bold text-red-800 text-lg">100°C</p>
        <p class="text-xs text-red-600 mt-1"><span data-bn="পানি ফুটার বিন্দু" data-en="Boiling point">পানি ফুটার বিন্দু</span></p>
      </button>
      <button
        onclick="document.getElementById('celsius-input').value='38.5'; document.getElementById('celsius-input').dispatchEvent(new Event('input'))"
        class="bg-orange-50 border border-orange-200 rounded-xl p-3 text-center hover:bg-orange-100 transition-colors cursor-pointer"
      >
        <p class="font-bold text-orange-800 text-lg">38.5°C</p>
        <p class="text-xs text-orange-600 mt-1"><span data-bn="জ্বর" data-en="Fever">জ্বর</span></p>
      </button>
    </div>
  </div>

  <!-- Quick Reference Table -->
  <section id="quick-ref" class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="সাধারণ তাপমাত্রা রেফারেন্স" data-en="Common Temperature Reference">সাধারণ তাপমাত্রা রেফারেন্স</span></h2>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead><tr class="bg-teal-700 text-white"><th class="p-3 text-left"><span data-bn="সেলসিয়াস (°C)" data-en="°C">সেলসিয়াস (°C)</span></th><th class="p-3 text-left"><span data-bn="ফারেনহাইট (°F)" data-en="°F">ফারেনহাইট (°F)</span></th><th class="p-3 text-left"><span data-bn="প্রসঙ্গ" data-en="Context">প্রসঙ্গ</span></th></tr></thead>
        <tbody>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">-10°C</td><td class="p-3 font-bold">14°F</td><td class="p-3"><span data-bn="ঠান্ডা ঘর" data-en="Cold room">ঠান্ডা ঘর</span></td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">0°C</td><td class="p-3 font-bold">32°F</td><td class="p-3"><span data-bn="পানি জমার বিন্দু" data-en="Water freezing point">পানি জমার বিন্দু</span></td></tr>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">20°C</td><td class="p-3 font-bold">68°F</td><td class="p-3"><span data-bn="আরামদায়ক ঘরের তাপমাত্রা" data-en="Comfortable room temperature">আরামদায়ক ঘরের তাপমাত্রা</span></td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">25°C</td><td class="p-3 font-bold">77°F</td><td class="p-3"><span data-bn="উষ্ণ আবহাওয়া" data-en="Warm weather">উষ্ণ আবহাওয়া</span></td></tr>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">37°C</td><td class="p-3 font-bold">98.6°F</td><td class="p-3"><span data-bn="শরীরের তাপমাত্রা" data-en="Normal body temperature">শরীরের তাপমাত্রা</span></td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">38.5°C</td><td class="p-3 font-bold">101.3°F</td><td class="p-3"><span data-bn="জ্বর" data-en="Fever">জ্বর</span></td></tr>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">40°C</td><td class="p-3 font-bold">104°F</td><td class="p-3"><span data-bn="উচ্চ জ্বর" data-en="High fever">উচ্চ জ্বর</span></td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">100°C</td><td class="p-3 font-bold">212°F</td><td class="p-3"><span data-bn="পানি ফুটার বিন্দু" data-en="Water boiling point">পানি ফুটার বিন্দু</span></td></tr>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">180°C</td><td class="p-3 font-bold">356°F</td><td class="p-3"><span data-bn="ওভেনের তাপমাত্রা (মাঝারি)" data-en="Oven temperature (moderate)">ওভেনের তাপমাত্রা (মাঝারি)</span></td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">200°C</td><td class="p-3 font-bold">392°F</td><td class="p-3"><span data-bn="ওভেনের তাপমাত্রা (গরম)" data-en="Oven temperature (hot)">ওভেনের তাপমাত্রা (গরম)</span></td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="সেলসিয়াস ঘরে তাপমাত্রা লিখুন" data-en="Enter temperature in the Celsius box">সেলসিয়াস ঘরে তাপমাত্রা লিখুন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="ফারেনহাইট তাৎক্ষণিকভাবে দেখাবে" data-en="Fahrenheit appears instantly">ফারেনহাইট তাৎক্ষণিকভাবে দেখাবে</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="উপরের বাটনগুলো ক্লিক করে সাধারণ তাপমাত্রা সরাসরি দেখুন" data-en="Click the quick-reference buttons above for common temperatures">উপরের বাটনগুলো ক্লিক করে সাধারণ তাপমাত্রা সরাসরি দেখুন</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        সেলসিয়াস থেকে ফারেনহাইট কনভার্টার আপনাকে দ্রুত তাপমাত্রা রূপান্তর করতে সাহায্য করবে। আমাদের দেশে তাপমাত্রা সেলসিয়াসে পরিমাপ করা হয়, কিন্তু আমেরিকা ও কিছু দেশে ফারেনহাইট ব্যবহার হয়। শরীরের স্বাভাবিক তাপমাত্রা ৩৭ ডিগ্রি সেলসিয়াস, যা ফারেনহাইটে ৯৮.৬ ডিগ্রি। জ্বর হলে তাপমাত্রা ৩৮ ডিগ্রি সেলসিয়াস বা তার বেশি হয়। পানি ০ ডিগ্রি সেলসিয়াসে জমে এবং ১০০ ডিগ্রিতে ফোটে। রান্নার রেসিপিতে তাপমাত্রা ফারেনহাইটে দেওয়া থাকলে এই টুলটি কাজে আসবে। আবহাওয়ার তাপমাত্রাও এই কনভার্টারে রূপান্তর করতে পারবেন। এটি বিনামূল্যে এবং যেকোনো ডিভাইসে কাজ করে।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ১:" data-en="Example 1:">উদাহরণ ১:</span>
          <span data-bn=" শরীরের স্বাভাবিক তাপমাত্রা ৩৭°C" data-en=" Normal body temperature 37°C"> শরীরের স্বাভাবিক তাপমাত্রা ৩৭°C</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ৩৭°C" data-en="Input: 37°C">ইনপুট: ৩৭°C</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ৯৮.৬°F" data-en="Result: 98.6°F">ফলাফল: ৯৮.৬°F</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ২:" data-en="Example 2:">উদাহরণ ২:</span>
          <span data-bn=" পানি ফুটার তাপমাত্রা ১০০°C" data-en=" Water boiling point 100°C"> পানি ফুটার তাপমাত্রা ১০০°C</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ১০০°C" data-en="Input: 100°C">ইনপুট: ১০০°C</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ২১২°F" data-en="Result: 212°F">ফলাফল: ২১২°F</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ৩:" data-en="Example 3:">উদাহরণ ৩:</span>
          <span data-bn=" পানি জমার তাপমাত্রা ০°C" data-en=" Water freezing point 0°C"> পানি জমার তাপমাত্রা ০°C</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ০°C" data-en="Input: 0°C">ইনপুট: ০°C</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ৩২°F" data-en="Result: 32°F">ফলাফল: ৩২°F</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
