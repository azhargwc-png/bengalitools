---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "জমি পরিমাপ কনভার্টার",
      "url": "https://www.bengalitools.com/converters/land-area/",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "১ বিঘা সমান কত কাঠা?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "পশ্চিমবঙ্গ ও বাংলাদেশের মানদণ্ড অনুযায়ী ১ বিঘা = ২০ কাঠা = ১৪,৪০০ বর্গফুট।"
          }
        },
        {
          "@type": "Question",
          "name": "১ কাঠা সমান কত বর্গফুট?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "১ কাঠা = ৭২০ বর্গফুট = ১৬ ছটাক।"
          }
        },
        {
          "@type": "Question",
          "name": "ডেসিমেল ও শতাংশ কি একই?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "হ্যাঁ, ডেসিমেল ও শতাংশ (ডিসমিল) একই একক। ১ ডেসিমেল = ৪৩৫.৬ বর্গফুট = ১/১০০ একর।"
          }
        },
        {
          "@type": "Question",
          "name": "১ একর সমান কত বিঘা?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "১ একর = ৩.০২৫ বিঘা = ৬০.৫ কাঠা = ১০০ ডেসিমেল = ৪৩,৫৬০ বর্গফুট।"
          }
        },
        {
          "@type": "Question",
          "name": "পশ্চিমবঙ্গ ও বাংলাদেশে বিঘার মাপ কি আলাদা?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "না, উভয় জায়গায় ১ বিঘা = ২০ কাঠা = ১৪,৪০০ বর্গফুট।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="জমির পরিমাণ কনভার্টার — বিঘা, কাঠা, ডেসিমেল, একর | BanglaTools"
  titleBn="জমির পরিমাণ কনভার্টার — বিঘা, কাঠা, ডেসিমেল, একর | BanglaTools"
  description="বিঘা, কাঠা, ছটাক, ডেসিমেল, একর, বর্গফুট, বর্গমিটার — যেকোনো জমির মাপ রূপান্তর করুন। পশ্চিমবঙ্গ ও বাংলাদেশের মানদণ্ড অনুযায়ী।"
  descriptionBn="বিঘা, কাঠা, ছটাক, ডেসিমেল, একর, বর্গফুট, বর্গমিটার — যেকোনো জমির মাপ রূপান্তর করুন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="জমির পরিমাণ কনভার্টার" data-en="Land Area Converter">জমির পরিমাণ কনভার্টার</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="বিঘা, কাঠা, ডেসিমেল, একর — যেকোনো এককে লিখুন, সব এককে রূপান্তর দেখুন" data-en="Type in any unit — Bigha, Katha, Decimal, Acre — and see all conversions instantly">বিঘা, কাঠা, ডেসিমেল, একর — যেকোনো এককে লিখুন, সব এককে রূপান্তর দেখুন</span>
  </p>

  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">

    <!-- Input row -->
    <div class="flex gap-3 mb-6">
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="land-input">
          <span data-bn="পরিমাণ" data-en="Amount">পরিমাণ</span>
        </label>
        <input
          type="number"
          id="land-input"
          placeholder="যেমন: 1"
          min="0"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-xl focus:border-teal-500 focus:outline-none min-h-[52px]"
        />
      </div>
      <div class="w-44">
        <label class="block text-sm font-medium text-gray-700 mb-1" for="land-unit">
          <span data-bn="একক" data-en="Unit">একক</span>
        </label>
        <select
          id="land-unit"
          class="w-full px-3 py-3 border-2 border-gray-300 rounded-xl text-base focus:border-teal-500 focus:outline-none min-h-[52px] bg-white"
        >
          <option value="bigha">বিঘা (Bigha)</option>
          <option value="katha">কাঠা (Katha)</option>
          <option value="chhatak">ছটাক (Chhatak)</option>
          <option value="decimal">ডেসিমেল (Decimal)</option>
          <option value="acre">একর (Acre)</option>
          <option value="sqft">বর্গফুট (Sqft)</option>
          <option value="sqm">বর্গমিটার (Sqm)</option>
          <option value="sqyard">বর্গ গজ (Sq Yard)</option>
          <option value="hectare">হেক্টর (Hectare)</option>
        </select>
      </div>
    </div>

    <!-- Results grid -->
    <div id="results-grid" class="hidden">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">
        <span data-bn="রূপান্তরের ফলাফল" data-en="Conversion Results">রূপান্তরের ফলাফল</span>
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div class="result-card bg-teal-600 text-white rounded-xl p-4" data-unit="bigha">
          <p class="text-xs font-medium opacity-80 mb-1">বিঘা / Bigha</p>
          <p class="result-val text-xl font-bold">—</p>
        </div>
        <div class="result-card bg-white border-2 border-gray-200 rounded-xl p-4" data-unit="katha">
          <p class="text-xs font-medium text-gray-500 mb-1">কাঠা / Katha</p>
          <p class="result-val text-xl font-bold text-gray-900">—</p>
        </div>
        <div class="result-card bg-white border-2 border-gray-200 rounded-xl p-4" data-unit="chhatak">
          <p class="text-xs font-medium text-gray-500 mb-1">ছটাক / Chhatak</p>
          <p class="result-val text-xl font-bold text-gray-900">—</p>
        </div>
        <div class="result-card bg-white border-2 border-gray-200 rounded-xl p-4" data-unit="decimal">
          <p class="text-xs font-medium text-gray-500 mb-1">ডেসিমেল / Decimal</p>
          <p class="result-val text-xl font-bold text-gray-900">—</p>
        </div>
        <div class="result-card bg-white border-2 border-gray-200 rounded-xl p-4" data-unit="acre">
          <p class="text-xs font-medium text-gray-500 mb-1">একর / Acre</p>
          <p class="result-val text-xl font-bold text-gray-900">—</p>
        </div>
        <div class="result-card bg-white border-2 border-gray-200 rounded-xl p-4" data-unit="sqft">
          <p class="text-xs font-medium text-gray-500 mb-1">বর্গফুট / Sqft</p>
          <p class="result-val text-xl font-bold text-gray-900">—</p>
        </div>
        <div class="result-card bg-white border-2 border-gray-200 rounded-xl p-4" data-unit="sqm">
          <p class="text-xs font-medium text-gray-500 mb-1">বর্গমিটার / Sqm</p>
          <p class="result-val text-xl font-bold text-gray-900">—</p>
        </div>
        <div class="result-card bg-white border-2 border-gray-200 rounded-xl p-4" data-unit="sqyard">
          <p class="text-xs font-medium text-gray-500 mb-1">বর্গ গজ / Sq Yard</p>
          <p class="result-val text-xl font-bold text-gray-900">—</p>
        </div>
        <div class="result-card bg-white border-2 border-gray-200 rounded-xl p-4" data-unit="hectare">
          <p class="text-xs font-medium text-gray-500 mb-1">হেক্টর / Hectare</p>
          <p class="result-val text-xl font-bold text-gray-900">—</p>
        </div>
      </div>
    </div>

    <button onclick="resetLand()" class="mt-4 w-full py-2 px-4 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-sm font-medium transition-colors">
      <span data-bn="পরিষ্কার করুন ✕" data-en="Clear ✕">পরিষ্কার করুন ✕</span>
    </button>
  </div>

  <!-- Reference table -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="দ্রুত রূপান্তর টেবিল (পশ্চিমবঙ্গ মান)" data-en="Quick Reference Table (West Bengal Standard)">দ্রুত রূপান্তর টেবিল (পশ্চিমবঙ্গ মান)</span>
    </h2>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="bg-teal-700 text-white">
            <th class="p-3 text-left rounded-tl-xl"><span data-bn="একক" data-en="Unit">একক</span></th>
            <th class="p-3 text-right">বিঘা</th>
            <th class="p-3 text-right">কাঠা</th>
            <th class="p-3 text-right">ডেসিমেল</th>
            <th class="p-3 text-right rounded-tr-xl">বর্গফুট</th>
          </tr>
        </thead>
        <tbody>
          <tr class="bg-white border-b border-gray-200">
            <td class="p-3 font-medium">১ বিঘা</td>
            <td class="p-3 text-right font-bold text-teal-700">১</td>
            <td class="p-3 text-right">২০</td>
            <td class="p-3 text-right">৩৩.০৬</td>
            <td class="p-3 text-right">১৪,৪০০</td>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <td class="p-3 font-medium">১ কাঠা</td>
            <td class="p-3 text-right">০.০৫</td>
            <td class="p-3 text-right font-bold text-teal-700">১</td>
            <td class="p-3 text-right">১.৬৫</td>
            <td class="p-3 text-right">৭২০</td>
          </tr>
          <tr class="bg-white border-b border-gray-200">
            <td class="p-3 font-medium">১ ছটাক</td>
            <td class="p-3 text-right">০.০০৩১</td>
            <td class="p-3 text-right">০.০৬২৫</td>
            <td class="p-3 text-right">০.১০৩</td>
            <td class="p-3 text-right">৪৫</td>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <td class="p-3 font-medium">১ ডেসিমেল</td>
            <td class="p-3 text-right">০.০৩০২</td>
            <td class="p-3 text-right">০.৬০৫</td>
            <td class="p-3 text-right font-bold text-teal-700">১</td>
            <td class="p-3 text-right">৪৩৫.৬</td>
          </tr>
          <tr class="bg-white border-b border-gray-200">
            <td class="p-3 font-medium">১ একর</td>
            <td class="p-3 text-right">৩.০২৫</td>
            <td class="p-3 text-right">৬০.৫</td>
            <td class="p-3 text-right">১০০</td>
            <td class="p-3 text-right">৪৩,৫৬০</td>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <td class="p-3 font-medium">১ হেক্টর</td>
            <td class="p-3 text-right">৭.৪৭৮</td>
            <td class="p-3 text-right">১৪৯.৫</td>
            <td class="p-3 text-right">২৪৭.১</td>
            <td class="p-3 text-right">১,০৭,৬৩৯</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="ড্রপডাউন থেকে আপনার এককটি বেছে নিন (যেমন: বিঘা)" data-en="Select your unit from the dropdown (e.g. Bigha)">ড্রপডাউন থেকে আপনার এককটি বেছে নিন (যেমন: বিঘা)</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="পরিমাণ লিখুন (যেমন: ২.৫)" data-en="Enter the amount (e.g. 2.5)">পরিমাণ লিখুন (যেমন: ২.৫)</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="সব এককে রূপান্তর তাৎক্ষণিকভাবে দেখুন" data-en="See all unit conversions instantly">সব এককে রূপান্তর তাৎক্ষণিকভাবে দেখুন</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        জমির পরিমাণ কনভার্টারটি পশ্চিমবঙ্গ ও বাংলাদেশে প্রচলিত সব জমি মাপার এককের মধ্যে রূপান্তর করে। বিঘা, কাঠা, ছটাক, ডেসিমেল, একর, বর্গফুট, বর্গমিটার, বর্গ গজ ও হেক্টর — যেকোনো এককে পরিমাণ দিলে বাকি সব এককে ফলাফল একসাথে দেখা যায়। পশ্চিমবঙ্গের মানদণ্ড অনুযায়ী ১ বিঘা = ২০ কাঠা = ১৪,৪০০ বর্গফুট। জমি কেনাবেচা, সরকারি দলিল যাচাই, কৃষি জমির হিসাব ও সম্পত্তির বিবাদ মেটাতে এই টুল বিশেষ কাজে আসে।
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="১ বিঘা সমান কত কাঠা?" data-en="How many Katha is 1 Bigha?">১ বিঘা সমান কত কাঠা?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="পশ্চিমবঙ্গ ও বাংলাদেশের মানদণ্ড অনুযায়ী ১ বিঘা = ২০ কাঠা = ১৪,৪০০ বর্গফুট।" data-en="By West Bengal and Bangladesh standard: 1 Bigha = 20 Katha = 14,400 sqft.">পশ্চিমবঙ্গ ও বাংলাদেশের মানদণ্ড অনুযায়ী ১ বিঘা = ২০ কাঠা = ১৪,৪০০ বর্গফুট।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="১ কাঠা সমান কত বর্গফুট?" data-en="How many sqft is 1 Katha?">১ কাঠা সমান কত বর্গফুট?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="১ কাঠা = ৭২০ বর্গফুট = ১৬ ছটাক। পশ্চিমবঙ্গ ও বাংলাদেশ উভয় জায়গায় এই মান প্রচলিত।" data-en="1 Katha = 720 sqft = 16 Chhatak. This is the standard used in both West Bengal and Bangladesh.">১ কাঠা = ৭২০ বর্গফুট = ১৬ ছটাক। পশ্চিমবঙ্গ ও বাংলাদেশ উভয় জায়গায় এই মান প্রচলিত।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="ডেসিমেল ও শতাংশ কি একই?" data-en="Are Decimal and Shotangso the same?">ডেসিমেল ও শতাংশ কি একই?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="হ্যাঁ, ডেসিমেল ও শতাংশ (ডিসমিল) একই একক। ১ ডেসিমেল = ৪৩৫.৬ বর্গফুট = ১/১০০ একর। সরকারি কাগজে সাধারণত শতাংশ বা ডিসমিল লেখা হয়।" data-en="Yes, Decimal and Shotangso (Dismil) are the same unit. 1 Decimal = 435.6 sqft = 1/100 Acre. Government documents usually use Shotangso or Dismil.">হ্যাঁ, ডেসিমেল ও শতাংশ (ডিসমিল) একই একক। ১ ডেসিমেল = ৪৩৫.৬ বর্গফুট = ১/১০০ একর। সরকারি কাগজে সাধারণত শতাংশ বা ডিসমিল লেখা হয়।</span>
        </p>
