<script>
  // Conversion factors — all relative to sqft
  const TO_SQFT: Record<string, number> = {
    bigha:   14400,
    katha:   720,
    chhatak: 45,
    decimal: 435.6,
    acre:    43560,
    sqft:    1,
    sqm:     10.76391,
    sqyard:  9,
    hectare: 107639.104,
  };

  const input   = document.getElementById('land-input') as HTMLInputElement;
  const unitSel = document.getElementById('land-unit') as HTMLSelectElement;
  const grid    = document.getElementById('results-grid')!;
  const cards   = document.querySelectorAll<HTMLElement>('.result-card');

  function fmt(n: number): string {
    if (n === 0) return '0';
    if (n >= 1000000) return n.toLocaleString('en-IN', { maximumFractionDigits: 2 });
    if (n >= 1)       return parseFloat(n.toFixed(4)).toString();
    return parseFloat(n.toPrecision(4)).toString();
  }

  function convert() {
    const val  = parseFloat(input.value);
    const unit = unitSel.value;
    if (isNaN(val) || val < 0) { grid.classList.add('hidden'); return; }

    const sqft = val * TO_SQFT[unit];

    cards.forEach(card => {
      const u = card.dataset.unit!;
      const result = sqft / TO_SQFT[u];
      card.querySelector('.result-val')!.textContent = fmt(result);

      // Highlight active unit card in teal
      if (u === unit) {
        card.className = 'result-card bg-teal-600 text-white rounded-xl p-4';
        card.querySelector('p:first-child')!.className = 'text-xs font-medium opacity-80 mb-1';
        card.querySelector('.result-val')!.className = 'result-val text-xl font-bold';
      } else {
        card.className = 'result-card bg-white border-2 border-gray-200 rounded-xl p-4';
        card.querySelector('p:first-child')!.className = 'text-xs font-medium text-gray-500 mb-1';
        card.querySelector('.result-val')!.className = 'result-val text-xl font-bold text-gray-900';
      }
    });

    grid.classList.remove('hidden');
  }

  input.addEventListener('input', convert);
  unitSel.addEventListener('change', convert);

  (window as any).resetLand = function () {
    input.value = '';
    grid.classList.add('hidden');
  };
</script>
