<script>
  const feetInput = document.getElementById('feet-input') as HTMLInputElement;
  const metersInput = document.getElementById('meters-input') as HTMLInputElement;
  const ftPart = document.getElementById('ft-part') as HTMLInputElement;
  const inPart = document.getElementById('in-part') as HTMLInputElement;
  const resultDisplay = document.getElementById('result-display') as HTMLElement;
  const resultMain = document.getElementById('result-main') as HTMLElement;
  const formulaDisplay = document.getElementById('formula-display') as HTMLElement;
  const ftInResult = document.getElementById('ft-in-result') as HTMLElement;

  feetInput?.addEventListener('input', () => {
    const feet = parseFloat(feetInput.value);
    if (!isNaN(feet) && feet >= 0) {
      const meters = feet * 0.3048;
      metersInput.value = meters.toFixed(4);
      resultMain.textContent = `${meters.toFixed(4)} m`;
      formulaDisplay.textContent = `${feet} ft × 0.3048 = ${meters.toFixed(4)} m`;
      resultDisplay.classList.remove('hidden');
    } else {
      metersInput.value = '';
      resultDisplay.classList.add('hidden');
    }
  });

  metersInput?.addEventListener('input', () => {
    const meters = parseFloat(metersInput.value);
    if (!isNaN(meters) && meters >= 0) {
      const feet = meters / 0.3048;
      feetInput.value = feet.toFixed(4);
      resultMain.textContent = `${feet.toFixed(4)} ft`;
      formulaDisplay.textContent = `${meters} m ÷ 0.3048 = ${feet.toFixed(4)} ft`;
      resultDisplay.classList.remove('hidden');
    } else {
      feetInput.value = '';
      resultDisplay.classList.add('hidden');
    }
  });

  function updateFtIn() {
    const ft = parseFloat(ftPart.value) || 0;
    const inches = parseFloat(inPart.value) || 0;
    if (ft > 0 || inches > 0) {
      const totalInches = (ft * 12) + inches;
      const meters = totalInches * 0.0254;
      ftInResult.textContent = `${ft}' ${inches}" = ${meters.toFixed(4)} meters`;
    } else {
      ftInResult.textContent = '';
    }
  }

  ftPart?.addEventListener('input', updateFtIn);
  inPart?.addEventListener('input', updateFtIn);

  (window as any).resetTool = function() {
    feetInput.value = '';
    metersInput.value = '';
    ftPart.value = '';
    inPart.value = '';
    resultDisplay.classList.add('hidden');
    ftInResult.textContent = '';
  };
</script>
