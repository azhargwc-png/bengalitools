<script>
  const cmInput = document.getElementById('cm-input') as HTMLInputElement;
  const inchesInput = document.getElementById('inches-input') as HTMLInputElement;
  const resultDisplay = document.getElementById('result-display') as HTMLElement;
  const resultMain = document.getElementById('result-main') as HTMLElement;
  const formulaDisplay = document.getElementById('formula-display') as HTMLElement;
  const feetInchesDisplay = document.getElementById('feet-inches-display') as HTMLElement;

  function cmToFeetInches(cm: number): string {
    const totalInches = cm / 2.54;
    const feet = Math.floor(totalInches / 12);
    const remainingInches = (totalInches % 12).toFixed(1);
    return `${feet}' ${remainingInches}"`;
  }

  cmInput?.addEventListener('input', () => {
    const cm = parseFloat(cmInput.value);
    if (!isNaN(cm) && cm >= 0) {
      const inches = cm / 2.54;
      inchesInput.value = inches.toFixed(4);
      resultMain.textContent = `${inches.toFixed(2)} inches`;
      formulaDisplay.textContent = `${cm} cm ÷ 2.54 = ${inches.toFixed(4)} inches`;
      resultDisplay.classList.remove('hidden');
      feetInchesDisplay.textContent = `= ${cmToFeetInches(cm)} (feet & inches)`;
      feetInchesDisplay.classList.remove('hidden');
    } else {
      inchesInput.value = '';
      resultDisplay.classList.add('hidden');
      feetInchesDisplay.classList.add('hidden');
    }
  });

  inchesInput?.addEventListener('input', () => {
    const inches = parseFloat(inchesInput.value);
    if (!isNaN(inches) && inches >= 0) {
      const cm = inches * 2.54;
      cmInput.value = cm.toFixed(4);
      resultMain.textContent = `${cm.toFixed(2)} cm`;
      formulaDisplay.textContent = `${inches} inches × 2.54 = ${cm.toFixed(4)} cm`;
      resultDisplay.classList.remove('hidden');
      const feet = Math.floor(inches / 12);
      const remainingInches = (inches % 12).toFixed(1);
      feetInchesDisplay.textContent = `= ${feet}' ${remainingInches}" (feet & inches)`;
      feetInchesDisplay.classList.remove('hidden');
    } else {
      cmInput.value = '';
      resultDisplay.classList.add('hidden');
      feetInchesDisplay.classList.add('hidden');
    }
  });

  (window as any).resetTool = function() {
    cmInput.value = '';
    inchesInput.value = '';
    resultDisplay.classList.add('hidden');
    feetInchesDisplay.classList.add('hidden');
  };
</script>
