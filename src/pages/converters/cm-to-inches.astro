---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "সেন্টিমিটার থেকে ইঞ্চি কনভার্টার",
      "url": "https://www.bengalitools.com/converters/cm-to-inches/",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "১ সেন্টিমিটার সমান কত ইঞ্চি?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "১ সেন্টিমিটার সমান ০.৩৯৩৭ ইঞ্চি। সহজে মনে রাখতে পারেন: প্রতি ১ সেন্টিমিটার প্রায় ০.৪ ইঞ্চির সমান।"
          }
        },
        {
          "@type": "Question",
          "name": "১ ইঞ্চি সমান কত সেন্টিমিটার?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "১ ইঞ্চি সমান ২.৫৪ সেন্টিমিটার। এটি একটি প্রমাণিত রূপান্তর হার।"
          }
        },
        {
          "@type": "Question",
          "name": "১৫৮ সেমি মানে ফুট-ইঞ্চিতে কত?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "১৫৮ সেন্টিমিটার মানে ৫ ফুট ২.২ ইঞ্চি।"
          }
        },
        {
          "@type": "Question",
          "name": "৫ ফুট মানে কত সেন্টিমিটার?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "৫ ফুট মানে ১৫২.৪ সেন্টিমিটার। হিসাব: ৫ × ৩০.৪৮ = ১৫২.৪ সেমি।"
          }
        },
        {
          "@type": "Question",
          "name": "টিভির স্ক্রিন সাইজ ইঞ্চিতে কেন মাপা হয়?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "টিভি শিল্পের শুরু যুক্তরাষ্ট্রে হয়েছিল যেখানে ইঞ্চি ব্যবহার হয়। সেই ঐতিহ্য এখনো বজায় আছে।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="cm to Inches Converter — সেন্টিমিটার থেকে ইঞ্চি | BanglaTools"
  description="Convert centimetres to inches or inches to cm. Height and screen size converter. সেন্টিমিটার থেকে ইঞ্চি রূপান্তর করুন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <!-- H1 -->
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="সেন্টিমিটার থেকে ইঞ্চি কনভার্টার" data-en="cm to inches Converter">সেন্টিমিটার থেকে ইঞ্চি কনভার্টার</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="তাৎক্ষণিকভাবে সেন্টিমিটার ও ইঞ্চির মধ্যে রূপান্তর করুন" data-en="Instantly convert between centimeters and inches">তাৎক্ষণিকভাবে সেন্টিমিটার ও ইঞ্চির মধ্যে রূপান্তর করুন</span>
  </p>

  <!-- AdSense Slot 1 -->
  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="cm-input">
          <span data-bn="সেন্টিমিটার (cm)" data-en="Centimeters (cm)">সেন্টিমিটার (cm)</span>
        </label>
        <input
          type="number"
          id="cm-input"
          placeholder="যেমন: 170"
          min="0"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-xl focus:border-teal-500 focus:outline-none"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="inches-input">
          <span data-bn="ইঞ্চি (inches)" data-en="Inches">ইঞ্চি (inches)</span>
        </label>
        <input
          type="number"
          id="inches-input"
          placeholder="যেমন: 66.93"
          min="0"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-xl focus:border-teal-500 focus:outline-none"
        />
      </div>
    </div>
    <div id="result-display" class="mt-4 text-center hidden">
      <p class="text-4xl font-bold text-teal-700" id="result-main"></p>
      <p class="text-sm text-gray-500 mt-1" id="formula-display"></p>
    </div>
    <div id="feet-inches-display" class="mt-2 text-sm text-amber-700 font-medium text-center bg-amber-50 rounded-lg py-2 px-4 hidden"></div>
    <button id="reset-btn" onclick="resetTool()" class="mt-3 w-full py-2 px-4 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-sm font-medium transition-colors"><span data-bn="পরিষ্কার করুন ✕" data-en="Clear ✕">পরিষ্কার করুন ✕</span></button>
  </div>

  <!-- Quick Reference Table -->
  <section id="quick-ref" class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><span data-bn="দ্রুত রূপান্তর টেবিল" data-en="Quick Reference Table">দ্রুত রূপান্তর টেবিল</span></h2>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead><tr class="bg-teal-700 text-white"><th class="p-3 text-left"><span data-bn="সেন্টিমিটার (cm)" data-en="cm">সেন্টিমিটার (cm)</span></th><th class="p-3 text-left"><span data-bn="ইঞ্চি (inches)" data-en="inches">ইঞ্চি (inches)</span></th><th class="p-3 text-left"><span data-bn="ফুট-ইঞ্চি" data-en="Feet-Inches">ফুট-ইঞ্চি</span></th></tr></thead>
        <tbody>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">150 cm</td><td class="p-3 font-bold">59.1 in</td><td class="p-3">4'11"</td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">155 cm</td><td class="p-3 font-bold">61.0 in</td><td class="p-3">5'1"</td></tr>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">158 cm</td><td class="p-3 font-bold">62.2 in</td><td class="p-3">5'2"</td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">160 cm</td><td class="p-3 font-bold">63.0 in</td><td class="p-3">5'3"</td></tr>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">163 cm</td><td class="p-3 font-bold">64.2 in</td><td class="p-3">5'4"</td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">165 cm</td><td class="p-3 font-bold">65.0 in</td><td class="p-3">5'5"</td></tr>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">170 cm</td><td class="p-3 font-bold">66.9 in</td><td class="p-3">5'7"</td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">175 cm</td><td class="p-3 font-bold">68.9 in</td><td class="p-3">5'9"</td></tr>
          <tr class="bg-white border-b border-gray-200"><td class="p-3">180 cm</td><td class="p-3 font-bold">70.9 in</td><td class="p-3">5'11"</td></tr>
          <tr class="bg-gray-50 border-b border-gray-200"><td class="p-3">183 cm</td><td class="p-3 font-bold">72.0 in</td><td class="p-3">6'0"</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="সেন্টিমিটার ঘরে আপনার পরিমাপ লিখুন" data-en="Enter your measurement in the cm box">সেন্টিমিটার ঘরে আপনার পরিমাপ লিখুন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="ইঞ্চি তাৎক্ষণিকভাবে দেখাবে এবং ফুট-ইঞ্চি ফরম্যাটও দেখাবে" data-en="Inches appear instantly along with feet and inches format">ইঞ্চি তাৎক্ষণিকভাবে দেখাবে এবং ফুট-ইঞ্চি ফরম্যাটও দেখাবে</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="ইঞ্চি থেকে সেন্টিমিটারও বের করতে পারবেন" data-en="You can also convert from inches to cm">ইঞ্চি থেকে সেন্টিমিটারও বের করতে পারবেন</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        সেন্টিমিটার থেকে ইঞ্চি কনভার্টার ব্যবহার করে আপনি খুব সহজে দৈর্ঘ্য রূপান্তর করতে পারবেন। মানুষের উচ্চতা পরিমাপ করতে অনেক দেশে ফুট ও ইঞ্চি ব্যবহার করা হয়, আবার অনেক দেশে সেন্টিমিটার ব্যবহার হয়। টেলিভিশন, মনিটর বা ফোনের স্ক্রিনের সাইজ সাধারণত ইঞ্চিতে দেওয়া হয়। আসবাবপত্র বা ঘরের পর্দার সাইজও ইঞ্চিতে পরিমাপ করা হয়। এই কনভার্টার ব্যবহার করে আপনি সহজেই জানতে পারবেন ১৭০ সেন্টিমিটার মানে কত ইঞ্চি বা কত ফুট। ১ সেন্টিমিটার সমান ০.৩৯৩৭ ইঞ্চি। একজন ব্যক্তির উচ্চতা ১৫৮ সেন্টিমিটার হলে তা ৬২.২ ইঞ্চি বা ৫ ফুট ২ ইঞ্চি। এই টুলটি ফুট-ইঞ্চি ফরম্যাটেও ফলাফল দেখায়।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ১:" data-en="Example 1:">উদাহরণ ১:</span>
          <span data-bn=" মহিলার গড় উচ্চতা ১৫৮ সেন্টিমিটার" data-en=" Average women's height 158 cm"> মহিলার গড় উচ্চতা ১৫৮ সেন্টিমিটার</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ১৫৮ সেমি" data-en="Input: 158 cm">ইনপুট: ১৫৮ সেমি</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ৬২.২ ইঞ্চি (৫ ফুট ২ ইঞ্চি)" data-en="Result: 62.2 inches (5 feet 2 inches)">ফলাফল: ৬২.২ ইঞ্চি (৫ ফুট ২ ইঞ্চি)</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ২:" data-en="Example 2:">উদাহরণ ২:</span>
          <span data-bn=" পুরুষের গড় উচ্চতা ১৭০ সেন্টিমিটার" data-en=" Average men's height 170 cm"> পুরুষের গড় উচ্চতা ১৭০ সেন্টিমিটার</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ১৭০ সেমি" data-en="Input: 170 cm">ইনপুট: ১৭০ সেমি</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ৬৬.৯৩ ইঞ্চি (৫ ফুট ৭ ইঞ্চি)" data-en="Result: 66.93 inches (5 feet 7 inches)">ফলাফল: ৬৬.৯৩ ইঞ্চি (৫ ফুট ৭ ইঞ্চি)</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ৩:" data-en="Example 3:">উদাহরণ ৩:</span>
          <span data-bn=" স্কেলের দৈর্ঘ্য ৩০ সেন্টিমিটার" data-en=" Standard ruler length 30 cm"> স্কেলের দৈর্ঘ্য ৩০ সেন্টিমিটার</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ৩০ সেমি" data-en="Input: 30 cm">ইনপুট: ৩০ সেমি</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ১১.৮১ ইঞ্চি" data-en="Result: 11.81 inches">ফলাফল: ১১.৮১ ইঞ্চি</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="১ সেন্টিমিটার সমান কত ইঞ্চি?" data-en="How many inches is 1 centimeter?">১ সেন্টিমিটার সমান কত ইঞ্চি?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="১ সেন্টিমিটার সমান ০.৩৯৩৭ ইঞ্চি। সহজে মনে রাখতে পারেন: প্রতি ১ সেন্টিমিটার প্রায় ০.৪ ইঞ্চির সমান।" data-en="1 centimeter equals 0.3937 inches. An easy approximation: 1 cm is roughly 0.4 inches.">১ সেন্টিমিটার সমান ০.৩৯৩৭ ইঞ্চি। সহজে মনে রাখতে পারেন: প্রতি ১ সেন্টিমিটার প্রায় ০.৪ ইঞ্চির সমান।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="১ ইঞ্চি সমান কত সেন্টিমিটার?" data-en="How many centimeters is 1 inch?">১ ইঞ্চি সমান কত সেন্টিমিটার?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="১ ইঞ্চি সমান ২.৫৪ সেন্টিমিটার। এটি একটি প্রমাণিত রূপান্তর হার যা আন্তর্জাতিকভাবে গ্রহণযোগ্য।" data-en="1 inch equals exactly 2.54 centimeters. This is the internationally standardized conversion.">১ ইঞ্চি সমান ২.৫৪ সেন্টিমিটার। এটি একটি প্রমাণিত রূপান্তর হার যা আন্তর্জাতিকভাবে গ্রহণযোগ্য।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="১৫৮ সেমি মানে ফুট-ইঞ্চিতে কত?" data-en="What is 158 cm in feet and inches?">১৫৮ সেমি মানে ফুট-ইঞ্চিতে কত?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="১৫৮ সেন্টিমিটার মানে ৫ ফুট ২.২ ইঞ্চি। এটি সাধারণত মহিলাদের গড় উচ্চতার কাছাকাছি।" data-en="158 cm equals 5 feet 2.2 inches (5'2\"). This is close to the average height of women in many countries.">১৫৮ সেন্টিমিটার মানে ৫ ফুট ২.২ ইঞ্চি। এটি সাধারণত মহিলাদের গড় উচ্চতার কাছাকাছি।</span>
        </p>
