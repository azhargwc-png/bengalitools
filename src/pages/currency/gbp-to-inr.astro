</ToolLayout>

<script>
  let currentRate = 0;
  let rateLoaded = false;

  async function fetchRate() {
    try {
      const res = await fetch('https://api.frankfurter.app/latest?from=GBP&to=INR');
      const data = await res.json();
      currentRate = data.rates.INR;
      rateLoaded = true;

      const rateEl = document.getElementById('live-rate');
      const updatedEl = document.getElementById('last-updated');
      const statusEl = document.getElementById('rate-status');

      if (rateEl) rateEl.textContent = `1 GBP = ₹${currentRate.toFixed(2)}`;
      if (updatedEl) updatedEl.textContent = new Date().toLocaleTimeString('bn-IN');
      if (statusEl) { statusEl.textContent = '🟢 লাইভ রেট'; statusEl.className = 'text-green-600 font-medium text-sm'; }

      calculate();

      // After getting currentRate, fetch yesterday for comparison
      try {
        const yesterday = new Date();
        yesterday.setDate(yesterday.getDate() - 1);
        // Skip weekends (go to Friday if Saturday/Sunday)
        if (yesterday.getDay() === 0) yesterday.setDate(yesterday.getDate() - 2);
        if (yesterday.getDay() === 6) yesterday.setDate(yesterday.getDate() - 1);
        const yDate = yesterday.toISOString().split('T')[0];
        const resY = await fetch(`https://api.frankfurter.app/${yDate}?from=GBP&to=INR`);
        const dataY = await resY.json();
        const prevRate = dataY.rates.INR;
        const diff = currentRate - prevRate;
        const diffPct = ((diff / prevRate) * 100).toFixed(2);
        const changeEl = document.getElementById('rate-change');
        if (changeEl) {
          if (diff > 0.001) {
            changeEl.innerHTML = `<span class="text-green-600 font-semibold">↑ +${Math.abs(diff).toFixed(4)} (+${diffPct}%)</span>`;
          } else if (diff < -0.001) {
            changeEl.innerHTML = `<span class="text-red-600 font-semibold">↓ ${diff.toFixed(4)} (${diffPct}%)</span>`;
          } else {
            changeEl.innerHTML = `<span class="text-gray-500">→ অপরিবর্তিত</span>`;
          }
        }
      } catch(e) { /* silently ignore if yesterday fetch fails */ }
    } catch(e) {
      const statusEl = document.getElementById('rate-status');
      if (statusEl) { statusEl.textContent = '⚠️ রেট লোড করতে সমস্যা'; statusEl.className = 'text-orange-600 font-medium text-sm'; }
    }
  }

  function calculate() {
    if (!rateLoaded) return;
    const fromInput = document.getElementById('from-input') as HTMLInputElement;
    const toInput = document.getElementById('to-input') as HTMLInputElement;
    if (!fromInput || !toInput) return;
    const val = parseFloat(fromInput.value);
    if (!isNaN(val) && val >= 0) {
      toInput.value = (val * currentRate).toFixed(2);
    }
  }

  function calculateReverse() {
    if (!rateLoaded) return;
    const fromInput = document.getElementById('from-input') as HTMLInputElement;
    const toInput = document.getElementById('to-input') as HTMLInputElement;
    if (!fromInput || !toInput) return;
    const val = parseFloat(toInput.value);
    if (!isNaN(val) && val >= 0) {
      fromInput.value = (val / currentRate).toFixed(2);
    }
  }

  function resetCurrency() {
    const fromInput = document.getElementById('from-input') as HTMLInputElement;
    const toInput = document.getElementById('to-input') as HTMLInputElement;
    if (fromInput) fromInput.value = '';
    if (toInput) toInput.value = '';
  }
  (window as any).resetCurrency = resetCurrency;

  document.getElementById('from-input')?.addEventListener('input', calculate);
  document.getElementById('to-input')?.addEventListener('input', calculateReverse);

  fetchRate();
</script>
