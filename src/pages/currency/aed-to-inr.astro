---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="দুবাই দিরহাম রেট আজকে — দিরহাম থেকে টাকা | BanglaTools"
  description="আজকের AED থেকে INR লাইভ রেট। দুবাই দিরহাম থেকে ভারতীয় রুপিতে রূপান্তর।"
>
  <!-- H1 -->
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="দুবাই দিরহাম রেট আজকে — দিরহাম থেকে টাকা" data-en="AED to INR — Dubai Dirham to Rupee Live Rate">দুবাই দিরহাম রেট আজকে — দিরহাম থেকে টাকা</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="আজকের লাইভ রেটে UAE দিরহাম থেকে ভারতীয় রুপিতে রূপান্তর করুন" data-en="Convert UAE Dirhams to Indian Rupees at today's live exchange rate">আজকের লাইভ রেটে UAE দিরহাম থেকে ভারতীয় রুপিতে রূপান্তর করুন</span>
  </p>

  <!-- AdSense Slot 1 -->
  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <!-- Rate display -->
    <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
      <span id="rate-status" class="text-gray-500 text-sm">লোড হচ্ছে...</span>
      <div>
        <p id="live-rate" class="text-2xl font-bold text-teal-700">লোড হচ্ছে...</p>
        <div id="rate-change" class="text-sm mt-1 min-h-[20px]"></div>
        <p class="text-sm text-gray-500">
          <span data-bn="সর্বশেষ আপডেট:" data-en="Last updated:">সর্বশেষ আপডেট:</span>
          <span id="last-updated">—</span>
        </p>
      </div>
    </div>
    <!-- Inputs -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="from-input">AED (د.إ)</label>
        <input
          type="number"
          id="from-input"
          placeholder="যেমন: 500"
          min="0"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="to-input">INR (₹)</label>
        <input
          type="number"
          id="to-input"
          placeholder="রুপি"
          min="0"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>
    </div>
    <div class="flex justify-end mt-3">
      <button onclick="resetCurrency()" class="py-2 px-4 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-sm font-medium transition-colors">
        <span data-bn="পরিষ্কার করুন ✕" data-en="Clear ✕">পরিষ্কার করুন ✕</span>
      </button>
    </div>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="AED ঘরে দিরহামের পরিমাণ লিখুন" data-en="Enter the dirham amount in the AED box">AED ঘরে দিরহামের পরিমাণ লিখুন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="লাইভ রেট অনুযায়ী রুপির পরিমাণ তাৎক্ষণিকভাবে দেখাবে" data-en="The rupee amount appears instantly based on the live rate">লাইভ রেট অনুযায়ী রুপির পরিমাণ তাৎক্ষণিকভাবে দেখাবে</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="রুপি থেকে দিরহামও বের করতে INR ঘরে টাইপ করুন" data-en="Type in the INR box to reverse-convert from rupees to dirhams">রুপি থেকে দিরহামও বের করতে INR ঘরে টাইপ করুন</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p data-lang-bn>
        এই টুলটি UAE দিরহাম (AED) থেকে ভারতীয় রুপি (INR)-তে তাৎক্ষণিক রূপান্তর করে। উপসাগরীয় অঞ্চলে — বিশেষত দুবাই, আবুধাবি, শারজাহ ও অন্য আমিরাতে — লক্ষ লক্ষ বাঙালি কর্মী কাজ করেন। তারা নিয়মিত বাড়িতে টাকা পাঠান। দিরহামের বর্তমান রুপি মূল্য জানা তাদের জন্য অত্যন্ত জরুরি। AED মুদ্রাটি মার্কিন ডলারের সাথে পেগড — তাই এর রেট তুলনামূলকভাবে স্থিতিশীল। সাধারণত ১ AED সমান প্রায় ₹২২-২৩ ভারতীয় রুপি। যারা দুবাই থেকে ভারতে পরিবারকে টাকা পাঠান, তারা এই টুল দিয়ে বুঝতে পারবেন কত দিরহাম পাঠালে কত রুপি পাওয়া যাবে। হাওয়ালা বা ব্যাংক ট্রান্সফারের আগে রেট যাচাই করতে এই টুলটি ব্যবহার করুন। এছাড়া যারা দুবাই ভ্রমণ করছেন বা সেখান থেকে কেনাকাটা করছেন তারাও দিরহামের রুপি মূল্য জানতে এই কনভার্টারটি ব্যবহার করতে পারেন। রেটটি প্রতিদিন আপডেট হয় এবং পেজ লোড হওয়ার সময় স্বয়ংক্রিয়ভাবে ফেচ করা হয়।
      </p>
      <p data-lang-en style="display:none">
        This tool converts UAE Dirhams (AED) to Indian Rupees (INR) using a live rate from the frankfurter.app API. Millions of Bengali-speaking workers are employed across the Gulf region — particularly in Dubai, Abu Dhabi, Sharjah, and other Emirates. They regularly send money back home to India and Bangladesh. Knowing the current AED to INR rate is essential for calculating how much their family will receive. The UAE Dirham is pegged to the US Dollar at a fixed rate of approximately 3.67 AED per USD, making it one of the most stable currencies for remittance planning. Typically, 1 AED equals around ₹22 to ₹23 Indian Rupees. This converter helps Gulf workers, travelers to Dubai, and online shoppers from UAE-based stores. The rate is fetched automatically on page load, and the tool supports reverse conversion — enter INR to see the equivalent AED. No account or login is required.
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ১:" data-en="Example 1:">উদাহরণ ১:</span>
          <span data-bn=" দুবাই থেকে ৫০০ দিরহাম পাঠানো" data-en=" Sending 500 AED from Dubai"> দুবাই থেকে ৫০০ দিরহাম পাঠানো</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ৫০০ AED" data-en="Input: 500 AED">ইনপুট: ৫০০ AED</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: প্রায় ₹১১,৩৫০ (বর্তমান রেট অনুযায়ী)" data-en="Result: approx ₹11,350 (at current rate)">ফলাফল: প্রায় ₹১১,৩৫০ (বর্তমান রেট অনুযায়ী)</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ২:" data-en="Example 2:">উদাহরণ ২:</span>
          <span data-bn=" মাসিক রেমিট্যান্স ১০০০ দিরহাম" data-en=" Monthly remittance of 1000 AED"> মাসিক রেমিট্যান্স ১০০০ দিরহাম</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ১০০০ AED" data-en="Input: 1000 AED">ইনপুট: ১০০০ AED</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: প্রায় ₹২২,৭০০ (বর্তমান রেট অনুযায়ী)" data-en="Result: approx ₹22,700 (at current rate)">ফলাফল: প্রায় ₹২২,৭০০ (বর্তমান রেট অনুযায়ী)</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ৩:" data-en="Example 3:">উদাহরণ ৩:</span>
          <span data-bn=" ৫০০০ দিরহামের বড় রেমিট্যান্স" data-en=" Large remittance of 5000 AED"> ৫০০০ দিরহামের বড় রেমিট্যান্স</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="ইনপুট: ৫০০০ AED" data-en="Input: 5000 AED">ইনপুট: ৫০০০ AED</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: প্রায় ₹১,১৩,৫০০ (বর্তমান রেট অনুযায়ী)" data-en="Result: approx ₹1,13,500 (at current rate)">ফলাফল: প্রায় ₹১,১৩,৫০০ (বর্তমান রেট অনুযায়ী)</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="আজকে ১ দিরহাম সমান কত রুপি?" data-en="How many rupees is 1 dirham today?">আজকে ১ দিরহাম সমান কত রুপি?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="সাধারণত ১ AED = প্রায় ₹২২-২৩। এই পেজে লাইভ রেট দেখানো হয়, তাই সঠিক মান উপরে দেখুন।" data-en="Typically 1 AED equals about ₹22-23. This page shows the live rate, so check the current value above.">সাধারণত ১ AED = প্রায় ₹২২-২৩। এই পেজে লাইভ রেট দেখানো হয়, তাই সঠিক মান উপরে দেখুন।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="দিরহাম কি ডলারের সাথে পেগড?" data-en="Is the dirham pegged to the US dollar?">দিরহাম কি ডলারের সাথে পেগড?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="হ্যাঁ। UAE দিরহাম মার্কিন ডলারের সাথে ৩.৬৭২৫ AED = ১ USD হারে পেগড। এই কারণে দিরহামের মূল্য অনেকটা স্থিতিশীল।" data-en="Yes. The UAE Dirham is pegged to the US Dollar at a fixed rate of 3.6725 AED = 1 USD. This makes the dirham a very stable currency.">হ্যাঁ। UAE দিরহাম মার্কিন ডলারের সাথে ৩.৬৭২৫ AED = ১ USD হারে পেগড। এই কারণে দিরহামের মূল্য অনেকটা স্থিতিশীল।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="দুবাই থেকে ভারতে টাকা পাঠানোর সেরা উপায় কী?" data-en="What is the best way to send money from Dubai to India?">দুবাই থেকে ভারতে টাকা পাঠানোর সেরা উপায় কী?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="ব্যাংক ট্রান্সফার, Western Union, Wise, বা স্থানীয় এক্সচেঞ্জ হাউসের মাধ্যমে পাঠানো যায়। পাঠানোর আগে বিভিন্ন সেবার রেট ও চার্জ তুলনা করুন।" data-en="You can send via bank transfer, Western Union, Wise, or local exchange houses. Compare rates and fees across services before sending.">ব্যাংক ট্রান্সফার, Western Union, Wise, বা স্থানীয় এক্সচেঞ্জ হাউসের মাধ্যমে পাঠানো যায়। পাঠানোর আগে বিভিন্ন সেবার রেট ও চার্জ তুলনা করুন।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="দিরহামের রেট কি প্রতিদিন বদলায়?" data-en="Does the AED rate change daily?">দিরহামের রেট কি প্রতিদিন বদলায়?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="দিরহাম ডলারের সাথে পেগড হওয়ায় AED-USD রেট স্থির থাকে, কিন্তু ডলার-রুপি রেট প্রতিদিন পরিবর্তন হওয়ায় AED-INR রেটও সামান্য পরিবর্তন হয়।" data-en="Since the dirham is pegged to USD, the AED-USD rate stays fixed, but because USD-INR fluctuates daily, the AED-INR rate changes slightly each day.">দিরহাম ডলারের সাথে পেগড হওয়ায় AED-USD রেট স্থির থাকে, কিন্তু ডলার-রুপি রেট প্রতিদিন পরিবর্তন হওয়ায় AED-INR রেটও সামান্য পরিবর্তন হয়।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="রুপি থেকে দিরহামেও কনভার্ট করা যাবে?" data-en="Can I convert INR to AED as well?">রুপি থেকে দিরহামেও কনভার্ট করা যাবে?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="হ্যাঁ। INR ঘরে রুপির পরিমাণ টাইপ করলে সমতুল্য দিরহাম স্বয়ংক্রিয়ভাবে দেখাবে।" data-en="Yes. Type the rupee amount in the INR box and the equivalent dirham amount will appear automatically.">হ্যাঁ। INR ঘরে রুপির পরিমাণ টাইপ করলে সমতুল্য দিরহাম স্বয়ংক্রিয়ভাবে দেখাবে।</span>
        </p>
      </details>
    </div>
  </section>

  <!-- AdSense Slot 2 -->
  <AdSlot slot="below-faq" />

  <!-- Related Tools -->
  <RelatedTools tools={[
    {
      url: "/currency/usd-to-inr",
      nameBn: "ডলার থেকে রুপি",
      nameEn: "USD to INR",
      descBn: "মার্কিন ডলার থেকে ভারতীয় রুপি",
      descEn: "US Dollar to Indian Rupee",
      icon: "🇺🇸"
    },
    {
      url: "/currency/gbp-to-inr",
      nameBn: "পাউন্ড থেকে রুপি",
      nameEn: "GBP to INR",
      descBn: "ব্রিটিশ পাউন্ড থেকে ভারতীয় রুপি",
      descEn: "British Pound to Indian Rupee",
      icon: "🇬🇧"
    },
    {
      url: "/currency/bdt-to-inr",
      nameBn: "বাংলাদেশি টাকা থেকে রুপি",
      nameEn: "BDT to INR",
      descBn: "বাংলাদেশি টাকা থেকে ভারতীয় রুপি",
      descEn: "Bangladesh Taka to Indian Rupee",
      icon: "🇧🇩"
    }
  ]} />
</ToolLayout>

<script>
  let currentRate = 0;
  let rateLoaded = false;

  async function fetchRate() {
    try {
      // AED is fixed-pegged to USD at 3.6725 AED = 1 USD
      // So we fetch USD→INR and derive AED→INR = usdToInr / 3.6725
      const AED_USD_PEG = 3.6725;
      const res = await fetch('https://api.frankfurter.app/latest?from=USD&to=INR');
      const data = await res.json();
      currentRate = data.rates.INR / AED_USD_PEG;
      rateLoaded = true;

      const rateEl = document.getElementById('live-rate');
      const updatedEl = document.getElementById('last-updated');
      const statusEl = document.getElementById('rate-status');

      if (rateEl) rateEl.textContent = `1 AED = ₹${currentRate.toFixed(2)}`;
      if (updatedEl) updatedEl.textContent = new Date().toLocaleTimeString('bn-IN');
      if (statusEl) { statusEl.textContent = '🟢 লাইভ রেট'; statusEl.className = 'text-green-600 font-medium text-sm'; }

      calculate();

      // After getting currentRate, fetch yesterday for comparison
      try {
        const yesterday = new Date();
        yesterday.setDate(yesterday.getDate() - 1);
        // Skip weekends (go to Friday if Saturday/Sunday)
        if (yesterday.getDay() === 0) yesterday.setDate(yesterday.getDate() - 2);
        if (yesterday.getDay() === 6) yesterday.setDate(yesterday.getDate() - 1);
        const yDate = yesterday.toISOString().split('T')[0];
        const resY = await fetch(`https://api.frankfurter.app/${yDate}?from=USD&to=INR`);
        const dataY = await resY.json();
        const prevRate = dataY.rates.INR / AED_USD_PEG;
        const diff = currentRate - prevRate;
        const diffPct = ((diff / prevRate) * 100).toFixed(2);
        const changeEl = document.getElementById('rate-change');
        if (changeEl) {
          if (diff > 0.001) {
            changeEl.innerHTML = `<span class="text-green-600 font-semibold">↑ +${Math.abs(diff).toFixed(4)} (+${diffPct}%)</span>`;
          } else if (diff < -0.001) {
            changeEl.innerHTML = `<span class="text-red-600 font-semibold">↓ ${diff.toFixed(4)} (${diffPct}%)</span>`;
          } else {
            changeEl.innerHTML = `<span class="text-gray-500">→ অপরিবর্তিত</span>`;
          }
        }
      } catch(e) { /* silently ignore if yesterday fetch fails */ }
    } catch(e) {
      const statusEl = document.getElementById('rate-status');
      if (statusEl) { statusEl.textContent = '⚠️ রেট লোড করতে সমস্যা'; statusEl.className = 'text-orange-600 font-medium text-sm'; }
    }
  }

  function calculate() {
    if (!rateLoaded) return;
    const fromInput = document.getElementById('from-input') as HTMLInputElement;
    const toInput = document.getElementById('to-input') as HTMLInputElement;
    if (!fromInput || !toInput) return;
    const val = parseFloat(fromInput.value);
    if (!isNaN(val) && val >= 0) {
      toInput.value = (val * currentRate).toFixed(2);
    }
  }

  function calculateReverse() {
    if (!rateLoaded) return;
    const fromInput = document.getElementById('from-input') as HTMLInputElement;
    const toInput = document.getElementById('to-input') as HTMLInputElement;
    if (!fromInput || !toInput) return;
    const val = parseFloat(toInput.value);
    if (!isNaN(val) && val >= 0) {
      fromInput.value = (val / currentRate).toFixed(2);
    }
  }

  function resetCurrency() {
    const fromInput = document.getElementById('from-input') as HTMLInputElement;
    const toInput = document.getElementById('to-input') as HTMLInputElement;
    if (fromInput) fromInput.value = '';
    if (toInput) toInput.value = '';
  }
  (window as any).resetCurrency = resetCurrency;

  document.getElementById('from-input')?.addEventListener('input', calculate);
  document.getElementById('to-input')?.addEventListener('input', calculateReverse);

  fetchRate();
</script>
