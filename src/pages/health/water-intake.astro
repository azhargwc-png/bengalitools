<script>
  const tipsBn = [
    'সকালে ঘুম থেকে উঠে এক গ্লাস জল পান করুন',
    'খাবার আগে এক গ্লাস জল পান করলে হজম ভালো হয়',
    'ব্যায়ামের আগে, মাঝে ও পরে পানি পান করুন',
    'ঘুমানোর আগে অল্প জল পান করুন — বেশি নয়',
    'প্রতিদিন নির্দিষ্ট সময়ে জল পানের অভ্যাস গড়ুন'
  ];

  const tipsEn = [
    'Drink a glass of water right after waking up',
    'A glass before meals aids digestion',
    'Drink water before, during and after exercise',
    'Have a small amount before bed — not too much',
    'Set regular water-drinking reminders throughout the day'
  ];

  function calculate() {
    const weight = parseFloat((document.getElementById('water-weight') as HTMLInputElement).value);
    const activity = (document.getElementById('water-activity') as HTMLSelectElement).value;
    const hotClimate = (document.getElementById('hot-climate') as HTMLInputElement).checked;

    if (isNaN(weight) || weight <= 0) {
      document.getElementById('water-result')!.classList.add('hidden');
      return;
    }

    let totalMl = weight * 35;

    if (activity === 'active') {
      totalMl += 500;
    } else if (activity === 'very_active') {
      totalMl += 1000;
    }

    if (hotClimate) {
      totalMl += 500;
    }

    const litres = totalMl / 1000;
    const glasses = Math.ceil(totalMl / 250);

    document.getElementById('water-result')!.classList.remove('hidden');
    document.getElementById('water-ml')!.textContent = Math.round(totalMl).toLocaleString();
    document.getElementById('water-litres')!.textContent = litres.toFixed(1);
    document.getElementById('water-glasses')!.textContent = String(glasses);

    // Tips
    const tipsList = document.getElementById('water-tips')!;
    tipsList.innerHTML = '';
    for (let i = 0; i < 3; i++) {
      const li = document.createElement('li');
      li.innerHTML = `<span data-bn="${tipsBn[i]}" data-en="${tipsEn[i]}">• ${tipsBn[i]}</span>`;
      tipsList.appendChild(li);
    }
  }

  document.getElementById('water-weight')?.addEventListener('input', calculate);
  document.getElementById('water-activity')?.addEventListener('change', calculate);
  document.getElementById('hot-climate')?.addEventListener('change', calculate);
</script>
