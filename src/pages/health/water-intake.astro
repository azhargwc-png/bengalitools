---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "দৈনিক জল পান ক্যালকুলেটর",
      "url": "https://www.bengalitools.com/health/water-intake/",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "প্রতিদিন কত গ্লাস জল পান করা উচিত?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "সাধারণত ৬০-৭০ কেজি ওজনের একজন প্রাপ্তবয়স্কের জন্য প্রতিদিন ৮-১০ গ্লাস (২-২.৫ লিটার) জল পান করা উচিত।"
          }
        },
        {
          "@type": "Question",
          "name": "৮ গ্লাসের নিয়ম কি সবার জন্য প্রযোজ্য?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "না, ৮ গ্লাসের নিয়মটি একটি সাধারণ নির্দেশিকা মাত্র। প্রকৃত চাহিদা ওজন, আবহাওয়া ও ব্যায়ামের উপর নির্ভর করে।"
          }
        },
        {
          "@type": "Question",
          "name": "পানিশূন্যতার লক্ষণ কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ঘন হলুদ প্রস্রাব, মাথাব্যথা, ক্লান্তি, মুখ শুকিয়ে যাওয়া ও মাথা ঘোরা পানিশূন্যতার লক্ষণ।"
          }
        },
        {
          "@type": "Question",
          "name": "গরমে বেশি জল পান করতে হয় কেন?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "গরমে ঘামের মাধ্যমে শরীর থেকে বেশি জল বেরিয়ে যায়। তাই গরমে জলের চাহিদা বাড়ে।"
          }
        },
        {
          "@type": "Question",
          "name": "চা বা কফি কি জলের বিকল্প হতে পারে?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "সাধারণ চা কিছুটা হিসেবে ধরা যায়, তবে বেশি ক্যাফেইনযুক্ত পানীয় প্রস্রাব বাড়িয়ে শরীর থেকে জল বের করতে পারে।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="দৈনিক জল পান ক্যালকুলেটর | BanglaTools"
  description="প্রতিদিন কতটুকু জল পান করা উচিত জানুন। ওজন অনুযায়ী জল পানের পরিমাণ হিসাব করুন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <!-- H1 -->
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="দৈনিক জল পান ক্যালকুলেটর" data-en="Daily Water Intake Calculator">দৈনিক জল পান ক্যালকুলেটর</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="আপনার ওজন ও জীবনধারা অনুযায়ী প্রতিদিন কতটুকু জল পান করা উচিত জানুন" data-en="Find out how much water you should drink daily based on your weight and lifestyle">আপনার ওজন ও জীবনধারা অনুযায়ী প্রতিদিন কতটুকু জল পান করা উচিত জানুন</span>
  </p>

  <!-- AdSense Slot 1 -->
  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <!-- Weight -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="water-weight">
          <span data-bn="ওজন (কিলোগ্রাম)" data-en="Weight (kg)">ওজন (কিলোগ্রাম)</span>
        </label>
        <input
          type="number"
          id="water-weight"
          placeholder="যেমন: 65"
          min="10"
          max="300"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>

      <!-- Activity level -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="water-activity">
          <span data-bn="শারীরিক কার্যকলাপ" data-en="Activity Level">শারীরিক কার্যকলাপ</span>
        </label>
        <select
          id="water-activity"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px] bg-white"
        >
          <option value="normal" data-bn="স্বাভাবিক (হাঁটাচলা, অফিস)" data-en="Normal (walking, office)">স্বাভাবিক (হাঁটাচলা, অফিস)</option>
          <option value="active" data-bn="সক্রিয় (ব্যায়াম, শারীরিক কাজ)" data-en="Active (exercise, physical work)">সক্রিয় (ব্যায়াম, শারীরিক কাজ)</option>
          <option value="very_active" data-bn="অত্যন্ত সক্রিয় (খেলাধুলা, কঠিন পরিশ্রম)" data-en="Very active (sports, heavy labour)">অত্যন্ত সক্রিয় (খেলাধুলা, কঠিন পরিশ্রম)</option>
        </select>
      </div>
    </div>

    <!-- Hot climate option -->
    <div class="flex items-center gap-3 mb-4">
      <input type="checkbox" id="hot-climate" class="w-5 h-5 accent-teal-600" />
      <label class="text-sm font-medium text-gray-700" for="hot-climate">
        <span data-bn="গরমের মৌসুম / গরম আবহাওয়া (+৫০০ মিলি যোগ হবে)" data-en="Hot season / hot climate (+500 ml will be added)">গরমের মৌসুম / গরম আবহাওয়া (+৫০০ মিলি যোগ হবে)</span>
      </label>
    </div>

    <!-- Result -->
    <div id="water-result" class="hidden">
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 text-center">
          <p class="text-xs text-blue-600 font-medium mb-1">
            <span data-bn="মোট (মিলিলিটার)" data-en="Total (ml)">মোট (মিলিলিটার)</span>
          </p>
          <p id="water-ml" class="text-3xl font-bold text-blue-700"></p>
          <p class="text-xs text-gray-400 mt-1">ml</p>
        </div>
        <div class="bg-teal-50 border border-teal-200 rounded-xl p-4 text-center">
          <p class="text-xs text-teal-600 font-medium mb-1">
            <span data-bn="লিটারে" data-en="In litres">লিটারে</span>
          </p>
          <p id="water-litres" class="text-3xl font-bold text-teal-700"></p>
          <p class="text-xs text-gray-400 mt-1">L</p>
        </div>
        <div class="bg-cyan-50 border border-cyan-200 rounded-xl p-4 text-center">
          <p class="text-xs text-cyan-600 font-medium mb-1">
            <span data-bn="গ্লাস (২৫০ মিলি)" data-en="Glasses (250 ml)">গ্লাস (২৫০ মিলি)</span>
          </p>
          <p id="water-glasses" class="text-3xl font-bold text-cyan-700"></p>
          <p class="text-xs text-gray-400 mt-1">
            <span data-bn="গ্লাস" data-en="glasses">গ্লাস</span>
          </p>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
        <p class="text-sm text-blue-800 font-medium mb-2">
          <span data-bn="💡 পরামর্শ" data-en="💡 Tips">💡 পরামর্শ</span>
        </p>
        <ul id="water-tips" class="space-y-1 text-sm text-blue-700">
        </ul>
      </div>
    </div>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="আপনার ওজন কেজিতে লিখুন" data-en="Enter your weight in kilograms">আপনার ওজন কেজিতে লিখুন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="আপনার শারীরিক কার্যকলাপের মাত্রা বেছে নিন" data-en="Select your physical activity level">আপনার শারীরিক কার্যকলাপের মাত্রা বেছে নিন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="গরমের মৌসুমে থাকলে গরমের চেকবক্সে টিক দিন" data-en="Check the hot climate box if it is summer or very warm">গরমের মৌসুমে থাকলে গরমের চেকবক্সে টিক দিন</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        এই টুলটি আপনার দৈনিক জল পানের সঠিক পরিমাণ হিসাব করে। মূল সূত্র হলো: বেস পরিমাণ = ওজন (কেজি) × ৩৫ মিলিলিটার। এরপর আপনার শারীরিক কার্যকলাপ অনুযায়ী: সক্রিয় হলে অতিরিক্ত ৫০০ মিলি এবং অত্যন্ত সক্রিয় হলে অতিরিক্ত ১০০০ মিলি যোগ হয়। গরমের মৌসুমে আরও ৫০০ মিলি যোগ করার পরামর্শ দেওয়া হয়। জল আমাদের শরীরের সবচেয়ে গুরুত্বপূর্ণ উপাদান। মানব শরীরের প্রায় ৬০-৭০% জল। পর্যাপ্ত জল পান না করলে ডিহাইড্রেশন হয়, যা মাথাব্যথা, ক্লান্তি, কিডনি সমস্যা ও ত্বকের শুষ্কতা ঘটাতে পারে। বাংলাদেশ ও পশ্চিমবঙ্গের গরম ও আর্দ্র জলবায়ুতে প্রচুর জল ঘামের মাধ্যমে বেরিয়ে যায়, তাই পর্যাপ্ত জল পান বিশেষভাবে জরুরি। ফলাফলটি মিলিলিটার, লিটার এবং ২৫০ মিলির গ্লাস হিসেবে দেখানো হয়।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ১:" data-en="Example 1:">উদাহরণ ১:</span>
          <span data-bn=" ৬০ কেজি, স্বাভাবিক কার্যকলাপ" data-en=" 60 kg, normal activity"> ৬০ কেজি, স্বাভাবিক কার্যকলাপ</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="বেস: ৬০ × ৩৫ = ২১০০ মিলি" data-en="Base: 60 × 35 = 2100 ml">বেস: ৬০ × ৩৫ = ২১০০ মিলি</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ২.১ লিটার = ৮ গ্লাস প্রতিদিন" data-en="Result: 2.1 litres = 8 glasses per day">ফলাফল: ২.১ লিটার = ৮ গ্লাস প্রতিদিন</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ২:" data-en="Example 2:">উদাহরণ ২:</span>
          <span data-bn=" ৭৫ কেজি, সক্রিয় ব্যক্তি" data-en=" 75 kg, active person"> ৭৫ কেজি, সক্রিয় ব্যক্তি</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="বেস: ৭৫ × ৩৫ = ২৬২৫ + ৫০০ = ৩১২৫ মিলি" data-en="Base: 75 × 35 = 2625 + 500 = 3125 ml">বেস: ৭৫ × ৩৫ = ২৬২৫ + ৫০০ = ৩১২৫ মিলি</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ৩.১ লিটার = ১৩ গ্লাস প্রতিদিন" data-en="Result: 3.1 litres = 13 glasses per day">ফলাফল: ৩.১ লিটার = ১৩ গ্লাস প্রতিদিন</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ৩:" data-en="Example 3:">উদাহরণ ৩:</span>
          <span data-bn=" ৮০ কেজি, গরমে অত্যন্ত সক্রিয়" data-en=" 80 kg, very active in hot weather"> ৮০ কেজি, গরমে অত্যন্ত সক্রিয়</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="বেস: ৮০ × ৩৫ = ২৮০০ + ১০০০ + ৫০০ = ৪৩০০ মিলি" data-en="Base: 80 × 35 = 2800 + 1000 + 500 = 4300 ml">বেস: ৮০ × ৩৫ = ২৮০০ + ১০০০ + ৫০০ = ৪৩০০ মিলি</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ৪.৩ লিটার = ১৭ গ্লাস প্রতিদিন" data-en="Result: 4.3 litres = 17 glasses per day">ফলাফল: ৪.৩ লিটার = ১৭ গ্লাস প্রতিদিন</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="প্রতিদিন কত গ্লাস জল পান করা উচিত?" data-en="How many glasses of water should I drink per day?">প্রতিদিন কত গ্লাস জল পান করা উচিত?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="সাধারণত ৬০-৭০ কেজি ওজনের একজন স্বাভাবিক সক্রিয় প্রাপ্তবয়স্কের জন্য প্রতিদিন ৮-১০ গ্লাস (২-২.৫ লিটার) জল পান যথেষ্ট। তবে ওজন ও কার্যকলাপ অনুযায়ী পরিমাণ বদলায়।" data-en="For a normally active adult weighing 60-70 kg, 8-10 glasses (2-2.5 litres) per day is generally sufficient. The amount varies by weight and activity.">সাধারণত ৬০-৭০ কেজি ওজনের একজন স্বাভাবিক সক্রিয় প্রাপ্তবয়স্কের জন্য প্রতিদিন ৮-১০ গ্লাস (২-২.৫ লিটার) জল পান যথেষ্ট। তবে ওজন ও কার্যকলাপ অনুযায়ী পরিমাণ বদলায়।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
