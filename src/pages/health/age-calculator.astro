<script>
  const dobInput = document.getElementById('dob-input') as HTMLInputElement;
  const calcDateInput = document.getElementById('calc-date-input') as HTMLInputElement;

  const weekdays = ['রবিবার', 'সোমবার', 'মঙ্গলবার', 'বুধবার', 'বৃহস্পতিবার', 'শুক্রবার', 'শনিবার'];
  const weekdaysEn = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const monthsBn = ['জানুয়ারি', 'ফেব্রুয়ারি', 'মার্চ', 'এপ্রিল', 'মে', 'জুন', 'জুলাই', 'আগস্ট', 'সেপ্টেম্বর', 'অক্টোবর', 'নভেম্বর', 'ডিসেম্বর'];
  const monthsEn = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

  // Set today's date as default for calculation date
  const today = new Date();
  calcDateInput.value = today.toISOString().split('T')[0];

  function calculate() {
    const dobVal = dobInput.value;
    if (!dobVal) { document.getElementById('age-result')!.classList.add('hidden'); return; }

    const calcVal = calcDateInput.value || today.toISOString().split('T')[0];
    const dob = new Date(dobVal);
    const calcDate = new Date(calcVal);

    if (dob >= calcDate) { document.getElementById('age-result')!.classList.add('hidden'); return; }

    // Calculate years, months, days
    let years = calcDate.getFullYear() - dob.getFullYear();
    let months = calcDate.getMonth() - dob.getMonth();
    let days = calcDate.getDate() - dob.getDate();

    if (days < 0) {
      months--;
      const prevMonth = new Date(calcDate.getFullYear(), calcDate.getMonth(), 0);
      days += prevMonth.getDate();
    }
    if (months < 0) {
      years--;
      months += 12;
    }

    // Total days lived
    const totalDays = Math.floor((calcDate.getTime() - dob.getTime()) / (1000 * 60 * 60 * 24));

    // Total hours lived
    const totalHours = Math.floor(totalDays * 24);

    // Day of week born
    const dayIdx = dob.getDay();
    const bornWeekday = `${weekdays[dayIdx]} / ${weekdaysEn[dayIdx]}`;

    // Next birthday
    let nextBday = new Date(calcDate.getFullYear(), dob.getMonth(), dob.getDate());
    if (nextBday <= calcDate) {
      nextBday = new Date(calcDate.getFullYear() + 1, dob.getMonth(), dob.getDate());
    }
    const daysToNextBday = Math.floor((nextBday.getTime() - calcDate.getTime()) / (1000 * 60 * 60 * 24));
    const nextBdayStr = `${nextBday.getDate()} ${monthsBn[nextBday.getMonth()]} ${nextBday.getFullYear()} / ${nextBday.getDate()} ${monthsEn[nextBday.getMonth()]} ${nextBday.getFullYear()}`;

    // Update DOM
    document.getElementById('age-result')!.classList.remove('hidden');
    document.getElementById('age-years')!.textContent = String(years);
    document.getElementById('age-months')!.textContent = String(months);
    document.getElementById('age-days')!.textContent = String(days);
    document.getElementById('age-hours')!.textContent = totalHours.toLocaleString();
    document.getElementById('born-weekday')!.textContent = bornWeekday;
    document.getElementById('total-days')!.textContent = totalDays.toLocaleString('bn-IN') + ' দিন / ' + totalDays.toLocaleString() + ' days';
    document.getElementById('next-birthday')!.textContent = nextBdayStr;
    document.getElementById('days-to-birthday')!.textContent = daysToNextBday === 0 ? 'আজই জন্মদিন! 🎂 / Today!' : `${daysToNextBday} দিন / ${daysToNextBday} days`;
  }

  function resetAge() {
    dobInput.value = '';
    calcDateInput.value = today.toISOString().split('T')[0];
    document.getElementById('age-result')!.classList.add('hidden');
  }

  (window as any).resetAge = resetAge;

  dobInput?.addEventListener('change', calculate);
  calcDateInput?.addEventListener('change', calculate);
</script>
