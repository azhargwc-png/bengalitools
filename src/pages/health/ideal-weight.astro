<script>
  let iwGender = 'male';

  function setIWGender(gender: string) {
    iwGender = gender;
    const btnMale = document.getElementById('iw-btn-male') as HTMLButtonElement;
    const btnFemale = document.getElementById('iw-btn-female') as HTMLButtonElement;
    if (gender === 'male') {
      btnMale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-teal-700 text-white min-h-[44px]';
      btnFemale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-gray-200 text-gray-700 min-h-[44px]';
    } else {
      btnMale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-gray-200 text-gray-700 min-h-[44px]';
      btnFemale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-teal-700 text-white min-h-[44px]';
    }
    calculate();
  }

  (window as any).setIWGender = setIWGender;

  function calculate() {
    const heightCm = parseFloat((document.getElementById('iw-height') as HTMLInputElement).value);
    if (isNaN(heightCm) || heightCm < 50) {
      document.getElementById('iw-result')!.classList.add('hidden');
      return;
    }

    const resultEl = document.getElementById('iw-result')!;
    const warningEl = document.getElementById('iw-warning')!;
    const formulaEl = document.getElementById('iw-formula')!;

    // Show warning for unusual heights
    if (heightCm < 100 || heightCm > 220) {
      warningEl.classList.remove('hidden');
      warningEl.textContent = 'উচ্চতাটি অস্বাভাবিক মনে হচ্ছে — অনুগ্রহ করে সঠিক মান দিন / The entered height seems unusual — please check your value.';
    } else {
      warningEl.classList.add('hidden');
    }

    const heightM = heightCm / 100;

    // BMI-based range
    const bmiLow = 18.5 * heightM * heightM;
    const bmiHigh = 24.9 * heightM * heightM;

    // Hamwi method
    const heightInches = heightCm / 2.54;
    let hamwi: number;
    if (iwGender === 'male') {
      hamwi = 48 + 2.7 * (heightInches - 60);
    } else {
      hamwi = 45.5 + 2.2 * (heightInches - 60);
    }
    const hamwiLow = hamwi * 0.9;
    const hamwiHigh = hamwi * 1.1;

    resultEl.classList.remove('hidden');

    document.getElementById('bmi-range')!.textContent =
      `${bmiLow.toFixed(1)} — ${bmiHigh.toFixed(1)} কেজি / kg`;

    document.getElementById('hamwi-result')!.textContent =
      `${hamwiLow.toFixed(1)} — ${hamwiHigh.toFixed(1)} কেজি / kg`;

    const methodLabel = iwGender === 'male' ? 'Male' : 'Female';
    formulaEl.textContent = `Hamwi (${methodLabel}): ${hamwi.toFixed(1)} kg ± 10% | BMI 18.5–24.9 at ${heightCm}cm`;
  }

  document.getElementById('iw-height')?.addEventListener('input', calculate);
</script>
