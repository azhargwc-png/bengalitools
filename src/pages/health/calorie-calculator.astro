---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "ক্যালরি ক্যালকুলেটর",
      "url": "https://www.bengalitools.com/health/calorie-calculator/",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "প্রতিদিন কত ক্যালরি খাওয়া উচিত?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "একজন গড় পুরুষের প্রতিদিন প্রায় ২০০০-২৫০০ ক্যালরি এবং মহিলার ১৬০০-২০০০ ক্যালরি দরকার।"
          }
        },
        {
          "@type": "Question",
          "name": "ওজন কমাতে কত ক্যালরি কমাতে হবে?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "প্রতিদিন ৫০০ ক্যালরি কমালে সপ্তাহে প্রায় ০.৫ কেজি ওজন কমে।"
          }
        },
        {
          "@type": "Question",
          "name": "TDEE মানে কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TDEE হলো Total Daily Energy Expenditure — আপনার দৈনিক মোট শক্তি খরচ।"
          }
        },
        {
          "@type": "Question",
          "name": "ক্যালরি ঘাটতি কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "যখন আপনি যত ক্যালরি খরচ করেন তার চেয়ে কম ক্যালরি খাচ্ছেন তখন ক্যালরি ঘাটতি তৈরি হয়।"
          }
        },
        {
          "@type": "Question",
          "name": "বাংলাদেশি খাবারে কত ক্যালরি থাকে?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "১ কাপ সাদা ভাত (১৮০গ্রাম) ≈ ২৪০ kcal, মাছের ঝোল (১ বাটি) ≈ ১৫০ kcal, ডাল (১ বাটি) ≈ ১১৫ kcal।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="দৈনিক ক্যালরি ক্যালকুলেটর | BanglaTools"
  description="দৈনিক ক্যালরির চাহিদা জানুন। বয়স, ওজন, উচ্চতা ও কাজের পরিমাণ অনুযায়ী ক্যালরি হিসাব করুন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <!-- H1 -->
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="দৈনিক ক্যালরি ক্যালকুলেটর" data-en="Daily Calorie Calculator">দৈনিক ক্যালরি ক্যালকুলেটর</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="বয়স, ওজন, উচ্চতা ও জীবনধারা অনুযায়ী দৈনিক ক্যালরির চাহিদা জানুন" data-en="Find your daily calorie needs based on age, weight, height and activity level">বয়স, ওজন, উচ্চতা ও জীবনধারা অনুযায়ী দৈনিক ক্যালরির চাহিদা জানুন</span>
  </p>

  <!-- AdSense Slot 1 -->
  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <!-- Gender -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          <span data-bn="লিঙ্গ" data-en="Gender">লিঙ্গ</span>
        </label>
        <div class="flex gap-2">
          <button
            id="btn-male"
            class="flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-teal-700 text-white min-h-[44px]"
            onclick="setGender('male')"
          >
            <span data-bn="পুরুষ" data-en="Male">পুরুষ</span>
          </button>
          <button
            id="btn-female"
            class="flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-gray-200 text-gray-700 min-h-[44px]"
            onclick="setGender('female')"
          >
            <span data-bn="মহিলা" data-en="Female">মহিলা</span>
          </button>
        </div>
      </div>

      <!-- Age -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="cal-age">
          <span data-bn="বয়স (বছর)" data-en="Age (years)">বয়স (বছর)</span>
        </label>
        <input
          type="number"
          id="cal-age"
          placeholder="যেমন: 30"
          min="10"
          max="100"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>

      <!-- Weight -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="cal-weight">
          <span data-bn="ওজন (কেজি)" data-en="Weight (kg)">ওজন (কেজি)</span>
        </label>
        <input
          type="number"
          id="cal-weight"
          placeholder="যেমন: 65"
          min="10"
          max="300"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>

      <!-- Height -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="cal-height">
          <span data-bn="উচ্চতা (সেমি)" data-en="Height (cm)">উচ্চতা (সেমি)</span>
        </label>
        <input
          type="number"
          id="cal-height"
          placeholder="যেমন: 165"
          min="50"
          max="250"
          step="any"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
      </div>
    </div>

    <!-- Activity level -->
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1" for="cal-activity">
        <span data-bn="শারীরিক কার্যকলাপের মাত্রা" data-en="Activity Level">শারীরিক কার্যকলাপের মাত্রা</span>
      </label>
      <select
        id="cal-activity"
        class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px] bg-white"
      >
        <option value="1.2" data-bn="বসে থাকা কাজ (অফিস, পড়াশোনা)" data-en="Sedentary (office/desk work)">বসে থাকা কাজ (অফিস, পড়াশোনা)</option>
        <option value="1.375" data-bn="হালকা ব্যায়াম (সপ্তাহে ১-৩ দিন)" data-en="Light exercise (1-3 days/week)">হালকা ব্যায়াম (সপ্তাহে ১-৩ দিন)</option>
        <option value="1.55" data-bn="মাঝারি ব্যায়াম (সপ্তাহে ৩-৫ দিন)" data-en="Moderate exercise (3-5 days/week)">মাঝারি ব্যায়াম (সপ্তাহে ৩-৫ দিন)</option>
        <option value="1.725" data-bn="কঠিন ব্যায়াম (সপ্তাহে ৬-৭ দিন)" data-en="Hard exercise (6-7 days/week)">কঠিন ব্যায়াম (সপ্তাহে ৬-৭ দিন)</option>
        <option value="1.9" data-bn="অত্যন্ত কঠিন ব্যায়াম (অ্যাথলিট)" data-en="Very hard (athlete level)">অত্যন্ত কঠিন ব্যায়াম (অ্যাথলিট)</option>
      </select>
    </div>

    <!-- Reset button -->
    <div class="flex justify-end mt-3">
      <button onclick="resetCalorie()" class="py-2 px-4 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-sm font-medium transition-colors"><span data-bn="পরিষ্কার করুন ✕" data-en="Clear ✕">পরিষ্কার করুন ✕</span></button>
    </div>

    <!-- Result -->
    <div id="calorie-result" class="hidden mt-4">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 text-center">
          <p class="text-xs font-medium text-blue-600 mb-1">
            <span data-bn="ওজন কমাতে" data-en="Weight Loss">ওজন কমাতে</span>
          </p>
          <p id="calories-loss" class="text-3xl font-bold text-blue-700"></p>
          <p class="text-xs text-gray-500 mt-1">kcal/day</p>
          <p class="text-xs text-gray-400 mt-1">(-500 kcal)</p>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-center">
          <p class="text-xs font-medium text-green-600 mb-1">
            <span data-bn="ওজন ধরে রাখতে" data-en="Maintenance">ওজন ধরে রাখতে</span>
          </p>
          <p id="calories-maintain" class="text-3xl font-bold text-green-700"></p>
          <p class="text-xs text-gray-500 mt-1">kcal/day</p>
          <p class="text-xs text-gray-400 mt-1">(TDEE)</p>
        </div>
        <div class="bg-orange-50 border border-orange-200 rounded-xl p-4 text-center">
          <p class="text-xs font-medium text-orange-600 mb-1">
            <span data-bn="ওজন বাড়াতে" data-en="Weight Gain">ওজন বাড়াতে</span>
          </p>
          <p id="calories-gain" class="text-3xl font-bold text-orange-700"></p>
          <p class="text-xs text-gray-500 mt-1">kcal/day</p>
          <p class="text-xs text-gray-400 mt-1">(+500 kcal)</p>
        </div>
      </div>
      <p id="calorie-bmr-info" class="text-xs text-gray-400 text-center mt-3"></p>
    </div>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="আপনার লিঙ্গ, বয়স, ওজন ও উচ্চতা দিন" data-en="Enter your gender, age, weight and height">আপনার লিঙ্গ, বয়স, ওজন ও উচ্চতা দিন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="শারীরিক কার্যকলাপের মাত্রা তালিকা থেকে বেছে নিন" data-en="Select your activity level from the dropdown">শারীরিক কার্যকলাপের মাত্রা তালিকা থেকে বেছে নিন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="ওজন কমানো, রাখা ও বাড়ানোর জন্য আলাদা ক্যালরি দেখাবে" data-en="See separate calorie targets for weight loss, maintenance and gain">ওজন কমানো, রাখা ও বাড়ানোর জন্য আলাদা ক্যালরি দেখাবে</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        এই ক্যালরি ক্যালকুলেটরটি Mifflin-St Jeor সূত্র ব্যবহার করে আপনার বেসাল মেটাবলিক রেট (BMR) এবং মোট দৈনিক শক্তি খরচ (TDEE) হিসাব করে। BMR হলো সেই পরিমাণ ক্যালরি যা বিশ্রামে থাকলেও আপনার শরীর ব্যবহার করে — শ্বাস নেওয়া, হৃদয় স্পন্দন, শরীরের তাপমাত্রা বজায় রাখার জন্য। TDEE হলো আপনার শারীরিক কার্যকলাপ যোগ করে মোট ক্যালরির চাহিদা। পুরুষের সূত্র: BMR = (১০ × ওজন) + (৬.২৫ × উচ্চতা) - (৫ × বয়স) + ৫। মহিলার সূত্র: BMR = (১০ × ওজন) + (৬.২৫ × উচ্চতা) - (৫ × বয়স) - ১৬১। এই টুলটি তিনটি লক্ষ্যমাত্রা দেখায়: ওজন কমানোর জন্য TDEE থেকে ৫০০ ক্যালরি কম, ওজন ধরে রাখার জন্য TDEE সমান, এবং ওজন বাড়ানোর জন্য TDEE থেকে ৫০০ ক্যালরি বেশি। সঠিক ক্যালরি হিসাব স্বাস্থ্যকর জীবনযাপনের একটি গুরুত্বপূর্ণ অংশ।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ১:" data-en="Example 1:">উদাহরণ ১:</span>
          <span data-bn=" পুরুষ, ৩০ বছর, ৭০ কেজি, ১৭০ সেমি, বসে থাকা কাজ" data-en=" Male, 30 years, 70 kg, 170 cm, sedentary"> পুরুষ, ৩০ বছর, ৭০ কেজি, ১৭০ সেমি, বসে থাকা কাজ</span>
        </p>
        <p class="text-gray-700 mt-1 text-sm">BMR = (10×70) + (6.25×170) - (5×30) + 5 = 1,667 kcal</p>
        <p class="text-gray-700 font-medium">
          <span data-bn="TDEE: ২,০০০ kcal/day | ওজন কমাতে: ১,৫০০ | বাড়াতে: ২,৫০০" data-en="TDEE: 2,000 kcal/day | Loss: 1,500 | Gain: 2,500">TDEE: ২,০০০ kcal/day | ওজন কমাতে: ১,৫০০ | বাড়াতে: ২,৫০০</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ২:" data-en="Example 2:">উদাহরণ ২:</span>
          <span data-bn=" মহিলা, ২৫ বছর, ৫৫ কেজি, ১৫৮ সেমি, হালকা ব্যায়াম" data-en=" Female, 25 years, 55 kg, 158 cm, light exercise"> মহিলা, ২৫ বছর, ৫৫ কেজি, ১৫৮ সেমি, হালকা ব্যায়াম</span>
        </p>
        <p class="text-gray-700 mt-1 text-sm">BMR = (10×55) + (6.25×158) - (5×25) - 161 = 1,326 kcal</p>
        <p class="text-gray-700 font-medium">
          <span data-bn="TDEE: ১,৮২৩ kcal/day | ওজন কমাতে: ১,৩২৩ | বাড়াতে: ২,৩২৩" data-en="TDEE: 1,823 kcal/day | Loss: 1,323 | Gain: 2,323">TDEE: ১,৮২৩ kcal/day | ওজন কমাতে: ১,৩২৩ | বাড়াতে: ২,৩২৩</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ৩:" data-en="Example 3:">উদাহরণ ৩:</span>
          <span data-bn=" পুরুষ, ২০ বছর, ৬০ কেজি, ১৭৫ সেমি, মাঝারি ব্যায়াম" data-en=" Male, 20 years, 60 kg, 175 cm, moderate exercise"> পুরুষ, ২০ বছর, ৬০ কেজি, ১৭৫ সেমি, মাঝারি ব্যায়াম</span>
        </p>
        <p class="text-gray-700 mt-1 text-sm">BMR = (10×60) + (6.25×175) - (5×20) + 5 = 1,698 kcal</p>
        <p class="text-gray-700 font-medium">
          <span data-bn="TDEE: ২,৬৩১ kcal/day | ওজন কমাতে: ২,১৩১ | বাড়াতে: ৩,১৩১" data-en="TDEE: 2,631 kcal/day | Loss: 2,131 | Gain: 3,131">TDEE: ২,৬৩১ kcal/day | ওজন কমাতে: ২,১৩১ | বাড়াতে: ৩,১৩১</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
