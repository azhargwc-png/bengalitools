<script>
  let selectedGender = 'male';

  function setGender(gender: string) {
    selectedGender = gender;
    const btnMale = document.getElementById('btn-male') as HTMLButtonElement;
    const btnFemale = document.getElementById('btn-female') as HTMLButtonElement;
    if (gender === 'male') {
      btnMale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-teal-700 text-white min-h-[44px]';
      btnFemale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-gray-200 text-gray-700 min-h-[44px]';
    } else {
      btnMale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-gray-200 text-gray-700 min-h-[44px]';
      btnFemale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-teal-700 text-white min-h-[44px]';
    }
    calculate();
  }

  (window as any).setGender = setGender;

  function calculate() {
    const age = parseFloat((document.getElementById('cal-age') as HTMLInputElement).value);
    const weight = parseFloat((document.getElementById('cal-weight') as HTMLInputElement).value);
    const height = parseFloat((document.getElementById('cal-height') as HTMLInputElement).value);
    const activity = parseFloat((document.getElementById('cal-activity') as HTMLSelectElement).value);

    if (isNaN(age) || isNaN(weight) || isNaN(height)) {
      document.getElementById('calorie-result')!.classList.add('hidden');
      return;
    }

    let bmr: number;
    if (selectedGender === 'male') {
      bmr = (10 * weight) + (6.25 * height) - (5 * age) + 5;
    } else {
      bmr = (10 * weight) + (6.25 * height) - (5 * age) - 161;
    }

    const tdee = Math.round(bmr * activity);
    const loss = tdee - 500;
    const gain = tdee + 500;

    document.getElementById('calorie-result')!.classList.remove('hidden');
    document.getElementById('calories-maintain')!.textContent = tdee.toLocaleString();
    document.getElementById('calories-loss')!.textContent = Math.max(1200, loss).toLocaleString();
    document.getElementById('calories-gain')!.textContent = gain.toLocaleString();
    document.getElementById('calorie-bmr-info')!.textContent = `BMR = ${Math.round(bmr).toLocaleString()} kcal/day × ${activity} = TDEE ${tdee.toLocaleString()} kcal/day`;
  }

  function resetCalorie() {
    (document.getElementById('cal-age') as HTMLInputElement).value = '';
    (document.getElementById('cal-weight') as HTMLInputElement).value = '';
    (document.getElementById('cal-height') as HTMLInputElement).value = '';
    (document.getElementById('cal-activity') as HTMLSelectElement).selectedIndex = 0;
    selectedGender = 'male';
    const btnMale = document.getElementById('btn-male') as HTMLButtonElement;
    const btnFemale = document.getElementById('btn-female') as HTMLButtonElement;
    btnMale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-teal-700 text-white min-h-[44px]';
    btnFemale.className = 'flex-1 py-2 px-3 rounded-lg font-semibold text-sm transition-all bg-gray-200 text-gray-700 min-h-[44px]';
    document.getElementById('calorie-result')!.classList.add('hidden');
  }

  (window as any).resetCalorie = resetCalorie;

  document.getElementById('cal-age')?.addEventListener('input', calculate);
  document.getElementById('cal-weight')?.addEventListener('input', calculate);
  document.getElementById('cal-height')?.addEventListener('input', calculate);
  document.getElementById('cal-activity')?.addEventListener('change', calculate);
</script>
