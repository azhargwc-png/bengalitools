<script>
  let currentUnit = 'metric';

  function setUnit(unit: string) {
    currentUnit = unit;
    const metricInputs = document.getElementById('metric-inputs') as HTMLElement;
    const imperialInputs = document.getElementById('imperial-inputs') as HTMLElement;
    const btnMetric = document.getElementById('btn-metric') as HTMLButtonElement;
    const btnImperial = document.getElementById('btn-imperial') as HTMLButtonElement;

    if (unit === 'metric') {
      metricInputs.style.display = '';
      imperialInputs.style.display = 'none';
      btnMetric.className = 'flex-1 py-2 px-4 rounded-lg font-semibold text-sm transition-all bg-teal-700 text-white';
      btnImperial.className = 'flex-1 py-2 px-4 rounded-lg font-semibold text-sm transition-all bg-gray-200 text-gray-700';
    } else {
      metricInputs.style.display = 'none';
      imperialInputs.style.display = '';
      btnMetric.className = 'flex-1 py-2 px-4 rounded-lg font-semibold text-sm transition-all bg-gray-200 text-gray-700';
      btnImperial.className = 'flex-1 py-2 px-4 rounded-lg font-semibold text-sm transition-all bg-teal-700 text-white';
    }
    calculate();
  }

  (window as any).setUnit = setUnit;

  function calculate() {
    let heightM = 0;
    let weightKg = 0;

    if (currentUnit === 'metric') {
      const hcm = parseFloat((document.getElementById('height-cm') as HTMLInputElement).value);
      const wkg = parseFloat((document.getElementById('weight-kg') as HTMLInputElement).value);
      if (isNaN(hcm) || isNaN(wkg) || hcm <= 0 || wkg <= 0) { hideResult(); return; }
      heightM = hcm / 100;
      weightKg = wkg;
    } else {
      const ft = parseFloat((document.getElementById('height-ft') as HTMLInputElement).value) || 0;
      const inch = parseFloat((document.getElementById('height-in') as HTMLInputElement).value) || 0;
      const lbs = parseFloat((document.getElementById('weight-lbs') as HTMLInputElement).value);
      if ((ft === 0 && inch === 0) || isNaN(lbs) || lbs <= 0) { hideResult(); return; }
      const totalInches = (ft * 12) + inch;
      heightM = totalInches * 0.0254;
      weightKg = lbs * 0.453592;
    }

    const bmi = weightKg / (heightM * heightM);
    showResult(bmi, heightM * 100, weightKg);
  }

  function hideResult() {
    const resultEl = document.getElementById('bmi-result') as HTMLElement;
    resultEl.classList.add('hidden');
  }

  function showResult(bmi: number, heightCm: number, weightKg: number) {
    const resultEl = document.getElementById('bmi-result') as HTMLElement;
    const bmiValueEl = document.getElementById('bmi-value') as HTMLElement;
    const bmiCategoryEl = document.getElementById('bmi-category') as HTMLElement;
    const bmiFormulaEl = document.getElementById('bmi-formula') as HTMLElement;

    resultEl.classList.remove('hidden');
    bmiValueEl.textContent = bmi.toFixed(1);

    const hm = (heightCm / 100).toFixed(2);
    bmiFormulaEl.textContent = `${weightKg.toFixed(1)} ÷ (${hm})² = ${bmi.toFixed(1)}`;

    if (bmi < 18.5) {
      bmiCategoryEl.className = 'inline-block px-4 py-2 rounded-full text-sm font-semibold bg-blue-100 text-blue-800';
      bmiCategoryEl.textContent = 'কম ওজন / Underweight';
    } else if (bmi < 25) {
      bmiCategoryEl.className = 'inline-block px-4 py-2 rounded-full text-sm font-semibold bg-green-100 text-green-800';
      bmiCategoryEl.textContent = 'স্বাস্থ্যকর / Healthy';
    } else if (bmi < 30) {
      bmiCategoryEl.className = 'inline-block px-4 py-2 rounded-full text-sm font-semibold bg-orange-100 text-orange-800';
      bmiCategoryEl.textContent = 'অতিরিক্ত ওজন / Overweight';
    } else {
      bmiCategoryEl.className = 'inline-block px-4 py-2 rounded-full text-sm font-semibold bg-red-100 text-red-800';
      bmiCategoryEl.textContent = 'স্থূলতা / Obese';
    }
  }

  document.getElementById('height-cm')?.addEventListener('input', calculate);
  document.getElementById('weight-kg')?.addEventListener('input', calculate);
  document.getElementById('height-ft')?.addEventListener('input', calculate);
  document.getElementById('height-in')?.addEventListener('input', calculate);
  document.getElementById('weight-lbs')?.addEventListener('input', calculate);
</script>
