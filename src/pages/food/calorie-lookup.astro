---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';
import { foods } from '../../data/foods.js';
---

<ToolLayout
  title="খাবারের ক্যালরি — বাংলা খাবার ক্যালরি | BanglaTools"
  description="বাংলা ও ভারতীয় খাবারের ক্যালরি জানুন। ১২০+ খাবারের ক্যালরি তথ্য।"
>
  <h1 class="text-2xl font-bold text-gray-900 mb-1">
    <span data-bn="খাবারের ক্যালরি" data-en="Food Calorie Lookup">খাবারের ক্যালরি</span>
  </h1>
  <p class="text-gray-500 mb-5">
    <span data-bn="১২০+ বাংলা ও ভারতীয় খাবার" data-en="120+ Bengali & Indian foods">১২০+ বাংলা ও ভারতীয় খাবার</span>
  </p>

  <AdSlot slot="above-tool" />

  <div class="mb-8">

    <!-- Search -->
    <div class="relative mb-4">
      <input
        type="text"
        id="food-search"
        placeholder="খাবার খুঁজুন — যেমন ভাত, chicken, luchi…"
        class="w-full px-4 py-3 pr-10 border-2 border-gray-300 rounded-xl text-base focus:border-teal-500 focus:outline-none"
        autocomplete="off"
      />
      <button
        id="clear-btn"
        class="hidden absolute right-3 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full bg-gray-200 hover:bg-gray-300 text-gray-600 text-xs font-bold"
        aria-label="Clear"
      >✕</button>
    </div>

    <!-- Category chips — horizontal scroll -->
    <div class="flex gap-2 overflow-x-auto pb-2 mb-4 scrollbar-hide" id="cat-filters">
      <button data-cat="all"           class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-teal-600 text-white whitespace-nowrap"><span data-bn="সব" data-en="All">সব</span></button>
      <button data-cat="staple"        class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="ভাত-রুটি" data-en="Staples">ভাত-রুটি</span></button>
      <button data-cat="fish"          class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="মাছ" data-en="Fish">মাছ</span></button>
      <button data-cat="egg"           class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="ডিম" data-en="Egg">ডিম</span></button>
      <button data-cat="meat"          class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="মাংস" data-en="Meat">মাংস</span></button>
      <button data-cat="veg"           class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="সবজি রান্না" data-en="Veg Dishes">সবজি রান্না</span></button>
      <button data-cat="sweet"         class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="মিষ্টি" data-en="Sweets">মিষ্টি</span></button>
      <button data-cat="snack"         class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="স্ন্যাকস" data-en="Snacks">স্ন্যাকস</span></button>
      <button data-cat="fruit"         class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="ফল" data-en="Fruit">ফল</span></button>
      <button data-cat="vegetable"     class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="কাঁচা সবজি" data-en="Vegetables">কাঁচা সবজি</span></button>
      <button data-cat="indian"        class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="ভারতীয়" data-en="Indian">ভারতীয়</span></button>
      <button data-cat="international" class="cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-700 hover:bg-teal-50 whitespace-nowrap"><span data-bn="আন্তর্জাতিক" data-en="Intl">আন্তর্জাতিক</span></button>
    </div>

    <!-- Result count -->
    <p id="result-count" class="text-sm text-gray-400 mb-3"></p>

    <!-- Food list -->
    <div id="food-list" class="space-y-2"></div>

    <!-- No results -->
    <div id="no-results" class="hidden text-center py-12 text-gray-400">
      <p class="text-3xl mb-2">🔍</p>
      <p class="text-sm"><span data-bn="কোনো খাবার পাওয়া যায়নি" data-en="No foods found">কোনো খাবার পাওয়া যায়নি</span></p>
    </div>

  </div>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-lg font-bold text-gray-900 mb-3">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="FAQ">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-3">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="এক কাপ ভাতে কত ক্যালরি?" data-en="How many calories in one cup of rice?">এক কাপ ভাতে কত ক্যালরি?</span>
        </summary>
        <p class="mt-2 text-gray-600 text-sm">
          <span data-bn="এক কাপ রান্না করা ভাত (প্রায় ২০০g) = প্রায় ২৬০ ক্যালরি।" data-en="One cup of cooked rice (approx 200g) = approx 260 calories.">এক কাপ রান্না করা ভাত (প্রায় ২০০g) = প্রায় ২৬০ ক্যালরি।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="ইলিশ মাছে কত ক্যালরি?" data-en="How many calories in hilsa fish?">ইলিশ মাছে কত ক্যালরি?</span>
        </summary>
        <p class="mt-2 text-gray-600 text-sm">
          <span data-bn="শোরষে ইলিশ: প্রতি ১০০g = ১৭৫ ক্যালরি। ১ পিস (১৫০g) = প্রায় ২৬৩ ক্যালরি।" data-en="Hilsa in mustard sauce: 175 cal/100g. 1 piece (150g) = approx 263 calories.">শোরষে ইলিশ: প্রতি ১০০g = ১৭৫ ক্যালরি। ১ পিস (১৫০g) = প্রায় ২৬৩ ক্যালরি।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="রসগোল্লায় কত ক্যালরি?" data-en="How many calories in rasgolla?">রসগোল্লায় কত ক্যালরি?</span>
        </summary>
        <p class="mt-2 text-gray-600 text-sm">
          <span data-bn="১টি রসগোল্লা (প্রায় ৫০g) = প্রায় ৯৩ ক্যালরি।" data-en="1 rasgolla (approx 50g) = approx 93 calories.">১টি রসগোল্লা (প্রায় ৫০g) = প্রায় ৯৩ ক্যালরি।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="ভাত খেলে কি মোটা হওয়া যায়?" data-en="Does eating rice cause weight gain?">ভাত খেলে কি মোটা হওয়া যায়?</span>
        </summary>
        <p class="mt-2 text-gray-600 text-sm">
          <span data-bn="ভাত নিজে থেকে মোটা করে না — মোট ক্যালরি বেশি হলেই ওজন বাড়ে।" data-en="Rice itself does not cause weight gain — a total calorie surplus leads to weight gain.">ভাত নিজে থেকে মোটা করে না — মোট ক্যালরি বেশি হলেই ওজন বাড়ে।</span>
        </p>
      </details>
    </div>
  </section>

  <AdSlot slot="below-faq" />

  <RelatedTools tools={[
    {
      url: "/food/bengali-food-chart",
      nameBn: "বাংলা খাবারের ক্যালরি চার্ট",
      nameEn: "Bengali Food Calorie Chart",
      descBn: "সমস্ত বাংলা খাবারের ক্যালরি চার্ট",
      descEn: "Complete Bengali food calorie chart",
      icon: "📊"
    },
    {
      url: "/health/ideal-weight",
      nameBn: "আদর্শ ওজন ক্যালকুলেটর",
      nameEn: "Ideal Weight Calculator",
      descBn: "আপনার আদর্শ ওজন জানুন",
      descEn: "Find your ideal body weight",
      icon: "⚖️"
    }
  ]} />
</ToolLayout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script define:vars={{ foodsData: foods }}>
  const searchInput = document.getElementById('food-search');
  const clearBtn    = document.getElementById('clear-btn');
  const foodList    = document.getElementById('food-list');
  const noResults   = document.getElementById('no-results');
  const resultCount = document.getElementById('result-count');
  const catBtns     = document.querySelectorAll('.cat-btn');

  let currentCat   = 'all';
  let currentQuery = '';

  const catLabels = {
    staple: 'ভাত-রুটি', fish: 'মাছ', egg: 'ডিম', meat: 'মাংস',
    veg: 'সবজি', sweet: 'মিষ্টি', snack: 'স্ন্যাকস',
    fruit: 'ফল', vegetable: 'কাঁচা সবজি',
    indian: 'ভারতীয়', international: 'আন্তর্জাতিক',
    dairy: 'দুগ্ধজাত', beverage: 'পানীয়', main: 'মূল খাবার'
  };

  function calColor(c) {
    if (c < 100) return '#16a34a';
    if (c < 200) return '#0d9488';
    if (c < 300) return '#d97706';
    return '#dc2626';
  }

  function renderFoods(list) {
    if (list.length === 0) {
      foodList.innerHTML = '';
      noResults.classList.remove('hidden');
      resultCount.textContent = '';
      return;
    }
    noResults.classList.add('hidden');
    resultCount.textContent = `${list.length}টি খাবার / ${list.length} foods`;

    foodList.innerHTML = list.map(f => `
      <div class="food-row bg-white border border-gray-200 rounded-xl overflow-hidden">
        <!-- Main row -->
        <div class="flex items-center justify-between gap-3 px-4 py-3 cursor-pointer select-none food-row-header" data-cal="${f.calories}">
          <div class="min-w-0">
            <p class="font-semibold text-gray-900 leading-snug">${f.bn}</p>
            <p class="text-xs text-gray-400 truncate">${f.en} · <span class="text-gray-400">${catLabels[f.category] || f.category}</span></p>
          </div>
          <div class="shrink-0 text-right">
            <p class="text-xl font-bold" style="color:${calColor(f.calories)}">${f.calories}</p>
            <p class="text-xs text-gray-400">kcal/100g</p>
          </div>
        </div>
        <!-- Expandable portion row -->
        <div class="portion-panel hidden border-t border-gray-100 bg-gray-50 px-4 py-3">
          <div class="flex items-center gap-2">
            <input
              type="number"
              class="portion-input w-20 px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:border-teal-500 focus:outline-none"
              placeholder="${f.serving}"
              min="1"
            />
            <span class="text-sm text-gray-500">g</span>
            <span class="portion-result text-sm font-bold text-teal-700 ml-1"></span>
          </div>
          <p class="text-xs text-gray-400 mt-1">সাধারণ পরিমাণ ${f.serving}g = ${f.servingCal} kcal</p>
        </div>
      </div>
    `).join('');

    // Toggle portion panel
    foodList.querySelectorAll('.food-row-header').forEach(header => {
      header.addEventListener('click', () => {
        const panel = header.nextElementSibling;
        const isHidden = panel.classList.contains('hidden');
        panel.classList.toggle('hidden', !isHidden);
        if (isHidden) {
          const inp = panel.querySelector('.portion-input');
          if (inp) setTimeout(() => inp.focus(), 30);
        }
      });
    });
  }

  // Portion calc via delegation
  foodList.addEventListener('input', e => {
    if (!e.target.classList.contains('portion-input')) return;
    const panel  = e.target.closest('.portion-panel');
    const header = panel.previousElementSibling;
    const cal    = parseFloat(header.dataset.cal);
    const g      = parseFloat(e.target.value);
    const res    = panel.querySelector('.portion-result');
    res.textContent = (!isNaN(g) && g > 0) ? `= ${Math.round(g / 100 * cal)} kcal` : '';
  });

  function filterAndRender() {
    let list = foodsData;
    if (currentCat !== 'all') list = list.filter(f => f.category === currentCat);
    if (currentQuery.trim()) {
      const q = currentQuery.toLowerCase().trim();
      list = list.filter(f => f.bn.includes(currentQuery) || f.en.toLowerCase().includes(q));
    }
    renderFoods(list);
  }

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentCat = btn.dataset.cat;
      catBtns.forEach(b => {
        const active = b === btn;
        b.className = b.className.replace(
          active ? /bg-gray-100 text-gray-700/ : /bg-teal-600 text-white/,
          active ? 'bg-teal-600 text-white'    : 'bg-gray-100 text-gray-700'
        );
      });
      filterAndRender();
    });
  });

  searchInput.addEventListener('input', e => {
    currentQuery = e.target.value;
    clearBtn.classList.toggle('hidden', !currentQuery);
    filterAndRender();
  });

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    currentQuery = '';
    clearBtn.classList.add('hidden');
    currentCat = 'all';
    catBtns.forEach(b => {
      if (b.dataset.cat === 'all') {
        b.className = b.className.replace('bg-gray-100 text-gray-700', 'bg-teal-600 text-white');
      } else {
        b.className = b.className.replace('bg-teal-600 text-white', 'bg-gray-100 text-gray-700');
      }
    });
    filterAndRender();
    searchInput.focus();
  });

  filterAndRender();
</script>
