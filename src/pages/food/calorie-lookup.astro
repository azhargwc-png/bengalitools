---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import { foods } from '../../data/foods.js';
---

<BaseLayout
  title="Indian & Bengali Food Calorie Calculator | BanglaTools"
  description="Calories in Indian and Bengali food — rice, cucumber, khichdi, dal, roti and 120+ more foods. বাংলা ও ভারতীয় খাবারের ক্যালরি জানুন।"
>
  <Header />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

    <h1 class="text-3xl font-bold text-gray-900 mb-1">
      <span data-bn="খাবারের ক্যালরি" data-en="Food Calorie Lookup">খাবারের ক্যালরি</span>
    </h1>
    <p class="text-gray-400 mb-8">
      <span data-bn="১২০+ বাংলা ও ভারতীয় খাবার" data-en="120+ Bengali & Indian foods">১২০+ বাংলা ও ভারতীয় খাবার</span>
    </p>

    <AdSlot slot="above-tool" />

    <!-- Search -->
    <div class="relative mb-5">
      <input
        type="text"
        id="food-search"
        placeholder="খাবার খুঁজুন — যেমন ভাত, chicken, luchi…"
        class="w-full px-5 py-4 pr-12 border-2 border-gray-200 rounded-2xl text-lg focus:border-teal-500 focus:outline-none bg-gray-50"
        autocomplete="off"
      />
      <button
        id="clear-btn"
        class="hidden absolute right-4 top-1/2 -translate-y-1/2 w-7 h-7 flex items-center justify-center rounded-full bg-gray-200 hover:bg-gray-300 text-gray-500 text-sm font-bold"
        aria-label="Clear"
      >✕</button>
    </div>

    <!-- Category chips -->
    <div class="flex gap-2 overflow-x-auto pb-3 mb-6 scrollbar-hide" id="cat-filters">
      <button data-cat="all"           class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-teal-600 text-white whitespace-nowrap"><span data-bn="সব" data-en="All">সব</span></button>
      <button data-cat="staple"        class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="ভাত-রুটি" data-en="Staples">ভাত-রুটি</span></button>
      <button data-cat="fish"          class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="মাছ" data-en="Fish">মাছ</span></button>
      <button data-cat="egg"           class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="ডিম" data-en="Egg">ডিম</span></button>
      <button data-cat="meat"          class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="মাংস" data-en="Meat">মাংস</span></button>
      <button data-cat="veg"           class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="সবজি" data-en="Veg">সবজি</span></button>
      <button data-cat="sweet"         class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="মিষ্টি" data-en="Sweets">মিষ্টি</span></button>
      <button data-cat="snack"         class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="স্ন্যাকস" data-en="Snacks">স্ন্যাকস</span></button>
      <button data-cat="fruit"         class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="ফল" data-en="Fruit">ফল</span></button>
      <button data-cat="vegetable"     class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="কাঁচা সবজি" data-en="Vegetables">কাঁচা সবজি</span></button>
      <button data-cat="indian"        class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="ভারতীয়" data-en="Indian">ভারতীয়</span></button>
      <button data-cat="international" class="cat-btn shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-teal-50 whitespace-nowrap"><span data-bn="আন্তর্জাতিক" data-en="Intl">আন্তর্জাতিক</span></button>
    </div>

    <!-- Count -->
    <p id="result-count" class="text-sm text-gray-400 mb-4"></p>

    <!-- Food grid -->
    <div id="food-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10"></div>

    <!-- No results -->
    <div id="no-results" class="hidden text-center py-16 text-gray-400">
      <p class="text-4xl mb-3">🔍</p>
      <p><span data-bn="কোনো খাবার পাওয়া যায়নি" data-en="No foods found">কোনো খাবার পাওয়া যায়নি</span></p>
    </div>

    <!-- FAQ -->
    <section class="mb-10 max-w-2xl">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="FAQ">সাধারণ প্রশ্নোত্তর</span>
      </h2>
      <div class="space-y-3">
        <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
          <summary class="font-semibold text-gray-900 cursor-pointer">
            <span data-bn="এক কাপ ভাতে কত ক্যালরি?" data-en="How many calories in one cup of rice?">এক কাপ ভাতে কত ক্যালরি?</span>
          </summary>
          <p class="mt-2 text-gray-600 text-sm">
            <span data-bn="এক কাপ রান্না করা ভাত (প্রায় ২০০g) = প্রায় ২৬০ ক্যালরি।" data-en="One cup of cooked rice (approx 200g) = approx 260 calories.">এক কাপ রান্না করা ভাত (প্রায় ২০০g) = প্রায় ২৬০ ক্যালরি।</span>
          </p>
        </details>
        <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
          <summary class="font-semibold text-gray-900 cursor-pointer">
            <span data-bn="ইলিশ মাছে কত ক্যালরি?" data-en="How many calories in hilsa?">ইলিশ মাছে কত ক্যালরি?</span>
          </summary>
          <p class="mt-2 text-gray-600 text-sm">
            <span data-bn="শোরষে ইলিশ: প্রতি ১০০g = ১৭৫ ক্যালরি। ১ পিস (১৫০g) = প্রায় ২৬৩ ক্যালরি।" data-en="Hilsa in mustard sauce: 175 cal/100g. 1 piece (150g) ≈ 263 calories.">শোরষে ইলিশ: প্রতি ১০০g = ১৭৫ ক্যালরি। ১ পিস (১৫০g) = প্রায় ২৬৩ ক্যালরি।</span>
          </p>
        </details>
        <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
          <summary class="font-semibold text-gray-900 cursor-pointer">
            <span data-bn="রসগোল্লায় কত ক্যালরি?" data-en="Calories in rasgolla?">রসগোল্লায় কত ক্যালরি?</span>
          </summary>
          <p class="mt-2 text-gray-600 text-sm">
            <span data-bn="১টি রসগোল্লা (প্রায় ৫০g) = প্রায় ৯৩ ক্যালরি।" data-en="1 rasgolla (approx 50g) = approx 93 calories.">১টি রসগোল্লা (প্রায় ৫০g) = প্রায় ৯৩ ক্যালরি।</span>
          </p>
        </details>
        <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
          <summary class="font-semibold text-gray-900 cursor-pointer">
            <span data-bn="ভাত খেলে কি মোটা হওয়া যায়?" data-en="Does rice cause weight gain?">ভাত খেলে কি মোটা হওয়া যায়?</span>
          </summary>
          <p class="mt-2 text-gray-600 text-sm">
            <span data-bn="ভাত নিজে থেকে মোটা করে না — মোট ক্যালরি বেশি হলেই ওজন বাড়ে।" data-en="Rice itself does not cause weight gain — excess total calories lead to weight gain.">ভাত নিজে থেকে মোটা করে না — মোট ক্যালরি বেশি হলেই ওজন বাড়ে।</span>
          </p>
        </details>
      </div>
    </section>

    <AdSlot slot="below-faq" />

    <div class="max-w-2xl">
      <RelatedTools tools={[
        {
          url: "/food/bengali-food-chart",
          nameBn: "বাংলা খাবারের ক্যালরি চার্ট",
          nameEn: "Bengali Food Calorie Chart",
          descBn: "সমস্ত বাংলা খাবারের ক্যালরি চার্ট",
          descEn: "Complete Bengali food calorie chart",
          icon: "📊"
        },
        {
          url: "/health/ideal-weight",
          nameBn: "আদর্শ ওজন ক্যালকুলেটর",
          nameEn: "Ideal Weight Calculator",
          descBn: "আপনার আদর্শ ওজন জানুন",
          descEn: "Find your ideal body weight",
          icon: "⚖️"
        }
      ]} />
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script define:vars={{ foodsData: foods }}>
  const searchInput = document.getElementById('food-search');
  const clearBtn    = document.getElementById('clear-btn');
  const foodGrid    = document.getElementById('food-grid');
  const noResults   = document.getElementById('no-results');
  const resultCount = document.getElementById('result-count');
  const catBtns     = document.querySelectorAll('.cat-btn');

  let currentCat   = 'all';
  let currentQuery = '';

  const catLabels = {
    staple: 'ভাত-রুটি', fish: 'মাছ', egg: 'ডিম', meat: 'মাংস',
    veg: 'সবজি', sweet: 'মিষ্টি', snack: 'স্ন্যাকস',
    fruit: 'ফল', vegetable: 'কাঁচা সবজি',
    indian: 'ভারতীয়', international: 'আন্তর্জাতিক',
    dairy: 'দুগ্ধজাত', beverage: 'পানীয়', main: 'মূল খাবার'
  };

  function calColor(c) {
    if (c < 100) return '#16a34a';
    if (c < 200) return '#0d9488';
    if (c < 300) return '#d97706';
    return '#dc2626';
  }

  function renderFoods(list) {
    if (list.length === 0) {
      foodGrid.innerHTML = '';
      noResults.classList.remove('hidden');
      resultCount.textContent = '';
      return;
    }
    noResults.classList.add('hidden');
    resultCount.textContent = `${list.length}টি খাবার / ${list.length} foods`;

    foodGrid.innerHTML = list.map(f => `
      <div class="food-card bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow">
        <div class="food-card-top p-5 cursor-pointer select-none" data-cal="${f.calories}" data-protein="${f.protein || 0}" data-carbs="${f.carbs || 0}" data-fat="${f.fat || 0}">
          <div class="flex justify-between items-start gap-3">
            <div class="min-w-0 flex-1">
              <p class="font-bold text-gray-900 text-lg leading-tight">${f.bn}</p>
              <p class="text-sm text-gray-400 mt-0.5">${f.en}</p>
            </div>
            <div class="shrink-0 text-right">
              <p class="text-3xl font-bold leading-none" style="color:${calColor(f.calories)}">${f.calories}</p>
              <p class="text-xs text-gray-400 mt-1">kcal / 100g</p>
            </div>
          </div>
          <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
            <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">${catLabels[f.category] || f.category}</span>
            <div class="flex gap-2 text-xs text-gray-400">
              <span title="Protein">P: ${f.protein || 0}g</span>
              <span title="Carbs">C: ${f.carbs || 0}g</span>
              <span title="Fat">F: ${f.fat || 0}g</span>
              <span>▾</span>
            </div>
          </div>
        </div>
        <div class="portion-panel hidden border-t border-gray-100 bg-gray-50 px-5 py-4">
          <p class="text-sm text-gray-500 mb-2">নিজের পরিমাণ লিখুন</p>
          <div class="flex items-center gap-3">
            <input
              type="number"
              class="portion-input w-24 px-3 py-2 border border-gray-300 rounded-xl text-base focus:border-teal-500 focus:outline-none bg-white"
              placeholder="${f.serving}"
              min="1"
            />
            <span class="text-gray-500">g</span>
            <span class="portion-result text-base font-bold text-teal-600"></span>
          </div>
          <div class="portion-macros hidden mt-2 flex gap-3 text-xs text-gray-500">
            <span class="text-blue-600 font-medium">প্রোটিন: <span class="macro-protein"></span>g</span>
            <span class="text-orange-500 font-medium">কার্বস: <span class="macro-carbs"></span>g</span>
            <span class="text-yellow-600 font-medium">ফ্যাট: <span class="macro-fat"></span>g</span>
          </div>
        </div>
      </div>
    `).join('');

    foodGrid.querySelectorAll('.food-card-top').forEach(top => {
      top.addEventListener('click', () => {
        const panel = top.nextElementSibling;
        const isHidden = panel.classList.contains('hidden');
        panel.classList.toggle('hidden', !isHidden);
        if (isHidden) setTimeout(() => panel.querySelector('.portion-input')?.focus(), 30);
      });
    });
  }

  foodGrid.addEventListener('input', e => {
    if (!e.target.classList.contains('portion-input')) return;
    const panel   = e.target.closest('.portion-panel');
    const top     = panel.previousElementSibling;
    const cal     = parseFloat(top.dataset.cal);
    const protein = parseFloat(top.dataset.protein) || 0;
    const carbs   = parseFloat(top.dataset.carbs)   || 0;
    const fat     = parseFloat(top.dataset.fat)     || 0;
    const g       = parseFloat(e.target.value);
    const res     = panel.querySelector('.portion-result');
    const macros  = panel.querySelector('.portion-macros');
    if (!isNaN(g) && g > 0) {
      res.textContent = `= ${Math.round(g / 100 * cal)} kcal`;
      panel.querySelector('.macro-protein').textContent = (g / 100 * protein).toFixed(1);
      panel.querySelector('.macro-carbs').textContent   = (g / 100 * carbs).toFixed(1);
      panel.querySelector('.macro-fat').textContent     = (g / 100 * fat).toFixed(1);
      macros.classList.remove('hidden');
    } else {
      res.textContent = '';
      macros.classList.add('hidden');
    }
  });

  function filterAndRender() {
    let list = foodsData;
    if (currentCat !== 'all') list = list.filter(f => f.category === currentCat);
    if (currentQuery.trim()) {
      const q = currentQuery.toLowerCase().trim();
      list = list.filter(f => f.bn.includes(currentQuery) || f.en.toLowerCase().includes(q));
    }
    renderFoods(list);
  }

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentCat = btn.dataset.cat;
      catBtns.forEach(b => {
        if (b === btn) {
          b.classList.remove('bg-gray-100', 'text-gray-600');
          b.classList.add('bg-teal-600', 'text-white');
        } else {
          b.classList.remove('bg-teal-600', 'text-white');
          b.classList.add('bg-gray-100', 'text-gray-600');
        }
      });
      filterAndRender();
    });
  });

  searchInput.addEventListener('input', e => {
    currentQuery = e.target.value;
    clearBtn.classList.toggle('hidden', !currentQuery);
    filterAndRender();
  });

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    currentQuery = '';
    clearBtn.classList.add('hidden');
    currentCat = 'all';
    catBtns.forEach(b => {
      if (b.dataset.cat === 'all') {
        b.classList.remove('bg-gray-100', 'text-gray-600');
        b.classList.add('bg-teal-600', 'text-white');
      } else {
        b.classList.remove('bg-teal-600', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-600');
      }
    });
    filterAndRender();
    searchInput.focus();
  });

  filterAndRender();
</script>
