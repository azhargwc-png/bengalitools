<script>
  const distInput = document.getElementById('fc-distance') as HTMLInputElement;
  const mileageInput = document.getElementById('fc-mileage') as HTMLInputElement;
  const priceInput = document.getElementById('fc-price') as HTMLInputElement;
  const fcResult = document.getElementById('fc-result')!;
  const presetBtns = document.querySelectorAll('.preset-btn') as NodeListOf<HTMLButtonElement>;

  presetBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      distInput.value = btn.dataset.dist || '';
      calculate();
    });
  });

  function calculate() {
    const dist = parseFloat(distInput.value);
    const mileage = parseFloat(mileageInput.value);
    const price = parseFloat(priceInput.value);

    if (!isNaN(dist) && !isNaN(mileage) && !isNaN(price) && dist > 0 && mileage > 0 && price > 0) {
      const litres = dist / mileage;
      const totalCost = litres * price;
      const per100 = (litres / dist) * 100 * price;

      document.getElementById('fc-total-cost')!.textContent = '₹' + totalCost.toFixed(2);
      document.getElementById('fc-litres')!.textContent = litres.toFixed(2) + ' L';
      document.getElementById('fc-breakdown')!.textContent =
        `${dist} km ÷ ${mileage} km/L = ${litres.toFixed(2)} L × ₹${price} = ₹${totalCost.toFixed(2)}`;
      document.getElementById('fc-per100')!.textContent =
        `প্রতি ১০০ km খরচ / Cost per 100 km: ₹${per100.toFixed(2)}`;
      fcResult.classList.remove('hidden');
    } else {
      fcResult.classList.add('hidden');
    }
  }

  distInput.addEventListener('input', calculate);
  mileageInput.addEventListener('input', calculate);
  priceInput.addEventListener('input', calculate);

  // Calculate on load with default values
  calculate();
</script>
