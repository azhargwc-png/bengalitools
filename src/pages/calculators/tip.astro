<script>
  const billInput = document.getElementById('bill-amount') as HTMLInputElement;
  const customTip = document.getElementById('custom-tip') as HTMLInputElement;
  const numPeople = document.getElementById('num-people') as HTMLInputElement;
  const tipResult = document.getElementById('tip-result')!;
  const tipButtons = document.querySelectorAll('.tip-btn') as NodeListOf<HTMLButtonElement>;

  let selectedTip = 0;

  function setTipBtn(val: number) {
    selectedTip = val;
    customTip.value = '';
    tipButtons.forEach(btn => {
      if (parseInt(btn.dataset.tip || '0') === val) {
        btn.className = 'tip-btn py-3 rounded-xl text-sm font-bold border-2 border-teal-500 bg-teal-500 text-white transition-all min-h-[44px]';
      } else {
        btn.className = 'tip-btn py-3 rounded-xl text-sm font-bold border-2 border-gray-300 bg-white text-gray-700 hover:border-teal-500 hover:text-teal-700 transition-all min-h-[44px]';
      }
    });
    calculate();
  }

  tipButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      setTipBtn(parseInt(btn.dataset.tip || '0'));
    });
  });

  customTip.addEventListener('input', () => {
    selectedTip = parseFloat(customTip.value) || 0;
    tipButtons.forEach(btn => {
      btn.className = 'tip-btn py-3 rounded-xl text-sm font-bold border-2 border-gray-300 bg-white text-gray-700 hover:border-teal-500 hover:text-teal-700 transition-all min-h-[44px]';
    });
    calculate();
  });

  billInput.addEventListener('input', calculate);
  numPeople.addEventListener('input', calculate);

  function calculate() {
    const bill = parseFloat(billInput.value);
    const people = parseInt(numPeople.value) || 1;
    const tipPct = selectedTip || parseFloat(customTip.value) || 0;

    if (!isNaN(bill) && bill > 0) {
      const tipAmt = (tipPct / 100) * bill;
      const total = bill + tipAmt;
      const perPerson = total / people;

      document.getElementById('tip-amount')!.textContent = '₹' + tipAmt.toFixed(2);
      document.getElementById('total-bill')!.textContent = '₹' + total.toFixed(2);
      document.getElementById('per-person')!.textContent = '₹' + perPerson.toFixed(2);
      document.getElementById('tip-breakdown')!.textContent =
        `₹${bill.toFixed(2)} বিল + ₹${tipAmt.toFixed(2)} টিপ (${tipPct}%) = ₹${total.toFixed(2)} ÷ ${people} জন`;
      tipResult.classList.remove('hidden');
    } else {
      tipResult.classList.add('hidden');
    }
  }
</script>
