<script>
  const startInput = document.getElementById('start-date') as HTMLInputElement;
  const endInput = document.getElementById('end-date') as HTMLInputElement;
  const btnToday = document.getElementById('btn-today')!;
  const diffResult = document.getElementById('diff-result')!;
  const diffError = document.getElementById('diff-error')!;

  const weekdaysBn = ['রবিবার', 'সোমবার', 'মঙ্গলবার', 'বুধবার', 'বৃহস্পতিবার', 'শুক্রবার', 'শনিবার'];
  const weekdaysEn = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

  const today = new Date();
  btnToday.addEventListener('click', () => {
    startInput.value = today.toISOString().split('T')[0];
    calculate();
  });

  function getWeekdayLabel(dateStr: string): string {
    if (!dateStr) return '';
    const d = new Date(dateStr + 'T00:00:00');
    const idx = d.getDay();
    return weekdaysBn[idx] + ' / ' + weekdaysEn[idx];
  }

  function calculate() {
    const startVal = startInput.value;
    const endVal = endInput.value;

    document.getElementById('start-weekday')!.textContent = getWeekdayLabel(startVal);
    document.getElementById('end-weekday')!.textContent = getWeekdayLabel(endVal);

    if (!startVal || !endVal) {
      diffResult.classList.add('hidden');
      diffError.classList.add('hidden');
      return;
    }

    const start = new Date(startVal + 'T00:00:00');
    const end = new Date(endVal + 'T00:00:00');

    if (end <= start) {
      diffResult.classList.add('hidden');
      diffError.classList.remove('hidden');
      return;
    }

    diffError.classList.add('hidden');

    // Total days
    const totalDays = Math.floor((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));
    const totalWeeks = Math.floor(totalDays / 7);

    // Years, months, remaining days
    let years = end.getFullYear() - start.getFullYear();
    let months = end.getMonth() - start.getMonth();
    let days = end.getDate() - start.getDate();

    if (days < 0) {
      months--;
      const prevMonthEnd = new Date(end.getFullYear(), end.getMonth(), 0);
      days += prevMonthEnd.getDate();
    }
    if (months < 0) {
      years--;
      months += 12;
    }

    const totalHours = totalDays * 24;
    document.getElementById('diff-years')!.textContent = String(years);
    document.getElementById('diff-months')!.textContent = String(months);
    document.getElementById('diff-weeks')!.textContent = String(totalWeeks);
    document.getElementById('diff-days')!.textContent = String(totalDays);
    document.getElementById('diff-hours')!.textContent = totalHours.toLocaleString();

    document.getElementById('diff-summary')!.textContent =
      `${years} বছর ${months} মাস ${days} দিন / ${years} years ${months} months ${days} days`;
    document.getElementById('diff-business-days')!.textContent =
      `মোট ${totalDays} দিন = ${totalWeeks} সপ্তাহ + ${totalDays % 7} দিন / Total ${totalDays} days = ${totalWeeks} weeks + ${totalDays % 7} days`;

    diffResult.classList.remove('hidden');
  }

  startInput.addEventListener('change', calculate);
  endInput.addEventListener('change', calculate);

  function resetTool() {
    startInput.value = '';
    endInput.value = '';
    document.getElementById('start-weekday')!.textContent = '';
    document.getElementById('end-weekday')!.textContent = '';
    diffResult.classList.add('hidden');
    diffError.classList.add('hidden');
  }
  (window as any).resetTool = resetTool;
</script>
