---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "তারিখের পার্থক্য ক্যালকুলেটর",
      "url": "https://www.bengalitools.com/calculators/date-difference/",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "দুটি তারিখের মধ্যে দিন সংখ্যা কীভাবে গণনা করব?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "দুটি তারিখকে মিলিসেকেন্ডে রূপান্তর করে বিয়োগ করুন। এই টুল স্বয়ংক্রিয়ভাবে হিসাব করে।"
          }
        },
        {
          "@type": "Question",
          "name": "লিপ ইয়ার কি সঠিকভাবে হিসাব হয়?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "হ্যাঁ, JavaScript-এর Date অবজেক্ট লিপ ইয়ার স্বয়ংক্রিয়ভাবে সঠিকভাবে সামলায়।"
          }
        },
        {
          "@type": "Question",
          "name": "কোন তারিখ কোন বারে পড়েছিল জানতে পারব?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "হ্যাঁ, এই টুলটি শুরু ও শেষ উভয় তারিখের বার স্বয়ংক্রিয়ভাবে দেখায়।"
          }
        },
        {
          "@type": "Question",
          "name": "ভিসার মেয়াদ বা পাসপোর্টের বৈধতা হিসাব করতে পারব?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "হ্যাঁ, ইস্যু তারিখ শুরুতে ও মেয়াদ শেষের তারিখ শেষে দিলে মোট বৈধতার দিন সংখ্যা পাবেন।"
          }
        },
        {
          "@type": "Question",
          "name": "আজ থেকে ১০০ দিন পরে কোন তারিখ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "আজ থেকে বাটনে ক্লিক করে শুরুর তারিখ সেট করুন। তারপর শেষের তারিখ বাড়িয়ে দেখুন।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="Date Difference Calculator — Days Between Two Dates | BanglaTools"
  description="Calculate days, months and years between two dates. দুই তারিখের মধ্যে কত দিন — বছর, মাস, সপ্তাহে দেখুন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <!-- H1 -->
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="দুই তারিখের মধ্যে কত দিন" data-en="Date Difference Calculator">দুই তারিখের মধ্যে কত দিন</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="দুটি তারিখের মধ্যে পার্থক্য বছর, মাস, সপ্তাহ ও দিনে জানুন" data-en="Find the difference between two dates in years, months, weeks and days">দুটি তারিখের মধ্যে পার্থক্য বছর, মাস, সপ্তাহ ও দিনে জানুন</span>
  </p>

  <!-- AdSlot above tool -->
  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <div class="flex items-center justify-between mb-1">
          <label class="block text-sm font-medium text-gray-700" for="start-date">
            <span data-bn="শুরুর তারিখ" data-en="Start Date">শুরুর তারিখ</span>
          </label>
          <button id="btn-today" class="text-xs text-teal-600 font-semibold hover:underline">
            <span data-bn="আজ থেকে" data-en="From Today">আজ থেকে</span>
          </button>
        </div>
        <input
          type="date"
          id="start-date"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
        <p id="start-weekday" class="text-xs text-teal-600 mt-1 font-medium"></p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="end-date">
          <span data-bn="শেষের তারিখ" data-en="End Date">শেষের তারিখ</span>
        </label>
        <input
          type="date"
          id="end-date"
          class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]"
        />
        <p id="end-weekday" class="text-xs text-teal-600 mt-1 font-medium"></p>
      </div>
    </div>

    <!-- Result -->
    <div id="diff-result" class="hidden">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-3">
        <div class="bg-teal-50 border border-teal-200 rounded-xl p-4 text-center">
          <p id="diff-years" class="text-3xl font-bold text-teal-700">0</p>
          <p class="text-sm text-gray-600 mt-1"><span data-bn="বছর" data-en="Years">বছর</span></p>
        </div>
        <div class="bg-teal-50 border border-teal-200 rounded-xl p-4 text-center">
          <p id="diff-months" class="text-3xl font-bold text-teal-700">0</p>
          <p class="text-sm text-gray-600 mt-1"><span data-bn="মাস" data-en="Months">মাস</span></p>
        </div>
        <div class="bg-teal-50 border border-teal-200 rounded-xl p-4 text-center">
          <p id="diff-weeks" class="text-3xl font-bold text-teal-700">0</p>
          <p class="text-sm text-gray-600 mt-1"><span data-bn="সপ্তাহ" data-en="Weeks">সপ্তাহ</span></p>
        </div>
        <div class="bg-teal-50 border border-teal-200 rounded-xl p-4 text-center">
          <p id="diff-days" class="text-3xl font-bold text-teal-700">0</p>
          <p class="text-sm text-gray-600 mt-1"><span data-bn="দিন (মোট)" data-en="Days (total)">দিন (মোট)</span></p>
        </div>
      </div>
      <div class="bg-teal-50 border border-teal-200 rounded-xl p-4 text-center mb-3">
        <p id="diff-hours" class="text-3xl font-bold text-teal-700">0</p>
        <p class="text-sm text-gray-600 mt-1"><span data-bn="ঘণ্টা (মোট)" data-en="Hours (total)">ঘণ্টা (মোট)</span></p>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-200 text-sm text-gray-700 space-y-1">
        <p id="diff-summary"></p>
        <p id="diff-business-days" class="text-gray-500"></p>
      </div>
    </div>

    <div id="diff-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-3 text-red-700 text-sm">
      <span data-bn="শেষের তারিখ শুরুর তারিখের পরে হতে হবে।" data-en="End date must be after start date.">শেষের তারিখ শুরুর তারিখের পরে হতে হবে।</span>
    </div>

    <!-- Reset button -->
    <button onclick="resetTool()" class="mt-3 w-full py-2 px-4 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl transition-colors text-sm">
      <span data-bn="পরিষ্কার করুন" data-en="Clear">পরিষ্কার করুন</span> ✕
    </button>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="শুরুর তারিখ বেছে নিন — 'আজ থেকে' বাটনে ক্লিক করলে আজকের তারিখ বসে যাবে" data-en="Select start date — click 'From Today' to set today's date automatically">শুরুর তারিখ বেছে নিন — 'আজ থেকে' বাটনে ক্লিক করলে আজকের তারিখ বসে যাবে</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="শেষের তারিখ বেছে নিন" data-en="Select the end date">শেষের তারিখ বেছে নিন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="বছর, মাস, সপ্তাহ ও মোট দিন স্বয়ংক্রিয়ভাবে দেখাবে। প্রতিটি তারিখের বারও দেখাবে।" data-en="Years, months, weeks and total days appear automatically, along with the day of the week for each date.">বছর, মাস, সপ্তাহ ও মোট দিন স্বয়ংক্রিয়ভাবে দেখাবে। প্রতিটি তারিখের বারও দেখাবে।</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        এই তারিখ পার্থক্য ক্যালকুলেটরটি দুটি তারিখের মধ্যে ব্যবধান বছর, মাস, সপ্তাহ এবং মোট দিনে প্রকাশ করে। শুধু দিন নয় — প্রতিটি তারিখ কোন বার (সোমবার, মঙ্গলবার ইত্যাদি) সেটাও দেখায়। 'আজ থেকে' বাটনটি স্বয়ংক্রিয়ভাবে আজকের তারিখ শুরুর তারিখে বসিয়ে দেয় — যা ডেডলাইন বা বিশেষ দিন গণনার জন্য দরকারি। পরীক্ষার আগে কতদিন বাকি, বিবাহবার্ষিকী কত দিন পরে, চুক্তির মেয়াদ কত — এইসব প্রশ্নের উত্তর দ্রুত পাওয়া যাবে। লিপ ইয়ার সঠিকভাবে হিসাবে ধরা হয়।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ১: স্বাধীনতা দিবস থেকে নববর্ষ" data-en="Example 1: Independence Day to New Year">উদাহরণ ১: স্বাধীনতা দিবস থেকে নববর্ষ</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="শুরু: ১৫ আগস্ট ২০২৫, শেষ: ১ জানুয়ারি ২০২৬" data-en="Start: 15 Aug 2025, End: 1 Jan 2026">শুরু: ১৫ আগস্ট ২০২৫, শেষ: ১ জানুয়ারি ২০২৬</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="পার্থক্য: ০ বছর ৪ মাস ১৭ দিন = মোট ১৩৯ দিন" data-en="Difference: 0 years 4 months 17 days = 139 total days">পার্থক্য: ০ বছর ৪ মাস ১৭ দিন = মোট ১৩৯ দিন</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ২: চুক্তির মেয়াদ" data-en="Example 2: Contract duration">উদাহরণ ২: চুক্তির মেয়াদ</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="শুরু: ১ জানুয়ারি ২০২৪, শেষ: ৩১ ডিসেম্বর ২০২৪" data-en="Start: 1 Jan 2024, End: 31 Dec 2024">শুরু: ১ জানুয়ারি ২০২৪, শেষ: ৩১ ডিসেম্বর ২০২৪</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="পার্থক্য: ১১ মাস ৩০ দিন = মোট ৩৬৫ দিন (লিপ ইয়ার)" data-en="Difference: 11 months 30 days = 365 total days (leap year)">পার্থক্য: ১১ মাস ৩০ দিন = মোট ৩৬৫ দিন (লিপ ইয়ার)</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ৩: পরীক্ষার আগে কতদিন বাকি" data-en="Example 3: Days left before exam">উদাহরণ ৩: পরীক্ষার আগে কতদিন বাকি</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="শুরু: আজকের তারিখ, শেষ: পরীক্ষার তারিখ" data-en="Start: today's date, End: exam date">'আজ থেকে' বাটন দিয়ে শুরু, শেষে পরীক্ষার তারিখ দিন</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="মোট দিন, সপ্তাহ ও বার সঙ্গে সঙ্গে দেখাবে" data-en="Total days, weeks and weekday shown instantly">মোট দিন, সপ্তাহ ও বার সঙ্গে সঙ্গে দেখাবে</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="দুটি তারিখের মধ্যে দিন সংখ্যা কীভাবে গণনা করব?" data-en="How to count days between two dates?">দুটি তারিখের মধ্যে দিন সংখ্যা কীভাবে গণনা করব?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="দুটি তারিখকে মিলিসেকেন্ডে রূপান্তর করে বিয়োগ করুন, তারপর ৮৬৪০০০০০ (এক দিনের মিলিসেকেন্ড) দিয়ে ভাগ করুন। এই টুল স্বয়ংক্রিয়ভাবে সেটি করে।" data-en="Convert both dates to milliseconds, subtract, then divide by 86,400,000 (milliseconds per day). This tool does it automatically.">দুটি তারিখকে মিলিসেকেন্ডে রূপান্তর করে বিয়োগ করুন, তারপর ৮৬৪০০০০০ (এক দিনের মিলিসেকেন্ড) দিয়ে ভাগ করুন। এই টুল স্বয়ংক্রিয়ভাবে সেটি করে।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="লিপ ইয়ার কি সঠিকভাবে হিসাব হয়?" data-en="Are leap years calculated correctly?">লিপ ইয়ার কি সঠিকভাবে হিসাব হয়?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="হ্যাঁ, JavaScript-এর Date অবজেক্ট লিপ ইয়ার স্বয়ংক্রিয়ভাবে সঠিকভাবে সামলায়।" data-en="Yes, JavaScript's Date object handles leap years automatically and correctly.">হ্যাঁ, JavaScript-এর Date অবজেক্ট লিপ ইয়ার স্বয়ংক্রিয়ভাবে সঠিকভাবে সামলায়।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="কোন তারিখ কোন বারে পড়েছিল জানতে পারব?" data-en="Can I find what day of the week a date falls on?">কোন তারিখ কোন বারে পড়েছিল জানতে পারব?</span>
        </summary>
        <p class="mt-3 text-gray-700">
