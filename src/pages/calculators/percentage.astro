<script>
  // Calculator 1: X is what % of Y
  const c1x = document.getElementById('c1-x') as HTMLInputElement;
  const c1y = document.getElementById('c1-y') as HTMLInputElement;
  const c1result = document.getElementById('c1-result')!;
  const c1answer = document.getElementById('c1-answer')!;
  const c1formula = document.getElementById('c1-formula')!;

  function calcC1() {
    const x = parseFloat(c1x.value);
    const y = parseFloat(c1y.value);
    if (!isNaN(x) && !isNaN(y) && y !== 0) {
      const pct = (x / y) * 100;
      c1answer.textContent = pct.toFixed(2) + '%';
      c1formula.textContent = `(${x} ÷ ${y}) × 100 = ${pct.toFixed(2)}%`;
      c1result.classList.remove('hidden');
    } else {
      c1result.classList.add('hidden');
    }
  }
  c1x.addEventListener('input', calcC1);
  c1y.addEventListener('input', calcC1);

  // Calculator 2: What is X% of Y
  const c2x = document.getElementById('c2-x') as HTMLInputElement;
  const c2y = document.getElementById('c2-y') as HTMLInputElement;
  const c2result = document.getElementById('c2-result')!;
  const c2answer = document.getElementById('c2-answer')!;
  const c2formula = document.getElementById('c2-formula')!;

  function calcC2() {
    const x = parseFloat(c2x.value);
    const y = parseFloat(c2y.value);
    if (!isNaN(x) && !isNaN(y)) {
      const val = (x / 100) * y;
      c2answer.textContent = val.toFixed(2);
      c2formula.textContent = `(${x} ÷ 100) × ${y} = ${val.toFixed(2)}`;
      c2result.classList.remove('hidden');
    } else {
      c2result.classList.add('hidden');
    }
  }
  c2x.addEventListener('input', calcC2);
  c2y.addEventListener('input', calcC2);

  // Calculator 3: Percentage change
  const c3x = document.getElementById('c3-x') as HTMLInputElement;
  const c3y = document.getElementById('c3-y') as HTMLInputElement;
  const c3result = document.getElementById('c3-result')!;
  const c3answer = document.getElementById('c3-answer')!;
  const c3label = document.getElementById('c3-label')!;
  const c3formula = document.getElementById('c3-formula')!;

  function calcC3() {
    const x = parseFloat(c3x.value);
    const y = parseFloat(c3y.value);
    if (!isNaN(x) && !isNaN(y) && x !== 0) {
      const change = ((y - x) / x) * 100;
      const absChange = Math.abs(change).toFixed(2);
      c3answer.textContent = absChange + '%';
      if (change > 0) {
        c3label.textContent = '▲ বৃদ্ধি / Increase';
        c3label.className = 'text-sm font-semibold mt-1 text-green-600';
        c3answer.className = 'text-4xl font-bold text-green-600';
      } else if (change < 0) {
        c3label.textContent = '▼ হ্রাস / Decrease';
        c3label.className = 'text-sm font-semibold mt-1 text-red-600';
        c3answer.className = 'text-4xl font-bold text-red-600';
      } else {
        c3label.textContent = '— কোনো পরিবর্তন নেই / No change';
        c3label.className = 'text-sm font-semibold mt-1 text-gray-500';
        c3answer.className = 'text-4xl font-bold text-teal-700';
      }
      c3formula.textContent = `((${y} - ${x}) ÷ ${x}) × 100 = ${change.toFixed(2)}%`;
      c3result.classList.remove('hidden');
    } else {
      c3result.classList.add('hidden');
    }
  }
  c3x.addEventListener('input', calcC3);
  c3y.addEventListener('input', calcC3);
</script>
