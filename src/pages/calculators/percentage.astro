---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "শতাংশ ক্যালকুলেটর",
      "url": "https://www.bengalitools.com/calculators/percentage/",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "শতাংশ বের করার সূত্র কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "শতাংশ = (অংশ ÷ মোট) × ১০০। যেমন ৫০ এর মধ্যে ২৫ হলো ৫০%।"
          }
        },
        {
          "@type": "Question",
          "name": "শতাংশ পরিবর্তন কীভাবে হিসাব করব?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "শতাংশ পরিবর্তন = ((নতুন মান - আগের মান) ÷ আগের মান) × ১০০।"
          }
        },
        {
          "@type": "Question",
          "name": "৫০০ টাকার ১৮% কত?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "৫০০ × (১৮ ÷ ১০০) = ৯০ টাকা।"
          }
        },
        {
          "@type": "Question",
          "name": "শতাংশ বৃদ্ধি ও হ্রাসের পার্থক্য কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "পরিবর্তনের সূত্রে ফলাফল ধনাত্মক (+) হলে বৃদ্ধি, ঋণাত্মক (-) হলে হ্রাস।"
          }
        },
        {
          "@type": "Question",
          "name": "পরীক্ষায় মোট নম্বর ৫০০, পেয়েছি ৩৮৫ — শতাংশ কত?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "(৩৮৫ ÷ ৫০০) × ১০০ = ৭৭%।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="Percentage Calculator — শতাংশ ক্যালকুলেটর | BanglaTools"
  description="Calculate percentage easily — 3 types of percentage calculation in one page. শতাংশ ক্যালকুলেটর দিয়ে সহজে শতাংশ বের করুন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <!-- H1 -->
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="শতাংশ ক্যালকুলেটর — শতাংশ বের করার নিয়ম" data-en="Percentage Calculator">শতাংশ ক্যালকুলেটর — শতাংশ বের করার নিয়ম</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="তিন ধরনের শতাংশ হিসাব এক পাতায় — সহজে ও দ্রুত" data-en="Three types of percentage calculations on one page — quick and easy">তিন ধরনের শতাংশ হিসাব এক পাতায় — সহজে ও দ্রুত</span>
  </p>

  <!-- AdSlot above tool -->
  <AdSlot slot="above-tool" />

  <!-- Tool Section -->
  <div class="space-y-6 mb-8">

    <!-- Calculator 1: X is what % of Y -->
    <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-teal-700 mb-4">
        <span data-bn="X, Y-এর কত শতাংশ?" data-en="X is what % of Y?">X, Y-এর কত শতাংশ?</span>
      </h3>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="c1-x">
            <span data-bn="X (মান)" data-en="X (value)">X (মান)</span>
          </label>
          <input type="number" id="c1-x" placeholder="যেমন: 25" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="c1-y">
            <span data-bn="Y (মোট)" data-en="Y (total)">Y (মোট)</span>
          </label>
          <input type="number" id="c1-y" placeholder="যেমন: 200" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
      </div>
      <div id="c1-result" class="hidden bg-teal-50 border border-teal-200 rounded-xl p-4 text-center">
        <p class="text-sm text-gray-500 mb-1">
          <span data-bn="ফলাফল" data-en="Result">ফলাফল</span>
        </p>
        <p id="c1-answer" class="text-4xl font-bold text-teal-700"></p>
        <p id="c1-formula" class="text-sm text-gray-500 mt-1"></p>
      </div>
    </div>

    <!-- Calculator 2: What is X% of Y -->
    <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-teal-700 mb-4">
        <span data-bn="Y-এর X% কত?" data-en="What is X% of Y?">Y-এর X% কত?</span>
      </h3>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="c2-x">
            <span data-bn="X (শতাংশ %)" data-en="X (percentage %)">X (শতাংশ %)</span>
          </label>
          <input type="number" id="c2-x" placeholder="যেমন: 15" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="c2-y">
            <span data-bn="Y (মোট মান)" data-en="Y (total value)">Y (মোট মান)</span>
          </label>
          <input type="number" id="c2-y" placeholder="যেমন: 500" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
      </div>
      <div id="c2-result" class="hidden bg-teal-50 border border-teal-200 rounded-xl p-4 text-center">
        <p class="text-sm text-gray-500 mb-1">
          <span data-bn="ফলাফল" data-en="Result">ফলাফল</span>
        </p>
        <p id="c2-answer" class="text-4xl font-bold text-teal-700"></p>
        <p id="c2-formula" class="text-sm text-gray-500 mt-1"></p>
      </div>
    </div>

    <!-- Calculator 3: Percentage Change -->
    <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
      <h3 class="text-lg font-bold text-teal-700 mb-4">
        <span data-bn="X থেকে Y-এ কত % পরিবর্তন?" data-en="% change from X to Y?">X থেকে Y-এ কত % পরিবর্তন?</span>
      </h3>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="c3-x">
            <span data-bn="X (আগের মান)" data-en="X (original value)">X (আগের মান)</span>
          </label>
          <input type="number" id="c3-x" placeholder="যেমন: 100" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="c3-y">
            <span data-bn="Y (নতুন মান)" data-en="Y (new value)">Y (নতুন মান)</span>
          </label>
          <input type="number" id="c3-y" placeholder="যেমন: 125" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
      </div>
      <div id="c3-result" class="hidden bg-teal-50 border border-teal-200 rounded-xl p-4 text-center">
        <p class="text-sm text-gray-500 mb-1">
          <span data-bn="ফলাফল" data-en="Result">ফলাফল</span>
        </p>
        <p id="c3-answer" class="text-4xl font-bold text-teal-700"></p>
        <p id="c3-label" class="text-sm font-semibold mt-1"></p>
        <p id="c3-formula" class="text-sm text-gray-500 mt-1"></p>
      </div>
    </div>

  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="প্রথম ক্যালকুলেটর: X এবং Y দিন — X, Y-এর কত শতাংশ তা জানতে" data-en="First calculator: Enter X and Y to find what percentage X is of Y">প্রথম ক্যালকুলেটর: X এবং Y দিন — X, Y-এর কত শতাংশ তা জানতে</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="দ্বিতীয় ক্যালকুলেটর: শতাংশ ও মোট মান দিন — ওই শতাংশ পরিমাণ বের করতে" data-en="Second calculator: Enter the percentage and total value to find the amount">দ্বিতীয় ক্যালকুলেটর: শতাংশ ও মোট মান দিন — ওই শতাংশ পরিমাণ বের করতে</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="তৃতীয় ক্যালকুলেটর: আগের ও নতুন মান দিন — পার্থক্যের শতাংশ বের করতে" data-en="Third calculator: Enter old and new values to find the percentage change">তৃতীয় ক্যালকুলেটর: আগের ও নতুন মান দিন — পার্থক্যের শতাংশ বের করতে</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৪.</span>
        <span data-bn="সব হিসাব রিয়েল-টাইমে আপডেট হয়, কোনো বাটন চাপতে হয় না" data-en="All calculations update in real time — no button press needed">সব হিসাব রিয়েল-টাইমে আপডেট হয়, কোনো বাটন চাপতে হয় না</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        এই শতাংশ ক্যালকুলেটরটি তিনটি আলাদা ধরনের শতাংশ হিসাব একসাথে করতে পারে। প্রথম ক্যালকুলেটরটি জানায় যে কোনো একটি সংখ্যা আরেকটি সংখ্যার কত শতাংশ — যেমন পরীক্ষায় পাওয়া নম্বর মোট নম্বরের কত শতাংশ। দ্বিতীয় ক্যালকুলেটর দিয়ে কোনো মানের নির্দিষ্ট শতাংশ বের করা যায় — যেমন ১০০০ টাকার ১৫% কত। তৃতীয় ক্যালকুলেটর দুটি সংখ্যার মধ্যে শতাংশ পরিবর্তন দেখায় — কোনো কিছুর দাম বা পরিমাণ কতটুকু বাড়ল বা কমল তা শতাংশে প্রকাশ করে। ব্যবসায়, পড়াশোনা, বা দৈনন্দিন জীবনে শতাংশ হিসাব অত্যন্ত গুরুত্বপূর্ণ। এই টুলটি সম্পূর্ণ বিনামূল্যে এবং ইন্টারনেট ছাড়াও কাজ করে।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ১: পরীক্ষার নম্বর" data-en="Example 1: Exam score percentage">উদাহরণ ১: পরীক্ষার নম্বর</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="X = ৭৫ (পাওয়া নম্বর), Y = ১০০ (মোট নম্বর)" data-en="X = 75 (marks obtained), Y = 100 (total marks)">X = ৭৫ (পাওয়া নম্বর), Y = ১০০ (মোট নম্বর)</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: (৭৫ ÷ ১০০) × ১০০ = ৭৫%" data-en="Result: (75 ÷ 100) × 100 = 75%">ফলাফল: (৭৫ ÷ ১০০) × ১০০ = ৭৫%</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ২: দামের উপর ছাড়" data-en="Example 2: Discount on price">উদাহরণ ২: দামের উপর ছাড়</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="X = ২০% (ছাড়), Y = ৫০০ টাকা (মূল দাম)" data-en="X = 20% (discount), Y = ₹500 (original price)">X = ২০% (ছাড়), Y = ৫০০ টাকা (মূল দাম)</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: (২০ ÷ ১০০) × ৫০০ = ১০০ টাকা ছাড়" data-en="Result: (20 ÷ 100) × 500 = ₹100 discount">ফলাফল: (২০ ÷ ১০০) × ৫০০ = ১০০ টাকা ছাড়</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ৩: দামের পরিবর্তন" data-en="Example 3: Price change">উদাহরণ ৩: দামের পরিবর্তন</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="X = ৮০ (আগের দাম), Y = ১০০ (নতুন দাম)" data-en="X = 80 (old price), Y = 100 (new price)">X = ৮০ (আগের দাম), Y = ১০০ (নতুন দাম)</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="ফলাফল: ((১০০ - ৮০) ÷ ৮০) × ১০০ = ২৫% বৃদ্ধি" data-en="Result: ((100 - 80) ÷ 80) × 100 = 25% increase">ফলাফল: ((১০০ - ৮০) ÷ ৮০) × ১০০ = ২৫% বৃদ্ধি</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="শতাংশ বের করার সূত্র কী?" data-en="What is the formula for percentage?">শতাংশ বের করার সূত্র কী?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="শতাংশ = (অংশ ÷ মোট) × ১০০। যেমন ৫০ এর মধ্যে ২৫ হলো ৫০%।" data-en="Percentage = (part ÷ whole) × 100. For example, 25 out of 50 is 50%.">শতাংশ = (অংশ ÷ মোট) × ১০০। যেমন ৫০ এর মধ্যে ২৫ হলো ৫০%।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="শতাংশ পরিবর্তন কীভাবে হিসাব করব?" data-en="How do I calculate percentage change?">শতাংশ পরিবর্তন কীভাবে হিসাব করব?</span>
        </summary>
        <p class="mt-3 text-gray-700">
