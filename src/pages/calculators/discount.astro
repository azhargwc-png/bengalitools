<script>
  let currency = '₹';

  // Currency toggle
  const btnInr = document.getElementById('btn-inr')!;
  const btnBdt = document.getElementById('btn-bdt')!;
  const currencyLabels = [
    document.getElementById('m1-currency-label')!,
    document.getElementById('m2-currency-label')!,
    document.getElementById('m2-currency-label2')!
  ];

  function setCurrency(sym: string) {
    currency = sym;
    currencyLabels.forEach(el => el.textContent = sym);
    calcMode1();
    calcMode2();
  }

  btnInr.addEventListener('click', () => {
    btnInr.className = 'px-4 py-2 rounded-lg text-sm font-semibold bg-teal-600 text-white transition-all';
    btnBdt.className = 'px-4 py-2 rounded-lg text-sm font-semibold bg-gray-200 text-gray-700 transition-all';
    setCurrency('₹');
  });
  btnBdt.addEventListener('click', () => {
    btnBdt.className = 'px-4 py-2 rounded-lg text-sm font-semibold bg-teal-600 text-white transition-all';
    btnInr.className = 'px-4 py-2 rounded-lg text-sm font-semibold bg-gray-200 text-gray-700 transition-all';
    setCurrency('৳');
  });

  // Mode tabs
  const tabMode1 = document.getElementById('tab-mode1')!;
  const tabMode2 = document.getElementById('tab-mode2')!;
  const mode1 = document.getElementById('mode1')!;
  const mode2 = document.getElementById('mode2')!;

  tabMode1.addEventListener('click', () => {
    tabMode1.className = 'flex-1 py-2 px-4 rounded-xl text-sm font-semibold bg-teal-600 text-white transition-all';
    tabMode2.className = 'flex-1 py-2 px-4 rounded-xl text-sm font-semibold bg-gray-200 text-gray-700 transition-all';
    mode1.classList.remove('hidden');
    mode2.classList.add('hidden');
  });
  tabMode2.addEventListener('click', () => {
    tabMode2.className = 'flex-1 py-2 px-4 rounded-xl text-sm font-semibold bg-teal-600 text-white transition-all';
    tabMode1.className = 'flex-1 py-2 px-4 rounded-xl text-sm font-semibold bg-gray-200 text-gray-700 transition-all';
    mode2.classList.remove('hidden');
    mode1.classList.add('hidden');
  });

  // Mode 1
  const m1price = document.getElementById('m1-price') as HTMLInputElement;
  const m1discount = document.getElementById('m1-discount') as HTMLInputElement;
  const m1result = document.getElementById('m1-result')!;

  function calcMode1() {
    const price = parseFloat(m1price.value);
    const disc = parseFloat(m1discount.value);
    if (!isNaN(price) && !isNaN(disc) && price > 0 && disc >= 0 && disc <= 100) {
      const discAmt = (disc / 100) * price;
      const final = price - discAmt;
      document.getElementById('m1-original-display')!.textContent = currency + price.toFixed(2);
      document.getElementById('m1-pct-badge')!.textContent = disc + '% OFF';
      document.getElementById('m1-final-price')!.textContent = currency + final.toFixed(2);
      document.getElementById('m1-discount-amt')!.textContent = currency + discAmt.toFixed(2);
      document.getElementById('m1-savings')!.textContent = currency + discAmt.toFixed(2);
      m1result.classList.remove('hidden');
    } else {
      m1result.classList.add('hidden');
    }
  }
  m1price.addEventListener('input', calcMode1);
  m1discount.addEventListener('input', calcMode1);

  // Mode 2
  const m2original = document.getElementById('m2-original') as HTMLInputElement;
  const m2sale = document.getElementById('m2-sale') as HTMLInputElement;
  const m2result = document.getElementById('m2-result')!;

  function calcMode2() {
    const orig = parseFloat(m2original.value);
    const sale = parseFloat(m2sale.value);
    if (!isNaN(orig) && !isNaN(sale) && orig > 0 && sale >= 0 && sale <= orig) {
      const saved = orig - sale;
      const pct = (saved / orig) * 100;
      document.getElementById('m2-pct')!.textContent = pct.toFixed(2) + '%';
      document.getElementById('m2-saved')!.textContent = currency + saved.toFixed(2);
      document.getElementById('m2-final')!.textContent = currency + sale.toFixed(2);
      m2result.classList.remove('hidden');
    } else {
      m2result.classList.add('hidden');
    }
  }
  m2original.addEventListener('input', calcMode2);
  m2sale.addEventListener('input', calcMode2);

  function resetDiscount() {
    m1price.value = '';
    m1discount.value = '';
    m2original.value = '';
    m2sale.value = '';
    m1result.classList.add('hidden');
    m2result.classList.add('hidden');
  }

  (window as any).resetDiscount = resetDiscount;
</script>
