---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "গতি ক্যালকুলেটর",
      "url": "https://www.bengalitools.com/calculators/speed/",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Web Browser",
      "inLanguage": "bn",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "গতি, দূরত্ব ও সময়ের সূত্র কী?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "গতি = দূরত্ব ÷ সময় | দূরত্ব = গতি × সময় | সময় = দূরত্ব ÷ গতি।"
          }
        },
        {
          "@type": "Question",
          "name": "km/h থেকে m/s কীভাবে রূপান্তর করব?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "km/h কে ০.২৭৭৮ দিয়ে গুণ করুন। যেমন ৭২ km/h = ২০ m/s।"
          }
        },
        {
          "@type": "Question",
          "name": "গড় গতি বলতে কী বোঝায়?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "গড় গতি = মোট দূরত্ব ÷ মোট সময়।"
          }
        },
        {
          "@type": "Question",
          "name": "ঢাকা থেকে কলকাতা যেতে কতক্ষণ লাগে?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "দূরত্ব প্রায় ২৮০ km। গড় ৬০ km/h হলে প্রায় ৪-৫ ঘণ্টা লাগে।"
          }
        },
        {
          "@type": "Question",
          "name": "mph কি ভারতে ব্যবহার হয়?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "না, ভারত ও বাংলাদেশে km/h ব্যবহার হয়। mph মূলত যুক্তরাষ্ট্র ও যুক্তরাজ্যে ব্যবহার হয়।"
          }
        }
      ]
    }
  ]
};
---

<ToolLayout
  title="গতি ক্যালকুলেটর — দূরত্ব সময় গতি | BanglaTools"
  description="গতি, দূরত্ব ও সময় হিসাব করুন। তিনটি মোডে সহজে হিসাব করুন।"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)}></script>
  <!-- H1 -->
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="গতি ক্যালকুলেটর — দূরত্ব সময় গতি" data-en="Speed Distance Time Calculator">গতি ক্যালকুলেটর — দূরত্ব সময় গতি</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="গতি, দূরত্ব বা সময় — যেকোনো একটি হিসাব করুন" data-en="Calculate speed, distance or time — choose any one">গতি, দূরত্ব বা সময় — যেকোনো একটি হিসাব করুন</span>
  </p>

  <!-- AdSlot above tool -->
  <AdSlot slot="above-tool" />

  <!-- Tool -->
  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">

    <!-- Mode Selector -->
    <div class="grid grid-cols-3 gap-2 mb-6">
      <button id="mode-speed" class="mode-btn py-2 px-3 rounded-xl text-sm font-semibold bg-teal-600 text-white transition-all min-h-[44px]">
        <span data-bn="গতি বের করুন" data-en="Find Speed">গতি বের করুন</span>
      </button>
      <button id="mode-dist" class="mode-btn py-2 px-3 rounded-xl text-sm font-semibold bg-gray-200 text-gray-700 transition-all min-h-[44px]">
        <span data-bn="দূরত্ব বের করুন" data-en="Find Distance">দূরত্ব বের করুন</span>
      </button>
      <button id="mode-time" class="mode-btn py-2 px-3 rounded-xl text-sm font-semibold bg-gray-200 text-gray-700 transition-all min-h-[44px]">
        <span data-bn="সময় বের করুন" data-en="Find Time">সময় বের করুন</span>
      </button>
    </div>

    <!-- Formula Display -->
    <div id="formula-display" class="bg-teal-50 border border-teal-200 rounded-xl p-3 text-center text-sm font-mono text-teal-800 mb-5">
      গতি = দূরত্ব ÷ সময় / Speed = Distance ÷ Time
    </div>

    <!-- Unit Selector -->
    <div class="mb-5">
      <label class="block text-sm font-medium text-gray-700 mb-1">
        <span data-bn="গতির একক" data-en="Speed Unit">গতির একক</span>
      </label>
      <select id="unit-select" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]">
        <option value="kmh">km/h (কিলোমিটার/ঘণ্টা)</option>
        <option value="ms">m/s (মিটার/সেকেন্ড)</option>
        <option value="mph">mph (মাইল/ঘণ্টা)</option>
      </select>
    </div>

    <!-- Mode: Find Speed -->
    <div id="panel-speed">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="sp-distance">
            <span data-bn="দূরত্ব (km)" data-en="Distance (km)">দূরত্ব (km)</span>
          </label>
          <input type="number" id="sp-distance" placeholder="যেমন: 180" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            <span data-bn="সময় (ঘণ্টা ও মিনিট)" data-en="Time (hours and minutes)">সময় (ঘণ্টা ও মিনিট)</span>
          </label>
          <div class="grid grid-cols-2 gap-2">
            <input type="number" id="sp-hours" placeholder="ঘণ্টা" min="0" class="w-full px-3 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
            <input type="number" id="sp-minutes" placeholder="মিনিট" min="0" max="59" class="w-full px-3 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
          </div>
        </div>
      </div>
    </div>

    <!-- Mode: Find Distance -->
    <div id="panel-dist" class="hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="dt-speed">
            <span data-bn="গতি" data-en="Speed">গতি</span>
          </label>
          <input type="number" id="dt-speed" placeholder="যেমন: 60" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            <span data-bn="সময় (ঘণ্টা ও মিনিট)" data-en="Time (hours and minutes)">সময় (ঘণ্টা ও মিনিট)</span>
          </label>
          <div class="grid grid-cols-2 gap-2">
            <input type="number" id="dt-hours" placeholder="ঘণ্টা" min="0" class="w-full px-3 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
            <input type="number" id="dt-minutes" placeholder="মিনিট" min="0" max="59" class="w-full px-3 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
          </div>
        </div>
      </div>
    </div>

    <!-- Mode: Find Time -->
    <div id="panel-time" class="hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="tm-distance">
            <span data-bn="দূরত্ব (km)" data-en="Distance (km)">দূরত্ব (km)</span>
          </label>
          <input type="number" id="tm-distance" placeholder="যেমন: 570" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="tm-speed">
            <span data-bn="গতি" data-en="Speed">গতি</span>
          </label>
          <input type="number" id="tm-speed" placeholder="যেমন: 80" class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-lg focus:border-teal-500 focus:outline-none min-h-[44px]" />
        </div>
      </div>
    </div>

    <!-- Result -->
    <div id="speed-result" class="hidden bg-teal-50 border border-teal-200 rounded-xl p-5 text-center">
      <p class="text-sm text-gray-500 mb-1" id="result-label-text">ফলাফল / Result</p>
      <p id="speed-answer" class="text-4xl font-bold text-teal-700 mb-2"></p>
      <p id="speed-formula-text" class="text-sm text-gray-500"></p>
      <p id="speed-conversions" class="text-xs text-gray-400 mt-2"></p>
    </div>

  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="কী বের করতে চান তা বেছে নিন — গতি, দূরত্ব বা সময়" data-en="Select what you want to find — speed, distance or time">কী বের করতে চান তা বেছে নিন — গতি, দূরত্ব বা সময়</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="একক বেছে নিন — km/h, m/s বা mph" data-en="Select the unit — km/h, m/s or mph">একক বেছে নিন — km/h, m/s বা mph</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="পরিচিত দুটি মান দিন — ঘণ্টা ও মিনিট আলাদা ঘরে দিতে পারবেন" data-en="Enter the two known values — hours and minutes can be entered separately">পরিচিত দুটি মান দিন — ঘণ্টা ও মিনিট আলাদা ঘরে দিতে পারবেন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৪.</span>
        <span data-bn="ফলাফল ও রূপান্তর মান সঙ্গে সঙ্গে দেখাবে" data-en="Result and unit conversions appear instantly">ফলাফল ও রূপান্তর মান সঙ্গে সঙ্গে দেখাবে</span>
      </li>
    </ol>
  </section>

  <!-- What this tool does -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="এই টুলটি কী করে" data-en="What This Tool Does">এই টুলটি কী করে</span>
    </h2>
    <div class="text-gray-700 leading-relaxed">
      <p>
        এই গতি ক্যালকুলেটরটি তিনটি মোডে কাজ করে। গতি মোডে দূরত্ব ও সময় দিলে গতি বের হয়। দূরত্ব মোডে গতি ও সময় দিলে দূরত্ব বের হয়। সময় মোডে দূরত্ব ও গতি দিলে কতক্ষণ লাগবে তা বের হয়। সময় ঘণ্টা ও মিনিট আলাদা ঘরে দেওয়া যায় — যা হিসাব সহজ করে। km/h, m/s ও mph একক সাপোর্ট করে। হাঁটা, সাইকেল চালানো, গাড়ি চালানো বা ট্রেনের গতি — সব ক্ষেত্রেই ব্যবহার করা যায়। পদার্থবিজ্ঞান ও গণিতের ছাত্রছাত্রীদের জন্যও উপকারী।
      </p>
    </div>
  </section>

  <!-- Examples -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="উদাহরণ" data-en="Examples">উদাহরণ</span>
    </h2>
    <div class="space-y-4">
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ১: সকালের হাঁটা" data-en="Example 1: Morning walk">উদাহরণ ১: সকালের হাঁটা</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="দূরত্ব: ৩ km, সময়: ৪৫ মিনিট" data-en="Distance: 3 km, Time: 45 minutes">দূরত্ব: ৩ km, সময়: ৪৫ মিনিট</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="গতি: ৪ km/h" data-en="Speed: 4 km/h">গতি: ৪ km/h</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ২: কলকাতা থেকে দিঘা হাইওয়ে ড্রাইভ" data-en="Example 2: Kolkata to Digha highway drive">উদাহরণ ২: কলকাতা থেকে দিঘা হাইওয়ে ড্রাইভ</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="দূরত্ব: ১৮০ km, গতি: ৬০ km/h" data-en="Distance: 180 km, Speed: 60 km/h">দূরত্ব: ১৮০ km, গতি: ৬০ km/h</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="সময়: ৩ ঘণ্টা" data-en="Time: 3 hours">সময়: ৩ ঘণ্টা</span>
        </p>
      </div>
      <div class="bg-teal-50 rounded-xl p-4 border border-teal-200">
        <p class="font-semibold text-teal-800">
          <span data-bn="উদাহরণ ৩: কলকাতা থেকে শিলিগুড়ি" data-en="Example 3: Kolkata to Siliguri">উদাহরণ ৩: কলকাতা থেকে শিলিগুড়ি</span>
        </p>
        <p class="text-gray-700 mt-1">
          <span data-bn="দূরত্ব: ৫৭০ km, সময়: ৮ ঘণ্টা ৩০ মিনিট" data-en="Distance: 570 km, Time: 8 hours 30 minutes">দূরত্ব: ৫৭০ km, সময়: ৮ ঘণ্টা ৩০ মিনিট</span>
        </p>
        <p class="text-gray-700 font-medium">
          <span data-bn="গড় গতি: প্রায় ৬৭ km/h" data-en="Average speed: approximately 67 km/h">গড় গতি: প্রায় ৬৭ km/h</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="গতি, দূরত্ব ও সময়ের সূত্র কী?" data-en="What are the formulas for speed, distance and time?">গতি, দূরত্ব ও সময়ের সূত্র কী?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="গতি = দূরত্ব ÷ সময় | দূরত্ব = গতি × সময় | সময় = দূরত্ব ÷ গতি। এই তিনটি সূত্র একটি মূল সম্পর্ক থেকে আসে।" data-en="Speed = Distance ÷ Time | Distance = Speed × Time | Time = Distance ÷ Speed. All three formulas derive from one fundamental relationship.">গতি = দূরত্ব ÷ সময় | দূরত্ব = গতি × সময় | সময় = দূরত্ব ÷ গতি। এই তিনটি সূত্র একটি মূল সম্পর্ক থেকে আসে।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="km/h থেকে m/s কীভাবে রূপান্তর করব?" data-en="How to convert km/h to m/s?">km/h থেকে m/s কীভাবে রূপান্তর করব?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="km/h কে ১০০০ দিয়ে গুণ করে ৩৬০০ দিয়ে ভাগ করুন, অথবা ০.২৭৭৮ দিয়ে গুণ করুন। যেমন ৭২ km/h = ২০ m/s।" data-en="Multiply km/h by 1000 and divide by 3600, or multiply by 0.2778. E.g., 72 km/h = 20 m/s.">km/h কে ১০০০ দিয়ে গুণ করে ৩৬০০ দিয়ে ভাগ করুন, অথবা ০.২৭৭৮ দিয়ে গুণ করুন। যেমন ৭২ km/h = ২০ m/s।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
