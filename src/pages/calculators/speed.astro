<script>
  let currentMode = 'speed';
  const unitSelect = document.getElementById('unit-select') as HTMLSelectElement;
  const speedResult = document.getElementById('speed-result')!;
  const formulaDisplay = document.getElementById('formula-display')!;

  const formulas: Record<string, string> = {
    speed: 'গতি = দূরত্ব ÷ সময় / Speed = Distance ÷ Time',
    dist: 'দূরত্ব = গতি × সময় / Distance = Speed × Time',
    time: 'সময় = দূরত্ব ÷ গতি / Time = Distance ÷ Speed'
  };

  const modeBtns = document.querySelectorAll('.mode-btn') as NodeListOf<HTMLButtonElement>;
  const panels: Record<string, HTMLElement> = {
    speed: document.getElementById('panel-speed')!,
    dist: document.getElementById('panel-dist')!,
    time: document.getElementById('panel-time')!
  };

  function setMode(mode: string) {
    currentMode = mode;
    Object.keys(panels).forEach(k => {
      panels[k].classList.toggle('hidden', k !== mode);
    });
    formulaDisplay.textContent = formulas[mode];
    modeBtns.forEach(btn => {
      const btnMode = btn.id.replace('mode-', '');
      if (btnMode === mode) {
        btn.className = 'mode-btn py-2 px-3 rounded-xl text-sm font-semibold bg-teal-600 text-white transition-all min-h-[44px]';
      } else {
        btn.className = 'mode-btn py-2 px-3 rounded-xl text-sm font-semibold bg-gray-200 text-gray-700 transition-all min-h-[44px]';
      }
    });
    speedResult.classList.add('hidden');
  }

  document.getElementById('mode-speed')!.addEventListener('click', () => setMode('speed'));
  document.getElementById('mode-dist')!.addEventListener('click', () => setMode('dist'));
  document.getElementById('mode-time')!.addEventListener('click', () => setMode('time'));

  function getUnitLabel(): string {
    const u = unitSelect.value;
    if (u === 'kmh') return 'km/h';
    if (u === 'ms') return 'm/s';
    return 'mph';
  }

  function getDistanceUnit(): string {
    const u = unitSelect.value;
    if (u === 'ms') return 'm';
    if (u === 'mph') return 'miles';
    return 'km';
  }

  function speedConversions(kmh: number): string {
    const ms = kmh / 3.6;
    const mph = kmh / 1.609;
    return `${kmh.toFixed(2)} km/h = ${ms.toFixed(2)} m/s = ${mph.toFixed(2)} mph`;
  }

  function getTimeHours(hoursId: string, minutesId: string): number {
    const h = parseFloat((document.getElementById(hoursId) as HTMLInputElement).value) || 0;
    const m = parseFloat((document.getElementById(minutesId) as HTMLInputElement).value) || 0;
    return h + m / 60;
  }

  function formatTime(hours: number): string {
    const h = Math.floor(hours);
    const m = Math.round((hours - h) * 60);
    if (h === 0) return `${m} মিনিট / ${m} minutes`;
    if (m === 0) return `${h} ঘণ্টা / ${h} hours`;
    return `${h} ঘণ্টা ${m} মিনিট / ${h} hrs ${m} min`;
  }

  function calculate() {
    const unit = unitSelect.value;
    speedResult.classList.add('hidden');

    if (currentMode === 'speed') {
      const dist = parseFloat((document.getElementById('sp-distance') as HTMLInputElement).value);
      const timeH = getTimeHours('sp-hours', 'sp-minutes');
      if (!isNaN(dist) && dist > 0 && timeH > 0) {
        let speed = dist / timeH;
        if (unit === 'ms') speed = (dist * 1000) / (timeH * 3600);
        else if (unit === 'mph') speed = dist / 1.609 / timeH;
        document.getElementById('result-label-text')!.textContent = 'গতি / Speed';
        document.getElementById('speed-answer')!.textContent = speed.toFixed(2) + ' ' + getUnitLabel();
        document.getElementById('speed-formula-text')!.textContent = `${dist} ÷ ${timeH.toFixed(2)} = ${speed.toFixed(2)} ${getUnitLabel()}`;
        const kmhSpeed = unit === 'kmh' ? speed : unit === 'ms' ? speed * 3.6 : speed * 1.609;
        document.getElementById('speed-conversions')!.textContent = speedConversions(kmhSpeed);
        speedResult.classList.remove('hidden');
      }
    } else if (currentMode === 'dist') {
      const speed = parseFloat((document.getElementById('dt-speed') as HTMLInputElement).value);
      const timeH = getTimeHours('dt-hours', 'dt-minutes');
      if (!isNaN(speed) && speed > 0 && timeH > 0) {
        let dist = speed * timeH;
        if (unit === 'ms') dist = speed * timeH * 3600 / 1000;
        else if (unit === 'mph') dist = speed * 1.609 * timeH;
        document.getElementById('result-label-text')!.textContent = 'দূরত্ব / Distance';
        document.getElementById('speed-answer')!.textContent = dist.toFixed(2) + ' ' + getDistanceUnit();
        document.getElementById('speed-formula-text')!.textContent = `${speed} × ${timeH.toFixed(2)} = ${dist.toFixed(2)} ${getDistanceUnit()}`;
        document.getElementById('speed-conversions')!.textContent = '';
        speedResult.classList.remove('hidden');
      }
    } else if (currentMode === 'time') {
      const dist = parseFloat((document.getElementById('tm-distance') as HTMLInputElement).value);
      const speed = parseFloat((document.getElementById('tm-speed') as HTMLInputElement).value);
      if (!isNaN(dist) && dist > 0 && !isNaN(speed) && speed > 0) {
        let timeH = dist / speed;
        if (unit === 'ms') timeH = (dist * 1000) / (speed * 3600);
        else if (unit === 'mph') timeH = (dist / 1.609) / speed;
        document.getElementById('result-label-text')!.textContent = 'সময় / Time';
        document.getElementById('speed-answer')!.textContent = formatTime(timeH);
        document.getElementById('speed-formula-text')!.textContent = `${dist} ÷ ${speed} = ${timeH.toFixed(3)} ঘণ্টা / hours`;
        document.getElementById('speed-conversions')!.textContent = '';
        speedResult.classList.remove('hidden');
      }
    }
  }

  // Add listeners to all inputs
  ['sp-distance', 'sp-hours', 'sp-minutes', 'dt-speed', 'dt-hours', 'dt-minutes', 'tm-distance', 'tm-speed'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculate);
  });
  unitSelect.addEventListener('change', calculate);
</script>
