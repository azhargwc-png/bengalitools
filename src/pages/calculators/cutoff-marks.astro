---
import ToolLayout from '../../layouts/ToolLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import AdSlot from '../../components/AdSlot.astro';
---

<ToolLayout
  title="কাট-অফ মার্কস ক্যালকুলেটর — পরীক্ষার নম্বর ও শতাংশ | BanglaTools"
  titleBn="কাট-অফ মার্কস ক্যালকুলেটর — পরীক্ষার নম্বর ও শতাংশ | BanglaTools"
  description="মাধ্যমিক, উচ্চমাধ্যমিক, SSC, PSC পরীক্ষার প্রাপ্ত নম্বর থেকে শতাংশ বের করুন। বিষয়ভিত্তিক নম্বর যোগ করুন, কাট-অফ তুলনা করুন।"
  descriptionBn="মাধ্যমিক, উচ্চমাধ্যমিক, SSC, PSC পরীক্ষার প্রাপ্ত নম্বর থেকে শতাংশ বের করুন।"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">
    <span data-bn="কাট-অফ মার্কস ক্যালকুলেটর" data-en="Cut-off Marks Calculator">কাট-অফ মার্কস ক্যালকুলেটর</span>
  </h1>
  <p class="text-gray-600 mb-6 text-lg">
    <span data-bn="প্রাপ্ত নম্বর থেকে শতাংশ বের করুন এবং সাধারণ কাট-অফের সাথে তুলনা করুন" data-en="Calculate your percentage from marks and compare against common cut-offs">প্রাপ্ত নম্বর থেকে শতাংশ বের করুন এবং সাধারণ কাট-অফের সাথে তুলনা করুন</span>
  </p>

  <AdSlot slot="above-tool" />

  <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-200">

    <!-- Mode tabs -->
    <div class="flex gap-2 mb-5">
      <button id="tab-simple" class="tab-btn flex-1 py-2 rounded-xl text-sm font-bold border-2 border-teal-500 bg-teal-500 text-white transition-all min-h-[44px]">
        <span data-bn="সরল মোড" data-en="Simple Mode">সরল মোড</span>
      </button>
      <button id="tab-multi" class="tab-btn flex-1 py-2 rounded-xl text-sm font-bold border-2 border-gray-300 bg-white text-gray-700 hover:border-teal-500 transition-all min-h-[44px]">
        <span data-bn="বিষয়ভিত্তিক মোড" data-en="Subject-wise Mode">বিষয়ভিত্তিক মোড</span>
      </button>
    </div>

    <!-- Simple mode -->
    <div id="simple-mode">
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="obtained">
            <span data-bn="প্রাপ্ত নম্বর" data-en="Marks Obtained">প্রাপ্ত নম্বর</span>
          </label>
          <input type="number" id="obtained" placeholder="যেমন: 432" min="0" step="any"
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-xl focus:border-teal-500 focus:outline-none min-h-[52px]" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="total">
            <span data-bn="মোট নম্বর" data-en="Total Marks">মোট নম্বর</span>
          </label>
          <input type="number" id="total" placeholder="যেমন: 600" min="1" step="any"
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl text-xl focus:border-teal-500 focus:outline-none min-h-[52px]" />
        </div>
      </div>
    </div>

    <!-- Subject-wise mode -->
    <div id="multi-mode" class="hidden">
      <!-- Presets -->
      <div class="flex gap-2 mb-4 flex-wrap">
        <button data-preset="madhyamik" class="preset-btn px-3 py-2 rounded-lg text-sm font-semibold border-2 border-gray-300 bg-white text-gray-700 hover:border-teal-500 transition-all min-h-[44px]">মাধ্যমিক</button>
        <button data-preset="hs" class="preset-btn px-3 py-2 rounded-lg text-sm font-semibold border-2 border-gray-300 bg-white text-gray-700 hover:border-teal-500 transition-all min-h-[44px]">উচ্চমাধ্যমিক</button>
        <button data-preset="clear" class="preset-btn px-3 py-2 rounded-lg text-sm font-semibold border-2 border-gray-300 bg-white text-gray-700 hover:border-teal-500 transition-all min-h-[44px]">
          <span data-bn="পরিষ্কার" data-en="Clear">পরিষ্কার</span>
        </button>
      </div>

      <div id="subjects-list" class="space-y-3 mb-4">
        <!-- Rows injected by JS -->
      </div>

      <button id="add-subject" class="w-full py-2 border-2 border-dashed border-gray-300 rounded-xl text-sm font-medium text-gray-600 hover:border-teal-500 hover:text-teal-600 transition-all min-h-[44px]">
        <span data-bn="+ বিষয় যোগ করুন" data-en="+ Add Subject">+ বিষয় যোগ করুন</span>
      </button>
    </div>

    <!-- Result -->
    <div id="result-box" class="hidden mt-5">
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div class="bg-teal-600 text-white rounded-xl p-4 text-center">
          <p class="text-xs opacity-80 mb-1"><span data-bn="শতাংশ" data-en="Percentage">শতাংশ</span></p>
          <p id="res-pct" class="text-3xl font-bold">—</p>
        </div>
        <div class="bg-white border-2 border-gray-200 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1"><span data-bn="প্রাপ্ত" data-en="Obtained">প্রাপ্ত</span></p>
          <p id="res-obtained" class="text-2xl font-bold text-gray-900">—</p>
        </div>
        <div class="bg-white border-2 border-gray-200 rounded-xl p-4 text-center">
          <p class="text-xs text-gray-500 mb-1"><span data-bn="মোট" data-en="Total">মোট</span></p>
          <p id="res-total" class="text-2xl font-bold text-gray-900">—</p>
        </div>
      </div>

      <!-- Cut-off comparison -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-2 border-b border-gray-100">
          <span data-bn="সাধারণ কাট-অফের সাথে তুলনা" data-en="Cut-off Comparison">সাধারণ কাট-অফের সাথে তুলনা</span>
        </p>
        <div id="cutoff-rows" class="divide-y divide-gray-100"></div>
      </div>
    </div>

    <button onclick="resetCutoff()" class="mt-4 w-full py-2 px-4 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-sm font-medium transition-colors">
      <span data-bn="পরিষ্কার করুন ✕" data-en="Clear ✕">পরিষ্কার করুন ✕</span>
    </button>
  </div>

  <!-- How to use -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="কীভাবে ব্যবহার করবেন" data-en="How to Use">কীভাবে ব্যবহার করবেন</span>
    </h2>
    <ol class="space-y-3 text-gray-700">
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">১.</span>
        <span data-bn="সরল মোডে মোট প্রাপ্ত নম্বর ও পূর্ণমান লিখুন — অথবা বিষয়ভিত্তিক মোডে প্রতিটি বিষয়ের নম্বর দিন" data-en="In Simple mode enter total obtained and total marks — or in Subject-wise mode enter each subject separately">সরল মোডে মোট প্রাপ্ত নম্বর ও পূর্ণমান লিখুন — অথবা বিষয়ভিত্তিক মোডে প্রতিটি বিষয়ের নম্বর দিন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">২.</span>
        <span data-bn="শতাংশ তাৎক্ষণিকভাবে দেখুন" data-en="See your percentage instantly">শতাংশ তাৎক্ষণিকভাবে দেখুন</span>
      </li>
      <li class="flex gap-3">
        <span class="font-bold text-teal-700 min-w-[24px]">৩.</span>
        <span data-bn="সাধারণ পরীক্ষার কাট-অফের সাথে তুলনা দেখুন" data-en="Compare against common exam cut-offs">সাধারণ পরীক্ষার কাট-অফের সাথে তুলনা দেখুন</span>
      </li>
    </ol>
  </section>

  <!-- Common cutoffs table -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ পরীক্ষার আনুমানিক কাট-অফ" data-en="Approximate Cut-offs for Common Exams">সাধারণ পরীক্ষার আনুমানিক কাট-অফ</span>
    </h2>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="bg-teal-700 text-white">
            <th class="p-3 text-left rounded-tl-xl"><span data-bn="পরীক্ষা" data-en="Exam">পরীক্ষা</span></th>
            <th class="p-3 text-center"><span data-bn="বিভাগ" data-en="Category">বিভাগ</span></th>
            <th class="p-3 text-center rounded-tr-xl"><span data-bn="আনুমানিক কাট-অফ" data-en="Approx. Cut-off">আনুমানিক কাট-অফ</span></th>
          </tr>
        </thead>
        <tbody>
          <tr class="bg-white border-b border-gray-200">
            <td class="p-3 font-medium" rowspan="2">মাধ্যমিক (WBBSE)</td>
            <td class="p-3 text-center">প্রথম বিভাগ</td>
            <td class="p-3 text-center font-bold text-teal-700">৬০%+</td>
          </tr>
          <tr class="bg-white border-b border-gray-200">
            <td class="p-3 text-center">স্টার মার্কস</td>
            <td class="p-3 text-center font-bold text-teal-700">৭৫%+</td>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <td class="p-3 font-medium" rowspan="2">উচ্চমাধ্যমিক (WBCHSE)</td>
            <td class="p-3 text-center">প্রথম বিভাগ</td>
            <td class="p-3 text-center font-bold text-teal-700">৬০%+</td>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <td class="p-3 text-center">স্টার মার্কস</td>
            <td class="p-3 text-center font-bold text-teal-700">৭৫%+</td>
          </tr>
          <tr class="bg-white border-b border-gray-200">
            <td class="p-3 font-medium">SSC CGL (General)</td>
            <td class="p-3 text-center">—</td>
            <td class="p-3 text-center font-bold text-teal-700">~৭০%+</td>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <td class="p-3 font-medium">WB PSC Clerkship</td>
            <td class="p-3 text-center">General</td>
            <td class="p-3 text-center font-bold text-teal-700">~৬৫%+</td>
          </tr>
          <tr class="bg-white">
            <td class="p-3 font-medium rounded-bl-xl">Railway Group D</td>
            <td class="p-3 text-center">General</td>
            <td class="p-3 text-center font-bold text-teal-700 rounded-br-xl">~৫০%+</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-500 mt-2">
      <span data-bn="* কাট-অফ প্রতি বছর পরিবর্তন হয়। অফিশিয়াল নোটিফিকেশন দেখুন।" data-en="* Cut-offs change every year. Always check the official notification.">* কাট-অফ প্রতি বছর পরিবর্তন হয়। অফিশিয়াল নোটিফিকেশন দেখুন।</span>
    </p>
  </section>

  <!-- FAQ -->
  <section class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-4">
      <span data-bn="সাধারণ প্রশ্নোত্তর" data-en="Frequently Asked Questions">সাধারণ প্রশ্নোত্তর</span>
    </h2>
    <div class="space-y-4">
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="শতাংশ বের করার সূত্র কী?" data-en="What is the formula for percentage?">শতাংশ বের করার সূত্র কী?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="শতাংশ = (প্রাপ্ত নম্বর ÷ মোট নম্বর) × ১০০। উদাহরণ: ৪৫০ ÷ ৬০০ × ১০০ = ৭৫%।" data-en="Percentage = (Marks Obtained ÷ Total Marks) × 100. Example: 450 ÷ 600 × 100 = 75%.">শতাংশ = (প্রাপ্ত নম্বর ÷ মোট নম্বর) × ১০০। উদাহরণ: ৪৫০ ÷ ৬০০ × ১০০ = ৭৫%।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="মাধ্যমিকে প্রথম বিভাগ পেতে কত নম্বর লাগে?" data-en="How many marks for First Division in Madhyamik?">মাধ্যমিকে প্রথম বিভাগ পেতে কত নম্বর লাগে?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="মাধ্যমিকে ৬০০ নম্বরের মধ্যে ৩৬০ বা তার বেশি (৬০%) পেলে প্রথম বিভাগ। ৪৫০ বা তার বেশি (৭৫%) পেলে স্টার মার্কস।" data-en="In Madhyamik, 360 out of 600 (60%) or above = First Division. 450 or above (75%) = Star Marks.">মাধ্যমিকে ৬০০ নম্বরের মধ্যে ৩৬০ বা তার বেশি (৬০%) পেলে প্রথম বিভাগ। ৪৫০ বা তার বেশি (৭৫%) পেলে স্টার মার্কস।</span>
        </p>
      </details>
      <details class="bg-gray-50 rounded-xl p-4 border border-gray-200">
        <summary class="font-semibold text-gray-900 cursor-pointer">
          <span data-bn="কাট-অফ মার্কস মানে কী?" data-en="What does cut-off marks mean?">কাট-অফ মার্কস মানে কী?</span>
        </summary>
        <p class="mt-3 text-gray-700">
          <span data-bn="কাট-অফ মার্কস হল সেই ন্যূনতম নম্বর যা পেলে পরবর্তী ধাপে যাওয়া যায়। সরকারি চাকরির পরীক্ষায় কাট-অফ প্রতি বছর পরীক্ষার্থীর সংখ্যা ও পদের উপর নির্ভর করে পরিবর্তিত হয়।" data-en="Cut-off marks are the minimum marks required to qualify for the next stage. In government job exams, cut-offs change every year depending on the number of applicants and available posts.">কাট-অফ মার্কস হল সেই ন্যূনতম নম্বর যা পেলে পরবর্তী ধাপে যাওয়া যায়। সরকারি চাকরির পরীক্ষায় কাট-অফ প্রতি বছর পরীক্ষার্থীর সংখ্যা ও পদের উপর নির্ভর করে পরিবর্তিত হয়।</span>
        </p>
      </details>
    </div>
  </section>

  <AdSlot slot="below-faq" />

  <RelatedTools tools={[
    {
      url: "/calculators/marks-grade",
      nameBn: "নম্বর থেকে গ্রেড কনভার্টার",
      nameEn: "Marks to Grade Converter",
      descBn: "শতাংশ থেকে WB ও CBSE গ্রেড দেখুন",
      descEn: "Convert percentage to WB and CBSE grade",
      icon: "🎓"
    },
    {
      url: "/calculators/percentage",
      nameBn: "শতাংশ ক্যালকুলেটর",
      nameEn: "Percentage Calculator",
      descBn: "তিন ধরনের শতাংশ হিসাব",
      descEn: "Three types of percentage calculations",
      icon: "%"
    },
    {
      url: "/india/image-resizer",
      nameBn: "ফর্মের ছবি রিসাইজার",
      nameEn: "Form Photo Resizer",
      descBn: "SSC, PSC ফর্মের ছবি তৈরি করুন",
      descEn: "Resize photo for govt form applications",
      icon: "🖼️"
    }
  ]} />
</ToolLayout>

<script>
  const CUTOFFS = [
    { nameBn: 'মাধ্যমিক — স্টার মার্কস', nameEn: 'Madhyamik — Star Marks', pct: 75 },
    { nameBn: 'মাধ্যমিক — প্রথম বিভাগ', nameEn: 'Madhyamik — First Division', pct: 60 },
    { nameBn: 'উচ্চমাধ্যমিক — স্টার মার্কস', nameEn: 'HS — Star Marks', pct: 75 },
    { nameBn: 'উচ্চমাধ্যমিক — প্রথম বিভাগ', nameEn: 'HS — First Division', pct: 60 },
    { nameBn: 'SSC CGL (General)', nameEn: 'SSC CGL (General)', pct: 70 },
    { nameBn: 'WB PSC Clerkship', nameEn: 'WB PSC Clerkship', pct: 65 },
    { nameBn: 'Railway Group D', nameEn: 'Railway Group D', pct: 50 },
  ];

  const MADHYAMIK_SUBJECTS = ['বাংলা', 'ইংরেজি', 'গণিত', 'ইতিহাস', 'ভূগোল', 'জীবনবিজ্ঞান / ভৌতবিজ্ঞান'];
  const HS_SUBJECTS = ['বাংলা', 'ইংরেজি', 'বিষয় ৩', 'বিষয় ৪', 'বিষয় ৫'];

  let mode = 'simple';
  let subjectRows: { name: string; obtained: number | null; total: number | null }[] = [];

  // Tab switching
  document.getElementById('tab-simple')!.addEventListener('click', () => setMode('simple'));
  document.getElementById('tab-multi')!.addEventListener('click', () => setMode('multi'));

  function setMode(m: string) {
    mode = m;
    const isSimple = m === 'simple';
    document.getElementById('simple-mode')!.classList.toggle('hidden', !isSimple);
    document.getElementById('multi-mode')!.classList.toggle('hidden', isSimple);
    document.getElementById('tab-simple')!.className = `tab-btn flex-1 py-2 rounded-xl text-sm font-bold border-2 transition-all min-h-[44px] ${isSimple ? 'border-teal-500 bg-teal-500 text-white' : 'border-gray-300 bg-white text-gray-700 hover:border-teal-500'}`;
    document.getElementById('tab-multi')!.className = `tab-btn flex-1 py-2 rounded-xl text-sm font-bold border-2 transition-all min-h-[44px] ${!isSimple ? 'border-teal-500 bg-teal-500 text-white' : 'border-gray-300 bg-white text-gray-700 hover:border-teal-500'}`;
    document.getElementById('result-box')!.classList.add('hidden');
    if (!isSimple && subjectRows.length === 0) addSubjectRow();
  }

  // Simple mode inputs
  const obtainedInput = document.getElementById('obtained') as HTMLInputElement;
  const totalInput = document.getElementById('total') as HTMLInputElement;
  obtainedInput.addEventListener('input', calcSimple);
  totalInput.addEventListener('input', calcSimple);

  function calcSimple() {
    const o = parseFloat(obtainedInput.value);
    const t = parseFloat(totalInput.value);
    if (!isNaN(o) && !isNaN(t) && t > 0 && o <= t) showResult(o, t);
    else document.getElementById('result-box')!.classList.add('hidden');
  }

  // Presets
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const preset = (btn as HTMLElement).dataset.preset;
      if (preset === 'madhyamik') loadPreset(MADHYAMIK_SUBJECTS, 100);
      else if (preset === 'hs') loadPreset(HS_SUBJECTS, 100);
      else if (preset === 'clear') { subjectRows = []; renderSubjects(); document.getElementById('result-box')!.classList.add('hidden'); }
    });
  });

  function loadPreset(names: string[], total: number) {
    subjectRows = names.map(n => ({ name: n, obtained: null, total }));
    renderSubjects();
  }

  // Add subject
  document.getElementById('add-subject')!.addEventListener('click', addSubjectRow);

  function addSubjectRow(name = '', total = 100) {
    subjectRows.push({ name, obtained: null, total });
    renderSubjects();
  }

  function renderSubjects() {
    const list = document.getElementById('subjects-list')!;
    list.innerHTML = '';
    subjectRows.forEach((row, i) => {
      const div = document.createElement('div');
      div.className = 'grid grid-cols-[1fr_100px_100px_36px] gap-2 items-center';
      div.innerHTML = `
        <input type="text" placeholder="বিষয়ের নাম" value="${row.name}"
          class="px-3 py-2 border-2 border-gray-300 rounded-xl text-sm focus:border-teal-500 focus:outline-none min-h-[44px]"
          data-i="${i}" data-field="name" />
        <input type="number" placeholder="প্রাপ্ত" min="0" value="${row.obtained ?? ''}"
          class="px-3 py-2 border-2 border-gray-300 rounded-xl text-sm focus:border-teal-500 focus:outline-none min-h-[44px]"
          data-i="${i}" data-field="obtained" />
        <input type="number" placeholder="পূর্ণমান" min="1" value="${row.total ?? ''}"
          class="px-3 py-2 border-2 border-gray-300 rounded-xl text-sm focus:border-teal-500 focus:outline-none min-h-[44px]"
          data-i="${i}" data-field="total" />
        <button data-del="${i}" class="w-9 h-9 rounded-xl bg-red-50 text-red-500 hover:bg-red-100 font-bold text-lg flex items-center justify-center">×</button>
      `;
      list.appendChild(div);
    });

    list.querySelectorAll('input').forEach(inp => {
      inp.addEventListener('input', (e) => {
        const el = e.target as HTMLInputElement;
        const i = parseInt(el.dataset.i!);
        const field = el.dataset.field!;
        if (field === 'name') subjectRows[i].name = el.value;
        else if (field === 'obtained') subjectRows[i].obtained = parseFloat(el.value) || null;
        else subjectRows[i].total = parseFloat(el.value) || null;
        calcMulti();
      });
    });

    list.querySelectorAll('[data-del]').forEach(btn => {
      btn.addEventListener('click', () => {
        subjectRows.splice(parseInt((btn as HTMLElement).dataset.del!), 1);
        renderSubjects();
        calcMulti();
      });
    });
  }

  function calcMulti() {
    const valid = subjectRows.filter(r => r.obtained !== null && r.total !== null && r.total > 0);
    if (valid.length === 0) { document.getElementById('result-box')!.classList.add('hidden'); return; }
    const totalObt = valid.reduce((s, r) => s + (r.obtained ?? 0), 0);
    const totalMax = valid.reduce((s, r) => s + (r.total ?? 0), 0);
    showResult(totalObt, totalMax);
  }

  function showResult(obtained: number, total: number) {
    const pct = (obtained / total) * 100;
    document.getElementById('res-pct')!.textContent = pct.toFixed(2) + '%';
    document.getElementById('res-obtained')!.textContent = obtained % 1 === 0 ? obtained.toString() : obtained.toFixed(1);
    document.getElementById('res-total')!.textContent = total % 1 === 0 ? total.toString() : total.toFixed(1);

    const lang = (window as any).getLang?.() || 'bn';
    const rows = document.getElementById('cutoff-rows')!;
    rows.innerHTML = CUTOFFS.map(c => {
      const pass = pct >= c.pct;
      return `<div class="flex justify-between items-center px-4 py-2">
        <span class="text-sm">${lang === 'bn' ? c.nameBn : c.nameEn} (${c.pct}%)</span>
        <span class="text-sm font-bold ${pass ? 'text-green-600' : 'text-red-500'}">${pass ? '✓' : '✗'}</span>
      </div>`;
    }).join('');

    document.getElementById('result-box')!.classList.remove('hidden');
  }

  (window as any).resetCutoff = function () {
    obtainedInput.value = '';
    totalInput.value = '';
    subjectRows = [];
    renderSubjects();
    document.getElementById('result-box')!.classList.add('hidden');
  };
</script>
