{
  "headers": [
    {
      "source": "/_astro/:file*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.bengalitools.com" }],
      "destination": "https://bengalitools.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "bengalitools.vercel.app" }],
      "destination": "https://bengalitools.com/:path*",
      "permanent": true
    }
  ]
}
